        row = connection.execute(
            "SELECT id FROM scan_runs WHERE status = 'running' ORDER BY id DESC LIMIT 1"
        ).fetchone()
    return int(row["id"]) if row else None


def fetch_scan_report_json(scan_id: int) -> Optional[Dict[str, Any]]:
    with open_db_connection() as connection:
        row = connection.execute(
            "SELECT report_json FROM scan_runs WHERE id = ? LIMIT 1",
            (scan_id,),
