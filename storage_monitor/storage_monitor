      let amount = Number(value);
      let i = 0;
      while (amount >= 1024 && i < units.length - 1) { amount /= 1024; i++; }
      return i === 0 ? `${Math.round(amount)} ${units[i]}` : `${amount.toFixed(1)} ${units[i]}`;
