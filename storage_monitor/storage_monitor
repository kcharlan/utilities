<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Storage Monitor</title>
  <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@0.321.0/dist/umd/lucide.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=IBM+Plex+Mono:wght@400;500;600&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Archivo Black', 'sans-serif'],
            body: ['Manrope', 'sans-serif'],
            mono: ['IBM Plex Mono', 'monospace'],
          },
          colors: {
            dossier: {
              paper: '#efe4cf',
              panel: '#f7efe0',
              ink: '#1a1815',
              rust: '#c6512c',
              steel: '#1f4952',
              sand: '#9f8b72',
              cream: '#fff8ee',
            },
          },
          boxShadow: {
            panel: '0 14px 40px rgba(24, 20, 16, 0.10)',
          },
        }
      }
    };
  </script>
  <style>
    :root {
      --paper: #efe4cf;
      --panel: rgba(255, 248, 238, 0.88);
      --line: rgba(33, 28, 23, 0.14);
      --ink: #1a1815;
      --muted: #6f6255;
      --rust: #c6512c;
      --steel: #1f4952;
      --olive: #657459;
      --warning: #986320;
      --shadow: rgba(24, 20, 16, 0.14);
    }
    * { box-sizing: border-box; }
    html, body { min-height: 100%; }
    body {
      margin: 0;
      font-family: 'Manrope', sans-serif;
      color: var(--ink);
      background:
        linear-gradient(90deg, rgba(31, 73, 82, 0.10) 0, rgba(31, 73, 82, 0.10) 1px, transparent 1px, transparent 80px),
        linear-gradient(rgba(31, 73, 82, 0.08) 0, rgba(31, 73, 82, 0.08) 1px, transparent 1px, transparent 80px),
        radial-gradient(circle at top left, rgba(198, 81, 44, 0.16), transparent 28%),
        radial-gradient(circle at bottom right, rgba(31, 73, 82, 0.14), transparent 30%),
        var(--paper);
      background-size: 80px 80px, 80px 80px, auto, auto, auto;
    }
    .grain::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.08;
      background-image:
        radial-gradient(circle at 25% 25%, rgba(0,0,0,0.6) 0 0.8px, transparent 1px),
        radial-gradient(circle at 75% 60%, rgba(0,0,0,0.35) 0 0.8px, transparent 1px);
      background-size: 14px 14px, 17px 17px;
      mix-blend-mode: multiply;
    }
    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      box-shadow: 0 14px 40px var(--shadow);
      backdrop-filter: blur(10px);
    }
    .capsule {
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.52);
    }
    .scan-bar {
      height: 14px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(31, 73, 82, 0.10);
      border: 1px solid rgba(31, 73, 82, 0.16);
    }
    .scan-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--rust), #f29a65, var(--steel));
      transition: width 220ms ease;
    }
    .usage-track {
      display: flex;
      width: 100%;
      height: 18px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(31, 73, 82, 0.10);
      border: 1px solid rgba(31, 73, 82, 0.12);
    }
    .usage-segment {
      height: 100%;
      min-width: 0;
    }
    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      display: inline-block;
    }
    .finding-row:hover {
      background: rgba(31, 73, 82, 0.06);
    }
    .hero-title {
      line-height: 0.92;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }
    .metric-frame {
      position: relative;
      overflow: hidden;
    }
    .metric-frame::after {
      content: "";
      position: absolute;
      inset: auto -30px 16px auto;
      width: 110px;
      height: 110px;
      border-radius: 24px;
      transform: rotate(18deg);
      background: linear-gradient(135deg, rgba(198, 81, 44, 0.14), rgba(31, 73, 82, 0.06));
      pointer-events: none;
    }
    .chart-bar {
      position: relative;
      height: 12px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(31, 73, 82, 0.10);
    }
    .chart-bar > span {
      display: block;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--steel), var(--rust));
    }
    .ticker {
      position: relative;
      overflow: hidden;
    }
    .ticker::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent, rgba(255,255,255,0.28), transparent);
      transform: translateX(-100%);
      animation: sweep 4.8s linear infinite;
      pointer-events: none;
    }
    @keyframes sweep {
      to { transform: translateX(100%); }
    }
  </style>
</head>
<body class="grain">
  <div id="root"></div>
  <script type="text/babel">
    const { useEffect, useMemo, useState } = React;

    const formatBytes = (value) => {
      if (value === null || value === undefined) return 'Unknown';
      const units = ['B', 'KB', 'MB', 'GB', 'TB', 'PB'];
      let amount = Number(value);
      let unitIndex = 0;
      while (amount >= 1024 && unitIndex < units.length - 1) {
        amount /= 1024;
        unitIndex += 1;
      }
      if (unitIndex === 0) return `${Math.round(amount)} ${units[unitIndex]}`;
      return `${amount.toFixed(1)} ${units[unitIndex]}`;
    };

    const formatDuration = (value) => {
      if (value === null || value === undefined) return null;
      if (value < 1000) return `${value} ms`;
      return `${(value / 1000).toFixed(1)} s`;
    };

    const pct = (part, total) => {
      if (!part || !total) return 0;
      return Math.max(0, Math.min(100, (part / total) * 100));
    };

    const riskTone = {
      low: 'bg-emerald-100 text-emerald-900 border-emerald-300',
      medium: 'bg-amber-100 text-amber-900 border-amber-300',
      high: 'bg-rose-100 text-rose-900 border-rose-300',
      none: 'bg-slate-100 text-slate-700 border-slate-200',
    };

    const categoryTone = {
      snapshot: '#c6512c',
      cache: '#1f4952',
      cache_bucket: '#1f4952',
      app_cache: '#7f5b13',
      runtime_payload: '#7762ad',
      model_store: '#4c6c38',
      model_cache: '#4c6c38',
      stale_installer: '#8d2f2f',
      large_file: '#3c5f89',
      user_media: '#7a4d75',
      user_files: '#3c5f89',
      export_data: '#7a4d75',
      user_data: '#7a4d75',
    };

    function useMonitorState() {
      const [report, setReport] = useState(null);
      const [scanStatus, setScanStatus] = useState({
        running: true,
        phase: 'Booting',
        progress: 0,
        phase_progress: 0,
        detail: 'Preparing first scan',
        completed_in_phase: 0,
        total_in_phase: 0,
      });
      const [busyToken, setBusyToken] = useState(null);
      const [message, setMessage] = useState('');

      useEffect(() => {
        let cancelled = false;
        fetch('/api/state')
          .then((res) => res.json())
          .then((data) => {
            if (cancelled) return;
            setReport(data.report);
            setScanStatus(data.scan_status);
            if (!data.report && !data.scan_status?.running) {
              fetch('/api/scan', { method: 'POST' }).catch(() => {});
            }
          })
          .catch(() => {});

        const events = new EventSource('/api/events');
        events.onmessage = (event) => {
          try {
            const packet = JSON.parse(event.data);
            if (packet.type === 'report') {
              setReport(packet.payload);
            } else if (packet.type === 'scan_status') {
              setScanStatus(packet.payload);
            } else if (packet.type === 'action_result') {
              setMessage(packet.payload.label || 'Action completed.');
              setBusyToken(null);
            }
          } catch (error) {
            console.error(error);
          }
        };
        return () => {
          cancelled = true;
          events.close();
        };
      }, []);

      const triggerScan = async () => {
        setMessage('');
        await fetch('/api/scan', { method: 'POST' });
      };

      const executeAction = async (actionToken) => {
        setBusyToken(actionToken);
        setMessage('');
        try {
          const response = await fetch('/api/actions/execute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action_token: actionToken }),
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.detail || 'Action failed');
          setMessage(data.label || 'Action completed.');
        } catch (error) {
          setBusyToken(null);
          setMessage(error.message);
        }
      };

      const revealPath = async (path) => {
        setMessage('');
        try {
          const response = await fetch('/api/reveal', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ path }),
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.detail || 'Reveal failed');
        } catch (error) {
          setMessage(error.message);
        }
      };

      return { report, scanStatus, busyToken, message, triggerScan, executeAction, revealPath };
    }

    const StatCard = ({ eyebrow, value, note, accentClass = 'text-dossier-rust' }) => (
      <div className="panel metric-frame rounded-[28px] p-5">
        <div className="text-[11px] font-mono uppercase tracking-[0.28em] text-[#7b6b5b]">{eyebrow}</div>
        <div className={`mt-4 font-display text-[2.2rem] ${accentClass}`}>{value}</div>
        <div className="mt-2 text-sm leading-6 text-[#5f554b]">{note}</div>
      </div>
    );

    const BreakdownList = ({ title, items }) => {
      const max = items?.length ? items[0].allocated_bytes : 0;
      return (
        <div className="panel rounded-[28px] p-5">
          <div className="flex items-center justify-between">
            <h3 className="font-display text-xl tracking-[0.04em] uppercase">{title}</h3>
            <div className="text-xs font-mono uppercase tracking-[0.22em] text-[#7b6b5b]">{items?.length || 0} items</div>
          </div>
          <div className="mt-5 space-y-4">
            {(items || []).map((item) => (
              <div key={item.path}>
                <div className="flex items-center justify-between gap-4 text-sm">
                  <div className="truncate font-semibold">{item.label}</div>
                  <div className="shrink-0 font-mono text-[#5f554b]">{formatBytes(item.allocated_bytes)}</div>
                </div>
                <div className="chart-bar mt-2">
                  <span style={{ width: `${pct(item.allocated_bytes, max)}%` }} />
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    };

    function App() {
      const { report, scanStatus, busyToken, message, triggerScan, executeAction, revealPath } = useMonitorState();
      const [riskFilter, setRiskFilter] = useState('all');

      const summary = report?.summary || {};
      const findings = useMemo(() => {
        const list = report?.findings || [];
        if (riskFilter === 'all') return list;
        return list.filter((item) => item.risk === riskFilter);
      }, [report, riskFilter]);

      const headlineActions = useMemo(() => {
        return (report?.findings || []).filter((item) => item.actionable).slice(0, 8);
      }, [report]);

      const containerSize = summary.container_size_bytes || 0;
      const liveBytes = summary.visible_data_bytes || 0;
      const hiddenBytes = summary.hidden_delta_bytes || 0;
      const freeBytes = summary.container_free_bytes || Math.max(containerSize - (summary.container_used_bytes || 0), 0);
      const reportTimestamp = report ? new Date(report.generated_at).toLocaleString() : null;

      return (
        <div className="min-h-screen px-5 py-6 text-dossier-ink md:px-8 lg:px-10">
          <div className="mx-auto max-w-[1600px]">
            <div className="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
              <section className="panel ticker rounded-[34px] p-6 md:p-8">
                <div className="flex flex-wrap items-start justify-between gap-6">
                  <div className="max-w-3xl">
                    <div className="text-[11px] font-mono uppercase tracking-[0.34em] text-[#7b6b5b]">Forensic Storage Console</div>
                    <h1 className="hero-title mt-4 font-display text-[3.3rem] md:text-[4.9rem]">Storage Monitor</h1>
                    <p className="mt-5 max-w-2xl text-[1.02rem] leading-7 text-[#574f47]">
                      Live APFS accounting, snapshot drift, cache watchlists, heavy runtime payloads, and large-file review, all in one launch scan.
                    </p>
                  </div>
                  <div className="min-w-[280px] max-w-[340px] space-y-4">
                    <div className="capsule rounded-[24px] p-4">
                      <div className="flex items-center justify-between gap-4">
                        <div>
                          <div className="text-[11px] font-mono uppercase tracking-[0.26em] text-[#7b6b5b]">Scan State</div>
                          <div className="mt-2 text-lg font-extrabold">{scanStatus?.running ? scanStatus.phase : 'Ready'}</div>
                          <div className="mt-2 text-sm leading-6 text-[#5f554b]">
                            {scanStatus?.detail || (scanStatus?.running ? 'Running probes' : 'Idle')}
                          </div>
                        </div>
                        <button
                          onClick={triggerScan}
                          className="rounded-full bg-[#1f4952] px-4 py-2 text-sm font-bold text-white transition hover:bg-[#16363d]"
                        >
                          Rescan
                        </button>
                      </div>
                      <div className="scan-bar mt-4">
                        <div className="scan-fill" style={{ width: `${Math.max(6, (scanStatus?.progress || 0) * 100)}%` }} />
                      </div>
                      <div className="mt-3 flex items-center justify-between text-xs font-mono uppercase tracking-[0.2em] text-[#786b5c]">
                        <span>
                          {scanStatus?.running
                            ? `${scanStatus?.completed_in_phase || 0}/${scanStatus?.total_in_phase || 0} tasks`
                            : 'Idle'}
                        </span>
                        <span>{Math.round((scanStatus?.progress || 0) * 100)}%</span>
                      </div>
                      <div className="mt-2 text-xs font-mono uppercase tracking-[0.16em] text-[#786b5c]">
                        Phase {Math.round((scanStatus?.phase_progress || 0) * 100)}%
                      </div>
                    </div>
                    <div className="capsule rounded-[24px] p-4 text-sm leading-6 text-[#5f554b]">
                      {message || (
                        report
                          ? (scanStatus?.running
                              ? `Showing saved report from ${reportTimestamp} while a fresh scan runs.`
                              : `Latest scan: ${reportTimestamp}`)
                          : 'Waiting for first report...'
                      )}
                    </div>
                  </div>
                </div>

                <div className="mt-8">
                  <div className="flex flex-wrap items-center gap-5 text-sm">
                    <div className="flex items-center gap-2"><span className="legend-dot" style={{ background: '#1f4952' }} /> Visible live data</div>
                    <div className="flex items-center gap-2"><span className="legend-dot" style={{ background: '#c6512c' }} /> Hidden or snapshot overhead</div>
                    <div className="flex items-center gap-2"><span className="legend-dot" style={{ background: '#d7c7b0' }} /> Free space</div>
                  </div>
                  <div className="usage-track mt-3">
                    <div className="usage-segment" style={{ width: `${pct(liveBytes, containerSize)}%`, background: '#1f4952' }} />
                    <div className="usage-segment" style={{ width: `${pct(hiddenBytes, containerSize)}%`, background: '#c6512c' }} />
                    <div className="usage-segment" style={{ width: `${pct(freeBytes, containerSize)}%`, background: '#d7c7b0' }} />
                  </div>
                </div>
              </section>

              <section className="grid gap-5 sm:grid-cols-2">
                <StatCard eyebrow="Container Used" value={formatBytes(summary.container_used_bytes)} note="APFS container usage across system, Data, preboot, and recovery volumes." />
                <StatCard eyebrow="Visible Data" value={formatBytes(summary.visible_data_bytes)} note="Reachable live files measured with du on the writable Data volume." accentClass="text-[#1f4952]" />
                <StatCard eyebrow="Hidden Delta" value={formatBytes(summary.hidden_delta_bytes)} note="Likely snapshots, purgeable, or other system-managed overhead not surfaced as live files." />
                <StatCard eyebrow="Safe Reclaim" value={formatBytes(summary.safe_reclaimable_bytes)} note="Paths marked low-risk and directly action-ready in the current report." accentClass="text-[#4c6c38]" />
              </section>
            </div>

            <div className="mt-6 grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
              <div className="grid gap-6 lg:grid-cols-2">
                <BreakdownList title="Data Volume" items={report?.breakdowns?.data_root || []} />
                <BreakdownList title="Home Directory" items={report?.breakdowns?.home_root || []} />
              </div>
              <div className="grid gap-6 lg:grid-cols-2">
                <BreakdownList title="User Library" items={report?.breakdowns?.library_root || []} />
                <BreakdownList title="Applications" items={report?.breakdowns?.applications_root || []} />
              </div>
            </div>

            <div className="mt-6 grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
              <section className="panel rounded-[30px] p-5">
                <div className="flex items-center justify-between gap-4">
                  <h2 className="font-display text-2xl uppercase tracking-[0.04em]">Action Deck</h2>
                  <div className="text-xs font-mono uppercase tracking-[0.22em] text-[#7b6b5b]">{headlineActions.length} ready</div>
                </div>
                <div className="mt-5 space-y-4">
                  {headlineActions.length === 0 && (
                    <div className="rounded-[22px] border border-[var(--line)] bg-white/40 p-5 text-sm text-[#5f554b]">
                      No direct cleanup actions are available yet. If this is the first launch, let the initial scan complete.
                    </div>
                  )}
                  {headlineActions.map((item) => (
                    <div key={item.path + item.label} className="rounded-[24px] border border-[var(--line)] bg-white/45 p-4">
                      <div className="flex items-start justify-between gap-4">
                        <div>
                          <div className="text-[11px] font-mono uppercase tracking-[0.26em] text-[#7b6b5b]">{item.category.replaceAll('_', ' ')}</div>
                          <div className="mt-2 text-lg font-extrabold">{item.label}</div>
                          <div className="mt-2 text-sm leading-6 text-[#5f554b]">{item.description}</div>
                          <div className="mt-3 font-mono text-xs text-[#796d60]">{item.path}</div>
                        </div>
                        <div className="text-right">
                          <div className={`inline-flex rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] ${riskTone[item.risk] || riskTone.none}`}>
                            {item.risk}
                          </div>
                          <div className="mt-3 font-display text-2xl text-[#c6512c]">{formatBytes(item.estimated_reclaim_bytes)}</div>
                        </div>
                      </div>
                      <div className="mt-4 flex flex-wrap gap-3">
                        {item.actions.map((action) => action.kind === 'execute' ? (
                          <button
                            key={action.label}
                            disabled={busyToken === action.action_token}
                            onClick={() => executeAction(action.action_token)}
                            className="rounded-full bg-[#c6512c] px-4 py-2 text-sm font-bold text-white transition hover:bg-[#a94425] disabled:opacity-60"
                          >
                            {busyToken === action.action_token ? 'Working...' : action.label}
                          </button>
                        ) : (
                          <button
                            key={action.label}
                            onClick={() => revealPath(action.target_path)}
                            className="rounded-full border border-[var(--line)] bg-white/60 px-4 py-2 text-sm font-bold text-[#1a1815] transition hover:bg-white"
                          >
                            {action.label}
                          </button>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </section>

              <section className="panel rounded-[30px] p-5">
                <div className="flex flex-wrap items-center justify-between gap-4">
                  <h2 className="font-display text-2xl uppercase tracking-[0.04em]">Findings</h2>
                  <div className="flex flex-wrap gap-2">
                    {['all', 'low', 'medium', 'high'].map((risk) => (
                      <button
                        key={risk}
                        onClick={() => setRiskFilter(risk)}
                        className={`rounded-full border px-3 py-2 text-xs font-bold uppercase tracking-[0.16em] ${riskFilter === risk ? 'border-[#1f4952] bg-[#1f4952] text-white' : 'border-[var(--line)] bg-white/55 text-[#1a1815]'}`}
                      >
                        {risk}
                      </button>
                    ))}
                  </div>
                </div>
                <div className="mt-5 overflow-hidden rounded-[24px] border border-[var(--line)]">
                  <div className="grid grid-cols-[1.4fr_0.75fr_0.7fr_0.9fr] gap-3 border-b border-[var(--line)] bg-white/55 px-4 py-3 text-[11px] font-mono uppercase tracking-[0.22em] text-[#7b6b5b]">
                    <div>Finding</div>
                    <div>Category</div>
                    <div>Risk</div>
                    <div>Size</div>
                  </div>
                  <div className="max-h-[680px] overflow-auto">
                    {findings.map((item) => (
                      <div key={item.path + item.label} className="finding-row border-b border-[var(--line)] px-4 py-4">
                        <div className="grid grid-cols-[1.4fr_0.75fr_0.7fr_0.9fr] gap-3">
                          <div>
                            <div className="font-bold">{item.label}</div>
                            <div className="mt-1 text-sm leading-6 text-[#5f554b]">{item.description}</div>
                            <div className="mt-2 font-mono text-xs text-[#796d60] break-all">{item.path}</div>
                            <div className="mt-3 flex flex-wrap gap-2">
                              {item.actions.map((action) => action.kind === 'execute' ? (
                                <button
                                  key={action.label}
                                  disabled={busyToken === action.action_token}
                                  onClick={() => executeAction(action.action_token)}
                                  className="rounded-full bg-[#c6512c] px-3 py-1.5 text-xs font-bold uppercase tracking-[0.14em] text-white disabled:opacity-60"
                                >
                                  {busyToken === action.action_token ? 'Working' : action.label}
                                </button>
                              ) : (
                                <button
                                  key={action.label}
                                  onClick={() => revealPath(action.target_path)}
                                  className="rounded-full border border-[var(--line)] bg-white/60 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.14em] text-[#1a1815]"
                                >
                                  {action.label}
                                </button>
                              ))}
                            </div>
                          </div>
                          <div className="self-start">
                            <div className="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-white" style={{ background: categoryTone[item.category] || '#5f554b' }}>
                              {item.category.replaceAll('_', ' ')}
                            </div>
                          </div>
                          <div className="self-start">
                            <div className={`inline-flex rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] ${riskTone[item.risk] || riskTone.none}`}>
                              {item.risk}
                            </div>
                          </div>
                          <div className="self-start text-right">
