      const now = Date.now();
      const diffMs = now - then.getTime();
      if (diffMs < 0) return 'just now';
      const sec = Math.floor(diffMs / 1000);
      if (sec < 60) return 'just now';
      const min = Math.floor(sec / 60);
      if (min < 60) return `${min}m ago`;
