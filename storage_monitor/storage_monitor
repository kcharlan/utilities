def remove_cached_subtree(scan_id: int, root_key: str, path_str: str) -> None:
    like_pattern = sql_like_prefix(path_str)
    with DB_WRITE_LOCK:
        with open_db_connection() as connection:
            connection.execute(
                """
                DELETE FROM nodes
                WHERE scan_id = ? AND root_key = ? AND (path = ? OR path LIKE ? ESCAPE '\\')
                """,
                (scan_id, root_key, path_str, like_pattern),
            )
            connection.execute(
                """
                DELETE FROM large_files
                WHERE scan_id = ? AND root_key = ? AND (path = ? OR path LIKE ? ESCAPE '\\')
                """,
                (scan_id, root_key, path_str, like_pattern),
            )
            connection.commit()


def store_immediate_breakdown(scan_id: int, root_key: str, root: Path, breakdown: Dict[str, Any]) -> None:
    if breakdown["total_bytes"] is None:
        return
    updated_at = iso_now()
    root_path = str(root)
    rows = [
        {
            "path": root_path,
            "parent_path": None if root == root.parent else str(root.parent),
            "name": root.name or root_path,
            "root_key": root_key,
            "depth": path_depth(root, root_path),
            "allocated_bytes": int(breakdown["total_bytes"]),
            "children_indexed": True,
            "updated_at": updated_at,
        }
    ]
    for item in breakdown["items"]:
        rows.append(
            {
                "path": item["path"],
                "parent_path": root_path,
                "name": item["label"],
                "root_key": root_key,
                "depth": path_depth(root, item["path"]),
                "allocated_bytes": int(item["allocated_bytes"]),
                "children_indexed": False,
                "updated_at": updated_at,
            }
        )
    with DB_WRITE_LOCK:
        with open_db_connection() as connection:
            connection.execute(
                "DELETE FROM nodes WHERE scan_id = ? AND root_key = ? AND parent_path = ?",
                (scan_id, root_key, root_path),
            )
            connection.executemany(
                """
                INSERT INTO nodes (
                    scan_id, path, parent_path, name, root_key, depth, allocated_bytes, children_indexed, updated_at
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
                ON CONFLICT(scan_id, path) DO UPDATE SET
                    parent_path = excluded.parent_path,
                    name = excluded.name,
                    root_key = excluded.root_key,
                    depth = excluded.depth,
                    allocated_bytes = excluded.allocated_bytes,
                    children_indexed = excluded.children_indexed,
                    updated_at = excluded.updated_at
                """,
                [
                    (
                        scan_id,
                        row["path"],
                        row["parent_path"],
                        row["name"],
                        row["root_key"],
                        row["depth"],
                        row["allocated_bytes"],
                        int(bool(row.get("children_indexed", False))),
                        row["updated_at"],
                    )
                    for row in rows
                ],
            )
            connection.commit()


def fetch_breakdown_from_db(scan_id: int, path_str: str, *, limit: Optional[int] = MAX_TOP_ITEMS) -> Optional[Dict[str, Any]]:
    with open_db_connection() as connection:
        path_row = connection.execute(
            """
            SELECT path, allocated_bytes, updated_at
            FROM nodes
            WHERE scan_id = ? AND path = ?
            LIMIT 1
            """,
            (scan_id, path_str),
        ).fetchone()
        if not path_row:
            return None
        query = """
            SELECT path, name, allocated_bytes
                 , children_indexed
            FROM nodes
            WHERE scan_id = ? AND parent_path = ?
            ORDER BY allocated_bytes DESC, name ASC
        """
        params: List[Any] = [scan_id, path_str]
        if limit is not None:
            query += " LIMIT ?"
            params.append(limit)
        child_rows = connection.execute(query, tuple(params)).fetchall()
    return {
        "path": path_str,
        "total_bytes": path_row["allocated_bytes"],
        "items": [
            {
                "path": row["path"],
                "label": row["name"],
                "allocated_bytes": row["allocated_bytes"],
                "is_cached": bool(row["children_indexed"]),
            }
            for row in child_rows
        ],
        "updated_at": path_row["updated_at"],
    }


def fetch_large_files_from_db(scan_id: int, limit: int = 25) -> Dict[str, Any]:
    with open_db_connection() as connection:
        rows = connection.execute(
            """
            SELECT path, name, apparent_bytes, allocated_bytes, updated_at
            FROM large_files
            WHERE scan_id = ?
            ORDER BY allocated_bytes DESC, name ASC
            LIMIT ?
            """,
            (scan_id, limit),
        ).fetchall()
    updated_at = None
    items: List[Dict[str, Any]] = []
    for row in rows:
        updated_at = max(updated_at or row["updated_at"], row["updated_at"])
        items.append(
            {
                "label": row["name"],
                "path": row["path"],
                "category": "large_file",
                "risk": "high",
                "apparent_bytes": row["apparent_bytes"],
                "allocated_bytes": row["allocated_bytes"],
                "description": "Large user file found in targeted home-directory scan.",
                "actionable": False,
                "actions": build_finding_actions(
                    {
                        "path": row["path"],
                        "label": row["name"],
                        "actionable": False,
                        "category": "large_file",
                        "risk": "high",
                    }
                ),
            }
        )
    return {"items": items, "updated_at": updated_at}


