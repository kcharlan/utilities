        except json.JSONDecodeError:
            return
    if report is None:
        return
    with STATE.lock:
        STATE.report = report


def add_subscriber() -> str:
    subscriber_id = str(uuid.uuid4())
    with STATE.lock:
        STATE.subscribers[subscriber_id] = queue.Queue()
    return subscriber_id


def remove_subscriber(subscriber_id: str) -> None:
    with STATE.lock:
        STATE.subscribers.pop(subscriber_id, None)


def sse_event_stream():
    subscriber_id = add_subscriber()
    try:
        with STATE.lock:
            if STATE.report is not None:
                yield f"data: {json.dumps({'type': 'report', 'payload': STATE.report})}\n\n"
            yield f"data: {json.dumps({'type': 'scan_status', 'payload': STATE.scan_status})}\n\n"
        while True:
            try:
                message = STATE.subscribers[subscriber_id].get(timeout=15)
            except queue.Empty:
                yield "event: heartbeat\ndata: {}\n\n"
                continue
            yield f"data: {json.dumps(message)}\n\n"
    finally:
        remove_subscriber(subscriber_id)


def extract_parenthetical_bytes(text: str) -> Optional[int]:
    match = re.search(r"\((\d+)\s+Bytes\)", text)
    if match:
        return int(match.group(1))
    return None


def parse_diskutil_info(stdout: str) -> Dict[str, Optional[int]]:
    info = {
        "volume_used_bytes": None,
        "container_free_bytes": None,
        "disk_size_bytes": None,
        "container_total_space_bytes": None,
    }
    for line in stdout.splitlines():
        if "Volume Used Space:" in line:
            info["volume_used_bytes"] = extract_parenthetical_bytes(line)
        elif "Container Free Space:" in line:
            info["container_free_bytes"] = extract_parenthetical_bytes(line)
        elif "Container Total Space:" in line:
            info["container_total_space_bytes"] = extract_parenthetical_bytes(line)
        elif "Disk Size:" in line:
            info["disk_size_bytes"] = extract_parenthetical_bytes(line)
    return info


def parse_apfs_list(stdout: str) -> Dict[str, Optional[int]]:
    parsed = {
        "container_size_bytes": None,
        "container_used_bytes": None,
    }
    size_match = re.search(r"Size \(Capacity Ceiling\):\s+(\d+)\s+B", stdout)
    used_match = re.search(r"Capacity In Use By Volumes:\s+(\d+)\s+B", stdout)
    if size_match:
        parsed["container_size_bytes"] = int(size_match.group(1))
    if used_match:
        parsed["container_used_bytes"] = int(used_match.group(1))
    return parsed


def parse_local_snapshot_names(stdout: str) -> List[str]:
    names: List[str] = []
    for line in stdout.splitlines():
        line = line.strip()
        if not line or line.startswith("Snapshots for volume group"):
            continue
        if line.startswith("com.apple."):
            names.append(line)
    return names


def parse_snapshot_token(snapshot_name: str) -> Optional[str]:
    match = re.match(r"com\.apple\.TimeMachine\.(\d{4}-\d{2}-\d{2}-\d{6})\.local", snapshot_name)
    if match:
        return match.group(1)
    return None


def list_root_breakdown(root: Path, limit: Optional[int] = MAX_TOP_ITEMS) -> Dict[str, Any]:
    started = time.time()
    if not root.exists():
        return {"total_bytes": None, "items": [], "duration_ms": 0}
    result = run_command(["du", "-x", "-k", "-d", "1", str(root)], timeout=360)
    if not result["stdout"].strip():
        return {"total_bytes": None, "items": [], "duration_ms": result["duration_ms"]}
    items: List[Dict[str, Any]] = []
    total_bytes: Optional[int] = None
    root_str = str(root).rstrip("/")
    root_resolved = str(root.resolve()).rstrip("/")
    for line in result["stdout"].splitlines():
        line = line.strip()
        if not line:
            continue
        if "\t" in line:
            size_str, path_str = line.split("\t", 1)
        else:
            parts = line.split(None, 1)
            if len(parts) != 2:
                continue
            size_str, path_str = parts
        if not size_str.isdigit():
            continue
        allocated_bytes = int(size_str) * 1024
        path_obj = Path(path_str)
        path_raw = path_str.rstrip("/")
        try:
            path_resolved = str(path_obj.resolve()).rstrip("/")
        except OSError:
            path_resolved = path_raw
        if path_raw in {root_str, root_resolved} or path_resolved in {root_str, root_resolved}:
            total_bytes = allocated_bytes
            continue
        # Detect firmlinks: on macOS /Users and /System/Volumes/Data/Users are
        # the same directory but Path.resolve() does not resolve firmlinks.
        # os.path.samefile compares device/inode and handles this correctly.
        try:
            if os.path.samefile(path_str, str(root)):
                total_bytes = allocated_bytes
                continue
        except OSError:
            pass
        items.append(
            {
                "path": path_str,
                "label": path_obj.name or path_str,
                "allocated_bytes": allocated_bytes,
            }
        )
    items.sort(key=lambda item: item["allocated_bytes"], reverse=True)
    if total_bytes is None and items:
        total_bytes = sum(item["allocated_bytes"] for item in items)
    return {
        "total_bytes": total_bytes,
        "items": items[:limit] if limit is not None else items,
        "duration_ms": int((time.time() - started) * 1000),
    }


def scan_directory_index(root: Path, root_key: str, timeout: int = 1800) -> Dict[str, Any]:
    started = time.time()
    if not root.exists():
        return {"total_bytes": None, "items": [], "rows": [], "duration_ms": 0}
    result = run_command(["du", "-x", "-k", str(root)], timeout=timeout)
    if not result["stdout"].strip():
        return {"total_bytes": None, "items": [], "rows": [], "duration_ms": result["duration_ms"]}

    updated_at = iso_now()
    rows: List[Dict[str, Any]] = []
    root_path = str(root.resolve())
    immediate_items: List[Dict[str, Any]] = []
    total_bytes: Optional[int] = None

    for line in result["stdout"].splitlines():
        line = line.strip()
        if not line:
            continue
        if "\t" in line:
            size_str, path_str = line.split("\t", 1)
        else:
            parts = line.split(None, 1)
            if len(parts) != 2:
                continue
            size_str, path_str = parts
        if not size_str.isdigit():
            continue
        try:
            resolved = str(Path(path_str).resolve())
        except OSError:
            resolved = path_str
        allocated_bytes = int(size_str) * 1024
        parent_path = None if resolved == root_path else str(Path(resolved).parent)
        rows.append(
            {
                "path": resolved,
                "parent_path": parent_path,
                "name": Path(resolved).name or resolved,
                "root_key": root_key,
                "depth": path_depth(root, resolved),
                "allocated_bytes": allocated_bytes,
                "children_indexed": True,
                "updated_at": updated_at,
            }
        )
        if resolved == root_path:
            total_bytes = allocated_bytes
        elif parent_path == root_path:
            immediate_items.append(
                {
                    "path": resolved,
                    "label": Path(resolved).name or resolved,
                    "allocated_bytes": allocated_bytes,
                }
            )

    immediate_items.sort(key=lambda item: item["allocated_bytes"], reverse=True)
    return {
        "total_bytes": total_bytes,
        "items": immediate_items[:MAX_TOP_ITEMS],
        "rows": rows,
        "duration_ms": int((time.time() - started) * 1000),
    }


def scan_immediate_child_breakdown(
    root: Path,
    *,
    exclude_names: Optional[List[str]] = None,
    injected_items: Optional[List[Dict[str, Any]]] = None,
    limit: int = MAX_TOP_ITEMS,
) -> Dict[str, Any]:
    started = time.time()
    if not root.exists():
        return {"total_bytes": None, "items": [], "duration_ms": 0}
    exclude = set(exclude_names or [])
    try:
        children = [child for child in root.iterdir() if child.name not in exclude]
    except OSError:
        return {"total_bytes": None, "items": [], "duration_ms": int((time.time() - started) * 1000)}
    task_map = {
        str(child): (lambda child=child: du_bytes(child, timeout=300))
        for child in children
    }
    child_sizes = run_parallel_call_map(task_map, max_workers=min(SCAN_WORKER_COUNT, max(1, len(task_map))))
    items: List[Dict[str, Any]] = []
    for child in children:
        allocated_bytes = child_sizes.get(str(child))
        if allocated_bytes is None:
            continue
        items.append(
            {
                "path": str(child),
                "label": child.name or str(child),
                "allocated_bytes": allocated_bytes,
            }
        )
    for item in injected_items or []:
        if item.get("allocated_bytes") is None:
            continue
        items.append(item)
    items.sort(key=lambda item: item["allocated_bytes"], reverse=True)
    total_bytes = sum(item["allocated_bytes"] for item in items)
    return {
        "total_bytes": total_bytes,
        "items": items[:limit],
        "duration_ms": int((time.time() - started) * 1000),
    }


def scan_watchlist_entry(spec: Dict[str, Any]) -> Dict[str, Any]:
    path = expand_path(spec["path"])
    exists = path.exists()
    allocated = du_bytes(path) if exists else None
    apparent = allocated
    if exists and path.is_file():
        file_sizes = stat_file_sizes(path)
        apparent = file_sizes["apparent_bytes"]
        allocated = file_sizes["allocated_bytes"]
    token = encode_action_token(
        {
            "kind": spec["cleanup_kind"],
            "path": str(path),
            "slug": spec["slug"],
        }
    ) if exists and spec["cleanup_kind"] else None
    return {
        "slug": spec["slug"],
        "label": spec["label"],
        "path": str(path),
        "exists": exists,
        "category": spec["category"],
        "risk": spec["risk"],
        "description": spec["description"],
        "actionable": bool(exists and spec["actionable"] and spec["cleanup_kind"]),
        "cleanup_kind": spec["cleanup_kind"],
        "apparent_bytes": apparent,
        "allocated_bytes": allocated,
        "estimated_reclaim_bytes": allocated if exists and spec["cleanup_kind"] else None,
        "action_token": token,
    }


def scan_watchlist() -> Dict[str, Any]:
    started = time.time()
    task_map = {
        spec["slug"]: (lambda spec=spec: scan_watchlist_entry(spec))
        for spec in WATCHLIST_SPECS
    }
    results = list(run_parallel_call_map(task_map).values())
    results.sort(key=lambda item: bytes_or_zero(item["allocated_bytes"]), reverse=True)
    return {
        "items": results,
        "duration_ms": int((time.time() - started) * 1000),
    }


def scan_large_files_in_root(root: Path) -> List[Dict[str, Any]]:
    result = run_command(
        [
            "find",
            str(root),
            "-xdev",
            "-type",
            "f",
            "-size",
            f"+{int(LARGE_FILE_THRESHOLD_BYTES / (1024 * 1024))}M",
            "-print",
        ],
        timeout=240,
    )
    if not result["ok"]:
        return []
    items: List[Dict[str, Any]] = []
    for line in result["stdout"].splitlines():
        if not line.strip():
            continue
        path = Path(line.strip())
        sizes = stat_file_sizes(path)
        if sizes["apparent_bytes"] is None:
            continue
        items.append(
            {
                "label": path.name,
                "path": str(path),
                "parent_path": str(path.parent),
                "category": "large_file",
                "risk": "high",
                "apparent_bytes": sizes["apparent_bytes"],
                "allocated_bytes": sizes["allocated_bytes"],
                "description": "Large user file found in targeted home-directory scan.",
                "actionable": False,
            }
        )
    return items


def scan_large_files(
    roots: List[Path],
    limit: int = 25,
    progress_callback: Optional[Any] = None,
) -> Dict[str, Any]:
    started = time.time()
    items: List[Dict[str, Any]] = []
    seen_paths = set()
    task_roots = [root for root in roots if root.exists()]
    task_map = {
        str(root): (lambda root=root: scan_large_files_in_root(root))
        for root in task_roots
    }
    grouped = run_parallel_call_map(task_map, progress_callback=progress_callback)
    for root_items in grouped.values():
        for item in root_items:
            if item["path"] in seen_paths:
                continue
            seen_paths.add(item["path"])
            items.append(item)
    items.sort(key=lambda item: bytes_or_zero(item["allocated_bytes"]), reverse=True)
    return {
        "items": items[:limit],
        "duration_ms": int((time.time() - started) * 1000),
    }



def build_finding_actions(finding: Dict[str, Any]) -> List[Dict[str, Any]]:
    actions: List[Dict[str, Any]] = []
    actions.append(
        {
            "label": "Reveal in Finder",
            "kind": "reveal",
            "target_path": finding["path"],
            "risk": "none",
            "estimated_reclaim_bytes": None,
        }
    )
    if finding.get("actionable") and finding.get("action_token"):
        action_kind = finding.get("cleanup_kind") or "cleanup"
        if action_kind == "trash_path":
            actions.append(
                {
                    "label": "Move to Trash",
                    "kind": "execute",
                    "action_token": finding["action_token"],
                    "risk": finding["risk"],
                    "estimated_reclaim_bytes": finding.get("estimated_reclaim_bytes"),
                }
            )
        elif action_kind == "delete_snapshot":
            actions.append(
                {
                    "label": "Delete Snapshot",
                    "kind": "execute",
                    "action_token": finding["action_token"],
                    "risk": finding["risk"],
                    "estimated_reclaim_bytes": None,
                }
            )
    return actions


def summarize_checks(checks: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    return checks


def collect_scan_report(scan_id: int) -> Dict[str, Any]:
    started_at = iso_now()
    checks: List[Dict[str, Any]] = []
    warnings: List[str] = []
    phases = [
        ("Metadata probes", 0.12),
        ("Parallel root scans", 0.63),
        ("Large file scan", 0.20),
        ("Report assembly", 0.05),
    ]
    phase_offsets: Dict[str, float] = {}
    offset = 0.0
    for phase_name, weight in phases:
        phase_offsets[phase_name] = offset
        offset += weight

    def set_phase_progress(phase_name: str, completed: int, total: int, detail: str) -> None:
        phase_weight = dict(phases)[phase_name]
        phase_ratio = 1.0 if total <= 0 else max(0.0, min(1.0, completed / total))
        progress = phase_offsets[phase_name] + (phase_weight * phase_ratio)
        set_scan_status(
            running=True,
            phase=phase_name,
            detail=detail,
            progress=progress,
            error=None,
        )

    def phase_callback_builder(phase_name: str):
        def _callback(task_name: str, completed: int, total: int) -> None:
            pretty = task_name.replace("_", " ")
            set_phase_progress(phase_name, completed, total, f"{pretty} complete")
        return _callback

    metadata_phase = "Metadata probes"
    root_phase = "Parallel root scans"
    large_phase = "Large file scan"
    assembly_phase = "Report assembly"

    set_phase_progress(metadata_phase, 0, 4, "Starting metadata probes")
    metadata_results = run_parallel_call_map(
        {
            "apfs_list": lambda: run_command(["diskutil", "apfs", "list"], timeout=120),
            "data_info": lambda: run_command(["diskutil", "info", str(DATA_VOLUME)], timeout=120),
            "root_info": lambda: run_command(["diskutil", "info", "/"], timeout=120),
            "snapshot_info": lambda: run_command(["tmutil", "listlocalsnapshots", "/"], timeout=120),
        },
        progress_callback=phase_callback_builder(metadata_phase),
    )
    apfs_list = metadata_results["apfs_list"]
    data_info = metadata_results["data_info"]
    root_info = metadata_results["root_info"]
    snapshot_info = metadata_results["snapshot_info"]
    checks.append(
        {
            "label": "APFS container",
            "command": apfs_list["command"],
            "ok": apfs_list["ok"],
            "duration_ms": apfs_list["duration_ms"],
            "summary": "Collected APFS container accounting." if apfs_list["ok"] else apfs_list["stderr"],
        }
    )
    checks.append(
        {
            "label": "Data volume info",
            "command": data_info["command"],
            "ok": data_info["ok"],
            "duration_ms": data_info["duration_ms"],
            "summary": "Collected Data volume usage." if data_info["ok"] else data_info["stderr"],
        }
    )
    checks.append(
        {
            "label": "System volume info",
            "command": root_info["command"],
            "ok": root_info["ok"],
            "duration_ms": root_info["duration_ms"],
            "summary": "Collected mounted system snapshot usage." if root_info["ok"] else root_info["stderr"],
        }
    )

    checks.append(
        {
            "label": "Local snapshots",
            "command": snapshot_info["command"],
            "ok": snapshot_info["ok"],
            "duration_ms": snapshot_info["duration_ms"],
            "summary": "Enumerated local snapshots." if snapshot_info["ok"] else snapshot_info["stderr"],
        }
    )

    # Parse metadata results early so we can stream them before root scans begin
    apfs_container = parse_apfs_list(apfs_list["stdout"] if apfs_list["ok"] else "")
    data_volume = parse_diskutil_info(data_info["stdout"] if data_info["ok"] else "")
    system_volume = parse_diskutil_info(root_info["stdout"] if root_info["ok"] else "")
    snapshot_names = parse_local_snapshot_names(snapshot_info["stdout"] if snapshot_info["ok"] else "")

    publish_event("metadata_ready", {
        "container_size_bytes": apfs_container["container_size_bytes"] or data_volume["disk_size_bytes"],
        "container_used_bytes": apfs_container["container_used_bytes"],
        "container_free_bytes": data_volume["container_free_bytes"],
        "data_volume_used_bytes": data_volume["volume_used_bytes"],
        "system_volume_used_bytes": system_volume["volume_used_bytes"],
        "updated_at": iso_now(),
    })

    for name in snapshot_names:
        token = parse_snapshot_token(name)
        if token is None:
            continue
        action_token = encode_action_token({"kind": "delete_snapshot", "snapshot_name": name, "token": token})
        try:
            parsed_date = datetime.strptime(token, "%Y-%m-%d-%H%M%S").replace(tzinfo=timezone.utc).isoformat()
        except ValueError:
            parsed_date = None
        publish_event("snapshot_found", {
            "snapshot_name": name,
            "parsed_date": parsed_date,
            "token": token,
            "action_token": action_token,
        })

    set_phase_progress(root_phase, 0, 5, "Starting root scans")
    root_scan_tasks = {
        "data_breakdown": lambda: list_root_breakdown(DATA_VOLUME, limit=None),
        "home_index": lambda: scan_directory_index(HOME_DIR, "home_root"),
        "applications_index": lambda: scan_directory_index(APPLICATIONS_DIR, "applications_root"),
        "watchlist": scan_watchlist,
    }
    parallel_scans = run_parallel_call_map(
        {
            **root_scan_tasks,
            "library_exists": lambda: {"exists": (HOME_DIR / "Library").exists()},
        },
        max_workers=min(SCAN_WORKER_COUNT, 5),
        progress_callback=phase_callback_builder(root_phase),
    )
    data_breakdown_result = parallel_scans["data_breakdown"]
    store_immediate_breakdown(scan_id, "data_root", DATA_VOLUME.resolve(), data_breakdown_result)
    data_prefetch_plan = select_data_prefetch_plan(data_breakdown_result["items"])
    for source_path, target_path in data_prefetch_plan["aliases"]:
        mark_alias_path_cached(scan_id, source_path, target_path, "data_root")
    data_prefetch_tasks = {
        str(path): (lambda path=path: scan_directory_index(path, "data_root"))
        for path in data_prefetch_plan["scan_paths"]
        if path.exists()
    }
    if data_prefetch_tasks:
        set_phase_progress(
            root_phase,
            5,
            5 + len(data_prefetch_tasks),
            "Prefetching top Data Volume subtrees",
        )
        prefetched = run_parallel_call_map(
            data_prefetch_tasks,
            max_workers=min(SCAN_WORKER_COUNT, max(1, len(data_prefetch_tasks))),
            progress_callback=lambda task_name, completed, total: set_phase_progress(
                root_phase,
                5 + completed,
                5 + total,
                f"{Path(task_name).name or task_name} prefetched",
            ),
        )
        for result in prefetched.values():
            upsert_node_rows(scan_id, result["rows"])
    visible_data_bytes = data_breakdown_result["total_bytes"]
    data_root_breakdown = fetch_breakdown_from_db(scan_id, str(DATA_VOLUME.resolve()))
    data_breakdown = data_root_breakdown["items"] if data_root_breakdown else data_breakdown_result["items"][:MAX_TOP_ITEMS]
    checks.append(
        {
            "label": "Visible Data volume usage",
            "command": f"du -xsk {DATA_VOLUME}",
            "ok": visible_data_bytes is not None,
            "duration_ms": data_breakdown_result.get("duration_ms"),
            "summary": f"Visible live data totals {format_number(visible_data_bytes)}.",
        }
    )

    home_index_result = parallel_scans["home_index"]
    upsert_node_rows(scan_id, home_index_result["rows"])
    home_root_breakdown = fetch_breakdown_from_db(scan_id, str(HOME_DIR.resolve()))
    home_breakdown = home_root_breakdown["items"] if home_root_breakdown else []
    home_total_bytes = home_root_breakdown["total_bytes"] if home_root_breakdown else None

    library_path = str((HOME_DIR / "Library").resolve())
    library_breakdown_result = fetch_breakdown_from_db(scan_id, library_path)
    if library_breakdown_result is None and parallel_scans["library_exists"]["exists"]:
        library_breakdown_result = {"path": library_path, "total_bytes": None, "items": [], "updated_at": iso_now()}
    library_breakdown = library_breakdown_result["items"] if library_breakdown_result else []
    large_file_roots: List[Path] = []
    for item in home_breakdown:
        if bytes_or_zero(item.get("allocated_bytes")) < 512 * 1024 * 1024:
            continue
        candidate = Path(item["path"])
        if not candidate.exists():
            continue
        large_file_roots.append(candidate)
    for fallback_name in ["Downloads", "Documents", "Pictures", "Movies"]:
        fallback_path = HOME_DIR / fallback_name
        if fallback_path.exists() and fallback_path not in large_file_roots:
            large_file_roots.append(fallback_path)
    checks.append(
        {
            "label": "Home directory usage",
            "command": f"du -xsk {HOME_DIR}",
            "ok": home_total_bytes is not None,
            "duration_ms": home_index_result.get("duration_ms"),
            "summary": f"Home directory totals {format_number(home_total_bytes)}.",
        }
    )
    checks.append(
        {
            "label": "Library usage",
            "command": f"du -xsk {HOME_DIR / 'Library'}",
            "ok": library_breakdown_result is not None and library_breakdown_result["total_bytes"] is not None,
            "duration_ms": home_index_result.get("duration_ms"),
            "summary": f"Library totals {format_number(library_breakdown_result['total_bytes'] if library_breakdown_result else None)}.",
        }
    )

    applications_breakdown_result = parallel_scans["applications_index"]
    upsert_node_rows(scan_id, applications_breakdown_result["rows"])
    applications_root_breakdown = fetch_breakdown_from_db(scan_id, str(APPLICATIONS_DIR.resolve()))
    applications_total_bytes = applications_root_breakdown["total_bytes"] if applications_root_breakdown else None
    applications_breakdown = applications_root_breakdown["items"] if applications_root_breakdown else []
    checks.append(
        {
            "label": "Applications usage",
            "command": f"du -xsk {APPLICATIONS_DIR}",
            "ok": applications_total_bytes is not None,
            "duration_ms": applications_breakdown_result.get("duration_ms"),
            "summary": f"Applications total {format_number(applications_total_bytes)}.",
        }
    )

    watchlist_result = parallel_scans["watchlist"]
    watchlist = watchlist_result["items"]
    checks.append(
        {
            "label": "Safe cleanup watchlist",
            "command": "internal watchlist probe set",
            "ok": True,
            "duration_ms": watchlist_result.get("duration_ms"),
            "summary": f"Scanned {len(watchlist)} known cache/runtime targets.",
        }
    )

    # Publish breakdown_ready events — home_root gets Library injected first (already done above)
    publish_event("breakdown_ready", {
        "root": "data_root",
        "items": data_breakdown,
        "total_bytes": data_breakdown_result["total_bytes"],
        "updated_at": iso_now(),
    })
    publish_event("breakdown_ready", {
        "root": "library_root",
        "items": library_breakdown,
        "total_bytes": library_breakdown_result["total_bytes"] if library_breakdown_result else None,
        "updated_at": iso_now(),
    })
    publish_event("breakdown_ready", {
        "root": "applications_root",
        "items": applications_breakdown,
        "total_bytes": applications_total_bytes,
        "updated_at": iso_now(),
    })
    publish_event("breakdown_ready", {
        "root": "home_root",
        "items": home_breakdown,
        "total_bytes": home_total_bytes,
        "updated_at": iso_now(),
    })

    set_phase_progress(large_phase, 0, max(1, len(large_file_roots)), "Starting large-file scan")
    large_files_result = scan_large_files(
        large_file_roots,
        progress_callback=phase_callback_builder(large_phase),
    )
    large_files = large_files_result["items"]
    replace_large_file_rows(scan_id, "home_root", [
        {
            "path": item["path"],
            "parent_path": item["parent_path"],
            "name": item["label"],
            "apparent_bytes": item["apparent_bytes"],
            "allocated_bytes": item["allocated_bytes"],
            "updated_at": iso_now(),
        }
        for item in large_files
    ])
    checks.append(
        {
            "label": "Large file inventory",
            "command": "targeted find probes across large home buckets",
            "ok": True,
            "duration_ms": large_files_result.get("duration_ms"),
            "summary": f"Found {len(large_files)} large files >= 1 GB.",
        }
    )

    set_phase_progress(assembly_phase, 0, 1, "Assembling final report")
    hidden_delta_bytes = None
    if data_volume["volume_used_bytes"] is not None and visible_data_bytes is not None:
        hidden_delta_bytes = max(data_volume["volume_used_bytes"] - visible_data_bytes, 0)

    # Build snapshots as a separate top-level section
    snapshots_updated_at = iso_now()
    snapshots_list: List[Dict[str, Any]] = []
    for name in snapshot_names:
        token = parse_snapshot_token(name)
        if token is None:
            continue
        action_token = encode_action_token({"kind": "delete_snapshot", "snapshot_name": name, "token": token})
        # Parse token (YYYY-MM-DD-HHMMSS) into ISO date string
        try:
            parsed_date = datetime.strptime(token, "%Y-%m-%d-%H%M%S").replace(tzinfo=timezone.utc).isoformat()
        except ValueError:
            parsed_date = None
        snapshots_list.append(
            {
                "snapshot_name": name,
                "token": token,
                "parsed_date": parsed_date,
                "action_token": action_token,
            }
        )

    findings_updated_at = iso_now()
    findings: List[Dict[str, Any]] = []
    for item in watchlist:
        if item["exists"]:
            findings.append(
                {
                    "label": item["label"],
                    "path": item["path"],
                    "category": item["category"],
                    "risk": item["risk"],
                    "description": item["description"],
                    "apparent_bytes": item["apparent_bytes"],
                    "allocated_bytes": item["allocated_bytes"],
                    "estimated_reclaim_bytes": item["estimated_reclaim_bytes"],
                    "actionable": item["actionable"],
                    "cleanup_kind": item["cleanup_kind"],
                    "action_token": item["action_token"],
                }
            )
    findings.sort(
        key=lambda item: (
            bytes_or_zero(item.get("estimated_reclaim_bytes")) or bytes_or_zero(item.get("allocated_bytes")),
        ),
        reverse=True,
    )
    findings = findings[:MAX_FINDINGS]
    for finding in findings:
        finding["actions"] = build_finding_actions(finding)
        publish_event("finding_added", finding)

    large_files_updated_at = iso_now()
    large_files_with_actions = list(large_files)
    for lf in large_files_with_actions:
        if "actions" not in lf:
            lf["actions"] = build_finding_actions(lf)
        publish_event("large_file_found", lf)

    safe_reclaimable_bytes = sum(
        bytes_or_zero(item.get("estimated_reclaim_bytes"))
        for item in findings
        if item.get("risk") == "low" and item.get("actionable")
    )
    medium_reclaimable_bytes = sum(
        bytes_or_zero(item.get("estimated_reclaim_bytes"))
        for item in findings
        if item.get("risk") == "medium" and item.get("actionable")
    )
    snapshot_count = len(snapshots_list)

    if not apfs_list["ok"]:
        warnings.append(f"Failed to collect APFS list: {apfs_list['stderr']}")
    if not snapshot_info["ok"]:
        warnings.append(f"Failed to collect local snapshots: {snapshot_info['stderr']}")
    if hidden_delta_bytes is None:
        warnings.append("Could not compute hidden/system-managed delta on the Data volume.")

    breakdowns_updated_at = iso_now()
    report = {
        "version": VERSION,
        "generated_at": iso_now(),
        "started_at": started_at,
        "warnings": warnings,
        "summary": {
            "container_size_bytes": apfs_container["container_size_bytes"] or data_volume["disk_size_bytes"],
            "container_used_bytes": apfs_container["container_used_bytes"],
            "container_free_bytes": data_volume["container_free_bytes"],
            "data_volume_used_bytes": data_volume["volume_used_bytes"],
            "system_volume_used_bytes": system_volume["volume_used_bytes"],
            "visible_data_bytes": visible_data_bytes,
            "hidden_delta_bytes": hidden_delta_bytes,
            "home_total_bytes": home_total_bytes,
            "applications_total_bytes": applications_total_bytes,
            "snapshot_count": snapshot_count,
            "safe_reclaimable_bytes": safe_reclaimable_bytes,
            "medium_reclaimable_bytes": medium_reclaimable_bytes,
        },
        "breakdowns": {
            "data_root": {
                "items": data_breakdown,
                "total_bytes": data_breakdown_result["total_bytes"],
                "updated_at": breakdowns_updated_at,
            },
            "home_root": {
                "items": home_breakdown,
                "total_bytes": home_total_bytes,
                "updated_at": breakdowns_updated_at,
            },
            "library_root": {
                "items": library_breakdown,
                "total_bytes": library_breakdown_result["total_bytes"],
                "updated_at": breakdowns_updated_at,
            },
            "applications_root": {
                "items": applications_breakdown,
                "total_bytes": applications_total_bytes,
                "updated_at": breakdowns_updated_at,
            },
        },
        "watchlist": watchlist,
        "large_files": {
            "items": large_files_with_actions,
            "updated_at": large_files_updated_at,
        },
        "findings": {
            "items": findings,
            "updated_at": findings_updated_at,
        },
        "snapshots": {
            "items": snapshots_list,
            "updated_at": snapshots_updated_at,
        },
        "checks": summarize_checks(checks),
    }
    set_phase_progress(assembly_phase, 1, 1, "Report assembled")
    return report


def persist_report(report: Dict[str, Any]) -> None:
    atomic_write_json(RUNTIME_PATHS.latest_scan, report)
    timestamp = report["generated_at"].replace(":", "-")
    history_path = RUNTIME_PATHS.history_dir / f"scan-{timestamp}.json"
    atomic_write_json(history_path, report)


def run_scan_thread(scan_id: int) -> None:
    try:
        report = collect_scan_report(scan_id)
        persist_report(report)
        finalize_scan_run(scan_id, report)
        with STATE.lock:
            STATE.report = report
            STATE.scan_status = {
                "running": False,
                "phase": "idle",
                "detail": "Idle",
                "started_at": None,
                "updated_at": iso_now(),
                "progress": 1.0,
                "error": None,
            }
            STATE.scan_thread = None
        publish_event("scan_complete", report)
        publish_event("scan_status", dict(STATE.scan_status))
    except Exception as exc:
        logger.exception("Storage scan failed")
        mark_scan_run_failed(scan_id, str(exc))
        with STATE.lock:
            STATE.scan_status = {
                "running": False,
                "phase": "error",
                "detail": str(exc),
                "started_at": None,
                "updated_at": iso_now(),
                "progress": 0.0,
                "error": str(exc),
            }
            STATE.scan_thread = None
        publish_event("scan_status", dict(STATE.scan_status))


def start_scan() -> bool:
    with STATE.lock:
        if STATE.scan_thread is not None and STATE.scan_thread.is_alive():
            return False
        clear_breakdown_cache()
        scan_id = create_scan_run(iso_now())
        STATE.scan_status = {
            "running": True,
            "phase": "initializing",
            "detail": "Preparing task graph",
            "started_at": iso_now(),
            "updated_at": iso_now(),
            "progress": 0.0,
            "error": None,
        }
        thread = threading.Thread(target=run_scan_thread, args=(scan_id,), daemon=True)
        STATE.scan_thread = thread
        thread.start()
    publish_event("scan_status", dict(STATE.scan_status))
    return True


def resolve_action(action_token: str) -> Dict[str, Any]:
    try:
        payload = decode_action_token(action_token)
    except Exception as exc:
        raise HTTPException(status_code=400, detail=f"Invalid action token: {exc}") from exc
    with STATE.lock:
        report = STATE.report
    if report is None:
        raise HTTPException(status_code=400, detail="No scan report is loaded yet.")
    findings_items = report.get("findings", {}).get("items", [])
    snapshots_items = report.get("snapshots", {}).get("items", [])
    allowed_tokens = {
        item.get("action_token")
        for item in (*findings_items, *snapshots_items)
        if item.get("action_token")
    }
    if action_token not in allowed_tokens:
        raise HTTPException(status_code=400, detail="Action token is not present in the latest report.")
    return payload


def unique_trash_destination(path: Path) -> Path:
    TRASH_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    candidate = TRASH_DIR / f"storage-monitor-{stamp}-{path.name}"
    if not candidate.exists():
        return candidate
    suffix = 1
    while True:
        test = TRASH_DIR / f"storage-monitor-{stamp}-{suffix}-{path.name}"
        if not test.exists():
            return test
        suffix += 1


def execute_trash_path(path: Path) -> Dict[str, Any]:
    if not path.exists():
        raise HTTPException(status_code=404, detail=f"Path does not exist: {path}")
    destination = unique_trash_destination(path)
    sizes = stat_file_sizes(path) if path.is_file() else {"allocated_bytes": du_bytes(path), "apparent_bytes": du_bytes(path)}
    shutil.move(str(path), str(destination))
    return {
        "ok": True,
        "label": "Moved to Trash",
        "source_path": str(path),
        "trash_path": str(destination),
        "estimated_reclaim_bytes": sizes["allocated_bytes"],
    }


def execute_delete_snapshot(snapshot_name: str, token: str, *, elevate: bool = False) -> Dict[str, Any]:
    if elevate:
        # token is validated by parse_snapshot_token as \d{4}-\d{2}-\d{2}-\d{6}
        # so it is safe for shell interpolation.
        result = run_command(
            [
                "osascript", "-e",
                f'do shell script "tmutil deletelocalsnapshots {token}" with administrator privileges',
            ],
            timeout=300,
        )
    else:
        result = run_command(["tmutil", "deletelocalsnapshots", token], timeout=300)

    if result["ok"]:
        return {
            "ok": True,
            "label": "Deleted Snapshot",
            "snapshot_name": snapshot_name,
            "stdout": result["stdout"],
            "estimated_reclaim_bytes": None,
        }

    stderr = result["stderr"] or ""
    if "70" in stderr or "Stale" in stderr or "busy" in stderr.lower():
        detail = (
            f"macOS refused to delete snapshot {token}. "
            "This snapshot may be mounted or referenced by Time Machine. "
            "Try disconnecting your Time Machine backup disk and retrying, "
            "or wait for macOS to release it automatically."
        )
    elif not elevate and ("permission" in stderr.lower() or "not permitted" in stderr.lower() or result.get("returncode") in {1, 70}):
        detail = (
            f"Snapshot {token} requires admin privileges to delete. "
            "Use the 'Delete (admin)' button to authenticate."
        )
    elif "canceled" in stderr.lower() or "-128" in stderr:
        detail = "Authentication was cancelled."
    else:
        detail = stderr or "Failed to delete snapshot."
    raise HTTPException(status_code=500, detail=detail)


def record_action(payload: Dict[str, Any], result: Dict[str, Any]) -> None:
    append_jsonl(
        RUNTIME_PATHS.action_log,
        {
            "timestamp": iso_now(),
            "payload": payload,
            "result": result,
        },
    )


def reveal_path(path_str: str) -> Dict[str, Any]:
    path = Path(path_str).expanduser()
    if not path.exists():
        raise HTTPException(status_code=404, detail=f"Path does not exist: {path}")
    if path.is_file():
        subprocess.Popen(["open", "-R", str(path)])
    else:
        subprocess.Popen(["open", str(path)])
    return {"ok": True}


def collect_metadata() -> Dict[str, Any]:
    """Run diskutil probes in parallel and return container/volume stats."""
    results = run_parallel_call_map(
        {
            "apfs_list": lambda: run_command(["diskutil", "apfs", "list"], timeout=120),
            "data_info": lambda: run_command(["diskutil", "info", str(DATA_VOLUME)], timeout=120),
            "root_info": lambda: run_command(["diskutil", "info", "/"], timeout=120),
        }
    )
    apfs_list = results["apfs_list"]
    data_info = results["data_info"]
    root_info = results["root_info"]
    apfs_container = parse_apfs_list(apfs_list["stdout"] if apfs_list["ok"] else "")
    data_volume = parse_diskutil_info(data_info["stdout"] if data_info["ok"] else "")
    system_volume = parse_diskutil_info(root_info["stdout"] if root_info["ok"] else "")
    return {
        "container_size_bytes": apfs_container["container_size_bytes"] or data_volume["disk_size_bytes"],
        "container_used_bytes": apfs_container["container_used_bytes"],
        "container_free_bytes": data_volume["container_free_bytes"],
        "data_volume_used_bytes": data_volume["volume_used_bytes"],
        "system_volume_used_bytes": system_volume["volume_used_bytes"],
        "updated_at": iso_now(),
    }


def collect_snapshot_section() -> Dict[str, Any]:
    snapshot_info = run_command(["tmutil", "listlocalsnapshots", "/"], timeout=120)
    snapshot_names = parse_local_snapshot_names(snapshot_info["stdout"] if snapshot_info["ok"] else "")
    items: List[Dict[str, Any]] = []
    for name in snapshot_names:
        token = parse_snapshot_token(name)
        if token is None:
            continue
        action_token = encode_action_token({"kind": "delete_snapshot", "snapshot_name": name, "token": token})
        try:
            parsed_date = datetime.strptime(token, "%Y-%m-%d-%H%M%S").replace(tzinfo=timezone.utc).isoformat()
        except ValueError:
            parsed_date = None
        items.append(
            {
                "snapshot_name": name,
                "token": token,
                "parsed_date": parsed_date,
                "action_token": action_token,
            }
        )
    return {"items": items, "updated_at": iso_now()}


def build_findings_section(watchlist: List[Dict[str, Any]]) -> Dict[str, Any]:
    findings: List[Dict[str, Any]] = []
    for item in watchlist:
        if not item["exists"]:
            continue
        finding = {
            "label": item["label"],
            "path": item["path"],
            "category": item["category"],
            "risk": item["risk"],
            "description": item["description"],
            "apparent_bytes": item["apparent_bytes"],
            "allocated_bytes": item["allocated_bytes"],
            "estimated_reclaim_bytes": item["estimated_reclaim_bytes"],
            "actionable": item["actionable"],
            "cleanup_kind": item["cleanup_kind"],
            "action_token": item["action_token"],
        }
        finding["actions"] = build_finding_actions(finding)
        findings.append(finding)
    findings.sort(
        key=lambda item: (
            bytes_or_zero(item.get("estimated_reclaim_bytes")) or bytes_or_zero(item.get("allocated_bytes")),
        ),
        reverse=True,
    )
    return {"items": findings[:MAX_FINDINGS], "updated_at": iso_now()}


def build_breakdowns_from_db(scan_id: int) -> Dict[str, Any]:
    data_root = fetch_breakdown_from_db(scan_id, str(DATA_VOLUME.resolve()))
    home_root = fetch_breakdown_from_db(scan_id, str(HOME_DIR.resolve()))
    library_root = fetch_breakdown_from_db(scan_id, str((HOME_DIR / "Library").resolve()))
    applications_root = fetch_breakdown_from_db(scan_id, str(APPLICATIONS_DIR.resolve()))
    return {
        "data_root": data_root or {"items": [], "total_bytes": None, "updated_at": None},
        "home_root": home_root or {"items": [], "total_bytes": None, "updated_at": None},
        "library_root": library_root or {"items": [], "total_bytes": None, "updated_at": None},
        "applications_root": applications_root or {"items": [], "total_bytes": None, "updated_at": None},
    }


def build_updated_report(
    scan_id: int,
    base_report: Dict[str, Any],
    metadata: Dict[str, Any],
    watchlist: List[Dict[str, Any]],
    snapshots: Dict[str, Any],
) -> Dict[str, Any]:
    breakdowns = build_breakdowns_from_db(scan_id)
    large_files = fetch_large_files_from_db(scan_id)
    findings = build_findings_section(watchlist)
    visible_data_bytes = breakdowns["data_root"]["total_bytes"]
    hidden_delta_bytes = None
    if metadata["data_volume_used_bytes"] is not None and visible_data_bytes is not None:
        hidden_delta_bytes = max(metadata["data_volume_used_bytes"] - visible_data_bytes, 0)
    safe_reclaimable_bytes = sum(
        bytes_or_zero(item.get("estimated_reclaim_bytes"))
        for item in findings["items"]
        if item.get("risk") == "low" and item.get("actionable")
    )
    medium_reclaimable_bytes = sum(
        bytes_or_zero(item.get("estimated_reclaim_bytes"))
        for item in findings["items"]
        if item.get("risk") == "medium" and item.get("actionable")
    )
    return {
        **base_report,
        "generated_at": iso_now(),
        "summary": {
            "container_size_bytes": metadata["container_size_bytes"],
            "container_used_bytes": metadata["container_used_bytes"],
            "container_free_bytes": metadata["container_free_bytes"],
            "data_volume_used_bytes": metadata["data_volume_used_bytes"],
            "system_volume_used_bytes": metadata["system_volume_used_bytes"],
            "visible_data_bytes": visible_data_bytes,
            "hidden_delta_bytes": hidden_delta_bytes,
            "home_total_bytes": breakdowns["home_root"]["total_bytes"],
            "applications_total_bytes": breakdowns["applications_root"]["total_bytes"],
            "snapshot_count": len(snapshots["items"]),
            "safe_reclaimable_bytes": safe_reclaimable_bytes,
            "medium_reclaimable_bytes": medium_reclaimable_bytes,
        },
        "breakdowns": breakdowns,
        "watchlist": watchlist,
        "large_files": large_files,
        "findings": findings,
        "snapshots": snapshots,
    }


def refresh_directory_chain(scan_id: int, directory: Path) -> None:
    root_key = root_key_for_path(directory)
    if root_key is None:
        return
    root_boundary = ROOT_PATHS[root_key]
    current = directory.resolve()
    while True:
        breakdown = list_root_breakdown(current, limit=None)
        store_immediate_breakdown(scan_id, root_key, current, breakdown)
        if current == root_boundary:
            break
        current = current.parent


def refresh_large_files_for_paths(scan_id: int, paths: List[Path]) -> None:
    files: List[Dict[str, Any]] = []
    seen_paths = set()
    for path in paths:
        if not path.exists():
            continue
        if path.is_file():
            sizes = stat_file_sizes(path)
            if sizes["apparent_bytes"] is None or sizes["apparent_bytes"] < LARGE_FILE_THRESHOLD_BYTES:
                continue
            item = {
                "path": str(path),
                "parent_path": str(path.parent),
                "name": path.name,
                "apparent_bytes": sizes["apparent_bytes"],
                "allocated_bytes": sizes["allocated_bytes"],
                "updated_at": iso_now(),
            }
            if item["path"] not in seen_paths:
                seen_paths.add(item["path"])
                files.append(item)
            continue
        for item in scan_large_files_in_root(path):
            file_row = {
                "path": item["path"],
                "parent_path": item["parent_path"],
                "name": item["label"],
                "apparent_bytes": item["apparent_bytes"],
                "allocated_bytes": item["allocated_bytes"],
                "updated_at": iso_now(),
            }
            if file_row["path"] in seen_paths:
                continue
            seen_paths.add(file_row["path"])
            files.append(file_row)
    upsert_large_file_rows(scan_id, "home_root", files)


def refresh_after_action(action: Dict[str, Any], result: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    scan_id = fetch_active_scan_id()
    with STATE.lock:
        base_report = dict(STATE.report or {})
    metadata = collect_metadata()
    if scan_id is None or not base_report:
        publish_event("metadata_ready", metadata)
        return None

    if action.get("kind") == "trash_path":
        source_path = Path(action["path"]).expanduser()
        trash_path = Path(result["trash_path"]).expanduser()
        source_root_key = root_key_for_path(source_path)
        if source_root_key is not None:
            remove_cached_subtree(scan_id, source_root_key, str(source_path.resolve()))
            refresh_directory_chain(scan_id, source_path.parent)
        destination_root_key = root_key_for_path(trash_path)
        if destination_root_key is not None:
            refresh_directory_chain(scan_id, trash_path.parent)
        refresh_large_files_for_paths(scan_id, [trash_path])

    watchlist = scan_watchlist()["items"]
    snapshots = collect_snapshot_section()
    report = build_updated_report(scan_id, base_report, metadata, watchlist, snapshots)
    persist_report(report)
    persist_report_json(scan_id, report)
    with STATE.lock:
        STATE.report = report
    publish_event("metadata_ready", metadata)
    publish_event("report", report)
    return report


ALLOWED_BREAKDOWN_ROOTS: List[Path] = [
    DATA_VOLUME.resolve(),
    HOME_DIR.resolve(),
    (HOME_DIR / "Library").resolve(),
    APPLICATIONS_DIR.resolve(),
]
ROOT_PATHS: Dict[str, Path] = {
    "data_root": DATA_VOLUME.resolve(),
    "home_root": HOME_DIR.resolve(),
    "library_root": (HOME_DIR / "Library").resolve(),
    "applications_root": APPLICATIONS_DIR.resolve(),
}
ALIASABLE_ROOT_TARGETS: List[Path] = [
    APPLICATIONS_DIR.resolve(),
    HOME_DIR.resolve(),
    (HOME_DIR / "Library").resolve(),
]


def root_key_for_path(path: Path) -> Optional[str]:
    resolved = path.resolve()
    for root_key, root_path in ROOT_PATHS.items():
        try:
            resolved.relative_to(root_path)
            return root_key
        except ValueError:
            continue
        except Exception:
            continue
    return None


def canonicalize_breakdown_path(path: Path) -> Path:
    resolved = path.resolve()
    for target in ALIASABLE_ROOT_TARGETS:
        if samefile_or_false(resolved, target):
            return target
    return resolved


def alias_target_for_data_child(path: Path) -> Optional[Path]:
    resolved = path.resolve()
    for target in ALIASABLE_ROOT_TARGETS:
        if samefile_or_false(resolved, target):
            return target
    return None


def validate_breakdown_path(path_str: str) -> Path:
    """Resolve path_str and verify it is a directory under an allowed root."""
    try:
        resolved = Path(path_str).expanduser().resolve()
    except (ValueError, OSError, RuntimeError) as exc:
        raise HTTPException(status_code=400, detail=f"Invalid path: {exc}") from exc
    if not resolved.exists():
        raise HTTPException(status_code=404, detail=f"Path does not exist: {resolved}")
    if not resolved.is_dir():
        raise HTTPException(status_code=400, detail=f"Path is not a directory: {resolved}")
    for allowed_root in ALLOWED_BREAKDOWN_ROOTS:
        try:
            resolved.relative_to(allowed_root)
            return resolved
        except ValueError:
            continue
        except Exception:
            continue
    raise HTTPException(
        status_code=400,
        detail=f"Path is not under an allowed breakdown root: {resolved}",
    )


def choose_scan_id_for_path(path_str: str) -> Optional[int]:
    running_scan_id = fetch_running_scan_id()
    if running_scan_id is not None and fetch_breakdown_from_db(running_scan_id, path_str) is not None:
        return running_scan_id
    active_scan_id = fetch_active_scan_id()
    if active_scan_id is not None:
        return active_scan_id
    return running_scan_id


def store_breakdown_for_path(scan_id: int, path: Path) -> Dict[str, Any]:
    canonical_path = canonicalize_breakdown_path(path)
    root_key = root_key_for_path(canonical_path)
    if root_key is None:
        raise HTTPException(status_code=400, detail=f"Path is not under a supported root: {path}")
    breakdown = list_root_breakdown(canonical_path, limit=None)
    store_immediate_breakdown(scan_id, root_key, canonical_path, breakdown)
    response = fetch_breakdown_from_db(scan_id, str(canonical_path))
    if response is None:
        raise HTTPException(status_code=500, detail=f"Failed to persist breakdown for {path}")
    return response


