                  background: isScanning ? 'var(--warning)' : 'var(--success)',
                  animation: isScanning ? 'pulse 1.5s ease infinite' : 'none',
                }} />
                {isScanning ? `Scanning: ${scanStatus?.phase || 'preparing'}` : (scanAge ? `Scanned ${scanAge}` : 'Ready')}
              </div>
            </div>

            {/* Center: usage bar */}
            {containerSize > 0 && (
              <div style={{ display: 'flex', alignItems: 'center', gap: 10, flex: 1, maxWidth: 360, minWidth: 200 }}>
                <span className="mono" style={{ fontSize: 11, color: 'var(--text-secondary)', whiteSpace: 'nowrap' }}>
                  {formatBytes(usedBytes)} used
