    except json.JSONDecodeError:
        return None
    return payload if isinstance(payload, dict) else None


def upsert_node_rows(scan_id: int, rows: List[Dict[str, Any]]) -> None:
    if not rows:
        return
    payload = [
        (
            scan_id,
            row["path"],
            row["parent_path"],
            row["name"],
            row["root_key"],
            row["depth"],
            row["allocated_bytes"],
            int(bool(row.get("children_indexed", False))),
            row["updated_at"],
        )
        for row in rows
    ]
    with DB_WRITE_LOCK:
        with open_db_connection() as connection:
            connection.executemany(
                """
                INSERT INTO nodes (
                    scan_id, path, parent_path, name, root_key, depth, allocated_bytes, children_indexed, updated_at
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
                ON CONFLICT(scan_id, path) DO UPDATE SET
                    parent_path = excluded.parent_path,
                    name = excluded.name,
                    root_key = excluded.root_key,
                    depth = excluded.depth,
                    allocated_bytes = excluded.allocated_bytes,
                    children_indexed = excluded.children_indexed,
                    updated_at = excluded.updated_at
                """,
                payload,
            )
            connection.commit()


