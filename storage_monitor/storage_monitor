def run_command(args: List[str], timeout: int = 120) -> Dict[str, Any]:
    start = time.time()
    try:
        result = subprocess.run(
            args,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
        return {
            "ok": result.returncode == 0,
            "returncode": result.returncode,
            "stdout": result.stdout,
            "stderr": result.stderr,
            "duration_ms": int((time.time() - start) * 1000),
            "command": " ".join(args),
        }
    except Exception as exc:
        return {
            "ok": False,
            "returncode": None,
            "stdout": "",
            "stderr": str(exc),
            "duration_ms": int((time.time() - start) * 1000),
            "command": " ".join(args),
        }


def run_parallel_call_map(
    task_map: Dict[str, Any],
    max_workers: Optional[int] = None,
    progress_callback: Optional[Any] = None,
) -> Dict[str, Any]:
    if not task_map:
        return {}
    worker_count = max_workers or min(SCAN_WORKER_COUNT, len(task_map))
    results: Dict[str, Any] = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=worker_count) as executor:
        future_map = {executor.submit(func): key for key, func in task_map.items()}
        for future in concurrent.futures.as_completed(future_map):
            key = future_map[future]
            results[key] = future.result()
            if progress_callback is not None:
                progress_callback(key, len(results), len(task_map))
    return results


def expand_path(path_str: str) -> Path:
    return Path(os.path.expanduser(path_str)).resolve()


def safe_stat(path: Path) -> Optional[os.stat_result]:
    try:
        return path.stat()
    except OSError:
        return None


def allocated_bytes_from_stat(stat_result: Optional[os.stat_result]) -> Optional[int]:
    if stat_result is None:
        return None
    blocks = getattr(stat_result, "st_blocks", None)
    if blocks is None:
        return None
    return int(blocks) * 512


def du_bytes(path: Path, timeout: int = 240) -> Optional[int]:
    if not path.exists():
        return None
    result = run_command(["du", "-xsk", str(path)], timeout=timeout)
    if not result["stdout"].strip():
        return None
    first = result["stdout"].strip().splitlines()[0]
    match = re.match(r"^\s*(\d+)", first)
    if not match:
        return None
    return int(match.group(1)) * 1024


def stat_file_sizes(path: Path) -> Dict[str, Optional[int]]:
    stat_result = safe_stat(path)
    if stat_result is None:
        return {"apparent_bytes": None, "allocated_bytes": None}
    return {
        "apparent_bytes": int(stat_result.st_size),
        "allocated_bytes": allocated_bytes_from_stat(stat_result) or int(stat_result.st_size),
    }


def bytes_or_zero(value: Optional[int]) -> int:
    return int(value or 0)


def format_number(value: Optional[int]) -> str:
    if value is None:
        return "Unknown"
    units = ["B", "KB", "MB", "GB", "TB", "PB"]
    amount = float(value)
    for unit in units:
        if amount < 1024.0 or unit == units[-1]:
            if unit == "B":
                return f"{int(amount)} {unit}"
            return f"{amount:.1f} {unit}"
        amount /= 1024.0
    return f"{int(value)} B"


def encode_action_token(payload: Dict[str, Any]) -> str:
    return base64.urlsafe_b64encode(json.dumps(payload, sort_keys=True).encode("utf-8")).decode("ascii")


def decode_action_token(token: str) -> Dict[str, Any]:
    return json.loads(base64.urlsafe_b64decode(token.encode("ascii")).decode("utf-8"))


def publish_event(event_type: str, payload: Dict[str, Any]) -> None:
    message = {"type": event_type, "payload": payload}
    stale_ids: List[str] = []
    with STATE.lock:
        subscribers = list(STATE.subscribers.items())
    for subscriber_id, subscriber_queue in subscribers:
        try:
            subscriber_queue.put_nowait(message)
        except Exception:
            stale_ids.append(subscriber_id)
    if stale_ids:
        with STATE.lock:
            for subscriber_id in stale_ids:
                STATE.subscribers.pop(subscriber_id, None)


def set_scan_status(**updates: Any) -> None:
    with STATE.lock:
        STATE.scan_status.update(updates)
        STATE.scan_status["updated_at"] = iso_now()
        snapshot = dict(STATE.scan_status)
    publish_event("scan_status", snapshot)


