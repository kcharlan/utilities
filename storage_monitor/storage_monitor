class AppState:
    def __init__(self) -> None:
        self.lock = threading.Lock()
        self.report: Optional[Dict[str, Any]] = None
        self.scan_status: Dict[str, Any] = {
            "running": False,
            "phase": "idle",
            "detail": "Idle",
            "started_at": None,
            "updated_at": iso_now(),
            "progress": 0.0,
            "error": None,
        }
        self.scan_thread: Optional[threading.Thread] = None
        self.subscribers: Dict[str, "queue.Queue[Dict[str, Any]]"] = {}


def iso_now() -> str:
    return datetime.now(timezone.utc).isoformat()


STATE = AppState()

# In-memory TTL cache for breakdown (du) results, keyed by resolved path string.
# Cleared on each new scan so rescans always produce fresh data.
_breakdown_cache: Dict[str, tuple] = {}  # {path_str: (timestamp, result_dict)}
_breakdown_cache_lock = threading.Lock()


def get_cached_breakdown(path_key: str) -> Optional[Dict[str, Any]]:
    """Return cached breakdown result if present and not expired, else None."""
    with _breakdown_cache_lock:
        entry = _breakdown_cache.get(path_key)
    if entry is None:
        return None
    cached_at, result = entry
    if time.time() - cached_at > BREAKDOWN_CACHE_TTL_SECONDS:
        with _breakdown_cache_lock:
            _breakdown_cache.pop(path_key, None)
        return None
    return result


def set_cached_breakdown(path_key: str, result: Dict[str, Any]) -> None:
    """Store a breakdown result in the cache."""
    with _breakdown_cache_lock:
        _breakdown_cache[path_key] = (time.time(), result)


def clear_breakdown_cache() -> None:
    """Flush the entire breakdown cache (called on scan start and after actions)."""
    with _breakdown_cache_lock:
        _breakdown_cache.clear()


def path_parent(path_str: str) -> Optional[str]:
    path = Path(path_str)
    return str(path.parent) if path.parent != path else None


def path_depth(root: Path, path_str: str) -> int:
    try:
        return len(Path(path_str).relative_to(root).parts)
    except ValueError:
        return 0


def sql_like_prefix(path_str: str) -> str:
    escaped = path_str.replace("\\", "\\\\").replace("%", "\\%").replace("_", "\\_")
    return f"{escaped}/%"


def samefile_or_false(left: Path, right: Path) -> bool:
    try:
        return os.path.samefile(str(left), str(right))
    except OSError:
        return False


def create_scan_run(started_at: str) -> int:
    with DB_WRITE_LOCK:
        with open_db_connection() as connection:
            cursor = connection.execute(
                "INSERT INTO scan_runs (started_at, status, active) VALUES (?, 'running', 0)",
                (started_at,),
            )
            connection.commit()
            return int(cursor.lastrowid)


def finalize_scan_run(scan_id: int, report: Dict[str, Any]) -> None:
    report_json = json.dumps(report, sort_keys=True)
    with DB_WRITE_LOCK:
        with open_db_connection() as connection:
            connection.execute("UPDATE scan_runs SET active = 0 WHERE active = 1")
            connection.execute(
                """
                UPDATE scan_runs
                SET completed_at = ?, status = 'completed', active = 1, report_json = ?
                WHERE id = ?
                """,
                (iso_now(), report_json, scan_id),
            )
            connection.commit()


def mark_scan_run_failed(scan_id: int, error_text: str) -> None:
    with DB_WRITE_LOCK:
        with open_db_connection() as connection:
            connection.execute(
                """
                UPDATE scan_runs
                SET completed_at = ?, status = 'failed', report_json = ?
                WHERE id = ?
                """,
                (
                    iso_now(),
                    json.dumps({"error": error_text, "updated_at": iso_now()}, sort_keys=True),
                    scan_id,
                ),
            )
            connection.commit()


