@app.get("/api/breakdown")
def api_breakdown(path: str) -> Dict[str, Any]:
    validated = validate_breakdown_path(path)
    cache_key = str(canonicalize_breakdown_path(validated))
    cached = get_cached_breakdown(cache_key)
    if cached is not None:
        return cached
    scan_id = choose_scan_id_for_path(cache_key)
    response = fetch_breakdown_from_db(scan_id, cache_key) if scan_id is not None else None
    if response is None:
        if scan_id is not None:
            response = store_breakdown_for_path(scan_id, validated)
        else:
            result = list_root_breakdown(validated)
            response = {
                "path": cache_key,
                "total_bytes": result["total_bytes"],
                "items": result["items"],
                "updated_at": iso_now(),
            }
    set_cached_breakdown(cache_key, response)
    return response


@app.post("/api/actions/execute")
def api_execute_action(payload: Dict[str, Any]) -> Dict[str, Any]:
    action_token = payload.get("action_token")
    if not action_token:
        raise HTTPException(status_code=400, detail="Missing action_token.")
    action = resolve_action(action_token)
    kind = action.get("kind")
    if kind == "trash_path":
        result = execute_trash_path(Path(action["path"]))
    elif kind == "delete_snapshot":
        elevate = payload.get("elevate", False)
        result = execute_delete_snapshot(action["snapshot_name"], action["token"], elevate=elevate)
    else:
        raise HTTPException(status_code=400, detail=f"Unsupported action kind: {kind}")
    record_action(action, result)
    publish_event("action_result", result)
    try:
        refresh_after_action(action, result)
    except Exception:
        logger.exception("Immediate post-action refresh failed")
    return result


@app.post("/api/reveal")
def api_reveal(payload: Dict[str, Any]) -> Dict[str, Any]:
    path = payload.get("path")
    if not path:
        raise HTTPException(status_code=400, detail="Missing path.")
    return reveal_path(path)


@app.post("/api/shutdown")
def api_shutdown() -> Dict[str, Any]:
    """Gracefully shut down the server."""
    logger.info("Shutdown requested via API")
    RUNTIME_PATHS.pid_file.unlink(missing_ok=True)
    # Schedule shutdown after response is sent
    threading.Thread(target=lambda: (time.sleep(0.5), os.kill(os.getpid(), signal.SIGTERM)), daemon=True).start()
    return {"ok": True, "label": "Shutting down..."}


