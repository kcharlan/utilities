            "running": False,
            "phase": "idle",
            "detail": "Idle",
            "started_at": None,
            "updated_at": iso_now(),
            "progress": 0.0,
            "phase_progress": 0.0,
            "completed_in_phase": 0,
            "total_in_phase": 0,
            "error": None,
        }
        self.scan_thread: Optional[threading.Thread] = None
        self.subscribers: Dict[str, "queue.Queue[Dict[str, Any]]"] = {}


def iso_now() -> str:
    return datetime.now(timezone.utc).isoformat()


