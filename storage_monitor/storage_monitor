@dataclass(frozen=True)
class RuntimePaths:
    home: Path
    venv: Path
    venv_python: Path
    bootstrap_state: Path
    latest_scan: Path
    history_dir: Path
    action_log: Path
    last_port: Path


def build_runtime_paths() -> RuntimePaths:
    override = os.environ.get("STORAGE_MONITOR_HOME")
    home = Path(override).expanduser() if override else Path.home() / ".storage_monitor"
    return RuntimePaths(
        home=home,
        venv=home / "venv",
        venv_python=home / "venv" / "bin" / "python",
        bootstrap_state=home / BOOTSTRAP_STATE_FILENAME,
        latest_scan=home / "latest_scan.json",
        history_dir=home / "history",
        action_log=home / "action_log.jsonl",
        last_port=home / "last_port",
    )


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Storage Monitor: scan local storage, surface reclaim candidates, and run safe cleanup actions.",
    )
    parser.add_argument("--port", "-p", type=int, default=8473, help="Preferred localhost port (default: 8473).")
    parser.add_argument("--no-browser", action="store_true", help="Do not auto-open the browser UI.")
    return parser.parse_args()


def bootstrap_needed(argv: List[str]) -> bool:
    return not any(arg in {"-h", "--help"} for arg in argv)


def desired_bootstrap_state() -> Dict[str, str]:
    return {
        "bootstrap_version": BOOTSTRAP_VERSION,
        "python_version": f"{sys.version_info.major}.{sys.version_info.minor}",
    }


def read_bootstrap_state(paths: RuntimePaths) -> Optional[Dict[str, Any]]:
    if not paths.bootstrap_state.is_file():
        return None
    try:
        data = json.loads(paths.bootstrap_state.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return None
    return data if isinstance(data, dict) else None


def write_bootstrap_state(paths: RuntimePaths) -> None:
    paths.bootstrap_state.write_text(
        json.dumps(desired_bootstrap_state(), indent=2) + "\n",
        encoding="utf-8",
    )


def ensure_runtime_home(paths: RuntimePaths) -> None:
    paths.home.mkdir(parents=True, exist_ok=True)
    paths.history_dir.mkdir(parents=True, exist_ok=True)


def install_runtime_dependencies(paths: RuntimePaths) -> None:
    subprocess.check_call(
        [str(paths.venv_python), "-m", "pip", "install", "--quiet", *DEPENDENCIES]
    )


def ensure_private_venv(paths: RuntimePaths) -> None:
    ensure_runtime_home(paths)
    in_target_venv = Path(sys.prefix).resolve() == paths.venv.resolve()
    bootstrap_state = read_bootstrap_state(paths)
    needs_refresh = (
        not paths.venv_python.exists()
        or bootstrap_state != desired_bootstrap_state()
    )

    if not in_target_venv:
        if needs_refresh:
            if paths.venv.exists():
                shutil.rmtree(paths.venv)
            sys.stderr.write(
                f"[storage_monitor] Preparing private runtime at {paths.venv}\n"
            )
            venv.EnvBuilder(with_pip=True).create(paths.venv)
            install_runtime_dependencies(paths)
            write_bootstrap_state(paths)
        os.execv(
            str(paths.venv_python),
            [str(paths.venv_python), str(Path(__file__).resolve()), *sys.argv[1:]],
        )

    if needs_refresh:
        install_runtime_dependencies(paths)
        write_bootstrap_state(paths)


if __name__ == "__main__":
    _runtime_paths = build_runtime_paths()
    if bootstrap_needed(sys.argv[1:]):
        ensure_private_venv(_runtime_paths)
    else:
        parse_args()

