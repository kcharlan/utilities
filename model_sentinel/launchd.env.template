# Model Sentinel launchd environment bootstrap.
#
# Live file location after ./setup_launchd.sh:
#   ~/.model_sentinel/launchd.env
#
# This file is sourced by the launchd runner script using bash.
# It may contain plain exports and/or shell commands that source another
# secrets file.
#
# Keep this file private:
#   chmod 600 ~/.model_sentinel/launchd.env

# Option 1: source an existing secrets/bootstrap script.
# Example:
# source "$HOME/path/to/your/secrets.sh"

# Option 2: export the values directly here.
# Example:
# export OPENROUTER_AI_CREDS="..."
# export ABACUS_AI_CREDS="..."

