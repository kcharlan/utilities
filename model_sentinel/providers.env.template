# Model Sentinel provider configuration template.
#
# The live config file is created by ./setup.sh at:
#   ~/.model_sentinel/providers.env
#
# IMPORTANT:
# - Do not place raw API keys in this file.
# - Export the credential variables in your shell before running the tool.
# - Missing required credential env vars should cause the tool to halt.

# -----------------------------
# OpenRouter
# -----------------------------
MODEL_SENTINEL_PROVIDER_OPENROUTER_ENABLED=1
MODEL_SENTINEL_PROVIDER_OPENROUTER_LABEL=OpenRouter
MODEL_SENTINEL_PROVIDER_OPENROUTER_KIND=openrouter
MODEL_SENTINEL_PROVIDER_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_SENTINEL_PROVIDER_OPENROUTER_MODELS_PATH=/models
MODEL_SENTINEL_PROVIDER_OPENROUTER_API_KEY_ENV=OPENROUTER_AI_CREDS

# -----------------------------
# Abacus.AI
# -----------------------------
MODEL_SENTINEL_PROVIDER_ABACUS_ENABLED=1
MODEL_SENTINEL_PROVIDER_ABACUS_LABEL=Abacus.AI
MODEL_SENTINEL_PROVIDER_ABACUS_KIND=abacus
MODEL_SENTINEL_PROVIDER_ABACUS_BASE_URL=https://routellm.abacus.ai/v1
MODEL_SENTINEL_PROVIDER_ABACUS_MODELS_PATH=/models
MODEL_SENTINEL_PROVIDER_ABACUS_API_KEY_ENV=ABACUS_AI_CREDS

# Future providers can be added by following the same naming pattern.
# A future implementation may add optional fields such as custom headers,
# auth scheme overrides, request timeouts, or provider-specific query params.

