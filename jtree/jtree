    string: { border: '#66bb6a', bg: 'rgba(102,187,106,0.08)', badgeBg: 'rgba(102,187,106,0.15)', text: '#66bb6a' },
    number: { border: '#ffa726', bg: 'rgba(255,167,38,0.08)', badgeBg: 'rgba(255,167,38,0.15)', text: '#ffa726' },
    boolean: { border: '#ef5350', bg: 'rgba(239,83,80,0.08)', badgeBg: 'rgba(239,83,80,0.15)', text: '#ef5350' },
