    // Annotate parent types after fetching
    const annotateParentTypes = useCallback(async () => {
        const newCache = new Map(childrenCache);
        for (const [parentPath, children] of newCache) {
            try {
                const parentNode = parentPath === '' ? rootNode : await api(`/api/node?path=${encodeURIComponent(parentPath)}`);
                if (parentNode) {
                    const annotated = children.map((c, i) => ({ ...c, _parentType: parentNode.type, _isLastInArray: parentNode.type === 'array' && i === children.length - 1 }));
                    newCache.set(parentPath, annotated);
                }
            } catch (e) { /* ignore */ }
        }
        setChildrenCache(newCache);
    }, [childrenCache, rootNode]);

    // Initial load
    useEffect(() => {
        fetchStatus();
        fetchNodeData('').then(node => {
            if (node && (node.type === 'object' || node.type === 'array')) {
                fetchChildren('');
            }
        });
    }, []);

    // Expand/collapse
    const toggleExpand = useCallback(async (path) => {
        setExpandedSet(prev => {
            const next = new Set(prev);
            if (next.has(path)) {
                next.delete(path);
            } else {
                next.add(path);
            }
            return next;
        });

        if (!expandedSet.has(path) && !childrenCache.has(path)) {
            await fetchChildren(path);
        }
        pendingCenterRef.current = path;
    }, [expandedSet, childrenCache, fetchChildren]);

    // Expand all descendants
    const expandAll = useCallback(async (path) => {
        const toExpand = [path];
        const visited = new Set();
        // Local cache to track freshly fetched children (closure's childrenCache is stale)
        const localCache = new Map(childrenCache);
        while (toExpand.length > 0) {
            const p = toExpand.shift();
            if (visited.has(p)) continue;
            visited.add(p);
            if (!localCache.has(p)) {
                try {
                    const data = await api(`/api/children?path=${encodeURIComponent(p)}&offset=0&limit=200`);
                    localCache.set(p, data.children || []);
                } catch (e) {
                    continue;
                }
            }
            const children = localCache.get(p) || [];
            for (const c of children) {
                if (c.type === 'object' || c.type === 'array') {
                    toExpand.push(c.path);
                }
            }
        }
        // Batch update: push all fetched children into cache and expand all at once
        setChildrenCache(prev => {
            const next = new Map(prev);
            for (const [k, v] of localCache) next.set(k, v);
            return next;
        });
        setExpandedSet(prev => {
            const next = new Set(prev);
            for (const p of visited) next.add(p);
            return next;
        });
        // Schedule view re-centering on the target node after layout recomputes
        pendingCenterRef.current = path;
    }, [childrenCache]);

    // Collapse all descendants
    const collapseAll = useCallback((path) => {
        setExpandedSet(prev => {
            const next = new Set(prev);
            for (const p of prev) {
                // Root path ('') is ancestor of everything
                if (path === '' || p === path || p.startsWith(path + '.')) {
                    next.delete(p);
                }
            }
            return next;
        });
        pendingCenterRef.current = path;
    }, []);

    // Refresh tree from root
    const refreshTree = useCallback(async () => {
        const node = await fetchNodeData('');
        if (!node) return;
        // Re-fetch children for all expanded paths
        const expanded = [...expandedSet];
        const newCache = new Map();
        for (const p of expanded) {
            try {
                const data = await api(`/api/children?path=${encodeURIComponent(p)}&offset=0&limit=500`);
                // Annotate with parent type
                const parentNode = await api(`/api/node?path=${encodeURIComponent(p)}`);
                const children = data.children.map((c, i) => ({ ...c, _parentType: parentNode.type, _isLastInArray: parentNode.type === 'array' && i === data.children.length - 1 }));
                newCache.set(p, children);
            } catch (e) {
                // Path may no longer exist after mutation
            }
        }
        setChildrenCache(newCache);
        fetchStatus();
    }, [expandedSet, fetchNodeData, fetchStatus]);

    // Build visible nodes list
    const visibleNodes = useMemo(() => {
        if (!rootNode) return [];
        const nodes = [rootNode];
        const addChildren = (path) => {
            if (!expandedSet.has(path)) return;
            const children = childrenCache.get(path) || [];
            for (const child of children) {
                nodes.push(child);
                if (child.type === 'object' || child.type === 'array') {
                    addChildren(child.path);
                }
            }
        };
        addChildren('');
        return nodes;
    }, [rootNode, expandedSet, childrenCache]);

    // Compute layout
    const positions = useMemo(() => {
        const p = new Map();
        p._nextY = 0;
        if (visibleNodes.length === 0) return p;
        const root = visibleNodes.find(n => n.path === '');
        if (root) layoutSubtree(root, 0, p, expandedSet, childrenCache);
        return p;
    }, [visibleNodes, expandedSet, childrenCache]);

    // Compute group colors for parent-child lineage
    const groupColors = useMemo(() => {
        return computeGroupColors(rootNode, expandedSet, childrenCache, isDark);
    }, [rootNode, expandedSet, childrenCache, isDark]);

    const edges = useMemo(() => computeEdges(positions, expandedSet, childrenCache), [positions, expandedSet, childrenCache]);

    // Compute containment lanes for expanded nodes
    const lanes = useMemo(() => {
        return computeLanes(positions, expandedSet, childrenCache, groupColors);
    }, [positions, expandedSet, childrenCache, groupColors]);

    // Center view on pending path after layout recomputation (e.g., after expandAll/collapseAll)
    useEffect(() => {
        if (pendingCenterRef.current !== null) {
            const path = pendingCenterRef.current;
            pendingCenterRef.current = null;
            const pos = positions.get(path);
            if (pos) {
                setPan({ x: canvasSize.width / 3 - pos.x * zoom, y: canvasSize.height / 3 - pos.y * zoom });
            }
        }
    }, [positions, canvasSize, zoom]);

    // Pan and zoom handlers
    const handleWheel = useCallback((e) => {
        e.preventDefault();
        if (e.ctrlKey || e.metaKey) {
            const delta = e.deltaY > 0 ? 0.9 : 1.1;
            setZoom(z => Math.max(0.1, Math.min(3, z * delta)));
        } else {
            setPan(p => ({ x: p.x - e.deltaX, y: p.y - e.deltaY }));
        }
    }, []);

    const handleMouseDown = useCallback((e) => {
        if (e.button !== 0) return;
        if (e.target.closest('.graph-node')) return;
        setIsPanning(true);
        panStart.current = { x: e.clientX, y: e.clientY, panX: pan.x, panY: pan.y };
    }, [pan]);

    const handleMouseMove = useCallback((e) => {
        if (!isPanning) return;
        setPan({
            x: panStart.current.panX + (e.clientX - panStart.current.x),
            y: panStart.current.panY + (e.clientY - panStart.current.y),
        });
    }, [isPanning]);

    const handleMouseUp = useCallback(() => {
        setIsPanning(false);
    }, []);

    // Node click
    // Single click: select only
    const handleNodeClick = useCallback((node) => {
        setSelectedPath(node.path);
    }, []);

    // Double-click: toggle expand/collapse for containers, edit for leaves
    const handleNodeDoubleClick = useCallback((node) => {
        if (node.type === 'object' || node.type === 'array') {
            toggleExpand(node.path);
        } else if (!status?.readonly) {
            setModal({ type: 'edit', node });
        }
    }, [toggleExpand, status]);

    // Chevron click: toggle expand/collapse directly
    const handleChevronClick = useCallback((node) => {
        toggleExpand(node.path);
    }, [toggleExpand]);

    // Context menu
    const handleContextMenu = useCallback((e, node) => {
        setContextMenu({ x: e.clientX, y: e.clientY, node });
    }, []);

    // Context menu actions
    const handleContextAction = useCallback((action, node) => {
        switch (action) {
            case 'toggleExpand':
                toggleExpand(node.path);
                break;
            case 'expandAll':
                expandAll(node.path);
                break;
            case 'collapseAll':
                collapseAll(node.path);
                break;
            case 'addChild':
                setModal({ type: 'addChild', node });
                break;
            case 'delete':
                if (node.childCount > 0) {
                    setModal({ type: 'delete', node });
                } else {
                    handleDelete(node.path);
                }
                break;
            case 'rename':
                setModal({ type: 'rename', node });
                break;
            case 'editValue':
                setModal({ type: 'edit', node });
                break;
            case 'moveUp': {
                const parts = node.path.split('.');
                const idx = parseInt(parts.pop(), 10);
                const parentPath = parts.join('.');
                if (idx > 0) handleMoveChild(parentPath, idx, idx - 1);
                break;
            }
            case 'moveDown': {
                const parts = node.path.split('.');
                const idx = parseInt(parts.pop(), 10);
                const parentPath = parts.join('.');
                handleMoveChild(parentPath, idx, idx + 1);
                break;
            }
            case 'moveTo':
                setModal({ type: 'moveTo', node });
                break;
            case 'copyNode':
                handleCopy(node.path);
                break;
            case 'paste':
                handlePaste(node.path);
                break;
        }
    }, [toggleExpand, expandAll, collapseAll, handleMoveChild, handleCopy, handlePaste]);

    // Mutations
    const handleEditSave = useCallback(async (path, value) => {
        try {
            await api(`/api/node?path=${encodeURIComponent(path)}`, {
                method: 'PUT',
                body: JSON.stringify({ value }),
            });
            setModal(null);
            setToast('Value updated');
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [refreshTree]);

    const handleAddChild = useCallback(async (parentPath, key, value, type) => {
        try {
            await api(`/api/node?path=${encodeURIComponent(parentPath)}`, {
                method: 'POST',
                body: JSON.stringify({ key, value, type }),
            });
            setModal(null);
            // Ensure parent is expanded
            setExpandedSet(prev => {
                const next = new Set(prev);
                next.add(parentPath);
                return next;
            });
            setToast('Child added');
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [refreshTree]);

    const handleDelete = useCallback(async (path) => {
        try {
            await api(`/api/node?path=${encodeURIComponent(path)}`, { method: 'DELETE' });
            setModal(null);
            // Remove from expanded set
            setExpandedSet(prev => {
                const next = new Set(prev);
                for (const p of prev) {
                    if (p === path || p.startsWith(path + '.')) next.delete(p);
                }
                return next;
            });
            setToast('Deleted (Ctrl+Z to undo)');
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [refreshTree]);

    const handleRename = useCallback(async (path, newKey) => {
        try {
            await api(`/api/rename?path=${encodeURIComponent(path)}`, {
                method: 'POST',
                body: JSON.stringify({ newKey }),
            });
            setModal(null);
            setToast('Key renamed');
            // Update expanded paths
            setExpandedSet(prev => {
                const next = new Set();
                const oldKey = path.split('.').pop();
                const parentPath = path.split('.').slice(0, -1).join('.');
                const newPath = parentPath ? `${parentPath}.${newKey}` : newKey;
                for (const p of prev) {
                    if (p === path) {
                        next.add(newPath);
                    } else if (p.startsWith(path + '.')) {
                        next.add(newPath + p.slice(path.length));
                    } else {
                        next.add(p);
                    }
                }
                return next;
            });
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [refreshTree]);

    const handleSave = useCallback(async () => {
        try {
            await api('/api/save', { method: 'POST' });
            setToast('Saved');
            fetchStatus();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [fetchStatus]);

    const handleSaveAs = useCallback(async (filePath) => {
        try {
            await api('/api/save-as', {
                method: 'POST',
                body: JSON.stringify({ path: filePath }),
            });
            setModal(null);
            setToast(`Saved to ${filePath}`);
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, []);

    const reloadAfterOpen = useCallback(async () => {
        setModal(null);
        setExpandedSet(new Set(['']));
        setChildrenCache(new Map());
        setSelectedPath('');
        setSearchMatchPath(null);
        setPan({ x: 40, y: 40 });
        setZoom(1);
        const s = await api('/api/status');
        setStatus(s);
        const node = await api('/api/node?path=');
        setRootNode(node);
        if (node && (node.type === 'object' || node.type === 'array')) {
            const data = await api('/api/children?path=&offset=0&limit=500');
            const annotated = data.children.map((c, i) => ({ ...c, _parentType: node.type, _isLastInArray: node.type === 'array' && i === data.children.length - 1 }));
            setChildrenCache(new Map([['', annotated]]));
        }
        setToast(`Opened ${s.fileName}`);
    }, []);

    const handleOpenPath = useCallback(async (filePath) => {
        try {
            setOpenError(null);
            await api('/api/open', {
                method: 'POST',
                body: JSON.stringify({ path: filePath }),
            });
            await reloadAfterOpen();
        } catch (e) {
            setOpenError(e.message);
        }
    }, [reloadAfterOpen]);

    const handleOpenContent = useCallback(async (content, fileName) => {
        try {
            setOpenError(null);
            await api('/api/open-content', {
                method: 'POST',
                body: JSON.stringify({ content, fileName }),
            });
            await reloadAfterOpen();
        } catch (e) {
            setOpenError(e.message);
            throw e; // re-throw so the modal knows it failed
        }
    }, [reloadAfterOpen]);

    const handleUndo = useCallback(async () => {
        try {
            await api('/api/undo', { method: 'POST' });
            setToast('Undone');
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [refreshTree]);

    const handleRedo = useCallback(async () => {
        try {
            await api('/api/redo', { method: 'POST' });
            setToast('Redone');
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [refreshTree]);

    const handleMoveChild = useCallback(async (parentPath, fromIndex, toIndex) => {
        try {
            await api(`/api/move?path=${encodeURIComponent(parentPath)}`, {
                method: 'POST',
                body: JSON.stringify({ fromIndex, toIndex }),
            });
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [refreshTree]);

    const handleCopy = useCallback(async (path) => {
        try {
            const data = await api(`/api/copy?path=${encodeURIComponent(path)}`);
            setClipboard(data);
            setToast('Copied');
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, []);

    const handlePaste = useCallback(async (targetPath) => {
        if (!clipboard) {
            setToast('Nothing to paste');
            return;
        }
        // Find the target node to check if it's a container
        let pastePath = targetPath;
        try {
            const targetNode = await api(`/api/node?path=${encodeURIComponent(targetPath)}`);
            if (targetNode.type !== 'object' && targetNode.type !== 'array') {
                // Not a container — paste into parent instead
                const parts = targetPath.split('.');
                parts.pop();
                pastePath = parts.join('.');
            }
        } catch (e) {
            // If we can't resolve, try anyway
        }
        try {
            await api(`/api/paste?path=${encodeURIComponent(pastePath)}`, {
                method: 'POST',
                body: JSON.stringify({ key: clipboard.key, value: clipboard.value }),
            });
            setToast('Pasted');
            // Ensure target is expanded
            setExpandedSet(prev => {
                const next = new Set(prev);
                next.add(pastePath);
                return next;
            });
            await refreshTree();
        } catch (e) {
            setToast(`Error: ${e.message}`);
        }
    }, [clipboard, refreshTree]);

    // Export current view
    const [showExportMenu, setShowExportMenu] = useState(false);

    const handleExport = useCallback(async (format) => {
        setShowExportMenu(false);
        const contentEl = graphContentRef.current;
        if (!contentEl) return;

        // Compute full bounds of the graph content
        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        for (const [path, pos] of positions) {
            if (path === '_nextY') continue;
            minX = Math.min(minX, pos.x);
            minY = Math.min(minY, pos.y);
            maxX = Math.max(maxX, pos.x + pos.width);
            maxY = Math.max(maxY, pos.y + (pos.height || 62));
        }
        // Include lane padding
        for (const lane of lanes) {
            minX = Math.min(minX, lane.x);
            minY = Math.min(minY, lane.y);
            maxX = Math.max(maxX, lane.x + lane.width);
            maxY = Math.max(maxY, lane.y + lane.height);
        }
        const padding = 40;
        const fullWidth = maxX - minX + padding * 2;
        const fullHeight = maxY - minY + padding * 2;

        // Build SVG string (used for all export formats)
        const svgNS = 'http://www.w3.org/2000/svg';
        const bg = isDark ? '#0a1628' : '#f0f4f8';
        let svg = `<svg xmlns="${svgNS}" width="${fullWidth}" height="${fullHeight}" viewBox="0 0 ${fullWidth} ${fullHeight}">`;
        svg += `<rect width="100%" height="100%" fill="${bg}"/>`;
        const ox = -minX + padding;
        const oy = -minY + padding;
        svg += `<g transform="translate(${ox}, ${oy})">`;
        for (const lane of lanes) {
            const lc = lane.color || (isDark ? 'rgba(255,255,255,0.15)' : 'rgba(0,0,0,0.12)');
            svg += `<rect x="${lane.x}" y="${lane.y}" width="${lane.width}" height="${lane.height}" rx="12" fill="none" stroke="${lc}" stroke-width="1.5" stroke-dasharray="6,4" opacity="0.6"/>`;
        }
        for (const edge of edges) {
            const chain = groupColors?.get(edge.childPath);
            const ec = (chain && chain.length > 0) ? chain[chain.length - 1] : (isDark ? '#4fc3f7' : '#0288d1');
            const d = bezierPath(edge.from, edge.to);
            svg += `<path d="${d}" fill="none" stroke="${ec}" stroke-width="1.5" opacity="0.4"/>`;
        }
        svg += '<defs>';
        visibleNodes.forEach((node, idx) => {
            const pos = positions.get(node.path);
            if (!pos) return;
            const nh = pos.height || 62;
            svg += `<clipPath id="clip${idx}"><rect x="${pos.x}" y="${pos.y}" width="${pos.width}" height="${nh}" rx="10"/></clipPath>`;
        });
        svg += '</defs>';
        visibleNodes.forEach((node, idx) => {
            const pos = positions.get(node.path);
            if (!pos) return;
            const tc = typeColor(node.type, isDark);
            const isLeaf = node.childCount === 0;
            const keyName = node.path ? node.path.split('.').pop() : 'root';
            const displayKey = /^\\d+$/.test(keyName) ? `[${keyName}]` : keyName;
            const chain = groupColors?.get(node.path) || [];
            const ownColor = chain.length > 0 ? chain[chain.length - 1] : tc.border;
            const nodeBg = isDark ? '#0f1f3a' : '#ffffff';
            const textColor = isDark ? '#c8d6e5' : '#1e293b';
            const subTextColor = isDark ? '#8899aa' : '#64748b';
            const nh = pos.height || 62;
            svg += `<g clip-path="url(#clip${idx})">`;
            svg += `<rect x="${pos.x}" y="${pos.y}" width="${pos.width}" height="${nh}" rx="10" fill="${nodeBg}"/>`;
            if (!isLeaf) {
                svg += `<rect x="${pos.x}" y="${pos.y}" width="4" height="${nh}" fill="${ownColor}"/>`;
            }
            const escaped = displayKey.substring(0, 25).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            const textX = isLeaf ? pos.x + 14 : pos.x + 18;
            svg += `<text x="${textX}" y="${pos.y + 26}" fill="${textColor}" font-family="'DM Sans', Helvetica, sans-serif" font-size="13" font-weight="600">${escaped}</text>`;
            svg += `<rect x="${pos.x + pos.width - 60}" y="${pos.y + 12}" width="48" height="18" rx="4" fill="${tc.badgeBg}"/>`;
            svg += `<text x="${pos.x + pos.width - 36}" y="${pos.y + 25}" fill="${tc.text}" font-family="'DM Sans', Helvetica, sans-serif" font-size="9" text-anchor="middle" font-weight="500">${node.type}</text>`;
            if (isLeaf) {
                const val = String(node.value ?? 'null').substring(0, 28).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                svg += `<text x="${textX}" y="${pos.y + 48}" fill="${subTextColor}" font-family="'JetBrains Mono', monospace" font-size="11">${val}</text>`;
            } else {
                const expanded = expandedSet.has(node.path);
                const chevron = expanded ? '\u25BE' : '\u25B8';
                const summ = (node.summary || '').substring(0, 28).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                svg += `<text x="${textX}" y="${pos.y + 48}" fill="${subTextColor}" font-family="'DM Sans', Helvetica, sans-serif" font-size="11">${chevron} ${summ}</text>`;
            }
            svg += '</g>';
        });
        svg += '</g></svg>';

        if (format === 'svg') {
            const blob = new Blob([svg], { type: 'image/svg+xml' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = (status?.fileName || 'jtree').replace(/\\.json$/, '') + '.svg';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            setToast('Exported SVG');
            return;
        }

        // PNG or JPEG: render the SVG to a canvas
        const scale = 2;
        try {
            const svgBlob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
            const svgUrl = URL.createObjectURL(svgBlob);
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                canvas.width = fullWidth * scale;
                canvas.height = fullHeight * scale;
                const ctx = canvas.getContext('2d');
                ctx.scale(scale, scale);
                ctx.drawImage(img, 0, 0, fullWidth, fullHeight);
                URL.revokeObjectURL(svgUrl);
                const mimeType = format === 'jpeg' ? 'image/jpeg' : 'image/png';
                const ext = format === 'jpeg' ? '.jpg' : '.png';
                canvas.toBlob((blob) => {
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = (status?.fileName || 'jtree').replace(/\\.json$/, '') + ext;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                    setToast(`Exported ${format.toUpperCase()}`);
                }, mimeType, format === 'jpeg' ? 0.92 : undefined);
            };
            img.onerror = () => {
                URL.revokeObjectURL(svgUrl);
                setToast('Export error: failed to render SVG to canvas');
            };
            img.src = svgUrl;
        } catch (e) {
            setToast(`Export error: ${e.message}`);
        }
    }, [positions, lanes, edges, visibleNodes, groupColors, expandedSet, isDark, status]);

    // Search navigation
    const handleSearchNavigate = useCallback(async (path) => {
        setShowSearch(false);
        setSearchMatchPath(path);
        setTimeout(() => setSearchMatchPath(null), 4500);

        // Expand all ancestors
        const parts = path.split('.');
        const toExpand = [];
        for (let i = 0; i < parts.length - 1; i++) {
            toExpand.push(parts.slice(0, i + 1).join('.'));
        }
        toExpand.unshift('');

        for (const p of toExpand) {
            if (!expandedSet.has(p)) {
                await toggleExpand(p);
            }
        }

        setSelectedPath(path);

        // Pan to node after layout recalculation
        setTimeout(() => {
            const pos = positions.get(path);
            if (pos) {
                setPan({ x: -pos.x + canvasSize.width / 3, y: -pos.y + canvasSize.height / 3 });
            }
        }, 200);
    }, [expandedSet, toggleExpand, positions, canvasSize]);

    // Minimap navigation
    const handleMinimapNavigate = useCallback((x, y) => {
        setPan({ x: -x, y: -y });
    }, []);

    // Sidebar navigation: expand ancestors if needed, then pan to node
    const handleNavSidebarNavigate = useCallback(async (path) => {
        setSelectedPath(path);

        // Ensure all ancestors are expanded in the main canvas
        if (path) {
            const parts = path.split('.');
            const toExpand = [''];
            for (let i = 0; i < parts.length; i++) {
                toExpand.push(parts.slice(0, i + 1).join('.'));
            }
            // Only expand the path itself if it's a container that we want to navigate to
            // The last segment might be the target; expand ancestors up to but not including it
            for (const p of toExpand.slice(0, -1)) {
                if (!expandedSet.has(p)) {
                    await toggleExpand(p);
                }
            }
        }

        // Pan to node after layout settles
        pendingCenterRef.current = path;
        // Force a positions recompute by ensuring expandedSet triggers
        setExpandedSet(prev => new Set(prev));
    }, [expandedSet, toggleExpand]);

    // Keyboard shortcuts
    useEffect(() => {
        const handler = (e) => {
            const isMod = e.metaKey || e.ctrlKey;
            if (isMod && e.key === 's') {
                e.preventDefault();
                if (status?.hasFilePath) {
                    handleSave();
                } else if (status?.loaded) {
                    setModal({ type: 'saveAs' });
                }
            } else if (isMod && e.shiftKey && e.key === 'z') {
                e.preventDefault();
                handleRedo();
            } else if (isMod && e.key === 'z') {
                e.preventDefault();
                handleUndo();
            } else if (isMod && e.key === 'y') {
                e.preventDefault();
                handleRedo();
            } else if (isMod && e.key === 'c' && selectedPath !== null && !window.getSelection()?.toString()) {
                e.preventDefault();
                handleCopy(selectedPath);
            } else if (isMod && e.key === 'v' && selectedPath !== null) {
                e.preventDefault();
                handlePaste(selectedPath);
            } else if (isMod && e.key === 'f') {
                e.preventDefault();
                setShowSearch(s => !s);
            } else if (isMod && e.key === 'o') {
                e.preventDefault();
                setOpenError(null);
                setModal({ type: 'open' });
            } else if (isMod && e.key === 'b') {
                e.preventDefault();
                setShowNav(s => !s);
            } else if (e.key === 'Escape') {
                setShowSearch(false);
                setContextMenu(null);
                setShowExportMenu(false);
                setModal(null);
            }
        };
        window.addEventListener('keydown', handler);
        return () => window.removeEventListener('keydown', handler);
    }, [handleSave, handleUndo, handleRedo, handleCopy, handlePaste, selectedPath]);

    // Breadcrumb navigation
    const handleBreadcrumbNavigate = useCallback(async (path) => {
        setSelectedPath(path);
        // Ensure path is expanded
        if (!expandedSet.has(path)) {
            await toggleExpand(path);
        }
        // Pan to node
        setTimeout(() => {
            const pos = positions.get(path);
            if (pos) {
                setPan({ x: -pos.x + 100, y: -pos.y + canvasSize.height / 3 });
            }
        }, 100);
    }, [expandedSet, toggleExpand, positions, canvasSize]);

    // Fetch children with parent type annotation on expand
    useEffect(() => {
        // When children cache updates, annotate parent types
        const annotate = async () => {
            let changed = false;
            const newCache = new Map(childrenCache);
            for (const [parentPath, children] of newCache) {
                if (children.length > 0 && children[0]._parentType === null) {
                    try {
                        const parentNode = parentPath === '' ? rootNode : await api(`/api/node?path=${encodeURIComponent(parentPath)}`);
                        if (parentNode) {
                            newCache.set(parentPath, children.map((c, i) => ({ ...c, _parentType: parentNode.type, _isLastInArray: parentNode.type === 'array' && i === children.length - 1 })));
                            changed = true;
                        }
                    } catch (e) { /* ignore */ }
                }
            }
            if (changed) setChildrenCache(newCache);
        };
        annotate();
    }, [childrenCache, rootNode]);

    const noFileLoaded = status && !status.loaded;
    const stillLoading = !status || (status.loaded && !rootNode);

    if (stillLoading) {
        return (
            <div className="h-screen w-screen flex items-center justify-center">
                <div className="text-sm opacity-50">Loading...</div>
            </div>
        );
    }

    return (
        <div className="h-screen w-screen flex flex-col overflow-hidden">
            {/* Header */}
            <div className="flex items-center justify-between px-4 h-14 border-b flex-shrink-0"
                 style={{
                     background: isDark ? '#0d1b30' : '#ffffff',
                     borderColor: isDark ? '#1a3a5c' : '#e2e8f0',
                     position: 'relative',
                     zIndex: 50,
                 }}>
                <div className="flex items-center gap-3">
                    <span className="text-base font-semibold" style={{color: '#4fc3f7'}}>jtree</span>
                    <span className="text-xs opacity-40 font-mono">{status?.file || status?.fileName}</span>
                    {(status?.file || status?.fileName) && (
                        <button
                            className="btn btn-ghost p-0.5 opacity-40 hover:opacity-80"
                            title="Copy path to clipboard"
                            onClick={() => { const text = status.file || status.fileName; navigator.clipboard.writeText(text); setToast('Copied to clipboard'); }}
                        >
                            <Icon name="clipboard-copy" size={12} />
                        </button>
                    )}
                    {status?.dirty && <span className="text-xs text-amber-400 font-medium">unsaved</span>}
                    {status?.readonly && <span className="text-xs px-1.5 py-0.5 rounded bg-amber-900/30 text-amber-400">readonly</span>}
                </div>
                <div className="flex items-center gap-1">
                    <button className="btn btn-ghost flex items-center gap-1" onClick={() => { setOpenError(null); setModal({ type: 'open' }); }} title="Open file (Ctrl+O)">
                        <Icon name="folder-open" size={14} /> Open
                    </button>
                    {status?.loaded && !status?.readonly && (
                        <>
                            <button className="btn btn-ghost flex items-center gap-1" onClick={handleUndo} title="Undo (Ctrl+Z)" disabled={!status?.canUndo}>
                                <Icon name="undo-2" size={14} /> Undo
                            </button>
                            <button className="btn btn-ghost flex items-center gap-1" onClick={handleRedo} title="Redo (Ctrl+Shift+Z)" disabled={!status?.canRedo}>
                                <Icon name="redo-2" size={14} /> Redo
                            </button>
                            {status?.hasFilePath ? (
                                <button className="btn btn-primary flex items-center gap-1" onClick={handleSave} title="Save (Ctrl+S)">
                                    <Icon name="save" size={14} /> Save
                                </button>
                            ) : (
                                <button className="btn btn-primary flex items-center gap-1" onClick={() => setModal({ type: 'saveAs' })} title="Save As (Ctrl+S)">
                                    <Icon name="save" size={14} /> Save As
                                </button>
                            )}
                            {status?.hasFilePath && (
                                <button className="btn btn-ghost flex items-center gap-1" onClick={() => setModal({ type: 'saveAs' })} title="Save As...">
                                    <Icon name="file-down" size={14} /> Save As
                                </button>
                            )}
                        </>
                    )}
                    {status?.loaded && (
                        <div style={{ position: 'relative', display: 'inline-block' }}>
                            <button className="btn btn-ghost flex items-center gap-1" onClick={() => setShowExportMenu(s => !s)} title="Export view">
                                <Icon name="image" size={14} /> Export
                            </button>
                            {showExportMenu && (
                                <div className="context-menu" style={{ position: 'absolute', top: '100%', right: 0, marginTop: 4, minWidth: 140, zIndex: 100 }}>
                                    <div className="context-menu-item" onClick={() => handleExport('png')}>
                                        <Icon name="image" size={14} /> PNG
                                    </div>
                                    <div className="context-menu-item" onClick={() => handleExport('svg')}>
                                        <Icon name="file-code" size={14} /> SVG
                                    </div>
                                    <div className="context-menu-item" onClick={() => handleExport('jpeg')}>
                                        <Icon name="file-image" size={14} /> JPEG
                                    </div>
                                </div>
                            )}
                        </div>
                    )}
                    {status?.loaded && (
                        <button className={`btn btn-ghost flex items-center gap-1 ${showNav ? 'opacity-100' : ''}`} onClick={() => setShowNav(s => !s)} title="Navigator (Ctrl+B)">
                            <Icon name="list-tree" size={14} />
                        </button>
                    )}
                    {status?.loaded && (
                        <button className="btn btn-ghost flex items-center gap-1" onClick={() => setShowSearch(s => !s)} title="Search (Ctrl+F)">
                            <Icon name="search" size={14} />
                        </button>
                    )}
                    <button className="btn btn-ghost" onClick={() => setIsDark(d => !d)} title="Toggle theme">
                        <Icon name={isDark ? 'sun' : 'moon'} size={14} />
                    </button>
                </div>
            </div>

            {/* Breadcrumb - only when file loaded */}
            {!noFileLoaded && (
                <div className="border-b flex-shrink-0" style={{
                    background: isDark ? '#0b1726' : '#f8fafc',
                    borderColor: isDark ? '#1a3a5c' : '#e2e8f0',
                    position: 'relative',
                    zIndex: 40,
                }}>
                    <Breadcrumb path={selectedPath} onNavigate={handleBreadcrumbNavigate} isDark={isDark} />
                </div>
            )}

            {/* Welcome screen when no file loaded */}
            {noFileLoaded ? (
                <div className="flex-1 blueprint-grid flex items-center justify-center">
                    <div className="text-center" style={{maxWidth: 400}}>
                        <div className="text-4xl font-bold mb-3" style={{color: '#4fc3f7'}}>jtree</div>
                        <p className="text-sm opacity-50 mb-6">Interactive JSON Viewer & Editor</p>
                        <button
                            className="btn btn-primary flex items-center gap-2 mx-auto text-base px-6 py-3"
                            onClick={() => { setOpenError(null); setModal({ type: 'open' }); }}
                        >
                            <Icon name="folder-open" size={18} /> Open a JSON file
                        </button>
                        <p className="text-xs opacity-30 mt-4 font-mono">or run: jtree &lt;file.json&gt;</p>
                    </div>
                </div>
            ) : (
            <div className="flex flex-1 overflow-hidden">
            {/* Navigator sidebar */}
            <NavSidebar
                rootNode={rootNode}
                activePath={selectedPath}
                onNavigate={handleNavSidebarNavigate}
                isDark={isDark}
                isOpen={showNav}
                onToggleOpen={() => setShowNav(s => !s)}
            />
            {/* Canvas */}
            <div
                ref={canvasRef}
                className="flex-1 relative blueprint-grid"
                style={{ cursor: isPanning ? 'grabbing' : 'grab' }}
                onWheel={handleWheel}
                onMouseDown={handleMouseDown}
                onMouseMove={handleMouseMove}
                onMouseUp={handleMouseUp}
                onMouseLeave={handleMouseUp}
                onClick={() => { setContextMenu(null); setShowExportMenu(false); }}
            >
                <div
                    ref={graphContentRef}
                    style={{
                        transform: `translate(${pan.x}px, ${pan.y}px) scale(${zoom})`,
                        transformOrigin: '0 0',
                        position: 'absolute',
                        top: 0,
                        left: 0,
                    }}
                >
                    <LaneLayer lanes={lanes} isDark={isDark} />
                    <SVGEdgeLayer edges={edges} isDark={isDark} groupColors={groupColors} />
                    {visibleNodes.map(node => {
                        const pos = positions.get(node.path);
                        if (!pos) return null;
                        return (
                            <GraphNode
                                key={node.path}
                                node={node}
                                pos={pos}
                                groupColor={groupColors.get(node.path)}
                                isExpanded={expandedSet.has(node.path)}
                                isSelected={selectedPath === node.path}
                                isSearchMatch={searchMatchPath === node.path}
                                isDark={isDark}
                                onClick={handleNodeClick}
                                onDoubleClick={handleNodeDoubleClick}
                                onChevronClick={handleChevronClick}
                                onContextMenu={handleContextMenu}
                            />
                        );
                    })}
                </div>

                {/* Zoom indicator */}
                <div className="absolute bottom-4 left-4 text-xs font-mono opacity-40">
                    {Math.round(zoom * 100)}%
                </div>
            </div>
            </div>
            )}

            {/* Overlays */}
            {showSearch && (
                <SearchBar
                    onSearch={handleSearchNavigate}
                    onClose={() => setShowSearch(false)}
                    isDark={isDark}
                />
            )}

            {contextMenu && (
                <ContextMenu
                    x={contextMenu.x}
                    y={contextMenu.y}
                    node={contextMenu.node}
                    onClose={() => setContextMenu(null)}
                    onAction={handleContextAction}
                    readonly={status?.readonly}
                    isDark={isDark}
                    hasClipboard={!!clipboard}
                />
            )}

            {modal?.type === 'edit' && (
                <EditModal node={modal.node} onSave={handleEditSave} onClose={() => setModal(null)} isDark={isDark} />
            )}
            {modal?.type === 'addChild' && (
                <AddChildModal parentNode={modal.node} onSave={handleAddChild} onClose={() => setModal(null)} />
            )}
            {modal?.type === 'delete' && (
                <DeleteConfirmModal node={modal.node} onConfirm={handleDelete} onClose={() => setModal(null)} />
            )}
            {modal?.type === 'rename' && (
                <RenameKeyModal node={modal.node} onSave={handleRename} onClose={() => setModal(null)} />
            )}
            {modal?.type === 'moveTo' && (
                <MoveToModal node={modal.node} onMove={(pp, from, to) => { handleMoveChild(pp, from, to); setModal(null); }} onClose={() => setModal(null)} />
            )}
            {modal?.type === 'saveAs' && (
                <SaveAsModal currentFile={status?.file} onSave={handleSaveAs} onBrowserSave={(name) => { setModal(null); setToast(`Saved as ${name}`); fetchStatus(); }} onClose={() => setModal(null)} />
            )}
            {modal?.type === 'open' && (
                <OpenFileModal onOpenContent={handleOpenContent} onOpenPath={handleOpenPath} onClose={() => setModal(null)} error={openError} />
            )}

            {!noFileLoaded && (
                <Minimap
                    positions={positions}
                    viewBox={{ x: -pan.x / zoom, y: -pan.y / zoom }}
                    canvasSize={{ width: canvasSize.width / zoom, height: canvasSize.height / zoom }}
                    onNavigate={handleMinimapNavigate}
                    isDark={isDark}
                />
            )}

            {toast && <Toast message={toast} onClose={() => setToast(null)} />}
        </div>
    );
};

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(
    <ErrorBoundary>
        <App />
    </ErrorBoundary>
);
</script>
</body>
</html>"""


# --- Server Lifecycle ---

def find_free_port(start_port, max_attempts=20):
    for port in range(start_port, start_port + max_attempts):
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind(("127.0.0.1", port))
                return port
            except OSError:
                continue
    raise RuntimeError(f"No free port found in range {start_port}–{start_port + max_attempts - 1}")

def open_browser(port):
    time.sleep(1.5)
    webbrowser.open(f"http://127.0.0.1:{port}")

def main():
    global json_manager
    args = parse_args()

    if args.file_path:
        if not os.path.exists(args.file_path):
            logger.error(f"Error: File not found: {args.file_path}")
            sys.exit(1)

        try:
            json_manager = JSONManager(args.file_path, readonly=args.readonly)
        except json.JSONDecodeError as e:
            logger.error(f"Error: Invalid JSON: {e}")
            sys.exit(1)
        except ValueError as e:
            logger.error(f"Error: {e}")
            sys.exit(1)

        logger.info(f"jtree starting for: {args.file_path}")
        if args.readonly:
            logger.info("Read-only mode enabled")
    else:
        logger.info("jtree starting with no file (use Open to load one)")

    port = find_free_port(args.port)
    if port != args.port:
        logger.warning(f"Port {args.port} is in use; using port {port} instead.")

    logger.info(f"API available at http://127.0.0.1:{port}")

    threading.Thread(target=open_browser, args=(port,), daemon=True).start()

    uvicorn.run(app, host="127.0.0.1", port=port, log_level="info")

if __name__ == "__main__":
    main()
