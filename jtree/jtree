    useEffect(() => {
        const handler = (e) => { if (menuRef.current && !menuRef.current.contains(e.target)) onClose(); };
        document.addEventListener('mousedown', handler);
        return () => document.removeEventListener('mousedown', handler);
    }, [onClose]);

    const isContainer = node.type === 'object' || node.type === 'array';
    const isRoot = node.path === '';

    return (
        <div ref={menuRef} className="context-menu" style={{ left: x, top: y }}>
            {isContainer && (
                <div className="context-menu-item" onClick={() => { onAction('toggleExpand', node); onClose(); }}>
                    <Icon name="chevrons-right" size={14} /> Expand/Collapse
                </div>
            )}
            {isContainer && (
                <div className="context-menu-item" onClick={() => { onAction('expandAll', node); onClose(); }}>
                    <Icon name="maximize-2" size={14} /> Expand All
                </div>
            )}
            {isContainer && (
                <div className="context-menu-item" onClick={() => { onAction('collapseAll', node); onClose(); }}>
                    <Icon name="minimize-2" size={14} /> Collapse All
                </div>
            )}
            {isContainer && <div className="context-menu-separator" />}
            {!readonly && isContainer && (
                <div className="context-menu-item" onClick={() => { onAction('addChild', node); onClose(); }}>
                    <Icon name="plus" size={14} /> Add Child
                </div>
            )}
            {!readonly && !isRoot && (
                <div className="context-menu-item" onClick={() => { onAction('delete', node); onClose(); }}>
                    <Icon name="trash-2" size={14} className="text-red-400" /> Delete
                </div>
