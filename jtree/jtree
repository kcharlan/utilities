            {!readonly && node.childCount === 0 && node.type !== 'object' && node.type !== 'array' && (
                <div className="context-menu-item" onClick={() => { onAction('editValue', node); onClose(); }}>
                    <Icon name="edit" size={14} /> Edit Value
                </div>
            )}
            {!readonly && !isRoot && node._parentType === 'array' && (() => {
                const idx = parseInt(node.path.split('.').pop(), 10);
                return (
                    <React.Fragment>
                        <div className="context-menu-separator" />
                        <div className={`context-menu-item ${idx === 0 ? 'opacity-30 pointer-events-none' : ''}`}
                            onClick={() => { if (idx > 0) { onAction('moveUp', node); onClose(); } }}>
                            <Icon name="arrow-up" size={14} /> Move Up
                        </div>
                        <div className={`context-menu-item ${node._isLastInArray ? 'opacity-30 pointer-events-none' : ''}`}
                            onClick={() => { if (!node._isLastInArray) { onAction('moveDown', node); onClose(); } }}>
                            <Icon name="arrow-down" size={14} /> Move Down
                        </div>
                        <div className="context-menu-item" onClick={() => { onAction('moveTo', node); onClose(); }}>
                            <Icon name="arrow-right-left" size={14} /> Move to Position...
                        </div>
                    </React.Fragment>
                );
            })()}
            <div className="context-menu-separator" />
            <div className="context-menu-item" onClick={() => { onAction('copyNode', node); onClose(); }}>
                <Icon name="copy" size={14} /> Copy Node
            </div>
            {!readonly && isContainer && (
                <div className={`context-menu-item ${!hasClipboard ? 'opacity-30 pointer-events-none' : ''}`}
                    onClick={() => { if (hasClipboard) { onAction('paste', node); onClose(); } }}>
                    <Icon name="clipboard-paste" size={14} /> Paste
                </div>
            )}
            <div className="context-menu-separator" />
            <div className="context-menu-item" onClick={() => { navigator.clipboard.writeText(node.path); onClose(); }}>
                <Icon name="link" size={14} /> Copy Path
