const TYPE_COLORS_LIGHT = {
    object: { border: '#0288d1', bg: 'rgba(2,136,209,0.06)', badgeBg: 'rgba(2,136,209,0.12)', text: '#0277bd' },
    array: { border: '#7b1fa2', bg: 'rgba(123,31,162,0.06)', badgeBg: 'rgba(123,31,162,0.12)', text: '#6a1b9a' },
    string: { border: '#2e7d32', bg: 'rgba(46,125,50,0.06)', badgeBg: 'rgba(46,125,50,0.12)', text: '#1b5e20' },
    number: { border: '#e65100', bg: 'rgba(230,81,0,0.06)', badgeBg: 'rgba(230,81,0,0.12)', text: '#e65100' },
    boolean: { border: '#c62828', bg: 'rgba(198,40,40,0.06)', badgeBg: 'rgba(198,40,40,0.12)', text: '#b71c1c' },
    null: { border: '#546e7a', bg: 'rgba(84,110,122,0.06)', badgeBg: 'rgba(84,110,122,0.12)', text: '#37474f' },
};

function typeColor(type, isDark) {
    return (isDark ? TYPE_COLORS : TYPE_COLORS_LIGHT)[type] || TYPE_COLORS.null;
}

// Group colors: visually distinct palette for parent-child lineage
// Each level assigns siblings distinct colors; nodes accumulate ancestor colors as stripes
const GROUP_PALETTE_DARK = [
    '#4fc3f7', '#ab47bc', '#66bb6a', '#ffa726', '#ef5350',
    '#26c6da', '#ec407a', '#9ccc65', '#ffca28', '#7e57c2',
    '#29b6f6', '#d4e157', '#ff7043', '#78909c', '#5c6bc0',
];
const GROUP_PALETTE_LIGHT = [
    '#0288d1', '#7b1fa2', '#2e7d32', '#e65100', '#c62828',
    '#00838f', '#ad1457', '#558b2f', '#f9a825', '#512da8',
    '#0277bd', '#9e9d24', '#d84315', '#546e7a', '#283593',
];

function getGroupColor(index, isDark) {
    const palette = isDark ? GROUP_PALETTE_DARK : GROUP_PALETTE_LIGHT;
    return palette[index % palette.length];
}

function computeGroupColors(rootNode, expandedSet, childrenCache, isDark) {
    // Returns Map<path, string[]> - each value is an array of ancestor colors
    // from outermost to this node's own color.
    const colors = new Map();
    colors.set('', []);  // root has no ancestry stripes

    const palette = isDark ? GROUP_PALETTE_DARK : GROUP_PALETTE_LIGHT;
    const walk = (path, ancestorColors, parentColorIdx) => {
        if (!expandedSet.has(path)) return;
        const children = childrenCache.get(path) || [];
        let offset = 0;
        children.forEach((child, i) => {
            // Pick color, but skip parent's color index to avoid same color adjacent
            let idx = (i + offset) % palette.length;
            if (idx === parentColorIdx) {
                offset++;
                idx = (i + offset) % palette.length;
            }
            const ownColor = palette[idx];
            const chain = [...ancestorColors, ownColor];
            colors.set(child.path, chain);
            if (child.type === 'object' || child.type === 'array') {
                walk(child.path, chain, idx);
            }
        });
    };

    walk('', [], -1);
    return colors;
}

function formatValue(value, type) {
    if (type === 'null') return 'null';
    if (type === 'boolean') return value ? 'true' : 'false';
    if (type === 'number') return String(value);
    if (type === 'string') {
        if (value.length > 60) return JSON.stringify(value.slice(0, 57) + '...');
        return JSON.stringify(value);
    }
    return String(value);
}

function pathSegments(path) {
    if (!path) return [{ label: 'root', path: '' }];
    const parts = path.split('.');
    const segs = [{ label: 'root', path: '' }];
    for (let i = 0; i < parts.length; i++) {
        const p = parts.slice(0, i + 1).join('.');
        const label = /^\\d+$/.test(parts[i]) ? `[${parts[i]}]` : parts[i];
        segs.push({ label, path: p });
    }
    return segs;
}

// --- Layout Algorithm ---

const NODE_WIDTH = 220;
const H_GAP = 80;
const V_GAP = 28;
const GROUP_GAP = 40;
const NODE_HEIGHT_BASE = 62;
const NODE_HEIGHT_LEAF = 62;

function computeLayout(nodes, expandedSet, childrenCache) {
    // nodes: array of {path, type, childCount, ...} that are visible
    // Returns: Map<path, {x, y, width, height}>
    const positions = new Map();
    if (!nodes || nodes.length === 0) return positions;

    // Build tree structure from flat list
    const root = nodes.find(n => n.path === '');
    if (!root) return positions;

    layoutSubtree(root, 0, positions, expandedSet, childrenCache);
    return positions;
}

function layoutSubtree(node, depth, positions, expandedSet, childrenCache) {
    const isLeaf = node.childCount === 0;
    const h = isLeaf ? NODE_HEIGHT_LEAF : NODE_HEIGHT_BASE;
    const x = depth * (NODE_WIDTH + H_GAP);
    const isExpanded = expandedSet.has(node.path);
    const children = isExpanded ? (childrenCache.get(node.path) || []) : [];

    if (children.length === 0) {
        const y = positions._nextY || 0;
        positions.set(node.path, { x, y, width: NODE_WIDTH, height: h });
        positions._nextY = y + h + V_GAP;
        return h;
    }

    // Reserve top lane padding before first child
    const lanePad = LANE_PAD_BASE + LANE_PAD_PER_DEPTH * 2;
    positions._nextY = (positions._nextY || 0) + lanePad;

    // Layout children first
    let totalChildHeight = lanePad;
    for (let i = 0; i < children.length; i++) {
        const child = children[i];
        const childIsExpanded = expandedSet.has(child.path);
        const ch = layoutSubtree(child, depth + 1, positions, expandedSet, childrenCache);
        totalChildHeight += ch + V_GAP;
        // Add extra group gap after expanded children to visually separate groups
        if (childIsExpanded && i < children.length - 1) {
            positions._nextY = (positions._nextY || 0) + GROUP_GAP;
            totalChildHeight += GROUP_GAP;
        }
    }
    totalChildHeight -= V_GAP; // remove last gap

    // Reserve bottom lane padding after last child
    positions._nextY = (positions._nextY || 0) + lanePad;
    totalChildHeight += lanePad;

    // Center parent among children
    const firstChild = positions.get(children[0].path);
    const lastChild = positions.get(children[children.length - 1].path);
    const centerY = firstChild.y + (lastChild.y + lastChild.height - firstChild.y) / 2 - h / 2;

    positions.set(node.path, { x, y: centerY, width: NODE_WIDTH, height: h });
    // Add group gap after this entire subtree so next sibling group is separated
    positions._nextY = (positions._nextY || 0) + GROUP_GAP;
    return Math.max(h, totalChildHeight) + GROUP_GAP;
}

function computeEdges(positions, expandedSet, childrenCache) {
    const edges = [];
    for (const [path, pos] of positions) {
        if (path === '_nextY') continue;
        if (!expandedSet.has(path)) continue;
        const children = childrenCache.get(path) || [];
        for (const child of children) {
            const childPos = positions.get(child.path);
            if (!childPos) continue;
            edges.push({
                from: { x: pos.x + pos.width, y: pos.y + pos.height / 2 },
                to: { x: childPos.x, y: childPos.y + childPos.height / 2 },
                parentPath: path,
                childPath: child.path,
                childType: child.type,
            });
        }
    }
    return edges;
}

function bezierPath(from, to) {
    const dx = (to.x - from.x) * 0.5;
    return `M ${from.x} ${from.y} C ${from.x + dx} ${from.y}, ${to.x - dx} ${to.y}, ${to.x} ${to.y}`;
}

// --- Lanes: dashed-border containment regions for expanded nodes ---

const LANE_PAD_BASE = 20;
const LANE_PAD_PER_DEPTH = 8;

function computeLanes(positions, expandedSet, childrenCache, groupColors) {
    // For each expanded node, compute a bounding rect around ALL descendants.
    // Outer (shallower) lanes get more padding so nested lanes don't overlap.
    const lanes = [];

    // First pass: find max depth so we can invert padding (deeper = less padding)
    let maxDepth = 0;

    function getDescendantBounds(path) {
        const children = childrenCache.get(path) || [];
        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        for (const child of children) {
            const cp = positions.get(child.path);
            if (!cp) continue;
            minX = Math.min(minX, cp.x);
            minY = Math.min(minY, cp.y);
            maxX = Math.max(maxX, cp.x + cp.width);
            maxY = Math.max(maxY, cp.y + cp.height);
            if (expandedSet.has(child.path)) {
                const sub = getDescendantBounds(child.path);
                if (sub) {
                    minX = Math.min(minX, sub.minX);
                    minY = Math.min(minY, sub.minY);
                    maxX = Math.max(maxX, sub.maxX);
                    maxY = Math.max(maxY, sub.maxY);
                }
            }
        }
        if (minX === Infinity) return null;
        return { minX, minY, maxX, maxY };
    }

    // Collect raw lane data
    const rawLanes = [];
    for (const [path] of positions) {
        if (path === '_nextY') continue;
        if (!expandedSet.has(path)) continue;
        const children = childrenCache.get(path) || [];
        if (children.length === 0) continue;

        const bounds = getDescendantBounds(path);
        if (!bounds) continue;

        const chain = groupColors?.get(path);
        const color = (chain && chain.length > 0) ? chain[chain.length - 1] : null;
        const depth = path === '' ? 0 : path.split('.').length;
        if (depth > maxDepth) maxDepth = depth;

        rawLanes.push({ path, depth, bounds, color });
    }

    // Second pass: compute rects with depth-aware padding
    // Shallower lanes get more padding so they wrap outside deeper lanes
    for (const lane of rawLanes) {
        const depthInversion = maxDepth - lane.depth;
        const pad = LANE_PAD_BASE + depthInversion * LANE_PAD_PER_DEPTH;
        lanes.push({
            path: lane.path,
            depth: lane.depth,
            x: lane.bounds.minX - pad,
            y: lane.bounds.minY - pad,
            width: lane.bounds.maxX - lane.bounds.minX + pad * 2,
            height: lane.bounds.maxY - lane.bounds.minY + pad * 2,
            color: lane.color,
        });
    }

    // Sort by depth so outer lanes render behind inner lanes
    lanes.sort((a, b) => a.depth - b.depth);
    return lanes;
}

const LaneLayer = ({ lanes, isDark }) => {
    if (!lanes || lanes.length === 0) return null;
    return (
        <React.Fragment>
            {lanes.map((lane) => (
                <div
                    key={`lane-${lane.path}`}
                    style={{
                        position: 'absolute',
                        left: lane.x,
                        top: lane.y,
                        width: lane.width,
                        height: lane.height,
                        border: `1.5px dashed ${lane.color || (isDark ? 'rgba(255,255,255,0.15)' : 'rgba(0,0,0,0.12)')}`,
                        borderRadius: 12,
                        background: lane.color
                            ? (isDark ? `${lane.color}08` : `${lane.color}06`)
                            : 'transparent',
                        pointerEvents: 'none',
                    }}
                />
            ))}
        </React.Fragment>
    );
};

