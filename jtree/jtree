        let parsedValue;
        if (childType === 'object') parsedValue = {};
        else if (childType === 'array') parsedValue = [];
        else if (childType === 'number') parsedValue = Number(value) || 0;
        else if (childType === 'boolean') parsedValue = value === 'true';
        else if (childType === 'null') parsedValue = null;
        else parsedValue = value;
        onSave(parentNode.path, isObject ? key : null, parsedValue, childType);
