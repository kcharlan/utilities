});

const SVGEdgeLayer = ({ edges, isDark, groupColors }) => {
    return (
        <svg style={{ position: 'absolute', top: 0, left: 0, width: '100%', height: '100%', pointerEvents: 'none', overflow: 'visible' }}>
            {edges.map((edge, i) => {
                const chain = groupColors?.get(edge.childPath);
                const edgeColor = (chain && chain.length > 0) ? chain[chain.length - 1] : typeColor(edge.childType, isDark).border;
                return (
                    <path
                        key={i}
                        d={bezierPath(edge.from, edge.to)}
                        fill="none"
                        stroke={edgeColor}
                        strokeWidth={1.5}
                        opacity={0.4}
                    />
                );
            })}
        </svg>
    );
};

const Minimap = ({ positions, viewBox, canvasSize, onNavigate, isDark }) => {
    const minimapRef = useRef(null);
    const dragRef = useRef({ active: false, startX: 0, startY: 0, startViewX: 0, startViewY: 0 });
    const allPositions = [...positions.entries()].filter(([k]) => k !== '_nextY');
    if (allPositions.length === 0) return null;

    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
    for (const [, pos] of allPositions) {
        minX = Math.min(minX, pos.x);
        minY = Math.min(minY, pos.y);
        maxX = Math.max(maxX, pos.x + pos.width);
        maxY = Math.max(maxY, pos.y + pos.height);
    }
    const contentW = maxX - minX + 40;
    const contentH = maxY - minY + 40;
    const MIN_MINIMAP_SCALE = 0.01;
    const scale = Math.max(MIN_MINIMAP_SCALE, Math.min(200 / contentW, 150 / contentH, 1));

    const vpLeft = ((viewBox.x - minX + 20) * scale);
    const vpTop = ((viewBox.y - minY + 20) * scale);
    const vpW = (canvasSize.width * scale);
    const vpH = (canvasSize.height * scale);

    const minimapToWorld = useCallback((clientX, clientY) => {
        const rect = minimapRef.current.getBoundingClientRect();
        const mx = (clientX - rect.left) / scale + minX - 20;
        const my = (clientY - rect.top) / scale + minY - 20;
        return { x: mx, y: my };
    }, [scale, minX, minY]);

    const handleMouseDown = useCallback((e) => {
        e.preventDefault();
        e.stopPropagation();
        const world = minimapToWorld(e.clientX, e.clientY);
        // Check if click is inside the viewport rectangle
        const inVP = world.x >= viewBox.x && world.x <= viewBox.x + canvasSize.width
                  && world.y >= viewBox.y && world.y <= viewBox.y + canvasSize.height;
        if (inVP) {
            // Start dragging from current position
            dragRef.current = { active: true, startX: e.clientX, startY: e.clientY, startViewX: viewBox.x, startViewY: viewBox.y };
        } else {
            // Click outside viewport: jump to center on that point, then start drag
            const newX = world.x - canvasSize.width / 2;
            const newY = world.y - canvasSize.height / 2;
            onNavigate(newX, newY);
            dragRef.current = { active: true, startX: e.clientX, startY: e.clientY, startViewX: newX, startViewY: newY };
        }

        const handleMouseMove = (me) => {
            if (!dragRef.current.active) return;
            const dx = (me.clientX - dragRef.current.startX) / scale;
            const dy = (me.clientY - dragRef.current.startY) / scale;
            onNavigate(dragRef.current.startViewX + dx, dragRef.current.startViewY + dy);
        };

        const handleMouseUp = () => {
            dragRef.current.active = false;
            document.removeEventListener('mousemove', handleMouseMove);
            document.removeEventListener('mouseup', handleMouseUp);
        };

        document.addEventListener('mousemove', handleMouseMove);
        document.addEventListener('mouseup', handleMouseUp);
    }, [minimapToWorld, viewBox, canvasSize, onNavigate, scale]);

    return (
        <div className="minimap" ref={minimapRef} onMouseDown={handleMouseDown} style={{cursor: 'pointer'}}>
            <svg width={200} height={150}>
                {allPositions.map(([path, pos]) => (
                    <rect
                        key={path}
                        x={(pos.x - minX + 20) * scale}
                        y={(pos.y - minY + 20) * scale}
                        width={pos.width * scale}
                        height={pos.height * scale}
                        rx={2}
                        fill={isDark ? '#1a3a5c' : '#94a3b8'}
                        opacity={0.6}
                    />
                ))}
                <rect
                    x={Math.max(0, vpLeft)}
                    y={Math.max(0, vpTop)}
                    width={Math.min(vpW, 200)}
                    height={Math.min(vpH, 150)}
                    fill="none"
                    stroke="#3b82f6"
                    strokeWidth={2}
                    rx={2}
                />
            </svg>
        </div>
    );
};

