const NavSidebar = ({ rootNode, activePath, onNavigate, isDark, isOpen, onToggleOpen }) => {
    const [sidebarExpanded, setSidebarExpanded] = useState(new Set());
    const [navCache, setNavCache] = useState(new Map()); // path -> children array
    const [navRootNode, setNavRootNode] = useState(null);

    // Fetch root node's container-only children on mount
    useEffect(() => {
        if (!rootNode) return;
        const fetchRoot = async () => {
            try {
                const data = await api(`/api/children?path=&offset=0&limit=500`);
                const enriched = { ...rootNode, _navChildren: data.children || [] };
                setNavRootNode(enriched);
                setNavCache(prev => { const n = new Map(prev); n.set('', data.children || []); return n; });
            } catch (e) { console.error('Nav: failed to fetch root children', e); }
        };
        fetchRoot();
    }, [rootNode]);

    const handleToggle = useCallback(async (path) => {
        setSidebarExpanded(prev => {
            const next = new Set(prev);
            if (next.has(path)) {
                next.delete(path);
            } else {
                next.add(path);
            }
            return next;
        });

        // Fetch children if not cached
        if (!navCache.has(path)) {
            try {
                const data = await api(`/api/children?path=${encodeURIComponent(path)}&offset=0&limit=500`);
                setNavCache(prev => {
                    const n = new Map(prev);
                    n.set(path, data.children || []);
                    return n;
                });
            } catch (e) {
                console.error('Nav: failed to fetch children for', path, e);
            }
        }
    }, [navCache]);

    // Auto-reveal: when activePath changes, expand sidebar ancestors to show it
    useEffect(() => {
        if (!activePath && activePath !== '') return;
        if (!navRootNode) return;

        // Build ancestor paths (e.g. "a.b.c" -> ["", "a", "a.b", "a.b.c"])
        const parts = activePath ? activePath.split('.') : [];
        const ancestors = [''];
        for (let i = 0; i < parts.length; i++) {
            ancestors.push(parts.slice(0, i + 1).join('.'));
        }

        // Fetch any missing ancestors, then expand them all
        const revealAncestors = async () => {
            const toFetch = ancestors.filter(p => !navCache.has(p));
            if (toFetch.length > 0) {
                const fetched = new Map();
                for (const p of toFetch) {
                    try {
                        const data = await api(`/api/children?path=${encodeURIComponent(p)}&offset=0&limit=500`);
                        fetched.set(p, data.children || []);
                    } catch (e) { /* path may not exist or be a leaf */ }
                }
                if (fetched.size > 0) {
                    setNavCache(prev => {
                        const n = new Map(prev);
                        for (const [k, v] of fetched) n.set(k, v);
                        return n;
                    });
                }
            }
            // Expand all ancestors so the active node is visible
            setSidebarExpanded(prev => {
                const next = new Set(prev);
                for (const p of ancestors) next.add(p);
                return next;
            });
        };
        revealAncestors();
    }, [activePath, navRootNode]);

    // Enrich nodes with cached children for rendering
    const enrichNode = useCallback((node) => {
        const cached = navCache.get(node.path);
        if (!cached) return node;
        return {
            ...node,
            _navChildren: cached.map(c => enrichNode(c)),
        };
    }, [navCache]);

    const enrichedRoot = useMemo(() => {
        if (!navRootNode) return null;
        return enrichNode(navRootNode);
    }, [navRootNode, enrichNode]);

    if (!enrichedRoot) return null;

    return (
        <div className="nav-sidebar" style={{ width: isOpen ? 280 : 28 }}>
            {!isOpen && (
                <div className="nav-rail" onClick={onToggleOpen} title="Open navigator (Ctrl+B)">
                    <span className="nav-rail-icon">
                        <Icon name="list-tree" size={15} />
                    </span>
                    <span className="nav-rail-label">Nav</span>
                </div>
            )}
            {isOpen && (
                <div style={{ width: 280, overflow: 'hidden', display: 'flex', flexDirection: 'column', height: '100%' }}>
                    <div className="px-3 py-2 flex items-center gap-2 flex-shrink-0" style={{
                        borderBottom: `1px solid ${isDark ? '#1a3a5c' : '#e2e8f0'}`,
                    }}>
                        <Icon name="list-tree" size={13} className="opacity-40" />
                        <span className="text-xs font-semibold opacity-50 uppercase tracking-wider flex-1">Navigator</span>
                        <button
                            className="btn btn-ghost p-0.5 opacity-40 hover:opacity-80"
                            onClick={onToggleOpen}
                            title="Close navigator (Ctrl+B)"
                            style={{ lineHeight: 0 }}
                        >
                            <Icon name="panel-left-close" size={14} />
                        </button>
                    </div>
                    <div className="flex-1 overflow-y-auto overflow-x-hidden py-1 px-1" style={{ scrollbarGutter: 'stable' }}>
                        <NavSidebarItem
                            node={enrichedRoot}
                            depth={0}
                            activePath={activePath}
                            sidebarExpanded={sidebarExpanded}
                            onToggle={handleToggle}
                            onNavigate={onNavigate}
                            isDark={isDark}
                        />
                    </div>
                </div>
            )}
        </div>
    );
};

