    {delta!=null&&<p className={`text-xs ${deltaColor}`}>{delta>0?'+':''}{(delta*100).toFixed(1)}% {deltaLabel}</p>}
    {children}
  </div>;
}
function KPICards({summary,costCycle,setCostCycle,latCycle,setLatCycle}) {
  if(!summary) return <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
    {Array(6).fill(0).map((_,i)=><SkeletonCard key={i}/>)}</div>;
  const s = summary;
  const comp = s.comparison;
  const compLabel = s.compare_mode ? ({dow:'DoD',wow:'WoW',mom_date:'MoM',mom_relative:'MoM',qoq:'QoQ',yoy_date:'YoY',yoy_relative:'YoY',prior_period:'vs prior'}[s.compare_mode]||'vs prior') : null;
  const delta = (cur,prev) => (prev&&prev>0)?(cur-prev)/prev:null;

  const costKey = {avg:'avg_cost_per_request',p50:'p50_cost_per_request',p95:'p95_cost_per_request',min:'min_cost_per_request',max:'max_cost_per_request'}[costCycle]||'avg_cost_per_request';
  const latKey  = {avg:'avg_latency_ms',p50:'p50_latency_ms',p95:'p95_latency_ms',min:'min_latency_ms',max:'max_latency_ms'}[latCycle]||'avg_latency_ms';

  return <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
    <KPICard title="Total Requests" value={fmtNum(s.request_count)}
      delta={comp?delta(s.request_count,comp.request_count):null} deltaLabel={compLabel} positive={true}/>
    <KPICard title="Total Cost" value={fmt$(s.total_cost)}
      subValue={s.projected_cost?`~${fmt$(s.projected_cost)} projected`:null}
      delta={comp?delta(s.total_cost,comp.total_cost):null} deltaLabel={compLabel} positive={false}/>
    <KPICard title={`Cost/Req (${costCycle.toUpperCase()})`} value={fmt$4(s[costKey])}
      delta={comp?delta(s[costKey],comp[costKey]):null} deltaLabel={compLabel} positive={false}>
      <button onClick={()=>setCostCycle(c=>COST_CYCLES[(COST_CYCLES.indexOf(c)+1)%COST_CYCLES.length])}
        className="text-xs text-blue-400 hover:text-blue-300 self-start">cycle →</button>
    </KPICard>
    <KPICard title={`Latency (${latCycle.toUpperCase()})`} value={fmtMs(s[latKey])}
      delta={comp?delta(s[latKey],comp[latKey]):null} deltaLabel={compLabel} positive={false}>
      <button onClick={()=>setLatCycle(c=>LAT_CYCLES[(LAT_CYCLES.indexOf(c)+1)%LAT_CYCLES.length])}
        className="text-xs text-blue-400 hover:text-blue-300 self-start">cycle →</button>
    </KPICard>
