          </span>
        </div>
        <div className="flex gap-3">
          <button onClick={()=>setStep(5)} className="flex-1 py-2.5 border border-slate-700 text-slate-400 hover:text-slate-200 rounded-lg text-sm">Skip</button>
          <button onClick={()=>setStep(5)} disabled={!firstGen}
            className="flex-1 py-2.5 bg-blue-600 hover:bg-blue-500 disabled:opacity-40 text-white rounded-lg text-sm">Continue</button>
        </div>
      </>}
      {step===5&&<>
