function SavedViewsDropdown({views,onSelect,onSave,onDelete}) {
  const [open,setOpen]=useState(false);
  const [name,setName]=useState('');
  const [saving,setSaving]=useState(false);
  const ref=useRef();
  useEffect(()=>{ const h=e=>{ if(ref.current&&!ref.current.contains(e.target)) setOpen(false); };
    document.addEventListener('mousedown',h); return()=>document.removeEventListener('mousedown',h); },[]);
  return <div ref={ref} className="relative">
    <button onClick={()=>setOpen(!open)} className="flex items-center gap-1 px-2.5 py-1.5 text-xs text-slate-400 border border-slate-600 rounded hover:border-slate-500 hover:text-slate-300">
      <LI.Bookmark size={12}/> Views <LI.ChevronDown size={10}/>
    </button>
    {open&&<div className="absolute top-full mt-1 right-0 bg-slate-800 border border-slate-700 rounded-lg shadow-xl z-50 w-56 py-2">
      {saving?<div className="px-3 py-2">
        <input type="text" value={name} onChange={e=>setName(e.target.value)} placeholder="View name..."
          autoFocus onKeyDown={e=>{if(e.key==='Enter'&&name){onSave(name);setSaving(false);setName('');setOpen(false);}if(e.key==='Escape') setSaving(false);}}
          className="w-full bg-slate-700 text-xs text-slate-200 px-2 py-1 rounded outline-none mb-2"/>
        <div className="flex gap-2">
          <button onClick={()=>setSaving(false)} className="flex-1 py-1 text-xs text-slate-400 border border-slate-700 rounded">Cancel</button>
          <button onClick={()=>{if(name){onSave(name);setSaving(false);setName('');setOpen(false);}}} className="flex-1 py-1 text-xs bg-blue-600 text-white rounded">Save</button>
        </div>
      </div>:<>
        <button onClick={()=>setSaving(true)} className="w-full text-left px-3 py-1.5 text-xs text-blue-400 hover:bg-slate-700 flex items-center gap-2">
          <LI.Plus size={12}/> Save current view
        </button>
        {views.length>0&&<div className="border-t border-slate-700 mt-1 pt-1">
          {views.map(v=><div key={v.id} className="flex items-center justify-between px-3 py-1.5 hover:bg-slate-700 group">
            <button onClick={()=>{onSelect(v);setOpen(false);}} className="text-xs text-slate-300 truncate flex-1 text-left">{v.name}</button>
            <button onClick={()=>onDelete(v.id)} className="opacity-0 group-hover:opacity-100 text-slate-500 hover:text-red-400 ml-2"><LI.Trash2 size={10}/></button>
          </div>)}
        </div>}
      </>}
    </div>}
  </div>;
}

