}

// ── Main Chart ────────────────────────────────────────────────────────────────
function MainChart({data,chartType='area',metric='cost',groupBy='model',comparison,onExport}) {
  const ref=useRef();
  const [hidden,setHidden]=useState(new Set());

  // Compute Y domain that includes comparison data — must be before early returns (hooks rule)
  const yDomain = useMemo(()=>{
    if(!data?.comparison_series?.length || !data?.series?.length) return undefined;
    let maxVal=0;
    for(const s of data.series) for(const v of s.data) if(v>maxVal) maxVal=v;
    for(const s of data.comparison_series) for(const v of s.data) if(v>maxVal) maxVal=v;
    return maxVal>0 ? [0, Math.ceil(maxVal*1.05*100)/100] : undefined;
  },[data?.series,data?.comparison_series]);

  if(!data||!data.series) return <div className="bg-slate-800 rounded-xl p-4 h-96 flex items-center justify-center"><Spinner/></div>;
  if(!data.buckets?.length) return <div className="bg-slate-800 rounded-xl p-4"><EmptyState/></div>;

  const chartData = data.buckets.map((b,i)=>{
    const pt={bucket:b};
    data.series.forEach(s=>{pt[s.name]=s.data[i]??0;});
    if(data.comparison_series) data.comparison_series.forEach(s=>{pt['_c_'+s.name]=s.data[i]??0;});
    return pt;
  });

  const yFmt = v=>metric==='cost'?fmt$(v,2):metric==='latency'?fmtMs(v):fmtNum(v);
  const bucketSize = data.bucket_size||'day';
  const xFmt = v=>{
    if(!v) return '';
    if(bucketSize==='minute') return v.slice(11,16);
    if(bucketSize==='hour') return v.slice(11,16)||v;
    if(bucketSize==='day') return v.slice(5,10);
    if(bucketSize==='week') return v;
    if(bucketSize==='month') return v;
    return v;
  };
  const commonAxisProps={stroke:'#475569',fontSize:11,tick:{fill:'#94a3b8'}};
  const tooltipProps={content:<ChartTooltip metric={metric} compareRange={data.compare_range}/>,wrapperStyle:{outline:'none'}};
  const gridProps={strokeDasharray:'3 3',stroke:'#334155'};

  const renderSeries = (Series, extraProps={}) => data.series.map((s,i)=>{
    const col=modelColor(s.name);
    const hidden_=hidden.has(s.name);
    return <Series key={s.name} type="monotone" dataKey={s.name}
      stroke={col} fill={col} fillOpacity={hidden_?0:0.5} strokeOpacity={hidden_?0:1}
      {...extraProps}/>;
  });

  const handleLegend = e => setHidden(prev=>{const n=new Set(prev);n.has(e.value)?n.delete(e.value):n.add(e.value);return n;});

  const ChartEl = chartType==='line'?LineChart:chartType==='bar'?BarChart:AreaChart;
  const SeriesEl = chartType==='line'?Line:chartType==='bar'?Bar:Area;
  const stackId = chartType==='area'||chartType==='bar'?'1':undefined;

  return <div className="bg-slate-800 rounded-xl p-4">
    <div className="flex items-center justify-between mb-3">
      <h2 className="text-sm font-medium text-slate-300">
        {metric==='cost'?'Cost':metric==='requests'?'Requests':metric==='tokens'?'Tokens':'Latency'} over Time
        {groupBy!=='none'&&<span className="text-slate-500 font-normal ml-1">by {groupBy}</span>}
      </h2>
      <ExportMenu chartRef={ref} onCSV={onExport} name="timeseries"/>
    </div>
    <div ref={ref}>
      <ResponsiveContainer width="100%" height={380}>
        <ChartEl data={chartData}>
          <CartesianGrid {...gridProps}/>
          <XAxis dataKey="bucket" {...commonAxisProps} tickFormatter={xFmt}/>
          <YAxis {...commonAxisProps} tickFormatter={yFmt} width={70} {...(yDomain?{domain:yDomain}:{})}/>
          <Tooltip {...tooltipProps}/>
          <Legend onClick={handleLegend} wrapperStyle={{paddingTop:8,fontSize:11,color:'#94a3b8'}}/>
          {data.series.map((s,i)=>{
            const col=modelColor(s.name);
            const hiddenS=hidden.has(s.name);
            return <SeriesEl key={s.name} type="monotone" dataKey={s.name}
              stroke={col} fill={col}
              fillOpacity={hiddenS?0:0.5} strokeOpacity={hiddenS?0:1}
              stackId={stackId} dot={false}/>;
          })}
          {data.comparison_series&&data.comparison_series.map((s,i)=>{
            const col=modelColor(s.name);
            const CompEl = chartType==='line'?Line:Area;
            return <CompEl key={'_c_'+s.name} type="monotone" dataKey={'_c_'+s.name}
              stroke={col} strokeDasharray="5 3" strokeOpacity={0.6} strokeWidth={1.5}
              fill="none" fillOpacity={0} dot={false} legendType="none"/>;
          })}
        </ChartEl>
      </ResponsiveContainer>
    </div>
  </div>;
}

// ── Heatmap ───────────────────────────────────────────────────────────────────
function HeatmapView({data}) {
  if(!data) return <div className="bg-slate-800 rounded-xl p-4 h-64 animate-pulse"/>;
  const matrix = data.matrix||[];
  const allVals = matrix.flat().filter(v=>v!=null);
  const maxVal = allVals.length?Math.max(...allVals):1;
  const DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const HOURS=Array.from({length:24},(_,i)=>i);
  return <div className="bg-slate-800 rounded-xl p-4 overflow-x-auto">
    <h2 className="text-sm font-medium text-slate-300 mb-3">Usage Heatmap</h2>
    <div className="flex gap-1">
      <div className="flex flex-col gap-1 pt-5">
        {DAYS.map(d=><div key={d} className="h-6 w-8 text-xs text-slate-500 flex items-center">{d}</div>)}
      </div>
      <div>
        <div className="flex gap-1 mb-1">
          {HOURS.map(h=><div key={h} className="w-6 text-center text-slate-600" style={{fontSize:9}}>{h%6===0?h:''}</div>)}
        </div>
        {DAYS.map((d,di)=><div key={di} className="flex gap-1 mb-1">
          {HOURS.map(h=>{
            const v=matrix[di]?.[h];
            const intensity=v!=null?v/maxVal:0;
            return <div key={h} title={`${d} ${h}:00 — ${v!=null?v.toFixed(4):'no data'}`}
              className="w-6 h-6 rounded-sm cursor-default"
              style={{background:v!=null?`rgba(59,130,246,${0.1+intensity*0.9})`:'#1e293b'}}/>;
          })}
        </div>)}
      </div>
    </div>
  </div>;
}

// ── Breakdown Panel ───────────────────────────────────────────────────────────
function BreakdownPanel({title,data,type='bar',metric='cost',onFilter,chartRef,panelKey,dragProps,exportQS=''}) {
  if(!data) return <div className="bg-slate-800 rounded-xl p-4 h-64 animate-pulse"/>;
  const items = data.data||[];
  if(!items.length) return <div className="bg-slate-800 rounded-xl p-4"><h3 className="text-sm text-slate-400 mb-3">{title}</h3><EmptyState/></div>;
  const fmtVal = v=>metric==='cost'?fmt$(v,2):metric==='latency'?fmtMs(v):fmtNum(v);
  const BDTooltip = ({active,payload,label})=>{
    if(!active||!payload?.length) return null;
    const d=payload[0]?.payload;
    return <div className="bg-slate-800 border border-slate-600 rounded-lg px-3 py-2 shadow-xl text-xs">
      <p className="text-slate-300 font-medium mb-1">{d?.dimension||label}</p>
      <p className="text-slate-400">{fmtVal(payload[0]?.value)}</p>
    </div>;
  };
  const tooltipProps={content:<BDTooltip/>,wrapperStyle:{outline:'none'}};

  return <div className="bg-slate-800 rounded-xl p-4" {...dragProps}>
    <div className="flex items-center justify-between mb-3">
      <div className="flex items-center gap-2">
        {dragProps&&<LI.GripVertical size={14} className="text-slate-600 cursor-grab"/>}
        <h3 className="text-sm font-medium text-slate-300">{title}</h3>
      </div>
      <ExportMenu chartRef={chartRef} name={panelKey} onCSV={()=>window.open(`/api/export/csv?view=breakdown&group_by=${panelKey}&metric=${metric}&${exportQS}`)}/>
    </div>
    <div ref={chartRef}>
      {type==='pie'
        ? (()=>{
            // Roll up small slices into "Other" when there are many items
            const MAX_SLICES = 7;
            let pieItems = items;
            if(items.length > MAX_SLICES) {
              const sorted = [...items].sort((a,b)=>b.value-a.value);
              const top = sorted.slice(0,MAX_SLICES-1);
              const rest = sorted.slice(MAX_SLICES-1);
              const otherVal = rest.reduce((s,r)=>s+r.value,0);
              pieItems = [...top, {dimension:`Other (${rest.length})`, value:otherVal}];
            }
            const legendRows = Math.ceil(pieItems.length/3);
            const pieH = 200 + legendRows * 22;
            return <ResponsiveContainer width="100%" height={pieH}>
              <PieChart>
                <Pie data={pieItems} dataKey="value" nameKey="dimension" cx="50%" cy="45%" innerRadius={50} outerRadius={85}
                  onClick={e=>onFilter&&e.dimension&&!e.dimension.startsWith('Other')&&onFilter(e.dimension)}>
                  {pieItems.map((_,i)=><Cell key={i} fill={COLORS[i%COLORS.length]}/>)}
                </Pie>
                <Tooltip {...tooltipProps}/>
                <Legend wrapperStyle={{fontSize:11,color:'#94a3b8'}}/>
              </PieChart>
            </ResponsiveContainer>;
          })()
        : (()=>{
            const barItems = items.slice(0,10);
            const barH = Math.max(220, barItems.length * 28 + 40);
            return <ResponsiveContainer width="100%" height={barH}>
              <BarChart layout="vertical" data={barItems} onClick={e=>onFilter&&e&&onFilter(e.activePayload?.[0]?.payload?.dimension)}>
                <XAxis type="number" stroke="#475569" fontSize={11} tickFormatter={fmtVal}/>
                <YAxis type="category" dataKey="dimension" stroke="#475569" fontSize={10} width={130}
                  tick={({x,y,payload})=>{
                    const t=payload.value||'';
                    const label=t.length>20?t.slice(0,18)+'…':t;
                    return <g transform={`translate(${x},${y})`}><title>{t}</title><text x={-4} y={0} dy={4} textAnchor="end" fill="#94a3b8" fontSize={10}>{label}</text></g>;
                  }}/>
                <Tooltip {...tooltipProps}/>
                <Bar dataKey="value" radius={[0,4,4,0]}>
                  {barItems.map((entry,i)=><Cell key={i} fill={modelColor(entry.dimension)}/>)}
                </Bar>
              </BarChart>
            </ResponsiveContainer>;
          })()
      }
    </div>
  </div>;
}

// ── Log Viewer ────────────────────────────────────────────────────────────────
const ALL_COLS=[
  {key:'created_at',label:'Time',fmt:fmtDate},
  {key:'model_short',label:'Model'},
  {key:'provider_name',label:'Provider'},
  {key:'tokens_total',label:'Tokens',fmt:fmtNum,align:'right'},
  {key:'native_tokens_cached',label:'Cached',fmt:fmtNum,align:'right'},
  {key:'native_tokens_reasoning',label:'Reasoning',fmt:fmtNum,align:'right'},
  {key:'cost_usd',label:'Cost',fmt:fmt$4,align:'right'},
  {key:'generation_time_ms',label:'Latency',fmt:fmtMs,align:'right'},
  {key:'streamed',label:'Stream',fmt:v=>v?'✓':'-',align:'center'},
  {key:'finish_reason',label:'Finish'},
  {key:'origin',label:'Origin'},
  {key:'api_key_label',label:'API Key'},
];
const DEFAULT_COLS=['created_at','model_short','provider_name','tokens_total','cost_usd','generation_time_ms','finish_reason'];

function LogViewer({logData,logSort,setLogSort,logSearch,setLogSearch,logPage,setLogPage,logPageSize,setLogPageSize,visibleCols,setVisibleCols,expandedRow,setExpandedRow,onExportCSV}) {
  const [colOpen,setColOpen]=useState(false);
  const searchTimeout=useRef(null);
  const [localSearch,setLocalSearch]=useState(logSearch);
  const data = logData?.data||[];

  const handleSearch=v=>{setLocalSearch(v); clearTimeout(searchTimeout.current); searchTimeout.current=setTimeout(()=>setLogSearch(v),300);};
  const handleSort=col=>{
    if(logSort.col===col) setLogSort(s=>({...s,dir:s.dir==='desc'?'asc':'desc'}));
    else setLogSort({col,dir:'desc'});
  };
  const SortIcon=({col})=>{
    if(logSort.col!==col) return <LI.ChevronsUpDown size={10} className="text-slate-600 ml-0.5"/>;
    return logSort.dir==='desc'?<LI.ChevronDown size={10} className="text-blue-400 ml-0.5"/>:<LI.ChevronUp size={10} className="text-blue-400 ml-0.5"/>;
  };
  const cols=ALL_COLS.filter(c=>visibleCols.includes(c.key));
  const total=logData?.total||0;
  const pages=logData?.pages||1;

  return <div className="bg-slate-800 rounded-xl p-4">
    <div className="flex items-center gap-3 mb-3 flex-wrap">
      <h2 className="text-sm font-medium text-slate-300">Recent Generations</h2>
      <div className="flex items-center gap-1 bg-slate-700 rounded px-2 flex-1 min-w-32 max-w-56">
        <LI.Search size={12} className="text-slate-500"/>
        <input id="log-search" type="text" value={localSearch} onChange={e=>handleSearch(e.target.value)}
          placeholder="Search..." className="bg-transparent text-xs text-slate-200 outline-none py-1 w-full placeholder-slate-600"/>
      </div>
      <div className="relative">
        <button onClick={()=>setColOpen(!colOpen)} className="flex items-center gap-1 px-2 py-1 text-xs text-slate-400 border border-slate-700 rounded hover:border-slate-500">
          <LI.Columns size={12}/> Cols
