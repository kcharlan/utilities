def _validate_mapping(mapping: dict) -> bool:
    for k, v in mapping.items():
        if k.startswith("_"):
            continue
        if not isinstance(v, dict) or "attribute" not in v or "fallbacks" not in v:
            return False
    return True


def load_attribute_mapping() -> dict:
    if os.path.isfile(MAPPING_FILE):
        try:
            with open(MAPPING_FILE, "r") as f:
                data = json.load(f)
            if _validate_mapping(data):
                return data
            logger.warning("attribute_mapping.json is malformed; falling back to default")
        except (json.JSONDecodeError, OSError) as e:
            logger.warning("Failed to read attribute_mapping.json: %s; using default", e)
    # Write default to file
    try:
        with open(MAPPING_FILE, "w") as f:
            json.dump(DEFAULT_ATTRIBUTE_MAPPING, f, indent=2)
    except OSError:
        pass
    return DEFAULT_ATTRIBUTE_MAPPING


# === OTLP PARSER ===
def derive_model_short(model: str) -> str:
    if not model:
        return ""
    short = re.sub(r'^[^/]+/', '', model)          # strip provider prefix
    short = re.sub(r'-\d{8}$', '', short)           # strip YYYYMMDD suffix
    short = re.sub(r'-\d{4}-\d{2}-\d{2}$', '', short)  # strip YYYY-MM-DD suffix
    return short


def _flatten_attrs(attrs: list) -> dict:
    flat = {}
    for item in attrs or []:
        key = item.get("key", "")
        val_obj = item.get("value", {})
        if "stringValue" in val_obj:
            flat[key] = val_obj["stringValue"]
        elif "intValue" in val_obj:
            flat[key] = val_obj["intValue"]
        elif "doubleValue" in val_obj:
            flat[key] = val_obj["doubleValue"]
        elif "boolValue" in val_obj:
            flat[key] = val_obj["boolValue"]
        elif "arrayValue" in val_obj:
            vals = val_obj["arrayValue"].get("values", [])
            flat[key] = ", ".join(str(v.get("stringValue", v)) for v in vals)
        else:
            flat[key] = str(val_obj)
    return flat


def _cast(value, type_str: str):
    if value is None:
        return None
    try:
        if type_str == "integer":
            return int(float(str(value)))
        if type_str == "float":
            return float(str(value))
        if type_str == "boolean":
            if isinstance(value, bool):
                return value
            return str(value).lower() in ("true", "1", "yes")
    except (ValueError, TypeError):
        return None
    return str(value)


def extract_generation(span: dict, mapping: dict, resource_attrs: dict = None) -> dict:
    attrs = _flatten_attrs(span.get("attributes", []))
    if resource_attrs:
        # Resource-level attrs are available for mappings tagged with _source=resource
        # Merge them in (span attrs take precedence on collision)
        merged = dict(resource_attrs)
        merged.update(attrs)
        attrs = merged
    consumed_keys = set()
    gen = {}

    for col, cfg in mapping.items():
        if col.startswith("_"):
            continue
        primary = cfg.get("attribute", "")
        fallbacks = cfg.get("fallbacks", [])
        type_str = cfg.get("type", "string")

        value = None
        for key in [primary] + fallbacks:
            if key and key in attrs:
                value = attrs[key]
                consumed_keys.add(key)
                break

        if value is not None and type_str != "string":
            value = _cast(value, type_str)
        gen[col] = value

    # Unconsumed attributes -> trace_metadata
    leftover = {k: v for k, v in attrs.items() if k not in consumed_keys}
    gen["trace_metadata"] = json.dumps(leftover) if leftover else None

    # Derived fields
    start_ns = span.get("startTimeUnixNano")
    end_ns = span.get("endTimeUnixNano")
    if start_ns:
        try:
            start_ns = int(start_ns)
            dt = datetime.fromtimestamp(start_ns / 1e9, tz=timezone.utc)
            gen["created_at"] = dt.isoformat()
            gen["created_date"] = dt.strftime("%Y-%m-%d")
            gen["created_hour"] = dt.hour
            if end_ns:
                gen["latency_ms"] = int((int(end_ns) - start_ns) / 1_000_000)
        except (ValueError, OSError):
            pass
    if "created_at" not in gen or not gen.get("created_at"):
        now = datetime.now(timezone.utc)
        gen["created_at"] = now.isoformat()
        gen["created_date"] = now.strftime("%Y-%m-%d")
        gen["created_hour"] = now.hour

    # If the mapping didn't populate generation_time_ms, fall back to span latency
    if not gen.get("generation_time_ms") and gen.get("latency_ms"):
        gen["generation_time_ms"] = gen["latency_ms"]

    model = gen.get("model") or ""
    gen["model_short"] = derive_model_short(model)
    if not model:
        gen["model"] = gen.get("id", "unknown")

    gen["ingestion_source"] = "broadcast"
    gen["ingested_at"] = datetime.now(timezone.utc).isoformat()

    # Ensure numeric defaults
    for int_col in ("tokens_prompt", "tokens_completion", "native_tokens_prompt",
                    "native_tokens_completion", "native_tokens_reasoning",
                    "native_tokens_cached", "num_media_prompt",
                    "num_input_audio_prompt", "num_media_completion", "num_search_results"):
        if not gen.get(int_col):
            gen[int_col] = 0
    for float_col in ("cost_usd", "cost_upstream_usd", "cost_cache_usd",
                      "cost_data_usd", "cost_web_usd"):
        if not gen.get(float_col):
            gen[float_col] = 0.0
    for bool_col in ("streamed", "cancelled"):
        if not gen.get(bool_col):
            gen[bool_col] = False

    return gen


# === TIME RANGE HELPERS ===
def _get_tz(tz_str: str):
    try:
        return ZoneInfo(tz_str or "UTC")
    except (ZoneInfoNotFoundError, Exception):
        return timezone.utc


def _local_midnight(dt_local: datetime) -> datetime:
    return dt_local.replace(hour=0, minute=0, second=0, microsecond=0)


def _start_of_week(dt_local: datetime) -> datetime:
    """Monday 00:00:00 of the week containing dt_local."""
    monday = dt_local - timedelta(days=dt_local.weekday())
    return _local_midnight(monday)


def _start_of_month(dt_local: datetime) -> datetime:
    return dt_local.replace(day=1, hour=0, minute=0, second=0, microsecond=0)


def _start_of_quarter(dt_local: datetime) -> datetime:
    q_start_month = ((dt_local.month - 1) // 3) * 3 + 1
    return dt_local.replace(month=q_start_month, day=1, hour=0, minute=0, second=0, microsecond=0)


def _start_of_year(dt_local: datetime) -> datetime:
    return dt_local.replace(month=1, day=1, hour=0, minute=0, second=0, microsecond=0)


def _end_of_day(dt_local: datetime) -> datetime:
    return dt_local.replace(hour=23, minute=59, second=59, microsecond=999999)


def _end_of_week(start_of_week: datetime) -> datetime:
    return _end_of_day(start_of_week + timedelta(days=6))


def _end_of_month(dt_local: datetime) -> datetime:
    import calendar as cal_mod
    last_day = cal_mod.monthrange(dt_local.year, dt_local.month)[1]
    return dt_local.replace(day=last_day, hour=23, minute=59, second=59, microsecond=999999)


def _end_of_quarter(dt_local: datetime) -> datetime:
    q_end_month = (((dt_local.month - 1) // 3) + 1) * 3
    import calendar as cal_mod
    last_day = cal_mod.monthrange(dt_local.year, q_end_month)[1]
    return dt_local.replace(month=q_end_month, day=last_day, hour=23, minute=59, second=59, microsecond=999999)


def _end_of_year(dt_local: datetime) -> datetime:
    return dt_local.replace(month=12, day=31, hour=23, minute=59, second=59, microsecond=999999)


def _prev_month(dt_local: datetime) -> datetime:
    if dt_local.month == 1:
        return dt_local.replace(year=dt_local.year - 1, month=12)
    return dt_local.replace(month=dt_local.month - 1)


def parse_time_range(range_p: str, from_p: str, to_p: str, tz_p: str) -> Tuple[Optional[str], Optional[str]]:
    tz = _get_tz(tz_p)
    now_utc = datetime.now(timezone.utc)
    now_local = now_utc.astimezone(tz)

    if from_p and to_p:
        try:
            from_dt = datetime.fromisoformat(from_p.replace("Z", "+00:00"))
            to_dt = datetime.fromisoformat(to_p.replace("Z", "+00:00"))
            if from_dt.tzinfo is None:
                from_dt = from_dt.replace(tzinfo=tz)
            if to_dt.tzinfo is None:
                to_dt = to_dt.replace(tzinfo=tz)
            return from_dt.astimezone(timezone.utc).isoformat(), to_dt.astimezone(timezone.utc).isoformat()
        except ValueError:
            pass

    rng = range_p or "today"

    if rng == "all":
        return None, None

    if rng == "today":
        start = _local_midnight(now_local)
        end = now_local
    elif rng == "yesterday":
        yesterday = now_local - timedelta(days=1)
        start = _local_midnight(yesterday)
        end = _end_of_day(yesterday)
    elif rng == "this_week":
        start = _start_of_week(now_local)
        end = now_local
    elif rng == "last_week":
        prev_week_end = _start_of_week(now_local) - timedelta(seconds=1)
        start = _start_of_week(prev_week_end)
        end = _end_of_week(start)
    elif rng == "this_month":
        start = _start_of_month(now_local)
        end = now_local
    elif rng == "last_month":
        last_m = _prev_month(now_local)
        start = _start_of_month(last_m)
        end = _end_of_month(last_m)
    elif rng == "this_quarter":
        start = _start_of_quarter(now_local)
        end = now_local
    elif rng == "last_quarter":
        q_start = _start_of_quarter(now_local)
        prev_q_end = q_start - timedelta(seconds=1)
        start = _start_of_quarter(prev_q_end)
        end = _end_of_quarter(prev_q_end)
    elif rng == "this_year":
        start = _start_of_year(now_local)
        end = now_local
    elif rng == "last_year":
        prev_year = now_local.replace(year=now_local.year - 1)
        start = _start_of_year(prev_year)
        end = _end_of_year(prev_year)
    elif rng == "last_1h":
        start = now_utc - timedelta(hours=1)
        return start.isoformat(), now_utc.isoformat()
    elif rng == "last_6h":
        start = now_utc - timedelta(hours=6)
        return start.isoformat(), now_utc.isoformat()
    elif rng == "last_24h":
        start = now_utc - timedelta(hours=24)
        return start.isoformat(), now_utc.isoformat()
    elif rng == "last_7d":
        start = now_utc - timedelta(days=7)
        return start.isoformat(), now_utc.isoformat()
    elif rng == "last_30d":
        start = now_utc - timedelta(days=30)
        return start.isoformat(), now_utc.isoformat()
    elif rng == "last_90d":
        start = now_utc - timedelta(days=90)
        return start.isoformat(), now_utc.isoformat()
    else:
        # Default: today
        start = _local_midnight(now_local)
        end = now_local

    return start.astimezone(timezone.utc).isoformat(), end.astimezone(timezone.utc).isoformat()


def build_where_clause(model=None, provider=None, api_key=None,
                       origin=None, finish_reason=None) -> Tuple[str, list]:
    clauses = []
    params = []

    def multi(col, val):
        if not val:
            return
        items = [v.strip() for v in val.split(",") if v.strip()]
        if items:
            placeholders = ",".join("?" * len(items))
            clauses.append(f"AND {col} IN ({placeholders})")
            params.extend(items)

    multi("model_short", model)
    multi("provider_name", provider)
    multi("COALESCE(api_key_label, api_key_id)", api_key)
    multi("origin", origin)
    multi("finish_reason", finish_reason)

    return " ".join(clauses), params


# === COMPARISON RANGE COMPUTATION ===
def nth_weekday_of_month(year: int, month: int, weekday: int, n: int) -> Optional[int]:
    count = 0
    last = None
    for week in monthcalendar(year, month):
        if week[weekday] != 0:
            count += 1
            last = week[weekday]
            if count == n:
                return week[weekday]
    return last  # fall back to last occurrence


def which_occurrence(year: int, month: int, day: int) -> Tuple[int, int]:
    dt = date_type(year, month, day)
    weekday = dt.weekday()
    n = (day - 1) // 7 + 1
    return weekday, n


def compute_comparison_range(from_utc_str: str, to_utc_str: str, mode: str,
                              tz_str: str = "UTC") -> Tuple[str, str]:
    tz = _get_tz(tz_str)
    from_dt = datetime.fromisoformat(from_utc_str.replace("Z", "+00:00")).astimezone(tz)
    to_dt = datetime.fromisoformat(to_utc_str.replace("Z", "+00:00")).astimezone(tz)
    duration = to_dt - from_dt

    if mode == "prior_period":
        comp_from = from_dt - duration
        comp_to = from_dt
    elif mode == "dow":
        comp_from = from_dt - timedelta(days=7)
        comp_to = to_dt - timedelta(days=7)
    elif mode == "wow":
        comp_from = from_dt - timedelta(weeks=1)
        comp_to = to_dt - timedelta(weeks=1)
    elif mode == "mom_date":
        def prev_month_date(dt):
            if dt.month == 1:
                m, y = 12, dt.year - 1
            else:
                m, y = dt.month - 1, dt.year
            import calendar as cal_mod
            max_day = cal_mod.monthrange(y, m)[1]
            d = min(dt.day, max_day)
            return dt.replace(year=y, month=m, day=d)
        comp_from = prev_month_date(from_dt)
        comp_to = prev_month_date(to_dt)
    elif mode == "mom_relative":
        weekday, n = which_occurrence(from_dt.year, from_dt.month, from_dt.day)
        if from_dt.month == 1:
            pm, py = 12, from_dt.year - 1
        else:
            pm, py = from_dt.month - 1, from_dt.year
        comp_day = nth_weekday_of_month(py, pm, weekday, n)
        if comp_day:
            comp_from = from_dt.replace(year=py, month=pm, day=comp_day)
            comp_to = comp_from + duration
        else:
            comp_from = from_dt - timedelta(days=30)
            comp_to = to_dt - timedelta(days=30)
    elif mode == "qoq":
        # Shift back one quarter (~91 days)
        comp_from = from_dt - timedelta(days=91)
        comp_to = to_dt - timedelta(days=91)
    elif mode == "yoy_date":
        def prev_year_date(dt):
            try:
                return dt.replace(year=dt.year - 1)
            except ValueError:
                return dt.replace(year=dt.year - 1, day=28)
        comp_from = prev_year_date(from_dt)
        comp_to = prev_year_date(to_dt)
    elif mode == "yoy_relative":
        weekday, n = which_occurrence(from_dt.year, from_dt.month, from_dt.day)
        py = from_dt.year - 1
        comp_day = nth_weekday_of_month(py, from_dt.month, weekday, n)
        if comp_day:
            comp_from = from_dt.replace(year=py, day=comp_day)
            comp_to = comp_from + duration
        else:
            comp_from = from_dt - timedelta(days=365)
            comp_to = to_dt - timedelta(days=365)
    else:
        comp_from = from_dt - duration
        comp_to = from_dt

    return comp_from.astimezone(timezone.utc).isoformat(), comp_to.astimezone(timezone.utc).isoformat()


def default_comparison_mode(range_preset: str) -> Optional[str]:
    mapping = {
        "today": "dow", "yesterday": "dow",
        "this_week": "wow", "last_week": "wow",
        "this_month": "mom_date", "last_month": "mom_date",
        "this_quarter": "qoq", "last_quarter": "qoq",
        "this_year": "yoy_date", "last_year": "yoy_date",
    }
    if range_preset in mapping:
        return mapping[range_preset]
    if range_preset in ("all",):
        return None
    return "prior_period"


# === DAILY SUMMARY UPSERT ===
async def upsert_daily_summary(db: aiosqlite.Connection, gen: dict):
    date = gen.get("created_date", "")
    model = gen.get("model", "")
    provider = gen.get("provider_name") or ""
    key_id = gen.get("api_key_id") or ""
    tp = gen.get("tokens_prompt", 0) or 0
    tc = gen.get("tokens_completion", 0) or 0
    tt = tp + tc
    ntp = gen.get("native_tokens_prompt", 0) or 0
    ntc_cached = gen.get("native_tokens_cached", 0) or 0
    ntr = gen.get("native_tokens_reasoning", 0) or 0
    cost = gen.get("cost_usd", 0.0) or 0.0
    gen_ms = gen.get("generation_time_ms") or 0
    cancelled = 1 if gen.get("cancelled") else 0
    streamed = 1 if gen.get("streamed") else 0

    await db.execute("""
        INSERT INTO daily_summaries
            (date, model, provider_name, api_key_id,
             request_count, tokens_prompt, tokens_completion, tokens_total,
             native_tokens_cached, native_tokens_reasoning, cost_usd,
             avg_generation_ms, cancelled_count, streamed_count)
        VALUES (?, ?, ?, ?,
                1, ?, ?, ?,
                ?, ?, ?,
                ?, ?, ?)
        ON CONFLICT(date, model, provider_name, api_key_id)
        DO UPDATE SET
            request_count           = request_count + 1,
            tokens_prompt           = tokens_prompt + excluded.tokens_prompt,
            tokens_completion       = tokens_completion + excluded.tokens_completion,
            tokens_total            = tokens_total + excluded.tokens_total,
            native_tokens_cached    = native_tokens_cached + excluded.native_tokens_cached,
            native_tokens_reasoning = native_tokens_reasoning + excluded.native_tokens_reasoning,
            cost_usd                = cost_usd + excluded.cost_usd,
            avg_generation_ms       = (avg_generation_ms * request_count + excluded.avg_generation_ms)
                                      / (request_count + 1),
            cancelled_count         = cancelled_count + excluded.cancelled_count,
            streamed_count          = streamed_count + excluded.streamed_count
    """, (date, model, provider, key_id, tp, tc, tt,
          ntc_cached, ntr, cost, gen_ms, cancelled, streamed))


async def refresh_daily_summaries(days: Optional[int] = 2):
    db = await get_db()
    try:
        now = datetime.now(timezone.utc)
        if days is not None:
            cutoff = (now - timedelta(days=days)).strftime("%Y-%m-%d")
            await db.execute("DELETE FROM daily_summaries WHERE date >= ?", (cutoff,))
            where = "WHERE created_date >= ?"
            w_params = (cutoff,)
        else:
            await db.execute("DELETE FROM daily_summaries")
            where = ""
            w_params = ()

        await db.execute(f"""
            INSERT INTO daily_summaries
                (date, model, provider_name, api_key_id,
                 request_count, tokens_prompt, tokens_completion, tokens_total,
                 native_tokens_cached, native_tokens_reasoning, cost_usd,
                 avg_generation_ms, cancelled_count, streamed_count)
            SELECT
                created_date,
                model,
                COALESCE(provider_name, ''),
                COALESCE(api_key_id, ''),
                COUNT(*),
                SUM(tokens_prompt), SUM(tokens_completion), SUM(tokens_total),
                SUM(native_tokens_cached), SUM(native_tokens_reasoning),
                SUM(cost_usd),
                AVG(generation_time_ms),
                SUM(CASE WHEN cancelled THEN 1 ELSE 0 END),
                SUM(CASE WHEN streamed THEN 1 ELSE 0 END)
            FROM generations
            {where}
            GROUP BY created_date, model, COALESCE(provider_name,''), COALESCE(api_key_id,'')
        """, w_params)

        # Compute percentiles per group
        cursor = await db.execute("""
            SELECT DISTINCT date, model, provider_name, api_key_id FROM daily_summaries
        """ + (f"WHERE date >= ?" if days is not None else ""),
            (cutoff,) if days is not None else ())
        groups = await cursor.fetchall()

        for row in groups:
            d, m, prov, kid = row[0], row[1], row[2], row[3]
            cur2 = await db.execute("""
                SELECT generation_time_ms FROM generations
                WHERE created_date = ?
                  AND model = ?
                  AND COALESCE(provider_name,'') = ?
                  AND COALESCE(api_key_id,'') = ?
                  AND generation_time_ms IS NOT NULL
                ORDER BY generation_time_ms
            """, (d, m, prov, kid))
            vals = [r[0] for r in await cur2.fetchall()]
            if vals:
                p50 = vals[int(len(vals) * 0.50)]
                p95 = vals[min(int(len(vals) * 0.95), len(vals) - 1)]
                p99 = vals[min(int(len(vals) * 0.99), len(vals) - 1)]
                await db.execute("""
                    UPDATE daily_summaries
                    SET p50_generation_ms=?, p95_generation_ms=?, p99_generation_ms=?
                    WHERE date=? AND model=? AND provider_name=? AND api_key_id=?
                """, (p50, p95, p99, d, m, prov, kid))

        await db.commit()
    finally:
        await db.close()


# === ANOMALY DETECTION ===
async def refresh_model_stats():
    global _model_stats
    db = await get_db()
    try:
        cutoff = (datetime.now(timezone.utc) - timedelta(days=7)).isoformat()
        cur = await db.execute("""
            SELECT model_short,
                   AVG(cost_usd) as cost_mean,
                   AVG(cost_usd * cost_usd) as cost_sq_mean,
                   AVG(generation_time_ms) as lat_mean,
                   AVG(generation_time_ms * generation_time_ms) as lat_sq_mean,
                   AVG(tokens_total) as tok_mean,
                   AVG(tokens_total * tokens_total) as tok_sq_mean,
                   COUNT(*) as cnt
            FROM generations
            WHERE created_at >= ? AND cost_usd IS NOT NULL
            GROUP BY model_short
            HAVING cnt >= 5
        """, (cutoff,))
        rows = await cur.fetchall()
        stats = {}
        import math
        for r in rows:
            ms = dict(r)
            model = ms["model_short"]
            def std(mean, sq_mean):
                variance = sq_mean - mean * mean
                return math.sqrt(max(variance, 0))
            stats[model] = {
                "cost_mean": ms["cost_mean"] or 0,
                "cost_std": std(ms["cost_mean"] or 0, ms["cost_sq_mean"] or 0),
                "lat_mean": ms["lat_mean"] or 0,
                "lat_std": std(ms["lat_mean"] or 0, ms["lat_sq_mean"] or 0),
                "tok_mean": ms["tok_mean"] or 0,
                "tok_std": std(ms["tok_mean"] or 0, ms["tok_sq_mean"] or 0),
            }
        _model_stats = stats
    finally:
        await db.close()


def get_anomalies(gen: dict) -> list:
    model = gen.get("model_short", "")
    if model not in _model_stats:
        return []
    s = _model_stats[model]
    flags = []
    cost = gen.get("cost_usd") or 0
    lat = gen.get("generation_time_ms") or 0
    tok = (gen.get("tokens_prompt", 0) or 0) + (gen.get("tokens_completion", 0) or 0)
    if s["cost_std"] > 0 and cost > s["cost_mean"] + 3 * s["cost_std"]:
        flags.append("high_cost")
    if s["lat_std"] > 0 and lat > s["lat_mean"] + 3 * s["lat_std"]:
        flags.append("high_latency")
    if s["tok_std"] > 0 and tok > s["tok_mean"] + 3 * s["tok_std"]:
        flags.append("high_tokens")
    return flags


# === WEBSOCKET MANAGER ===
class ConnectionManager:
    def __init__(self):
        self.active: List[WebSocket] = []

    async def connect(self, ws: WebSocket):
        await ws.accept()
        self.active.append(ws)

    def disconnect(self, ws: WebSocket):
        if ws in self.active:
            self.active.remove(ws)

    async def broadcast(self, message: dict):
        dead = []
        for ws in self.active:
            try:
                await ws.send_json(message)
            except Exception:
                dead.append(ws)
        for ws in dead:
            self.disconnect(ws)


manager = ConnectionManager()

