        {colOpen&&<div className="absolute top-full mt-1 right-0 bg-slate-800 border border-slate-700 rounded-lg shadow-xl z-40 w-40 py-2">
          {ALL_COLS.map(c=><label key={c.key} className="flex items-center gap-2 px-3 py-1 text-xs text-slate-300 hover:bg-slate-700 cursor-pointer">
            <input type="checkbox" checked={visibleCols.includes(c.key)}
              onChange={()=>setVisibleCols(prev=>prev.includes(c.key)?prev.filter(k=>k!==c.key):[...prev,c.key])}
              className="accent-blue-500"/>
            {c.label}
          </label>)}
        </div>}
      </div>
      <button onClick={onExportCSV} className="flex items-center gap-1 px-2 py-1 text-xs text-slate-400 border border-slate-700 rounded hover:border-slate-500">
        <LI.Download size={12}/> CSV
      </button>
      <span className="text-xs text-slate-500 ml-auto">
        {total>0?`${(logPage-1)*logPageSize+1}–${Math.min(logPage*logPageSize,total)} of ${fmtNum(total)}`:'0 results'}
      </span>
    </div>

    <div className="overflow-x-auto">
      <table className="w-full text-xs">
        <thead>
          <tr className="border-b border-slate-700">
            {cols.map(c=><th key={c.key} className={`p-2 text-slate-400 font-medium cursor-pointer hover:text-slate-200 select-none ${c.align==='right'?'text-right':c.align==='center'?'text-center':'text-left'}`}
              onClick={()=>handleSort(c.key)}>
              <span className="flex items-center gap-0.5 whitespace-nowrap justify-start">{c.align==='right'&&<span className="flex-1"/>}{c.label}<SortIcon col={c.key}/></span>
            </th>)}
          </tr>
        </thead>
        <tbody>
          {data.length===0&&<tr><td colSpan={cols.length} className="p-4 text-center text-slate-500">No generations found</td></tr>}
          {data.map(row=><React.Fragment key={row.id}>
            <tr className={`border-b border-slate-700/50 hover:bg-slate-700/30 cursor-pointer transition-colors ${row.anomalies?.length?'border-l-2 border-l-amber-500':''} ${expandedRow===row.id?'bg-slate-700/40':''}`}
              onClick={()=>setExpandedRow(expandedRow===row.id?null:row.id)}>
              {cols.map(c=><td key={c.key} className={`p-2 text-slate-300 ${c.align==='right'?'text-right':c.align==='center'?'text-center':''} max-w-32 truncate`}>
                {c.fmt?c.fmt(row[c.key]):row[c.key]??'-'}
                {c.key==='model_short'&&row.anomalies?.length>0&&<span className="ml-1 text-amber-400" title={row.anomalies.join(', ')}>⚠</span>}
              </td>)}
            </tr>
            {expandedRow===row.id&&<tr>
              <td colSpan={cols.length} className="p-3 bg-slate-900/50">
                <div className="grid grid-cols-2 md:grid-cols-3 gap-2 text-xs mb-2">
                  {Object.entries(row).filter(([k])=>!['trace_metadata','anomalies'].includes(k)).map(([k,v])=><div key={k} className="flex gap-2">
                    <span className="text-slate-500 shrink-0">{k}:</span>
                    <span className="text-slate-300 break-all">{String(v??'-')}</span>
                  </div>)}
                </div>
                {row.trace_metadata&&<details className="mt-2">
                  <summary className="text-xs text-slate-500 cursor-pointer">trace_metadata</summary>
                  <pre className="mt-1 text-xs text-slate-400 bg-slate-900 rounded p-2 overflow-auto max-h-40">{JSON.stringify(JSON.parse(row.trace_metadata||'{}'),null,2)}</pre>
                </details>}
              </td>
            </tr>}
          </React.Fragment>)}
        </tbody>
      </table>
    </div>

    <div className="flex items-center justify-between mt-3 pt-3 border-t border-slate-700">
      <div className="flex items-center gap-2">
        <span className="text-xs text-slate-500">Per page:</span>
        {[25,50,100,250].map(n=><button key={n} onClick={()=>{setLogPageSize(n);setLogPage(1);}}
          className={`px-2 py-0.5 text-xs rounded ${logPageSize===n?'bg-blue-600 text-white':'text-slate-400 hover:text-slate-200'}`}>{n}</button>)}
      </div>
      <div className="flex items-center gap-1">
        <button onClick={()=>setLogPage(1)} disabled={logPage<=1}
          className="px-1.5 py-0.5 text-xs text-slate-400 hover:text-slate-200 disabled:opacity-30">First</button>
        <button onClick={()=>setLogPage(p=>Math.max(1,p-1))} disabled={logPage<=1}
          className="p-1 text-slate-400 hover:text-slate-200 disabled:opacity-30"><LI.ChevronLeft size={14}/></button>
        <input type="text" value={logPage} onChange={e=>{
          const v=parseInt(e.target.value,10);
          if(!isNaN(v)&&v>=1&&v<=pages) setLogPage(v);
          else if(e.target.value==='') setLogPage(1);
        }}
          onKeyDown={e=>{if(e.key==='Enter'){const v=parseInt(e.target.value,10);if(!isNaN(v))setLogPage(Math.max(1,Math.min(pages,v)));}}}
          className="w-10 text-center text-xs text-slate-300 bg-slate-700 rounded px-1 py-0.5 outline-none border border-slate-600 focus:border-blue-500"
        />
        <span className="text-xs text-slate-500">/ {pages}</span>
        <button onClick={()=>setLogPage(p=>Math.min(pages,p+1))} disabled={logPage>=pages}
          className="p-1 text-slate-400 hover:text-slate-200 disabled:opacity-30"><LI.ChevronRight size={14}/></button>
        <button onClick={()=>setLogPage(pages)} disabled={logPage>=pages}
          className="px-1.5 py-0.5 text-xs text-slate-400 hover:text-slate-200 disabled:opacity-30">Last</button>
      </div>
    </div>
  </div>;
}

