        cur2 = await db.execute(
            f"SELECT * FROM generations {where} ORDER BY {sort} {order} LIMIT ? OFFSET ?",
            w_p + [page_size, offset]
        )
        rows = await cur2.fetchall()
        data = []
        for row in rows:
            d = dict(row)
            d["anomalies"] = get_anomalies(d)
            data.append(d)

        return {
            "data": data,
            "total": total,
            "page": page,
            "page_size": page_size,
            "pages": max(1, (total + page_size - 1) // page_size),
        }
    finally:
        await db.close()


