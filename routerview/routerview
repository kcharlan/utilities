const COST_CYCLES = ['avg','p50','p95','min','max'];
const LAT_CYCLES  = ['avg','p50','p95','min','max'];
function KPICard({title,value,subValue,delta,deltaLabel,positive,children}) {
  const deltaColor = delta==null?'text-slate-500':positive===false?'text-red-400':'text-green-400';
  return <div className="bg-slate-800 rounded-xl p-4 flex flex-col gap-1 min-w-0">
