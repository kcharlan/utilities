    finally:
        await db.close()

    return {"status": "ok", "inserted": inserted, "skipped": skipped}


# === PERCENTILE QUERY HELPER ===
async def _percentile(db, pct: float, col: str, from_s: str, to_s: str,
                      extra_where: str, params: list) -> Optional[float]:
    count_where = f"WHERE {col} IS NOT NULL"
    if from_s:
        count_where += " AND created_at >= ? AND created_at < ?"
    count_where += f" {extra_where}"
    count_params = ([from_s, to_s] if from_s else []) + params
    cur = await db.execute(f"SELECT COUNT(*) FROM generations {count_where}", count_params)
    n = (await cur.fetchone())[0]
    if not n:
        return None
    offset = int(n * pct)
    select_where = count_where
    cur2 = await db.execute(
        f"SELECT {col} FROM generations {select_where} ORDER BY {col} LIMIT 1 OFFSET ?",
        count_params + [offset]
    )
    row = await cur2.fetchone()
    return row[0] if row else None


async def _run_summary_query(db, from_s, to_s, extra_where, params):
    where = "WHERE 1=1"
    w_params = []
    if from_s:
        where += " AND created_at >= ? AND created_at < ?"
        w_params = [from_s, to_s]
    where += f" {extra_where}"
    w_params = w_params + params

    cur = await db.execute(f"""
        SELECT
            COUNT(*) as request_count,
            COALESCE(SUM(cost_usd), 0) as total_cost,
            COALESCE(AVG(cost_usd), 0) as avg_cost,
            COALESCE(SUM(tokens_total), 0) as total_tokens,
            COALESCE(AVG(generation_time_ms), 0) as avg_latency_ms,
            COALESCE(SUM(native_tokens_cached), 0) as total_cached_tokens,
            COALESCE(SUM(native_tokens_prompt), 0) as total_prompt_tokens,
            MIN(cost_usd) as min_cost,
            MAX(cost_usd) as max_cost,
            MIN(generation_time_ms) as min_latency_ms,
            MAX(generation_time_ms) as max_latency_ms
        FROM generations {where}
    """, w_params)
    row = dict(await cur.fetchone())

    p50_lat = await _percentile(db, 0.50, "generation_time_ms", from_s, to_s, extra_where, params)
    p95_lat = await _percentile(db, 0.95, "generation_time_ms", from_s, to_s, extra_where, params)
    p50_cost = await _percentile(db, 0.50, "cost_usd", from_s, to_s, extra_where, params)
    p95_cost = await _percentile(db, 0.95, "cost_usd", from_s, to_s, extra_where, params)

    cached = row["total_cached_tokens"]
    prompt = row["total_prompt_tokens"]
    cache_hit_rate = (cached / prompt) if prompt else 0.0

    # Cost projection for partial periods
    now_utc = datetime.now(timezone.utc)
    projected_cost = None
    projected_requests = None
    if from_s and to_s:
        try:
            from_dt = datetime.fromisoformat(from_s.replace("Z", "+00:00"))
            to_dt = datetime.fromisoformat(to_s.replace("Z", "+00:00"))
            period_end = to_dt
            elapsed = (min(now_utc, period_end) - from_dt).total_seconds()
            total = (period_end - from_dt).total_seconds()
            if total > 0 and elapsed > 0:
                fraction = elapsed / total
                if fraction < 0.99:
                    projected_cost = row["total_cost"] / fraction
                    projected_requests = row["request_count"] / fraction
        except Exception:
            pass

    return {
        "request_count": row["request_count"],
        "total_cost": row["total_cost"],
        "avg_cost_per_request": row["avg_cost"],
        "min_cost_per_request": row["min_cost"],
        "max_cost_per_request": row["max_cost"],
        "p50_cost_per_request": p50_cost,
        "p95_cost_per_request": p95_cost,
        "total_tokens": row["total_tokens"],
        "avg_latency_ms": row["avg_latency_ms"],
        "min_latency_ms": row["min_latency_ms"],
        "max_latency_ms": row["max_latency_ms"],
        "p50_latency_ms": p50_lat,
        "p95_latency_ms": p95_lat,
        "cache_hit_rate": cache_hit_rate,
        "projected_cost": projected_cost,
        "projected_requests": projected_requests,
    }


