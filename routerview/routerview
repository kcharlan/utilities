// ── Setup Wizard ──────────────────────────────────────────────────────────────
function SetupWizard({onComplete,wsConnected,firstGen}) {
  const [step,setStep]=useState(1);
  const [apiKey,setApiKey]=useState('');
  const webhookUrl=`${window.location.origin}/v1/traces`;
  const copy=()=>navigator.clipboard.writeText(webhookUrl);
  const testConn=async()=>{
    const r=await fetch('/v1/traces',{method:'POST',headers:{'X-Test-Connection':'true'}}).catch(()=>null);
    if(r?.ok) alert('Connection OK!');
  };
  const saveKey=async()=>{
    if(apiKey) await fetch('/api/settings',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({openrouter_api_key:apiKey})});
    setStep(3);
  };
  const finish=async()=>{
    await fetch('/api/settings',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({setup_complete:'true'})});
    onComplete();
  };

  return <div className="fixed inset-0 z-50 bg-slate-950 flex items-center justify-center p-4">
    <div className="bg-slate-900 border border-slate-700 rounded-2xl p-8 w-full max-w-lg">
      <div className="flex gap-2 mb-8">
        {[1,2,3,4,5,6].map(i=><div key={i} className={`flex-1 h-1 rounded-full ${i<=step?'bg-blue-500':'bg-slate-700'}`}/>)}
      </div>
      {step===1&&<>
        <h2 className="text-2xl font-bold text-slate-100 mb-2">Welcome to RouterView</h2>
        <p className="text-slate-400 text-sm mb-6">Your self-hosted OpenRouter analytics dashboard. Real-time cost tracking, indefinite history, and SRE-grade observability.</p>
        <button onClick={()=>setStep(2)} className="w-full py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg font-medium">Get Started</button>
      </>}
      {step===2&&<>
        <h2 className="text-xl font-bold text-slate-100 mb-2">API Key (Optional)</h2>
        <p className="text-slate-400 text-sm mb-4">Provide your OpenRouter provisioning key to enable activity API backfill. Not required for live broadcast.</p>
        <input type="password" value={apiKey} onChange={e=>setApiKey(e.target.value)} placeholder="sk-or-v1-..."
          className="w-full bg-slate-800 text-sm text-slate-200 px-3 py-2 rounded border border-slate-700 outline-none focus:border-blue-500 mb-4"/>
        <div className="flex gap-3">
          <button onClick={()=>setStep(3)} className="flex-1 py-2.5 border border-slate-700 text-slate-400 hover:text-slate-200 rounded-lg text-sm">Skip</button>
          <button onClick={saveKey} className="flex-1 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm">Save & Continue</button>
        </div>
      </>}
      {step===3&&<>
        <h2 className="text-xl font-bold text-slate-100 mb-2">Configure Broadcast</h2>
        <p className="text-slate-400 text-sm mb-4">Paste this URL into <strong className="text-slate-300">OpenRouter Settings → Broadcast → Webhook</strong>:</p>
        <div className="flex items-center gap-2 bg-slate-800 rounded-lg px-3 py-2 mb-4">
          <code className="text-blue-300 text-xs flex-1 truncate">{webhookUrl}</code>
          <button onClick={copy} className="text-slate-400 hover:text-slate-200 shrink-0"><LI.Copy size={14}/></button>
        </div>
        <p className="text-slate-500 text-xs mb-4">You'll need a tunnel (Cloudflare Tunnel, ngrok) to expose this URL publicly. See docs for setup.</p>
        <div className="flex gap-3">
          <button onClick={testConn} className="flex-1 py-2.5 border border-slate-700 text-slate-400 hover:text-slate-200 rounded-lg text-sm">Test Connection</button>
          <button onClick={()=>setStep(4)} className="flex-1 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm">Continue</button>
        </div>
      </>}
      {step===4&&<>
        <h2 className="text-xl font-bold text-slate-100 mb-2">Verify</h2>
        <p className="text-slate-400 text-sm mb-6">Make any OpenRouter API request with broadcast enabled. RouterView will detect it here.</p>
        <div className={`flex items-center gap-3 p-4 rounded-lg border mb-6 ${firstGen?'border-green-500 bg-green-900/20':'border-slate-700 bg-slate-800'}`}>
          {firstGen?<LI.Check size={20} className="text-green-400"/>:<div className="w-5 h-5 rounded-full border-2 border-blue-400 border-t-transparent animate-spin"/>}
          <span className={`text-sm ${firstGen?'text-green-300':'text-slate-400'}`}>
