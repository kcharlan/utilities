                        vals = [gen_id] + [gen[c] for c in cols]

                        await db.execute(f"""
                            INSERT INTO generations ({col_list}) VALUES ({placeholder_list})
                            ON CONFLICT(id) DO UPDATE SET {set_clause}
                        """, vals)

                        await upsert_daily_summary(db, gen)
                        inserted += 1

                        anomalies = get_anomalies(gen)
                        await manager.broadcast({
                            "type": "generation",
                            "data": {
                                "id": gen_id,
                                "created_at": gen.get("created_at"),
                                "model_short": gen.get("model_short"),
