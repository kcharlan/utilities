  const mainChartRef=useRef();
  const panelRefs={model:useRef(),api_key:useRef(),provider:useRef()};

  // Ensure dark mode
  useEffect(()=>{ document.documentElement.classList.add('dark'); },[]);

  // Persist cols
  useEffect(()=>{ localStorage.setItem('rv_cols',JSON.stringify(visibleCols)); },[visibleCols]);

  // URL sync
  useEffect(()=>{
    const p=new URLSearchParams();
    if(timeRange!=='today') p.set('range',timeRange);
    Object.entries(filters).forEach(([k,v])=>{if(v.length) p.set(k,v.join(','));});
    const qs=p.toString(); history.replaceState(null,'',qs?`?${qs}`:'/');
  },[timeRange,filters]);

  // Check setup
  useEffect(()=>{
    fetch('/api/settings').then(r=>r.json()).then(s=>{ setSetupComplete(s.setup_complete==='true'); }).catch(()=>{setSetupComplete(true);});
    fetch('/api/views').then(r=>r.json()).then(setViews).catch(()=>{});
  },[]);

  // Build query string
  const buildQS = useCallback((extra={})=>{
    const p=new URLSearchParams();
    if(timeRange==='custom'){if(customFrom)p.set('from',customFrom);if(customTo)p.set('to',customTo);}
    else p.set('range',timeRange);
    p.set('tz',tz);
    if(filters.model.length) p.set('model',filters.model.join(','));
    if(filters.provider.length) p.set('provider',filters.provider.join(','));
    if(filters.api_key.length) p.set('api_key',filters.api_key.join(','));
    if(filters.origin.length) p.set('origin',filters.origin.join(','));
    if(filters.finish_reason.length) p.set('finish_reason',filters.finish_reason.join(','));
    if(compareEnabled) p.set('compare',compareMode);
    Object.entries(extra).forEach(([k,v])=>p.set(k,v));
    return p.toString();
  },[timeRange,customFrom,customTo,tz,filters,compareEnabled,compareMode]);

  // Fetch all data
  const fetchAbort = useRef(null);
  const fetchData = useCallback(async()=>{
    if(fetchAbort.current) fetchAbort.current.abort();
    const ac = new AbortController(); fetchAbort.current = ac;
    const sig = {signal:ac.signal};
    setLoading(true); setError(null);
    const qs=buildQS();
    const tsqs=buildQS({metric,group_by:groupBy});
    try {
      const [sumRes,tsRes,dimRes] = await Promise.all([
        fetch(`/api/summary?${qs}`,sig).then(r=>r.json()),
        fetch(`/api/timeseries?${tsqs}`,sig).then(r=>r.json()),
        fetch('/api/dimensions',sig).then(r=>r.json()),
      ]);
      setSummary(sumRes); setTimeseries(tsRes); setDimensions(dimRes);

      // Breakdown panels
      const [bmRes,bkRes,bpRes] = await Promise.all([
        fetch(`/api/breakdown?group_by=model&metric=cost&${qs}`,sig).then(r=>r.json()),
        fetch(`/api/breakdown?group_by=api_key&metric=cost&${qs}`,sig).then(r=>r.json()),
        fetch(`/api/breakdown?group_by=provider&metric=requests&${qs}`,sig).then(r=>r.json()),
      ]);
      setBreakdown({model:bmRes,api_key:bkRes,provider:bpRes});

      if(chartType==='heatmap') {
        const hm=await fetch(`/api/heatmap?metric=${metric}&${qs}`,sig).then(r=>r.json());
        setHeatmapData(hm);
      }
    } catch(e){ if(e.name==='AbortError') return; setError(String(e)); }
    finally { if(!ac.signal.aborted) setLoading(false); }
  },[buildQS,metric,groupBy,chartType]);

  const fetchLog = useCallback(async()=>{
    const qs=buildQS({page:logPage,page_size:logPageSize,sort:logSort.col,order:logSort.dir,search:logSearch});
    try { const d=await fetch(`/api/generations?${qs}`).then(r=>r.json()); setLogData(d); }
    catch(e){ console.warn('Log fetch failed',e); }
  },[buildQS,logPage,logPageSize,logSort,logSearch]);

  // KPI card cycles (persisted)
  const [costCycle,setCostCycle]=useState(()=>localStorage.getItem('rv_cost_agg')||'avg');
  const [latCycle,setLatCycle]=useState(()=>localStorage.getItem('rv_lat_agg')||'avg');
  useEffect(()=>localStorage.setItem('rv_cost_agg',costCycle),[costCycle]);
  useEffect(()=>localStorage.setItem('rv_lat_agg',latCycle),[latCycle]);

  // Fetch on mount and state changes
  useEffect(()=>{ fetchData(); },[fetchData]);
  useEffect(()=>{ fetchLog(); },[fetchLog]);

  // WebSocket
  useEffect(()=>{
    const proto=location.protocol==='https:'?'wss:':'ws:';
    let ws, delay=1000;
    function connect(){
      ws=new WebSocket(`${proto}//${location.host}/ws`);
      ws.onopen=()=>{setWsConnected(true);delay=1000;};
      ws.onclose=()=>{setWsConnected(false);setTimeout(connect,Math.min(delay,30000));delay*=2;};
      ws.onmessage=e=>{
        const msg=JSON.parse(e.data);
        if(msg.type==='generation'){
          const g=msg.data;
          if(!firstGen) setFirstGen(g);
          setLogData(prev=>!prev?prev:{...prev,data:[{...g,anomalies:g.anomalies||[],...Object.fromEntries(Object.entries(g).filter(([k])=>!['tokens_total'].includes(k))),tokens_total:(g.tokens_prompt||0)+(g.tokens_completion||0)}, ...prev.data.slice(0,prev.page_size-1)],total:prev.total+1});
          setSummary(prev=>!prev?prev:{...prev,request_count:prev.request_count+1,total_cost:prev.total_cost+(g.cost_usd||0),total_tokens:prev.total_tokens+(g.tokens_total||(g.tokens_prompt||0)+(g.tokens_completion||0))});
        }
      };
    }
    connect();
    return()=>{try{ws.close();}catch(_){}};
  },[]);

  // Keyboard shortcuts
  useEffect(()=>{
    const RANGES=RANGE_OPTS.map(o=>o.v).filter(v=>v!=='custom');
    function handleKey(e){
      if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.tagName==='SELECT') return;
      if(e.key==='/'){e.preventDefault();document.getElementById('log-search')?.focus();}
      else if(e.key==='ArrowLeft'){const i=RANGES.indexOf(timeRange);if(i>0)setTimeRange(RANGES[i-1]);else if(i===-1)setTimeRange(RANGES[RANGES.length-1]);}
      else if(e.key==='ArrowRight'){const i=RANGES.indexOf(timeRange);if(i>=0&&i<RANGES.length-1)setTimeRange(RANGES[i+1]);else if(i===-1)setTimeRange(RANGES[0]);}
      else if(e.key==='r'&&!e.metaKey){fetchData();fetchLog();}
      else if(e.key==='Escape'){setFilters({model:[],provider:[],api_key:[],origin:[],finish_reason:[]});}
      else if(e.key==='?'){setShowShortcuts(true);}
    }
    window.addEventListener('keydown',handleKey);
    return()=>window.removeEventListener('keydown',handleKey);
  },[timeRange,fetchData,fetchLog]);

  // Auto smart compare mode
  useEffect(()=>{
    const defaults={today:'dow',yesterday:'dow',this_week:'wow',last_week:'wow',this_month:'mom_date',last_month:'mom_date',this_quarter:'qoq',last_quarter:'qoq',this_year:'yoy_date',last_year:'yoy_date'};
    if(defaults[timeRange]) setCompareMode(defaults[timeRange]);
  },[timeRange]);

  // Drag-and-drop for panels
  const dragStart=(e,key)=>{dragSrc.current=key;};
  const dragOver=e=>{e.preventDefault();e.currentTarget.classList.add('drag-over');};
  const dragLeave=e=>e.currentTarget.classList.remove('drag-over');
  const drop=(e,key)=>{
    e.currentTarget.classList.remove('drag-over');
    if(!dragSrc.current||dragSrc.current===key) return;
    const src=dragSrc.current;
    setPanelOrder(prev=>{
      const next=[...prev]; const fi=next.indexOf(src); const ti=next.indexOf(key);
      next.splice(fi,1); next.splice(ti,0,src);
      localStorage.setItem('rv_panels',JSON.stringify(next));
      return next;
    });
    dragSrc.current=null;
  };

  // Saved views
  const selectView=v=>{
    const cfg=JSON.parse(v.config||'{}');
    if(cfg.timeRange) setTimeRange(cfg.timeRange);
    if(cfg.filters) setFilters(cfg.filters);
    if(cfg.chartType) setChartType(cfg.chartType);
    if(cfg.metric) setMetric(cfg.metric);
    if(cfg.groupBy) setGroupBy(cfg.groupBy);
    if(cfg.panelOrder) setPanelOrder(cfg.panelOrder);
    if(cfg.compareMode) setCompareMode(cfg.compareMode);
    if(cfg.compareEnabled!=null) setCompareEnabled(cfg.compareEnabled);
  };
  const saveView=async name=>{
    const config={timeRange,filters,chartType,metric,groupBy,panelOrder,compareMode,compareEnabled};
    await fetch('/api/views',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,config})});
    const v=await fetch('/api/views').then(r=>r.json()); setViews(v);
  };
  const deleteView=async id=>{
    await fetch(`/api/views/${id}`,{method:'DELETE'});
    setViews(prev=>prev.filter(v=>v.id!==id));
  };

  // Panel filter click -> set filter
  const onPanelFilter=(dim,val)=>{
    if(dim==='model') setFilters(f=>({...f,model:[...f.model.filter(x=>x!==val),val]}));
    else if(dim==='api_key') setFilters(f=>({...f,api_key:[...f.api_key.filter(x=>x!==val),val]}));
    else if(dim==='provider') setFilters(f=>({...f,provider:[...f.provider.filter(x=>x!==val),val]}));
  };

  const panelDefs={
    model:{title:'Cost by Model',type:'bar',metric:'cost',dim:'model'},
    api_key:{title:'Cost by API Key',type:'bar',metric:'cost',dim:'api_key'},
    provider:{title:'Requests by Provider',type:'pie',metric:'requests',dim:'provider'},
  };

  const exportLog=()=>window.open(`/api/export/csv?view=generations&${buildQS()}`);
  const exportTimeseries=()=>window.open(`/api/export/csv?view=timeseries&${buildQS()}`);

  if(!setupComplete) return <SetupWizard onComplete={()=>setSetupComplete(true)} wsConnected={wsConnected} firstGen={firstGen}/>;

  return <div className="min-h-screen bg-slate-950">
    <ErrorBanner error={error} onRetry={()=>{fetchData();fetchLog();}}/>
    <Header
      timeRange={timeRange} setTimeRange={setTimeRange}
      customFrom={customFrom} setCustomFrom={setCustomFrom}
      customTo={customTo} setCustomTo={setCustomTo}
      filters={filters} setFilters={setFilters}
      dimensions={dimensions}
      wsConnected={wsConnected} onSettings={()=>setShowSettings(true)}
      compareEnabled={compareEnabled} setCompareEnabled={setCompareEnabled}
      compareMode={compareMode} setCompareMode={setCompareMode}
      views={views} onSelectView={selectView} onSaveView={saveView} onDeleteView={deleteView}
      chartType={chartType} setChartType={setChartType}
      metric={metric} setMetric={setMetric}
      groupBy={groupBy} setGroupBy={setGroupBy}
    />

    <div className="p-4 flex flex-col gap-4 max-w-[1600px] mx-auto">
      <KPICards summary={summary} costCycle={costCycle} setCostCycle={setCostCycle} latCycle={latCycle} setLatCycle={setLatCycle}/>

      <div ref={mainChartRef}>
        {chartType==='heatmap'
          ?<HeatmapView data={heatmapData}/>
          :<MainChart data={timeseries} chartType={chartType} metric={metric} groupBy={groupBy} comparison={compareEnabled} onExport={exportTimeseries}/>
        }
      </div>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        {panelOrder.map(key=>{
          const def=panelDefs[key]; if(!def) return null;
          return <BreakdownPanel key={key}
            title={def.title} data={breakdown[key]} type={def.type} metric={def.metric}
            onFilter={val=>onPanelFilter(def.dim,val)}
            chartRef={panelRefs[key]} panelKey={key} exportQS={buildQS()}
            dragProps={{
              draggable:true,
              onDragStart:e=>dragStart(e,key),
              onDragOver:dragOver, onDragLeave:dragLeave,
              onDrop:e=>drop(e,key),
            }}/>;
        })}
      </div>

      <LogViewer logData={logData} logSort={logSort} setLogSort={setLogSort}
        logSearch={logSearch} setLogSearch={setLogSearch}
        logPage={logPage} setLogPage={setLogPage}
        logPageSize={logPageSize} setLogPageSize={setLogPageSize}
        visibleCols={visibleCols} setVisibleCols={setVisibleCols}
        expandedRow={expandedRow} setExpandedRow={setExpandedRow}
        onExportCSV={exportLog}/>
    </div>

    {showSettings&&<SettingsPanel onClose={()=>setShowSettings(false)}/>}
    {showShortcuts&&<ShortcutsModal onClose={()=>setShowShortcuts(false)}/>}
  </div>;
}

// ── Mount ─────────────────────────────────────────────────────────────────────
ReactDOM.createRoot(document.getElementById('root')).render(
  React.createElement(ErrorBoundary, null, React.createElement(App))
);
</script>
</body>
