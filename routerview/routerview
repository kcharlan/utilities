# === MAIN ===
def find_open_port(preferred: int, max_attempts: int = 20) -> int:
    for port in range(preferred, preferred + max_attempts):
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.bind(("", port))
            s.close()
            return port
        except OSError:
            continue
    raise RuntimeError(f"No open port found in range {preferred}-{preferred + max_attempts - 1}")


def parse_args():
    parser = argparse.ArgumentParser(
        prog="routerview",
        description="RouterView -- OpenRouter Analytics Dashboard"
    )
    parser.add_argument("-p", "--port", type=int, default=8100,
                        help="Preferred port (default: 8100)")
    parser.add_argument("--db", type=str, default=DB_DEFAULT,
                        help=f"SQLite database path (default: {DB_DEFAULT})")
    parser.add_argument("--debug", action="store_true",
                        help="Enable debug logging and OTLP payload capture")
    parser.add_argument("--host", type=str, default="127.0.0.1",
                        help="Bind address (default: 127.0.0.1)")
    return parser.parse_args()


def main():
    global _db_path, _debug_mode
    args = parse_args()
    _db_path = args.db
    _debug_mode = args.debug

    os.makedirs(DATA_DIR, exist_ok=True)
    if args.debug:
        os.makedirs(TRACES_DIR, exist_ok=True)

    init_database(args.db)
    load_attribute_mapping()

    port = find_open_port(args.port)
    with open(PORT_FILE, "w") as f:
        f.write(str(port))

    url = f"http://{args.host}:{port}"
    print(f"RouterView running at {url}")
    if args.debug:
        print(f"OTLP payload capture enabled: {TRACES_DIR}")

    import threading, webbrowser
    threading.Timer(1.0, lambda: webbrowser.open(url)).start()

    uvicorn.run(app, host=args.host, port=port,
                log_level="debug" if args.debug else "warning")


if __name__ == "__main__":
    main()
