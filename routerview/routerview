      <span className="flex items-center gap-1"><span style={{width:8,height:8,borderRadius:'50%',background:p.color,display:'inline-block'}}/>{p.name}</span>
      <span className="font-mono text-slate-200">{fmt(p.value)}</span>
    </div>)}
    {comp.length>0&&<>
      <p className="text-slate-500 mt-2 mb-1 border-t border-slate-700 pt-1">{compareRange||'Comparison'}</p>
      {comp.map((p,i)=><div key={i} className="flex justify-between gap-4 opacity-60">
        <span className="flex items-center gap-1"><span style={{width:8,height:8,borderRadius:'50%',background:p.color,display:'inline-block'}}/>{p.name.replace(/^_c_/,'')}</span>
        <span className="font-mono text-slate-200">{fmt(p.value)}</span>
