// ── Error Boundary ────────────────────────────────────────────────────────────
class ErrorBoundary extends React.Component {
  constructor(p){super(p);this.state={error:null};}
  static getDerivedStateFromError(e){return{error:e};}
  render(){
    if(this.state.error) return <div className="p-8 text-red-400 text-sm">
      <h2 className="font-bold mb-2">Something went wrong</h2>
      <pre className="text-xs opacity-70 overflow-auto">{this.state.error.message}</pre>
      <button onClick={()=>this.setState({error:null})} className="mt-4 px-3 py-1 border border-red-700 rounded text-xs hover:bg-red-900/30">Retry</button>
    </div>;
    return this.props.children;
  }
}

