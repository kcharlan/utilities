    const file=e.target.files?.[0]; if(!file) return;
    setImporting(true); setImportResult(null);
    const fd=new FormData(); fd.append('file',file);
    try {const r=await fetch('/api/import/csv',{method:'POST',body:fd}); const d=await r.json(); setImportResult(d);}
    catch(e){setImportResult({error:String(e)});}
    setImporting(false);
  };
  const pollApi=async()=>{
    setImporting(true);
    try{const r=await fetch('/api/import/poll',{method:'POST'}); const d=await r.json(); setImportResult(d);}
    catch(e){setImportResult({error:String(e)});}
    setImporting(false);
  };
  const refreshStats=async()=>{ await fetch('/api/admin/refresh-summaries',{method:'POST'}); alert('Summaries refreshed'); };

  return <div className="fixed inset-0 z-50 flex">
    <div className="flex-1 bg-black/60 backdrop-blur-sm" onClick={onClose}/>
    <div className="w-96 bg-slate-900 border-l border-slate-700 overflow-y-auto p-6 flex flex-col gap-6">
