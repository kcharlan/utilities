@app.post("/api/import/poll")
async def import_poll():
    db = await get_db()
    try:
        cur = await db.execute("SELECT value FROM settings WHERE key='openrouter_api_key'")
        row = await cur.fetchone()
        if not row:
            return JSONResponse(status_code=400, content={"error": "No OpenRouter API key configured"})
        api_key = row[0]
    finally:
        await db.close()

    try:
        async with httpx.AsyncClient(timeout=30) as client:
            headers = {"Authorization": f"Bearer {api_key}"}
            # Paginate activity API
            all_entries = []
            offset = 0
            page_size = 200
            while True:
                resp = await client.get(
                    "https://openrouter.ai/api/v1/activity",
                    headers=headers,
                    params={"offset": offset, "limit": page_size},
                )
                if resp.status_code != 200:
                    return JSONResponse(status_code=502,
                        content={"error": f"OpenRouter API returned {resp.status_code}"})
                page = resp.json()
                entries = page.get("data", [])
                all_entries.extend(entries)
                if len(entries) < page_size:
                    break
                offset += page_size
            data = {"data": all_entries}

            # Also fetch API keys for key-level attribution
            keys_data = []
            try:
                keys_resp = await client.get(
                    "https://openrouter.ai/api/v1/keys", headers=headers
                )
                if keys_resp.status_code == 200:
                    keys_data = keys_resp.json().get("data", [])
            except Exception:
                pass
    except Exception as e:
        return JSONResponse(status_code=502, content={"error": str(e)})

    # Activity API returns daily aggregates per model/provider.
    # We only write to daily_summaries (not synthetic generation rows)
    # because these are aggregates, not individual generations.
    db = await get_db()
    inserted = skipped = 0
    try:
        # Clean up any legacy synthetic generation rows from old poll imports
        await db.execute("DELETE FROM generations WHERE ingestion_source = 'activity_api'")

        for entry in data.get("data", []):
            try:
                raw_date = entry.get("date", "")
                model = entry.get("model", "")
                if not raw_date or not model:
                    skipped += 1
                    continue

                date_str = raw_date.strip()[:10]
                provider = entry.get("provider_name", "") or ""
                requests = entry.get("requests", 0) or 0
                prompt_tokens = entry.get("prompt_tokens", 0) or 0
                completion_tokens = entry.get("completion_tokens", 0) or 0
                reasoning_tokens = entry.get("reasoning_tokens", 0) or 0
                cost = entry.get("usage", 0) or 0
                model_short = derive_model_short(model)

                await db.execute("""
                    INSERT INTO daily_summaries
                    (date, model, provider_name, api_key_id, request_count,
                     tokens_prompt, tokens_completion, tokens_total,
                     native_tokens_reasoning, cost_usd)
                    VALUES (?,?,?,?,?,?,?,?,?,?)
                    ON CONFLICT(date, model, provider_name, api_key_id)
                    DO UPDATE SET
                        request_count = MAX(request_count, excluded.request_count),
                        tokens_prompt = MAX(tokens_prompt, excluded.tokens_prompt),
                        tokens_completion = MAX(tokens_completion, excluded.tokens_completion),
                        tokens_total = MAX(tokens_total, excluded.tokens_total),
                        native_tokens_reasoning = MAX(native_tokens_reasoning, excluded.native_tokens_reasoning),
                        cost_usd = MAX(cost_usd, excluded.cost_usd)
                """, (
                    date_str, model_short, provider, "",
                    requests, prompt_tokens, completion_tokens,
                    prompt_tokens + completion_tokens,
                    reasoning_tokens, cost,
                ))

                inserted += 1
            except Exception:
                logger.debug("Backfill entry error", exc_info=True)
                skipped += 1

        await db.commit()

        # Store key name mappings in settings for label resolution
        if keys_data:
            key_map = {kd.get("hash", "")[:16]: kd.get("name", "") for kd in keys_data if kd.get("name")}
            await db.execute(
                "INSERT INTO settings (key, value) VALUES ('key_name_map', ?) ON CONFLICT(key) DO UPDATE SET value=excluded.value",
                (json.dumps(key_map),)
            )

    finally:
        await db.close()

    return {"status": "ok", "inserted": inserted, "skipped": skipped}


