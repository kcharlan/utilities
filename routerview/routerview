  const primary = payload.filter(p=>!String(p.dataKey).startsWith('_c_'));
  const comp = payload.filter(p=>String(p.dataKey).startsWith('_c_'));
  return <div className="bg-slate-800 border border-slate-600 rounded-lg p-3 shadow-xl text-xs max-w-xs">
    <p className="text-slate-400 mb-2">{label}</p>
