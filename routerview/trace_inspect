#!/usr/bin/env python3
"""Inspect OTLP trace files and show how they align with the RouterView attribute mapping.

Usage:
    ./trace_inspect [trace_file]           # inspect a specific trace
    ./trace_inspect                        # inspect the latest trace in ~/.routerview/traces/
    ./trace_inspect --all                  # inspect all traces
"""

import json
import os
import sys
from pathlib import Path

DATA_DIR = os.path.expanduser("~/.routerview")
TRACES_DIR = os.path.join(DATA_DIR, "traces")
MAPPING_FILE = os.path.join(DATA_DIR, "attribute_mapping.json")

# trace_inspect reads the on-disk mapping file if present, otherwise falls back to this.
# Keep in sync with DEFAULT_ATTRIBUTE_MAPPING in routerview.
DEFAULT_ATTRIBUTE_MAPPING = {
    "id": {"attribute": "openrouter.trace.id", "fallbacks": ["gen_ai.generation.id", "openrouter.generation_id", "generation_id"], "_source": "resource"},
    "model": {"attribute": "gen_ai.request.model", "fallbacks": ["gen_ai.response.model", "llm.request.model"]},
    "provider_name": {"attribute": "trace.metadata.openrouter.provider_name", "fallbacks": ["trace.metadata.openrouter.provider_slug", "gen_ai.provider.name", "gen_ai.system", "llm.provider"]},
    "app_id": {"attribute": "openrouter.app_id", "fallbacks": ["trace.metadata.openrouter.app_id"]},
    "api_key_id": {"attribute": "openrouter.api_key_id", "fallbacks": ["trace.metadata.openrouter.entity_id", "openrouter.key_id"]},
    "api_key_label": {"attribute": "trace.metadata.openrouter.api_key_name", "fallbacks": ["openrouter.api_key_label", "openrouter.key_label"]},
    "tokens_prompt": {"attribute": "gen_ai.usage.input_tokens", "fallbacks": ["gen_ai.usage.prompt_tokens", "llm.usage.prompt_tokens"], "type": "integer"},
    "tokens_completion": {"attribute": "gen_ai.usage.output_tokens", "fallbacks": ["gen_ai.usage.completion_tokens", "llm.usage.completion_tokens"], "type": "integer"},
    "native_tokens_prompt": {"attribute": "gen_ai.usage.native_prompt_tokens", "fallbacks": ["openrouter.native_tokens_prompt"], "type": "integer"},
    "native_tokens_completion": {"attribute": "gen_ai.usage.native_completion_tokens", "fallbacks": ["openrouter.native_tokens_completion"], "type": "integer"},
    "native_tokens_reasoning": {"attribute": "gen_ai.usage.output_tokens.reasoning", "fallbacks": ["gen_ai.usage.reasoning_tokens", "openrouter.native_tokens_reasoning"], "type": "integer"},
    "native_tokens_cached": {"attribute": "gen_ai.usage.input_tokens.cached", "fallbacks": ["gen_ai.usage.cached_tokens", "openrouter.native_tokens_cached"], "type": "integer"},
    "cost_usd": {"attribute": "gen_ai.usage.total_cost", "fallbacks": ["openrouter.usage.total_cost", "gen_ai.usage.cost", "llm.usage.total_cost"], "type": "float"},
    "cost_upstream_usd": {"attribute": "openrouter.usage.upstream_cost", "fallbacks": [], "type": "float"},
    "cost_cache_usd": {"attribute": "openrouter.usage.cache_cost", "fallbacks": [], "type": "float"},
    "cost_data_usd": {"attribute": "openrouter.usage.data_cost", "fallbacks": [], "type": "float"},
    "cost_web_usd": {"attribute": "openrouter.usage.web_cost", "fallbacks": [], "type": "float"},
    "generation_time_ms": {"attribute": "openrouter.generation_time", "fallbacks": ["gen_ai.latency"], "type": "integer"},
    "finish_reason": {"attribute": "gen_ai.response.finish_reason", "fallbacks": ["gen_ai.response.finish_reasons", "trace.metadata.openrouter.finish_reason", "gen_ai.completion.finish_reason", "llm.response.stop_reason"]},
    "streamed": {"attribute": "gen_ai.request.streaming", "fallbacks": ["openrouter.streamed"], "type": "boolean"},
    "cancelled": {"attribute": "openrouter.cancelled", "fallbacks": [], "type": "boolean"},
    "origin": {"attribute": "trace.metadata.openrouter.source", "fallbacks": ["openrouter.origin", "http.url", "url.full"]},
    "external_user": {"attribute": "openrouter.external_user", "fallbacks": []},
    "num_media_prompt": {"attribute": "openrouter.num_media_prompt", "fallbacks": [], "type": "integer"},
    "num_input_audio_prompt": {"attribute": "openrouter.num_input_audio_prompt", "fallbacks": [], "type": "integer"},
    "num_media_completion": {"attribute": "openrouter.num_media_completion", "fallbacks": [], "type": "integer"},
    "num_search_results": {"attribute": "openrouter.num_search_results", "fallbacks": [], "type": "integer"},
}

BOLD = "\033[1m"
DIM = "\033[2m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
CYAN = "\033[36m"
RESET = "\033[0m"


def flatten_attrs(attrs):
    flat = {}
    for item in attrs or []:
        key = item.get("key", "")
        val_obj = item.get("value", {})
        if "stringValue" in val_obj:
            flat[key] = val_obj["stringValue"]
        elif "intValue" in val_obj:
            flat[key] = val_obj["intValue"]
        elif "doubleValue" in val_obj:
            flat[key] = val_obj["doubleValue"]
        elif "boolValue" in val_obj:
            flat[key] = val_obj["boolValue"]
        elif "arrayValue" in val_obj:
            vals = val_obj["arrayValue"].get("values", [])
            flat[key] = ", ".join(str(v.get("stringValue", v)) for v in vals)
        else:
            flat[key] = str(val_obj)
    return flat


def truncate(val, maxlen=80):
    s = str(val)
    if len(s) > maxlen:
        return s[:maxlen - 3] + "..."
    return s


def load_mapping():
    if os.path.isfile(MAPPING_FILE):
        try:
            with open(MAPPING_FILE) as f:
                return json.load(f), MAPPING_FILE
        except (json.JSONDecodeError, OSError):
            pass
    return DEFAULT_ATTRIBUTE_MAPPING, "(built-in default)"


def inspect_trace(path):
    with open(path) as f:
        data = json.load(f)

    mapping, mapping_source = load_mapping()
    print(f"\n{'=' * 90}")
    print(f"{BOLD}Trace:{RESET} {os.path.basename(path)}")
    print(f"{DIM}Mapping: {mapping_source}{RESET}")

    for rs_idx, rs in enumerate(data.get("resourceSpans", [])):
        res_attrs = flatten_attrs(rs.get("resource", {}).get("attributes", []))
        trace_id = res_attrs.get("openrouter.trace.id", "?")
        print(f"\n{BOLD}Resource #{rs_idx}{RESET}  trace.id={CYAN}{trace_id}{RESET}")

        if res_attrs:
            print(f"  {DIM}Resource attributes:{RESET}")
            for k, v in res_attrs.items():
                print(f"    {k}: {truncate(v)}")

        for ss in rs.get("scopeSpans", []):
            for span in ss.get("spans", []):
                span_attrs = flatten_attrs(span.get("attributes", []))
                # Merge resource-level attrs (span attrs win on collision)
                merged_attrs = dict(res_attrs)
                merged_attrs.update(span_attrs)
                span_attrs = merged_attrs
                span_name = span.get("name", "?")
                start_ns = span.get("startTimeUnixNano")
                end_ns = span.get("endTimeUnixNano")

                latency = ""
                if start_ns and end_ns:
                    latency = f"  latency={int((int(end_ns) - int(start_ns)) / 1_000_000)}ms"

                print(f"\n  {BOLD}Span:{RESET} {span_name}{latency}")
                print(f"  {'─' * 86}")

                # ── Section 1: Mapping alignment ──
                print(f"\n  {BOLD}Mapping Alignment{RESET}")
                print(f"  {'DB Column':<28} {'Status':<10} {'Matched Key':<42} {'Value'}")
                print(f"  {'─'*28} {'─'*10} {'─'*42} {'─'*30}")

                matched_keys = set()
                hits = 0
                misses = 0
                fallback_hits = 0

                for col, cfg in mapping.items():
                    if col.startswith("_"):
                        continue
                    primary = cfg.get("attribute", "")
                    fallbacks = cfg.get("fallbacks", [])

                    value = None
                    matched_key = None
                    used_fallback = False

                    if primary and primary in span_attrs:
                        value = span_attrs[primary]
                        matched_key = primary
                        matched_keys.add(primary)
                    else:
                        for fb in fallbacks:
                            if fb in span_attrs:
                                value = span_attrs[fb]
                                matched_key = fb
                                used_fallback = True
                                matched_keys.add(fb)
                                break

                    if value is not None:
                        if used_fallback:
                            status = f"{YELLOW}FALLBACK{RESET}"
                            fallback_hits += 1
                        else:
                            status = f"{GREEN}OK{RESET}"
                        hits += 1
                        print(f"  {col:<28} {status:<19} {matched_key:<42} {truncate(value, 40)}")
                    else:
                        status = f"{RED}MISS{RESET}"
                        misses += 1
                        tried = [primary] + fallbacks
                        print(f"  {col:<28} {status:<19} {DIM}tried: {', '.join(t for t in tried if t)}{RESET}")

                # ── Section 2: Unmapped attributes ──
                unmapped = {k: v for k, v in span_attrs.items() if k not in matched_keys}
                print(f"\n  {BOLD}Unmapped Attributes{RESET} (in trace but not consumed by any mapping)")

                if unmapped:
                    # Categorize
                    categories = {}
                    for k in sorted(unmapped):
                        prefix = k.split(".")[0]
                        categories.setdefault(prefix, []).append(k)

                    for prefix in sorted(categories):
                        for k in categories[prefix]:
                            val = unmapped[k]
                            is_large = isinstance(val, str) and len(val) > 200
                            tag = f" {DIM}(large payload, {len(val)} chars){RESET}" if is_large else ""
                            print(f"    {CYAN}{k}{RESET}: {truncate(val, 60)}{tag}")
                else:
                    print(f"    {DIM}(none -- all attributes consumed){RESET}")

                # ── Section 3: Summary ──
                total_mapped = hits + misses
                print(f"\n  {BOLD}Summary{RESET}")
                print(f"    Mapped:   {GREEN}{hits}{RESET}/{total_mapped} columns matched"
                      + (f" ({YELLOW}{fallback_hits} via fallback{RESET})" if fallback_hits else ""))
                print(f"    Missed:   {RED}{misses}{RESET}/{total_mapped} columns with no matching attribute")
                print(f"    Unmapped: {len(unmapped)} trace attributes not consumed by mapping")

                # ── Section 4: Suggestions ──
                suggestions = []

                # Check for near-misses: unmapped keys that look like they should map to a missed column
                # Build a keyword map from column names to semantic terms
                col_keywords = {
                    "id": ["generation.id", "trace.id"],
                    "cost_usd": ["cost", "total_cost"],
                    "cost_upstream_usd": ["upstream_cost"],
                    "cost_cache_usd": ["cache_cost"],
                    "cost_data_usd": ["data_cost"],
                    "cost_web_usd": ["web_cost"],
                    "api_key_label": ["api_key_name", "key_label", "key_name"],
                    "api_key_id": ["api_key_id", "key_id"],
                    "native_tokens_reasoning": ["reasoning", "reasoning_tokens"],
                    "native_tokens_cached": ["cached", "cached_tokens"],
                    "native_tokens_prompt": ["native_prompt", "native_tokens_prompt"],
                    "native_tokens_completion": ["native_completion", "native_tokens_completion"],
                    "provider_name": ["provider_name", "provider_slug"],
                    "generation_time_ms": ["generation_time", "latency"],
                    "streamed": ["streaming", "streamed"],
                    "origin": ["origin", "url", "source"],
                }

                for col, cfg in mapping.items():
                    if col.startswith("_"):
                        continue
                    primary = cfg.get("attribute", "")
                    fallbacks = cfg.get("fallbacks", [])
                    all_tried = [primary] + fallbacks

                    # Already matched?
                    if any(k in span_attrs for k in all_tried if k):
                        continue

                    # Use semantic keywords if available, else derive from column name
                    keywords = col_keywords.get(col, [col.replace("_", ".")])

                    for ukey in sorted(unmapped):
                        ukey_lower = ukey.lower()
                        # Check if the unmapped key contains any keyword
                        if any(kw in ukey_lower for kw in keywords):
                            suggestions.append((col, ukey, unmapped[ukey]))

                if suggestions:
                    print(f"\n  {BOLD}Suggested Mapping Fixes{RESET}")
                    for col, ukey, val in suggestions:
                        print(f"    {col:<28} <- {CYAN}{ukey}{RESET}  (sample: {truncate(val, 40)})")

    print(f"\n{'=' * 90}\n")


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--all":
        traces = sorted(Path(TRACES_DIR).glob("*.json"))
        if not traces:
            print(f"No traces found in {TRACES_DIR}")
            return
        for t in traces:
            inspect_trace(str(t))
    elif len(sys.argv) > 1 and sys.argv[1] != "--help":
        path = sys.argv[1]
        if not os.path.isfile(path):
            print(f"File not found: {path}")
            sys.exit(1)
        inspect_trace(path)
    elif len(sys.argv) == 1:
        traces = sorted(Path(TRACES_DIR).glob("*.json"))
        if not traces:
            print(f"No traces found in {TRACES_DIR}")
            return
        inspect_trace(str(traces[-1]))
    else:
        print(__doc__)


if __name__ == "__main__":
    main()
