                  <td className="py-2 px-2 capitalize text-gray-600 dark:text-gray-400">{d.side}</td>
                  <td className="py-2 px-2 capitalize text-gray-600 dark:text-gray-400">{d.area}</td>
                  <td className="py-2 px-2">
                    <div className="flex items-center gap-1.5">
                      <span className="inline-flex items-center px-1.5 py-0.5 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded text-xs font-mono font-bold">#{e.entryIndex}</span>
                      <span className={`inline-flex px-1 py-0 rounded text-[10px] font-mono ${e.status >= 400 ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300' : e.status >= 300 ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300'}`}>{e.status}</span>
                      <span className="font-mono text-[10px] text-gray-500 dark:text-gray-400">{e.method}</span>
                      <span className="font-mono text-[10px] text-gray-500 dark:text-gray-400 truncate max-w-[180px]" title={e.path}>{e.path}</span>
                    </div>
                  </td>
                  <td className="py-2 px-2">
                    <div className="flex items-center gap-1">
                      <button onClick={() => handleToggle(d)}
                        className="text-[10px] px-1.5 py-0.5 rounded border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"
                        title={d.redact ? 'Keep this value' : 'Redact this value'}>
                        {d.redact ? 'Keep' : 'Redact'}
                      </button>
                      <button onClick={() => onInspect(e.entryIndex, d.location)}
                        className="text-[10px] px-1.5 py-0.5 rounded border border-gray-300 dark:border-gray-600 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20"
                        title="View in Inspector">
                        <Icon name="Search" size={10} />
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
};

// --- App ---
const TABS = [
  { id: 'waterfall', label: 'Waterfall', icon: 'BarChart3' },
  { id: 'inspector', label: 'Inspector', icon: 'Search' },
  { id: 'security', label: 'Security', icon: 'Shield' },
  { id: 'decisions', label: 'Decisions', icon: 'ClipboardList' },
  { id: 'sequence', label: 'Sequence', icon: 'GitBranch' },
  { id: 'dashboard', label: 'Dashboard', icon: 'LayoutDashboard' },
  { id: 'export', label: 'Export', icon: 'Download' },
];

const App = () => {
  const [isDark, setIsDark] = useState(() => window.matchMedia('(prefers-color-scheme: dark)').matches);
  const [activeTab, setActiveTab] = useState('waterfall');
  const [status, setStatus] = useState(null);
  const [toast, setToast] = useState(null);
  const [selectedEntry, setSelectedEntry] = useState(null);

  useEffect(() => {
    document.documentElement.classList.toggle('dark', isDark);
  }, [isDark]);

  const fetchStatus = useCallback(async () => {
    try {
      const s = await api('/api/status');
      setStatus(s);
    } catch {}
  }, []);

  useEffect(() => { fetchStatus(); }, []);

  const showToast = (message, type) => setToast({ message, type });

  const [findingPath, setFindingPath] = useState(null);
  const [securityFindings, setSecurityFindings] = useState([]);
  const [manualRedactions, setManualRedactions] = useState([]);

  const refreshSecurity = useCallback(async () => {
    try {
      const d = await api('/api/security');
      setSecurityFindings(d.findings || []);
      setManualRedactions(d.manualRedactions || []);
    } catch {}
  }, []);

  // Fetch security findings once file is loaded
  useEffect(() => {
    if (status?.loaded) { refreshSecurity(); }
  }, [status?.loaded]);

  const redactionMap = useMemo(() => {
    const map = {};
    securityFindings.forEach(f => {
      map[`${f.entryIndex}|${f.location}`] = {
        state: f.redact ? 'auto-on' : 'auto-off',
        finding: f,
      };
    });
    (manualRedactions || []).forEach(m => {
      const key = `${m.entryIndex}|${m.location}`;
      if (!map[key]) {
        map[key] = { state: m.redact ? 'manual' : 'normal' };
      }
    });
    return map;
  }, [securityFindings, manualRedactions]);

  const toggleRedaction = useCallback(async (entryIndex, location, value) => {
    const key = `${entryIndex}|${location}`;
    const entry = redactionMap[key];
    if (entry && (entry.state === 'auto-on' || entry.state === 'auto-off')) {
      // Toggle auto finding
      await api('/api/security/toggle', { method: 'POST', body: JSON.stringify({ id: entry.finding.id }) });
    } else if (entry && entry.state === 'manual') {
      // Remove manual redaction
      await api('/api/redaction/remove-manual', { method: 'POST', body: JSON.stringify({ entryIndex, location }) });
    } else {
      // Add manual redaction
      await api('/api/redaction/manual', { method: 'POST', body: JSON.stringify({ entryIndex, location, value: value || '' }) });
    }
    await refreshSecurity();
  }, [redactionMap, refreshSecurity]);

  const handleInspect = (index, path) => {
    setSelectedEntry(index);
    setFindingPath(path || null);
    setActiveTab('inspector');
  };

  const handleLoad = () => {
    fetchStatus();
    setActiveTab('waterfall');
  };

  const criticalCount = status?.security?.critical || 0;

  return (
    <div className="light-bg min-h-screen text-ink dark:text-gray-200">
      {toast && <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />}

      {/* Header */}
      <header className="flex items-center justify-between px-4 py-2 bg-white/90 dark:bg-card-dark/90 border-b border-gray-200 dark:border-gray-700 backdrop-blur sticky top-0 z-40">
        <div className="flex items-center gap-2">
          <Icon name="Shield" size={20} className="text-blue-600" />
          <span className="font-bold text-sm tracking-tight">harscope</span>
          {status?.loaded && (
            <span className="text-xs text-gray-400 dark:text-gray-500 ml-2 font-mono">{status.fileName} &middot; {status.entryCount} entries &middot; {formatBytes(status.fileSize)}</span>
          )}
        </div>
        <button onClick={() => setIsDark(!isDark)} className="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" title="Toggle theme">
          <Icon name={isDark ? 'Sun' : 'Moon'} size={16} />
        </button>
      </header>

      {/* Tab Bar */}
      {status?.loaded && (
        <nav className="flex gap-0 px-4 bg-white/80 dark:bg-card-dark/80 border-b border-gray-200 dark:border-gray-700 backdrop-blur sticky top-[41px] z-30">
          {TABS.map(tab => (
            <button key={tab.id} onClick={() => setActiveTab(tab.id)}
              className={`flex items-center gap-1.5 px-4 py-2 text-xs font-medium transition-colors relative ${activeTab === tab.id ? 'tab-active' : 'text-gray-500 hover:text-gray-700 dark:hover:text-gray-300'}`}>
              <Icon name={tab.icon} size={14} />
              {tab.label}
              {tab.id === 'security' && criticalCount > 0 && (
                <span className="absolute -top-0.5 -right-0.5 bg-red-600 text-white text-[9px] font-bold rounded-full w-4 h-4 flex items-center justify-center">{criticalCount}</span>
              )}
            </button>
          ))}
        </nav>
      )}

      {/* Content */}
      <main className="h-[calc(100vh-82px)]" style={status?.loaded ? { height: 'calc(100vh - 114px)' } : {}}>
        {!status?.loaded ? (
          <WelcomeScreen onLoad={handleLoad} showToast={showToast} />
        ) : (
          <>
            {activeTab === 'waterfall' && <WaterfallView onInspect={handleInspect} securityFindings={securityFindings} />}
            {activeTab === 'inspector' && <InspectorView entryIndex={selectedEntry} findingPath={findingPath} securityFindings={securityFindings} redactionMap={redactionMap} onToggleRedaction={toggleRedaction} />}
            {activeTab === 'security' && <SecurityView onInspect={handleInspect} onRefreshSecurity={refreshSecurity} />}
            {activeTab === 'decisions' && <DecisionsView onInspect={handleInspect} onRefreshSecurity={refreshSecurity} />}
            {activeTab === 'sequence' && <SequenceView />}
            {activeTab === 'dashboard' && <DashboardView />}
            {activeTab === 'export' && <ExportView showToast={showToast} />}
          </>
        )}
      </main>
    </div>
  );
};

// --- Root Render ---
ReactDOM.createRoot(document.getElementById('root')).render(
  <ErrorBoundary><App /></ErrorBoundary>
);
</script>
</body>
</html>"""


# --- Server Lifecycle ---

def open_browser(port):
    time.sleep(1.5)
    webbrowser.open(f"http://127.0.0.1:{port}")

def find_available_port(start_port, max_attempts=20):
    """Find an available port starting from start_port."""
    import socket
    for offset in range(max_attempts):
        port = start_port + offset
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.bind(('127.0.0.1', port))
                return port
        except OSError:
            continue
    return None


def main():
    global har_manager, security_scanner
    args = parse_args()

    # --- CLI validation mode ---
    if args.validate:
        if not args.edl:
            print("Error: --validate requires --edl <file.edl.json>")
            sys.exit(1)
        for path, label in [(args.validate, 'Sanitized HAR'), (args.edl, 'EDL')]:
            if not os.path.exists(path):
                print(f"Error: {label} file not found: {path}")
                sys.exit(1)
        try:
            with open(args.validate, 'r', encoding='utf-8') as f:
                har_data = json.load(f)
            with open(args.edl, 'r', encoding='utf-8') as f:
                edl_data = json.load(f)
        except (json.JSONDecodeError, ValueError) as e:
            print(f"Error: Invalid JSON: {e}")
            sys.exit(1)

        result = ExportEngine.validate_edl(har_data, edl_data)
        summary = result['summary']

        if args.format == 'json':
            print(json.dumps(result, indent=2))
            sys.exit(0 if summary['valid'] else 1)

        # --- Human-readable text output ---
        print(f"EDL Validation: {summary['total']} decisions checked")
        print()

        # Column widths
        STATUS_W = 7   # "[PASS] " / "[FAIL] " / "[ERROR]"
        ACTION_W = 8   # "redact" / "keep"
        SOURCE_W = 8   # "auto" / "manual"
        ENTRY_W = 6    # "#NNN"

        # Print every decision
        for r in result['results']:
            entry = r.get('entry', {})
            status_tag = f"[{r['status'].upper()}]"
            action = r['action'].upper()
            source = f"({r.get('source', '?')})"
            idx = f"#{r['entryIndex']}"
            endpoint = f"{entry.get('method', '?')} {entry.get('domain', '')}{entry.get('path', '/')}"
            loc = f"{r.get('side', '?')} > {r.get('area', '?')} > {r.get('key', '?')}"

            print(f"  {status_tag:<{STATUS_W}} {action:<{ACTION_W}} {source:<{SOURCE_W}} {idx:<{ENTRY_W}} {endpoint}")
            print(f"  {'':<{STATUS_W}} {loc}")
            if r['status'] != 'pass':
                print(f"  {'':<{STATUS_W}} \u2514\u2500 {r.get('detail', '')}")
            print()

        # Summary
        print(f"Summary: {summary['pass']} pass, {summary['fail']} fail, {summary['error']} error")

        if summary['valid']:
            print("RESULT: VALID - all decisions verified")
            sys.exit(0)
        else:
            print("RESULT: INVALID - see issues above")
            sys.exit(1)

    if args.file_path:
        if not os.path.exists(args.file_path):
            print(f"Error: File not found: {args.file_path}")
            sys.exit(1)
        try:
            har_manager.load_file(args.file_path)
            security_scanner.scan(har_manager)
            logger.info(f"Loaded {len(har_manager.entries)} entries from {args.file_path}")
            sec = security_scanner.get_summary()
            logger.info(f"Security scan: {sec['critical']} critical, {sec['warning']} warning, {sec['info']} info")
        except Exception as e:
            print(f"Error loading file: {e}")
            sys.exit(1)

    port = find_available_port(args.port)
    if port is None:
        print(f"Error: No available port found (tried {args.port}-{args.port + 19})")
        sys.exit(1)
    if port != args.port:
        logger.info(f"Port {args.port} in use, using {port} instead")

    logger.info(f"harscope available at http://127.0.0.1:{port}")

    threading.Thread(target=open_browser, args=(port,), daemon=True).start()

    uvicorn.run(app, host="127.0.0.1", port=port, log_level="info")

if __name__ == "__main__":
    main()
