th{{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--slate-600);padding:8px 12px;text-align:left;font-weight:600}}
th.num,td.num{{text-align:right}}
td{{padding:8px 12px;border-bottom:1px solid var(--slate-200);vertical-align:top}}
tr:hover{{background:var(--slate-100)}}
td.mono{{font-family:var(--mono);font-size:12px}}
.badge{{display:inline-block;font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;padding:2px 8px;border-radius:3px}}
