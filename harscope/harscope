const TimingsChart = ({ timings, totalTime }) => {
  const phases = [
    { key: 'blocked', label: 'Blocked', color: TIMING_COLORS.blocked },
    { key: 'dns', label: 'DNS', color: TIMING_COLORS.dns },
    { key: 'connect', label: 'Connect', color: TIMING_COLORS.connect },
    { key: 'ssl', label: 'SSL/TLS', color: TIMING_COLORS.ssl },
    { key: 'send', label: 'Send', color: TIMING_COLORS.send },
    { key: 'wait', label: 'Wait (TTFB)', color: TIMING_COLORS.wait },
    { key: 'receive', label: 'Receive', color: TIMING_COLORS.receive },
  ];
  const total = phases.reduce((s, p) => s + Math.max(0, timings[p.key] || 0), 0);

  return (
    <div className="space-y-3">
      <div className="timing-bar h-6 rounded bg-gray-100 dark:bg-gray-800">
        {phases.map(p => {
          const val = Math.max(0, timings[p.key] || 0);
          if (val === 0) return null;
          return <div key={p.key} className="timing-segment" style={{ backgroundColor: p.color, width: `${(val / total) * 100}%` }} title={`${p.label}: ${formatMs(val)}`} />;
        })}
      </div>
      <div className="space-y-1">
        {phases.map(p => {
          const val = Math.max(0, timings[p.key] || 0);
          return (
            <div key={p.key} className="flex items-center gap-3 text-xs">
              <div className="w-3 h-3 rounded-sm flex-shrink-0" style={{ backgroundColor: p.color }}></div>
              <span className="text-gray-600 dark:text-gray-400 w-24">{p.label}</span>
              <div className="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded overflow-hidden">
                <div className="h-full rounded" style={{ backgroundColor: p.color, width: total > 0 ? `${(val / total) * 100}%` : '0%' }}></div>
              </div>
              <span className="font-mono text-gray-500 dark:text-gray-400 w-20 text-right">{formatMs(val)}</span>
            </div>
          );
        })}
      </div>
      <div className="text-xs text-gray-500 dark:text-gray-400 pt-2 border-t border-gray-200 dark:border-gray-700">
        Total: <span className="font-mono font-medium text-ink dark:text-white">{formatMs(totalTime)}</span>
      </div>
    </div>
  );
};

// --- SecurityView ---
const SecurityView = ({ onInspect }) => {
  const [data, setData] = useState(null);
  const [filterSeverity, setFilterSeverity] = useState('');
  const [filterCategory, setFilterCategory] = useState('');

  const fetchData = useCallback(() => { api('/api/security').then(setData); }, []);
  useEffect(() => { fetchData(); }, []);

  if (!data) return <LoadingSpinner />;

  const categories = [...new Set(data.findings.map(f => f.category))];
  let filtered = data.findings;
  if (filterSeverity) filtered = filtered.filter(f => f.severity === filterSeverity);
  if (filterCategory) filtered = filtered.filter(f => f.category === filterCategory);

  const handleToggle = async (id) => {
    await api('/api/security/toggle', { method: 'POST', body: JSON.stringify({ id }) });
    fetchData();
  };

  return (
    <div className="flex flex-col h-full">
      <div className="px-4 py-3 bg-white/80 dark:bg-card-dark/80 border-b border-gray-200 dark:border-gray-700 flex items-center gap-4">
        <div className="flex gap-3">
          <span className={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium ${severityBg('critical')}`}>
            <Icon name="AlertTriangle" size={12} /> {data.summary.critical} Critical
          </span>
          <span className={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium ${severityBg('warning')}`}>
            <Icon name="AlertCircle" size={12} /> {data.summary.warning} Warning
          </span>
          <span className={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium ${severityBg('info')}`}>
            <Icon name="Info" size={12} /> {data.summary.info} Info
          </span>
        </div>
        <div className="flex gap-2 ml-auto">
          <select value={filterSeverity} onChange={(e) => setFilterSeverity(e.target.value)}
            className="px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-xs dark:text-white">
            <option value="">All severities</option>
            <option value="critical">Critical</option>
            <option value="warning">Warning</option>
            <option value="info">Info</option>
          </select>
          <select value={filterCategory} onChange={(e) => setFilterCategory(e.target.value)}
            className="px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-xs dark:text-white">
            <option value="">All categories</option>
            {categories.map(c => <option key={c} value={c}>{c}</option>)}
          </select>
        </div>
      </div>
      <div className="flex-1 overflow-auto p-4 space-y-2">
        {filtered.length === 0 && <p className="text-gray-400 text-sm text-center py-8">No findings match the current filters</p>}
        {filtered.map(f => (
          <div key={f.id} className={`bg-white dark:bg-card-dark rounded-lg p-3 shadow-sm finding-${f.severity}`}>
            <div className="flex items-start gap-3">
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 mb-1">
                  <span className={`text-xs font-semibold uppercase ${severityColor(f.severity)}`}>{f.severity}</span>
                  <span className="text-xs px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded">{f.category}</span>
                  <button onClick={() => onInspect(f.entryIndex, f.location)} className="text-xs text-blue-600 dark:text-blue-400 hover:underline ml-auto">#{f.entryIndex} &rarr; Inspect</button>
                </div>
                <p className="text-sm text-ink dark:text-gray-200 mb-1">{f.description}</p>
                <p className="font-mono text-xs text-gray-500 dark:text-gray-400 truncate">{f.preview}</p>
              </div>
              <label className="flex items-center gap-1.5 cursor-pointer flex-shrink-0">
                <input type="checkbox" checked={f.redact} onChange={() => handleToggle(f.id)}
                  className="w-4 h-4 rounded border-gray-300 text-red-600 focus:ring-red-500" />
