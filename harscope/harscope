const BodyViewer = ({ body, findings, section }) => {
  const text = body.text || '';
  const mimeType = body.mimeType || '';
  const truncated = body._truncated;
  // Also handle postData.params (form-encoded)
  const params = body.params || [];

  // Extract flagged key names from finding paths for body highlighting
  const bodyFindingInfo = useMemo(() => {
    if (!findings) return { keys: new Set(), count: 0 };
    const bodyFindings = findings.filter(f => {
      const loc = (f.location || '').toLowerCase();
      const isBody = loc.includes('body') || loc.includes('postdata') || loc.includes('content') || loc.includes('(parsed)');
      if (!isBody) return false;
      // Only show findings for the active section (request vs response)
      if (section === 'request') return loc.includes('.request.') || loc.includes('postdata');
      return loc.includes('.response.') || loc.includes('.content');
    });
    const keys = new Set();
    bodyFindings.forEach(f => {
      // Extract key name from path like entries[0].request.postData.text(parsed).prepare_token
      const loc = f.location || '';
      const parts = loc.split('.');
      const last = parts[parts.length - 1].replace(/\x5c[.*\x5c]/, '').replace(/\x5c(parsed\x5c)/, '');
      if (last && last !== 'text' && last !== 'value') keys.add(last.toLowerCase());
      // Also try second-to-last for cases like .fieldName(parsed)
      if (parts.length >= 2) {
        const secondLast = parts[parts.length - 2].replace(/\x5c[.*\x5c]/, '').replace(/\x5c(parsed\x5c)/, '');
        if (secondLast && secondLast !== 'text' && secondLast !== 'value' && secondLast !== 'postData' && secondLast !== 'content')
          keys.add(secondLast.toLowerCase());
      }
    });
    return { keys, count: bodyFindings.length };
  }, [findings, section]);

  if (!text && !params.length) return <p className="text-gray-400 text-sm">No body content</p>;

  // Show form params if present
  if (params.length > 0 && !text) {
    return (
      <div>
        <div className="text-xs text-gray-400 mb-2">Form-encoded parameters</div>
        <ParamTable params={params} findings={findings} />
      </div>
    );
  }

  let display = text;
  let isJson = false;
  if (mimeType.includes('json') || text.trim().startsWith('{') || text.trim().startsWith('[')) {
    try {
      display = JSON.stringify(JSON.parse(text), null, 2);
      isJson = true;
    } catch {}
  }

  // JSON syntax highlighter that also marks flagged key-value pairs
  const syntaxHighlight = (str) => {
    if (!isJson) return str;
    const flaggedKeys = bodyFindingInfo.keys;
    let lastKey = '';
    return str.replace(
      /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\x5cs*:)?|\x5cb(true|false|null)\x5cb|-?\x5cd+(?:\x5c.\x5cd*)?(?:[eE][+-]?\x5cd+)?)/g,
      (match) => {
        if (/^"/.test(match)) {
          if (/:$/.test(match)) {
            // It's a JSON key - extract name and remember it
            lastKey = match.slice(1, match.lastIndexOf('"')).toLowerCase();
            const isFlaggedKey = flaggedKeys.has(lastKey);
            const cls = isFlaggedKey
              ? 'text-red-700 dark:text-red-400 font-semibold'
              : 'text-blue-600 dark:text-blue-400';
            return `<span class="${cls}">${match}</span>`;
          } else {
            // It's a string value - check if the preceding key was flagged
            const isFlaggedVal = flaggedKeys.has(lastKey);
            if (isFlaggedVal) {
              lastKey = '';
              return `<mark class="bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-200 rounded px-0.5">${match}</mark>`;
            }
            lastKey = '';
            return `<span class="text-green-600 dark:text-green-400">${match}</span>`;
          }
        }
        // Non-string value after a flagged key
        if (flaggedKeys.has(lastKey)) {
          const result = `<mark class="bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-200 rounded px-0.5">${match}</mark>`;
          lastKey = '';
          return result;
        }
        lastKey = '';
        if (/true|false/.test(match)) return `<span class="text-purple-600 dark:text-purple-400">${match}</span>`;
        if (/null/.test(match)) return `<span class="text-gray-400">${match}</span>`;
        return `<span class="text-amber-600 dark:text-amber-400">${match}</span>`;
      }
    );
  };

  const processedHtml = isJson ? syntaxHighlight(display) : display.replace(/</g, '&lt;').replace(/>/g, '&gt;');

  return (
    <div>
      {truncated && <div className="mb-2 px-3 py-1.5 bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-300 text-xs rounded">Body truncated to 500KB for display</div>}
      {bodyFindingInfo.count > 0 && (
        <div className="mb-2 px-3 py-1.5 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 text-xs rounded flex items-center gap-2">
          <Icon name="ShieldAlert" size={14} /> {bodyFindingInfo.count} security finding{bodyFindingInfo.count !== 1 ? 's' : ''} in {bodyFindingInfo.keys.size} field{bodyFindingInfo.keys.size !== 1 ? 's' : ''}
        </div>
      )}
      {params.length > 0 && (
        <div className="mb-4">
          <div className="text-xs text-gray-400 mb-2">Form-encoded parameters</div>
          <ParamTable params={params} findings={findings} />
        </div>
      )}
      <pre className="font-mono text-xs leading-relaxed whitespace-pre-wrap break-all bg-gray-50 dark:bg-gray-900/50 rounded-lg p-4 overflow-auto max-h-[60vh]"
        dangerouslySetInnerHTML={{ __html: processedHtml }} />
    </div>
  );
};

// --- WebSocket Viewer ---
const WebSocketViewer = ({ messages, findings }) => {
  const [expanded, setExpanded] = useState({});
  const [filter, setFilter] = useState('');

  const toggle = (i) => setExpanded(prev => ({ ...prev, [i]: !prev[i] }));

  const filtered = filter
    ? messages.filter((m, i) => {
        const d = (m.data || '').toLowerCase();
        return d.includes(filter.toLowerCase());
      })
    : messages;

  // Check if a WS message index has findings
  const msgHasFinding = (msgIdx) => {
    return findings.some(f => f.location.includes(`_webSocketMessages[${msgIdx}]`));
  };

  const formatWsData = (data) => {
    try {
      return JSON.stringify(JSON.parse(data), null, 2);
    } catch {
      return data;
    }
  };

  return (
    <div>
      <div className="flex items-center gap-3 mb-3">
        <span className="text-xs text-gray-500 dark:text-gray-400">{messages.length} messages</span>
        <input value={filter} onChange={(e) => setFilter(e.target.value)}
          placeholder="Filter messages..."
          className="px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-xs dark:text-white flex-1 max-w-xs focus:outline-none focus:ring-1 focus:ring-blue-500" />
      </div>
      <div className="space-y-1">
        {filtered.map((msg, i) => {
          const realIdx = messages.indexOf(msg);
          const isSend = msg.type === 'send';
          const hasFinding = msgHasFinding(realIdx);
          const isOpen = expanded[realIdx];

          return (
            <div key={realIdx} className={`rounded border ${hasFinding ? 'border-red-300 dark:border-red-700 bg-red-50/50 dark:bg-red-900/10' : 'border-gray-200 dark:border-gray-700'}`}>
              <button onClick={() => toggle(realIdx)}
                className="w-full flex items-center gap-2 px-3 py-1.5 text-xs text-left hover:bg-gray-50 dark:hover:bg-gray-800/50">
                <span className={`font-mono font-medium ${isSend ? 'text-blue-600 dark:text-blue-400' : 'text-green-600 dark:text-green-400'}`}>
                  {isSend ? '\u2191 SEND' : '\u2193 RECV'}
                </span>
                <span className="text-gray-400 font-mono text-[10px]">#{realIdx}</span>
                {hasFinding && <FlagBadge />}
                <span className="text-gray-400 text-[10px] ml-auto">{msg.time ? new Date(msg.time * 1000).toISOString().substr(11, 12) : ''}</span>
                <span className="text-gray-400 font-mono text-[10px] max-w-[300px] truncate">{(msg.data || '').slice(0, 80)}</span>
                <Icon name={isOpen ? 'ChevronDown' : 'ChevronRight'} size={12} className="text-gray-400 flex-shrink-0" />
              </button>
              {isOpen && (
                <pre className={`px-3 py-2 text-xs font-mono whitespace-pre-wrap break-all border-t ${hasFinding ? 'border-red-200 dark:border-red-800' : 'border-gray-200 dark:border-gray-700'} bg-gray-50 dark:bg-gray-900/50 max-h-[40vh] overflow-auto`}>
                  {formatWsData(msg.data || '')}
                </pre>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
};

