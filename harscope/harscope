class OpenRequest(BaseModel):
    path: str

@app.post("/api/open")
async def api_open(req: OpenRequest):
    path = req.path.strip()
    if not path:
        raise HTTPException(status_code=400, detail="Path is required")
    resolved = os.path.realpath(path)
    if not resolved.lower().endswith('.har'):
        raise HTTPException(status_code=400, detail="Only .har files are supported")
    if not os.path.isfile(resolved):
        raise HTTPException(status_code=400, detail=f"File not found: {resolved}")
    # Reject symlinks that resolve outside the original file's directory (path traversal guard)
    if os.path.islink(path):
        orig_dir = os.path.realpath(os.path.dirname(path))
        if not resolved.startswith(orig_dir + os.sep) and os.path.dirname(resolved) != orig_dir:
            raise HTTPException(status_code=403, detail="Symlinks pointing outside the file's directory are not allowed")
    try:
        har_manager.load_file(resolved)
        security_scanner.scan(har_manager)
        return {'ok': True, 'entryCount': len(har_manager.entries)}
    except json.JSONDecodeError as e:
        raise HTTPException(status_code=422, detail=f"Invalid HAR JSON: {e}")
    except Exception as e:
        raise HTTPException(status_code=400, detail=str(e))


class ContentRequest(BaseModel):
    content: str
    filename: str

@app.post("/api/open-content")
async def api_open_content(req: ContentRequest):
    if len(req.content) > MAX_HAR_BYTES:
        raise HTTPException(status_code=413, detail=f"Content exceeds {MAX_HAR_BYTES // (1024*1024)} MB limit")
    try:
        har_manager.from_content(req.content, req.filename)
        security_scanner.scan(har_manager)
        return {'ok': True, 'entryCount': len(har_manager.entries)}
    except Exception as e:
        raise HTTPException(status_code=400, detail=str(e))


@app.post("/api/upload")
async def api_upload(file: UploadFile = File(...)):
    try:
        content = await file.read(MAX_HAR_BYTES + 1)
        if len(content) > MAX_HAR_BYTES:
            raise HTTPException(status_code=413, detail=f"File exceeds {MAX_HAR_BYTES // (1024*1024)} MB limit")
        try:
            text = content.decode('utf-8')
        except UnicodeDecodeError:
            raise HTTPException(status_code=400, detail="File is not valid UTF-8")
        har_manager.from_content(text, file.filename or 'upload.har')
        security_scanner.scan(har_manager)
        return {'ok': True, 'entryCount': len(har_manager.entries)}
    except HTTPException:
        raise
