BOOTSTRAP_STATE_FILENAME = "bootstrap_state.json"
BOOTSTRAP_VERSION = 1
DEPENDENCIES = ["fastapi", "uvicorn", "python-multipart"]


@dataclass(frozen=True)
class RuntimePaths:
    home: Path
    venv: Path
    venv_python: Path
    bootstrap_state: Path


def build_runtime_paths():
    override = os.environ.get("HARSCOPE_HOME")
    home = Path(override).expanduser() if override else Path.home() / ".harscope"
    return RuntimePaths(
        home=home,
        venv=home / "venv",
        venv_python=home / "venv" / "bin" / "python",
        bootstrap_state=home / BOOTSTRAP_STATE_FILENAME,
    )


def parse_args():
    parser = argparse.ArgumentParser(
        description="harscope: HAR File Analyzer & Sanitizer",
        epilog="Launches a local web server and opens the browser interface."
    )
    parser.add_argument(
        "file_path",
        nargs="?",
        default=None,
        help="Path to the HAR file to open (optional; opens welcome screen if omitted)."
    )
    parser.add_argument(
        "--port", "-p",
        type=int,
        default=8200,
        help="Port to run the server on (default: 8200)."
    )
    parser.add_argument(
        "--validate",
        metavar="SANITIZED_HAR",
        help="Validate a sanitized HAR file against an EDL. Requires --edl."
    )
    parser.add_argument(
        "--edl",
        metavar="EDL_JSON",
        help="Path to the .edl.json file for validation."
    )
    parser.add_argument(
        "--format", "-f",
        choices=["text", "json"],
        default="text",
        help="Output format for --validate results (default: text)."
    )
    return parser.parse_args()


def bootstrap_needed(argv):
    return not any(arg in {"-h", "--help"} for arg in argv)


def desired_bootstrap_state():
    return {
        "bootstrap_version": BOOTSTRAP_VERSION,
        "python_version": f"{sys.version_info.major}.{sys.version_info.minor}",
    }


def read_bootstrap_state(paths):
    if not paths.bootstrap_state.is_file():
        return None
    try:
        data = json.loads(paths.bootstrap_state.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return None
    return data if isinstance(data, dict) else None


def write_bootstrap_state(paths):
    paths.bootstrap_state.write_text(
        json.dumps(desired_bootstrap_state(), indent=2) + "\n",
        encoding="utf-8",
    )


def ensure_runtime_home(paths):
    paths.home.mkdir(parents=True, exist_ok=True)


def install_runtime_dependencies(paths):
    subprocess.check_call(
        [str(paths.venv_python), "-m", "pip", "install", "--upgrade", "pip"]
    )
    subprocess.check_call(
        [str(paths.venv_python), "-m", "pip", "install", *DEPENDENCIES]
    )


def ensure_private_venv(paths):
    ensure_runtime_home(paths)
    in_target_venv = Path(sys.prefix).resolve() == paths.venv.resolve()
    bootstrap_state = read_bootstrap_state(paths)
    needs_refresh = (
        not paths.venv_python.exists()
        or bootstrap_state != desired_bootstrap_state()
    )

    if not in_target_venv:
        if needs_refresh:
            if paths.venv.exists():
                shutil.rmtree(paths.venv)
            sys.stderr.write(
                f"[harscope] Preparing private runtime at {paths.venv}\n"
            )
            venv.EnvBuilder(with_pip=True).create(paths.venv)
            install_runtime_dependencies(paths)
            write_bootstrap_state(paths)
        os.execv(
            str(paths.venv_python),
            [str(paths.venv_python), str(Path(__file__).resolve()), *sys.argv[1:]],
        )

    if needs_refresh:
        install_runtime_dependencies(paths)
        write_bootstrap_state(paths)


if __name__ == "__main__":
    _runtime_paths = build_runtime_paths()
    if bootstrap_needed(sys.argv[1:]):
        ensure_private_venv(_runtime_paths)
    else:
        parse_args()

