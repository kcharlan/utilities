// Build inline checkbox + badge HTML for a given redaction state
const redactPrefixHtml = (state, location, keyRaw, inherited) => {
  const loc = location.replace(/"/g, '&quot;');
  if (inherited) {
    let cbColor = state === 'auto-on' ? 'cb-red' : state === 'manual' ? 'cb-amber' : 'cb-none';
    return `<span class="inline-flex items-center gap-1 mr-1 align-middle opacity-60"><input type="checkbox" readonly class="redact-cb ${cbColor} pointer-events-none" tabindex="-1"/></span>`;
  }
  if (!state) {
    return `<span class="inline-flex items-center gap-1 mr-1 align-middle" data-redact-location="${loc}" style="cursor:pointer"><input type="checkbox" checked readonly class="redact-cb cb-none pointer-events-none" tabindex="-1"/></span>`;
  }
  const checked = state === 'auto-off' ? ' checked' : '';
  let cbColor = 'cb-amber';
  let badgeClass = 'bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400';
  let badgeLabel = 'MANUAL';
  if (state === 'auto-on') { cbColor = 'cb-red'; badgeClass = 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400'; badgeLabel = 'FLAGGED'; }
  else if (state === 'auto-off') { cbColor = 'cb-teal'; badgeClass = 'bg-teal-100 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400'; badgeLabel = 'KEPT'; }
  return `<span class="inline-flex items-center gap-1 mr-1 align-middle" data-redact-location="${loc}" style="cursor:pointer"><input type="checkbox"${checked} readonly class="redact-cb ${cbColor} pointer-events-none" tabindex="-1"/><span class="inline-flex px-1 py-0 rounded text-[9px] font-semibold ${badgeClass}">${badgeLabel}</span></span>`;
};

// Build redaction info map from findings + manual redactions + parent propagation
const buildRedactionInfo = (findings, redactionMap, entryIndex, containerKey, text, sectionFilter) => {
  const keyStates = {};
  if (findings) {
    findings.filter(f => sectionFilter(f)).forEach(f => {
      const loc = f.location || '';
      const parts = loc.split('.');
      const last = parts[parts.length - 1].replace(/\x5b.*\x5d/, '').replace(/\x28parsed\x29/, '');
      if (last && last !== 'text' && last !== 'value' && last !== 'data') {
        const rKey = `${f.entryIndex}|${loc}`;
        const rm = redactionMap?.[rKey];
        const parsedIdx = loc.indexOf('(parsed).');
        const jsonPath = parsedIdx >= 0
          ? loc.slice(parsedIdx + 9).replace('(base64)', '').toLowerCase()
          : last.toLowerCase();
        keyStates[jsonPath] = { state: rm?.state || (f.redact ? 'auto-on' : 'auto-off'), location: loc, keyName: last };
      }
    });
  }
  if (redactionMap) {
    const prefix = `${entryIndex}|entries[${entryIndex}].${containerKey}.`;
    Object.keys(redactionMap).forEach(rKey => {
      if (!rKey.startsWith(prefix)) return;
      const rm = redactionMap[rKey];
      if (rm.state !== 'manual') return;
      const location = rKey.substring(rKey.indexOf('|') + 1);
      const parts = location.split('.');
      const last = parts[parts.length - 1];
      const parsedIdx = location.indexOf('(parsed).');
      const jsonPath = parsedIdx >= 0
        ? location.slice(parsedIdx + 9).replace('(base64)', '').toLowerCase()
        : last.toLowerCase();
      if (jsonPath && !keyStates[jsonPath]) {
        keyStates[jsonPath] = { state: 'manual', location, keyName: last };
      }
    });
  }
  // Propagate parent redaction to child keys
  try {
    const parsed = JSON.parse(text);
    const walkForPropagation = (obj, currentPath) => {
      if (!obj || typeof obj !== 'object') return;
      const entries = Array.isArray(obj)
        ? obj.map((v, i) => [String(i), v])
        : Object.entries(obj);
      for (const [k, v] of entries) {
        const keyPath = Array.isArray(obj)
          ? currentPath
          : (currentPath ? currentPath + '.' + k : k).toLowerCase();
        const info = keyStates[keyPath];
        if (info && (info.state === 'auto-on' || info.state === 'manual')
            && !info.inherited && v && typeof v === 'object') {
          const propagate = (child, parentPath, parentState) => {
            if (!child || typeof child !== 'object') return;
            const ce = Array.isArray(child) ? child.map((cv, ci) => [String(ci), cv]) : Object.entries(child);
            for (const [ck, cv] of ce) {
              const cp = Array.isArray(child) ? parentPath : (parentPath ? parentPath + '.' + ck : ck).toLowerCase();
              if (!Array.isArray(child) && !keyStates[cp]) {
                keyStates[cp] = { state: parentState, location: '', keyName: ck, inherited: true };
              }
              if (cv && typeof cv === 'object') propagate(cv, cp, parentState);
            }
          };
          propagate(v, keyPath, info.state);
        } else if (v && typeof v === 'object') {
          walkForPropagation(v, keyPath);
        }
      }
    };
    walkForPropagation(parsed, '');
  } catch {}
  return keyStates;
};

// JSON syntax highlighter with redaction-aware coloring
const highlightJsonWithRedaction = (str, redactionInfo, onToggleRedaction, entryIndex, locationPrefix) => {
  let pathStack = [];
  let lastPath = '';
  let prevEnd = 0;
  return str.replace(
    /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\x5cs*:)?|\x5cb(true|false|null)\x5cb|-?\x5cd+(?:\x5c.\x5cd*)?(?:[eE][+-]?\x5cd+)?)/g,
    (match, _g1, _g2, _g3, _g4, offset) => {
      for (let gi = prevEnd; gi < offset; gi++) {
        const gc = str[gi];
        if (gc === '{' || gc === '[') pathStack.push(null);
        else if (gc === '}' || gc === ']') pathStack.pop();
      }
      prevEnd = offset + match.length;

      if (/^"/.test(match)) {
        if (/:$/.test(match)) {
          const lastKeyRaw = match.slice(1, match.lastIndexOf('"'));
          pathStack[pathStack.length - 1] = lastKeyRaw;
          const currentPath = pathStack.filter(x => x !== null).join('.').toLowerCase();
          lastPath = currentPath;
          const info = redactionInfo[currentPath];
          const state = info?.state;
          const inherited = !!info?.inherited;
          let cls = 'text-blue-600 dark:text-blue-400';
          if (state === 'auto-on') cls = 'text-red-700 dark:text-red-400 font-semibold';
          else if (state === 'auto-off') cls = 'text-teal-700 dark:text-teal-400 font-semibold';
          else if (state === 'manual') cls = 'text-amber-700 dark:text-amber-400 font-semibold';
          if (inherited) cls += ' opacity-60';
          const rawPath = pathStack.filter(x => x !== null).join('.');
          const location = info?.location || `entries[${entryIndex}].${locationPrefix}.${rawPath}`;
          const prefix = onToggleRedaction ? redactPrefixHtml(state, location, lastKeyRaw, inherited) : '';
          if (inherited) {
            return `${prefix}<span class="${cls}">${match}</span>`;
          }
          return `${prefix}<span class="${cls}" data-redact-location="${location.replace(/"/g, '&quot;')}">${match}</span>`;
        } else {
          const info = redactionInfo[lastPath];
          const state = info?.state;
          let result;
          if (state === 'auto-on') result = `<mark class="bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-200 rounded px-0.5">${match}</mark>`;
          else if (state === 'auto-off') result = `<mark class="bg-teal-100 dark:bg-teal-900/30 text-teal-800 dark:text-teal-200 rounded px-0.5">${match}</mark>`;
          else if (state === 'manual') result = `<mark class="bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-200 rounded px-0.5">${match}</mark>`;
          else result = `<span class="text-green-600 dark:text-green-400">${match}</span>`;
          lastPath = '';
          return result;
        }
      }
      if (redactionInfo[lastPath]?.state) {
        const state = redactionInfo[lastPath].state;
        let markClass = 'bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-200';
        if (state === 'auto-off') markClass = 'bg-teal-100 dark:bg-teal-900/30 text-teal-800 dark:text-teal-200';
        else if (state === 'manual') markClass = 'bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-200';
        const result = `<mark class="${markClass} rounded px-0.5">${match}</mark>`;
        lastPath = '';
        return result;
      }
      lastPath = '';
      if (/true|false/.test(match)) return `<span class="text-purple-600 dark:text-purple-400">${match}</span>`;
      if (/null/.test(match)) return `<span class="text-gray-400">${match}</span>`;
      return `<span class="text-amber-600 dark:text-amber-400">${match}</span>`;
    }
  );
};

const BodyViewer = ({ body, findings, section, entryIndex, redactionMap, onToggleRedaction }) => {
  const text = body.text || '';
  const mimeType = body.mimeType || '';
  const truncated = body._truncated;
  const params = body.params || [];

  // Build body key for locations
  const bodyKey = section === 'request' ? 'request.postData' : 'response.content';

  // Extract flagged/redacted key info from findings + redactionMap (including manual)
  const bodyRedactionInfo = useMemo(() => {
    const sectionFilter = (f) => {
      const loc = (f.location || '').toLowerCase();
      const isBody = loc.includes('body') || loc.includes('postdata') || loc.includes('content') || loc.includes('(parsed)');
      if (!isBody) return false;
      if (section === 'request') return loc.includes('.request.') || loc.includes('postdata');
      return loc.includes('.response.') || loc.includes('.content');
    };
    return buildRedactionInfo(findings, redactionMap, entryIndex, `${bodyKey}.text(parsed)`, text, sectionFilter);
  }, [findings, section, redactionMap, entryIndex, bodyKey, text]);

  const bodyFindingCount = useMemo(() => {
    if (!findings) return 0;
    return findings.filter(f => {
      const loc = (f.location || '').toLowerCase();
      const isBody = loc.includes('body') || loc.includes('postdata') || loc.includes('content') || loc.includes('(parsed)');
      if (!isBody) return false;
      if (section === 'request') return loc.includes('.request.') || loc.includes('postdata');
      return loc.includes('.response.') || loc.includes('.content');
    }).length;
  }, [findings, section]);

  if (!text && !params.length) return <p className="text-gray-400 text-sm">No body content</p>;

  if (params.length > 0 && !text) {
    return (
      <div>
        <div className="text-xs text-gray-400 mb-2">Form-encoded parameters</div>
        <ParamTable params={params} findings={findings} entryIndex={entryIndex} redactionMap={redactionMap} onToggleRedaction={onToggleRedaction} />
      </div>
    );
  }

  let display = text;
  let isJson = false;
  if (mimeType.includes('json') || text.trim().startsWith('{') || text.trim().startsWith('[')) {
    try {
      display = JSON.stringify(JSON.parse(text), null, 2);
      isJson = true;
    } catch {}
  }

  const processedHtml = isJson ? highlightJsonWithRedaction(display, bodyRedactionInfo, onToggleRedaction, entryIndex, `${bodyKey}.text(parsed)`) : display.replace(/</g, '&lt;').replace(/>/g, '&gt;');

  // Click handler for JSON body keys
  const handleBodyClick = useCallback((e) => {
    if (!onToggleRedaction || !isJson) return;
    const el = e.target.closest('[data-redact-location]');
    if (!el) return;
    const location = el.getAttribute('data-redact-location');
    let val = '';
    try {
      const parsed = JSON.parse(text);
      const parsedIdx = location.indexOf('(parsed).');
      if (parsedIdx >= 0) {
        const pathStr = location.slice(parsedIdx + 9).replace('(base64)', '');
        const keys = pathStr.split('.').filter(Boolean);
        let current = parsed;
        for (const k of keys) {
          if (current && typeof current === 'object' && !Array.isArray(current)) {
            current = current[k];
          } else { current = undefined; break; }
        }
        if (current !== undefined) {
          val = typeof current === 'string' ? current : JSON.stringify(current);
        }
      }
    } catch {}
    onToggleRedaction(entryIndex, location, val);
  }, [onToggleRedaction, entryIndex, text, isJson]);

  // For non-JSON, provide a single toggle for entire body
  const handleNonJsonToggle = useCallback(() => {
    if (!onToggleRedaction) return;
    const location = `entries[${entryIndex}].${bodyKey}.text`;
    onToggleRedaction(entryIndex, location, text);
  }, [onToggleRedaction, entryIndex, bodyKey, text]);

  const nonJsonLocation = `entries[${entryIndex}].${bodyKey}.text`;
  const nonJsonRKey = `${entryIndex}|${nonJsonLocation}`;
  const nonJsonState = !isJson && redactionMap?.[nonJsonRKey]?.state || null;

  return (
    <div>
      {truncated && <div className="mb-2 px-3 py-1.5 bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-300 text-xs rounded">Body truncated to 500KB for display</div>}
      {bodyFindingCount > 0 && (
        <div className="mb-2 px-3 py-1.5 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 text-xs rounded flex items-center gap-2">
          <Icon name="ShieldAlert" size={14} /> {bodyFindingCount} security finding{bodyFindingCount !== 1 ? 's' : ''} detected
        </div>
      )}
      {isJson && onToggleRedaction && (
        <div className="mb-2 px-3 py-1.5 bg-gray-50 dark:bg-gray-800/50 text-gray-500 dark:text-gray-400 text-[11px] rounded flex items-center gap-2">
          <Icon name="MousePointerClick" size={12} /> Click any <span className="font-mono font-medium">"key":</span> name to toggle redaction
        </div>
      )}
      {!isJson && onToggleRedaction && text && (
        <div className="mb-2 flex items-center gap-2">
          <button onClick={handleNonJsonToggle}
            className={`flex items-center gap-1.5 px-2 py-1 text-xs rounded border ${nonJsonState === 'auto-on' || nonJsonState === 'manual' ? 'border-red-300 bg-red-50 text-red-700 dark:border-red-700 dark:bg-red-900/20 dark:text-red-300' : nonJsonState === 'auto-off' ? 'border-teal-300 bg-teal-50 text-teal-700 dark:border-teal-700 dark:bg-teal-900/20 dark:text-teal-300' : 'border-gray-300 bg-white text-gray-600 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300'} hover:opacity-80`}>
            <input type="checkbox" checked={nonJsonState === 'auto-off' || nonJsonState === null} readOnly className={`redact-cb ${nonJsonState === 'auto-on' ? 'cb-red' : nonJsonState === 'manual' ? 'cb-amber' : nonJsonState === 'auto-off' ? 'cb-teal' : 'cb-none'}`} tabIndex={-1} />
            {nonJsonState ? 'Toggle body redaction' : 'Redact body'}
            {nonJsonState && <RedactionBadge state={nonJsonState} />}
          </button>
        </div>
      )}
      {params.length > 0 && (
        <div className="mb-4">
          <div className="text-xs text-gray-400 mb-2">Form-encoded parameters</div>
          <ParamTable params={params} findings={findings} entryIndex={entryIndex} redactionMap={redactionMap} onToggleRedaction={onToggleRedaction} />
        </div>
      )}
      <pre className={`font-mono text-xs leading-relaxed whitespace-pre-wrap break-all bg-gray-50 dark:bg-gray-900/50 rounded-lg p-4 overflow-auto max-h-[60vh] ${isJson && onToggleRedaction ? 'cursor-pointer' : ''}`}
        onClick={isJson ? handleBodyClick : undefined}
        dangerouslySetInnerHTML={{ __html: processedHtml }} />
    </div>
  );
};

// --- WebSocket Viewer ---
const WebSocketViewer = ({ messages, findings, entryIndex, redactionMap, onToggleRedaction }) => {
  const [expanded, setExpanded] = useState({});
  const [filter, setFilter] = useState('');

  const toggleExpand = (i) => setExpanded(prev => ({ ...prev, [i]: !prev[i] }));

  const filtered = filter
    ? messages.filter((m, i) => {
        const d = (m.data || '').toLowerCase();
        return d.includes(filter.toLowerCase());
      })
    : messages;

  // Get findings for a specific WS message index
  const msgFindings = useCallback((msgIdx) => {
    return findings.filter(f => f.location.includes(`_webSocketMessages[${msgIdx}]`));
  }, [findings]);

  // Get the redaction state for a WS message's data field
  const getMsgRedactionState = useCallback((msgIdx) => {
    const location = `entries[${entryIndex}]._webSocketMessages[${msgIdx}].data`;
    const rKey = `${entryIndex}|${location}`;
    return { state: redactionMap?.[rKey]?.state || null, location };
  }, [entryIndex, redactionMap]);

  // Get redaction info for keys within a JSON WS message body (keyed by dotted path)
  const getMsgBodyRedactionInfo = useCallback((msgIdx, data) => {
    const mf = msgFindings(msgIdx);
    const sectionFilter = (f) => mf.includes(f);
    const containerKey = `_webSocketMessages[${msgIdx}].data(parsed)`;
    return buildRedactionInfo(mf, redactionMap, entryIndex, containerKey, data, sectionFilter);
  }, [msgFindings, entryIndex, redactionMap]);

  const handleToggleMsg = useCallback((e, msgIdx, data) => {
    e.stopPropagation();
    if (!onToggleRedaction) return;
    const location = `entries[${entryIndex}]._webSocketMessages[${msgIdx}].data`;
    onToggleRedaction(entryIndex, location, data || '');
  }, [onToggleRedaction, entryIndex]);

  // Click handler for JSON keys within expanded WS message
  const handleWsBodyClick = useCallback((e, msgIdx, data) => {
    if (!onToggleRedaction) return;
    const el = e.target.closest('[data-redact-location]');
    if (!el) return;
    const location = el.getAttribute('data-redact-location');
    let val = '';
    try {
      const parsed = JSON.parse(data);
      const parsedIdx = location.indexOf('(parsed).');
      if (parsedIdx >= 0) {
        const pathStr = location.slice(parsedIdx + 9).replace('(base64)', '');
        const keys = pathStr.split('.').filter(Boolean);
        let current = parsed;
        for (const k of keys) {
          if (current && typeof current === 'object' && !Array.isArray(current)) {
            current = current[k];
          } else { current = undefined; break; }
        }
        if (current !== undefined) {
          val = typeof current === 'string' ? current : JSON.stringify(current);
        }
      }
    } catch {}
    onToggleRedaction(entryIndex, location, val);
  }, [onToggleRedaction, entryIndex]);

  // Syntax highlight WS JSON body with redaction awareness
  const highlightWsJson = useCallback((data, msgIdx) => {
    let formatted;
    let isJson = false;
    try {
      formatted = JSON.stringify(JSON.parse(data), null, 2);
      isJson = true;
    } catch {
      formatted = data;
    }
    if (!isJson) return { html: formatted.replace(/</g, '&lt;').replace(/>/g, '&gt;'), isJson: false };

    const bodyInfo = getMsgBodyRedactionInfo(msgIdx, data);
    const locationPrefix = `_webSocketMessages[${msgIdx}].data(parsed)`;
    const html = highlightJsonWithRedaction(formatted, bodyInfo, onToggleRedaction, entryIndex, locationPrefix);
    return { html, isJson: true };
  }, [getMsgBodyRedactionInfo, entryIndex, onToggleRedaction]);

  return (
    <div>
      <div className="flex items-center gap-3 mb-3">
        <span className="text-xs text-gray-500 dark:text-gray-400">{messages.length} messages</span>
        <input value={filter} onChange={(e) => setFilter(e.target.value)}
          placeholder="Filter messages..."
          className="px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-xs dark:text-white flex-1 max-w-xs focus:outline-none focus:ring-1 focus:ring-blue-500" />
      </div>
      <div className="space-y-1">
        {filtered.map((msg, i) => {
          const realIdx = messages.indexOf(msg);
          const isSend = msg.type === 'send';
          const mFindings = msgFindings(realIdx);
          const hasFinding = mFindings.length > 0;
          const isOpen = expanded[realIdx];
          const msgData = msg.data || '';
          const { state: msgState, location: msgLocation } = getMsgRedactionState(realIdx);
          const rowClass = msgState === 'auto-on' ? 'redact-auto-on' : msgState === 'auto-off' ? 'redact-auto-off' : msgState === 'manual' ? 'redact-manual' : '';
          const borderClass = hasFinding && !msgState ? 'border-red-300 dark:border-red-700 bg-red-50/50 dark:bg-red-900/10' : msgState ? '' : 'border-gray-200 dark:border-gray-700';

          return (
            <div key={realIdx} className={`rounded border ${borderClass} ${rowClass}`}>
              <div className="flex items-center gap-2 px-3 py-1.5 text-xs">
                {onToggleRedaction && (
                  <input type="checkbox"
                    checked={msgState === 'auto-off' || msgState === null}
                    onChange={(e) => handleToggleMsg(e, realIdx, msgData)}
                    className={`redact-cb redact-checkbox ${msgState === 'auto-on' ? 'cb-red' : msgState === 'manual' ? 'cb-amber' : msgState === 'auto-off' ? 'cb-teal' : 'cb-none'}`} />
                )}
                <button onClick={() => toggleExpand(realIdx)}
                  className="flex items-center gap-2 flex-1 text-left hover:opacity-80 min-w-0">
                  <span className={`font-mono font-medium ${isSend ? 'text-blue-600 dark:text-blue-400' : 'text-green-600 dark:text-green-400'}`}>
                    {isSend ? '\u2191 SEND' : '\u2193 RECV'}
                  </span>
                  <span className="text-gray-400 font-mono text-[10px]">#{realIdx}</span>
                  {msgState ? <RedactionBadge state={msgState} /> : hasFinding ? <FlagBadge /> : null}
                  <span className="text-gray-400 text-[10px] ml-auto">{msg.time ? new Date(msg.time * 1000).toISOString().substr(11, 12) : ''}</span>
                  <span className="text-gray-400 font-mono text-[10px] max-w-[300px] truncate">{msgData.slice(0, 80)}</span>
                  <Icon name={isOpen ? 'ChevronDown' : 'ChevronRight'} size={12} className="text-gray-400 flex-shrink-0" />
                </button>
              </div>
              {isOpen && (() => {
                const { html, isJson } = highlightWsJson(msgData, realIdx);
                return (
                  <div>
                    {isJson && onToggleRedaction && (
                      <div className="px-3 py-1 border-t border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-900/30 text-[10px] text-gray-400 flex items-center gap-1">
                        <Icon name="MousePointerClick" size={10} /> Click key names to toggle redaction
                      </div>
                    )}
                    <pre className={`px-3 py-2 text-xs font-mono whitespace-pre-wrap break-all border-t ${hasFinding ? 'border-red-200 dark:border-red-800' : 'border-gray-200 dark:border-gray-700'} bg-gray-50 dark:bg-gray-900/50 max-h-[40vh] overflow-auto ${isJson && onToggleRedaction ? 'cursor-pointer' : ''}`}
                      onClick={isJson ? (e) => handleWsBodyClick(e, realIdx, msgData) : undefined}
                      dangerouslySetInnerHTML={{ __html: html }} />
                  </div>
                );
              })()}
            </div>
          );
        })}
      </div>
    </div>
  );
};

