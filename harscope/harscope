const SequenceMinimap = ({ layout, pan, zoom, canvasSize, onNavigate, isDark }) => {
  const { totalWidth, totalHeight, lifelinePositions, arrowPositions } = layout;
  if (totalWidth === 0 || totalHeight === 0) return null;

  const mmWidth = 180;
  const mmHeight = 100;
  const scaleX = mmWidth / totalWidth;
  const scaleY = mmHeight / totalHeight;
  const scale = Math.min(scaleX, scaleY);

  // Viewport rectangle in minimap coordinates
  const vpX = (-pan.x / zoom) * scale;
  const vpY = (-pan.y / zoom) * scale;
  const vpW = (canvasSize.width / zoom) * scale;
  const vpH = (canvasSize.height / zoom) * scale;

  const handleClick = (e) => {
    const rect = e.currentTarget.getBoundingClientRect();
    const clickX = e.clientX - rect.left;
    const clickY = e.clientY - rect.top;
    // Convert minimap click to content coordinates, then to pan
    const contentX = clickX / scale;
    const contentY = clickY / scale;
    onNavigate({
      x: -(contentX - canvasSize.width / zoom / 2) * zoom,
      y: -(contentY - canvasSize.height / zoom / 2) * zoom,
    });
  };

  return (
    <div className="seq-minimap" onClick={handleClick}>
      <svg width={mmWidth} height={mmHeight}>
        {/* Lifelines */}
        {lifelinePositions.map((ll, i) => (
          <line key={i} x1={ll.x * scale} y1={ll.y1 * scale} x2={ll.x * scale} y2={ll.y2 * scale}
            stroke={isDark ? '#4b5563' : '#d1d5db'} strokeWidth={0.5} />
        ))}
        {/* Arrows as tiny marks */}
        {arrowPositions.map((a, i) => (
          <line key={i} x1={a.x1 * scale} y1={a.y * scale} x2={a.x2 * scale} y2={a.y * scale}
            stroke={a.type === 'response' ? (a.status >= 400 ? '#ef4444' : '#9ca3af') : '#3b82f6'}
            strokeWidth={0.5} />
        ))}
        {/* Viewport indicator */}
        <rect x={vpX} y={vpY} width={vpW} height={vpH}
          fill="rgba(59,130,246,0.08)" stroke="#3b82f6" strokeWidth={1} rx={2} />
      </svg>
    </div>
  );
};

// --- SequenceView ---
const SequenceView = ({ onInspect, isDark }) => {
  const [data, setData] = useState(null);
  const [flows, setFlows] = useState([]);
  const [filters, setFilters] = useState({});
  const [showResponses, setShowResponses] = useState(true);
  const [domains, setDomains] = useState([]);
  const [offset, setOffset] = useState(0);
  const limit = 100;

  const [pan, setPan] = useState({ x: 40, y: 40 });
  const [zoom, setZoom] = useState(1);
  const [isPanning, setIsPanning] = useState(false);
  const [hoveredIndex, setHoveredIndex] = useState(null);
  const [zoomInput, setZoomInput] = useState(null);
  const panStart = useRef({ x: 0, y: 0, panX: 0, panY: 0 });
  const canvasRef = useRef(null);
  const [canvasSize, setCanvasSize] = useState({ width: 800, height: 600 });

  // Compute layout before hooks that reference it (avoids temporal dead zone)
  const layout = useMemo(() => {
    if (!data) return null;
    const msgs = showResponses ? data.messages : data.messages.filter(m => m.type === 'request');
    const pageMsgs = msgs.slice(offset, offset + limit);
    return computeSequenceLayout(data.participants, pageMsgs);
  }, [data, showResponses, offset, limit]);

  useEffect(() => {
    api('/api/domains').then(setDomains);
    api('/api/sequence/flows').then(setFlows);
  }, []);

  useEffect(() => {
    const params = new URLSearchParams();
    if (filters.domain) params.set('domain', filters.domain);
    if (filters.flow) params.set('flow', filters.flow);
    api(`/api/sequence?${params}`).then(setData);
  }, [filters]);

  // Track canvas size
  useEffect(() => {
    const el = canvasRef.current;
    if (!el) return;
    const ro = new ResizeObserver(entries => {
      for (const entry of entries) {
        setCanvasSize({ width: entry.contentRect.width, height: entry.contentRect.height });
      }
    });
    ro.observe(el);
    return () => ro.disconnect();
  }, []);

  const handleWheel = useCallback((e) => {
    if (!canvasRef.current) return;
    if (e.ctrlKey || e.metaKey) {
      e.preventDefault();
      const rect = canvasRef.current.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;
      setZoom(prev => {
        const next = Math.max(0.2, Math.min(3, prev * (1 - e.deltaY * 0.002)));
        const ratio = next / prev;
        setPan(p => ({
          x: mx - ratio * (mx - p.x),
          y: my - ratio * (my - p.y),
        }));
        return next;
      });
    } else {
      setPan(p => ({ x: p.x - e.deltaX, y: p.y - e.deltaY }));
    }
  }, []);

  const handleMouseDown = useCallback((e) => {
    if (e.button !== 0) return;
    setIsPanning(true);
    panStart.current = { x: e.clientX, y: e.clientY, panX: pan.x, panY: pan.y };
  }, [pan]);

  const handleMouseMove = useCallback((e) => {
    if (!isPanning) return;
    setPan({
      x: panStart.current.panX + (e.clientX - panStart.current.x),
      y: panStart.current.panY + (e.clientY - panStart.current.y),
    });
  }, [isPanning]);

  const handleMouseUp = useCallback(() => {
    setIsPanning(false);
  }, []);

  const handleKeyDown = useCallback((e) => {
    const PAN_STEP = 40;
    switch (e.key) {
      case '+': case '=':
        e.preventDefault();
        setZoom(z => Math.min(3, z * 1.15));
        break;
      case '-':
        e.preventDefault();
        setZoom(z => Math.max(0.2, z / 1.15));
        break;
      case '0':
        e.preventDefault();
        setPan({ x: 40, y: 40 });
        setZoom(1);
        break;
      case 'ArrowUp':
        e.preventDefault();
        setPan(p => ({ ...p, y: p.y + PAN_STEP }));
        break;
      case 'ArrowDown':
        e.preventDefault();
        setPan(p => ({ ...p, y: p.y - PAN_STEP }));
        break;
      case 'ArrowLeft':
        e.preventDefault();
        setPan(p => ({ ...p, x: p.x + PAN_STEP }));
        break;
      case 'ArrowRight':
        e.preventDefault();
        setPan(p => ({ ...p, x: p.x - PAN_STEP }));
        break;
      case 'Home':
        e.preventDefault();
        if (layout) {
          const sx = canvasSize.width / layout.totalWidth;
          const sy = canvasSize.height / layout.totalHeight;
          const fitZoom = Math.min(sx, sy, 1) * 0.9;
          setZoom(fitZoom);
          setPan({ x: (canvasSize.width - layout.totalWidth * fitZoom) / 2, y: (canvasSize.height - layout.totalHeight * fitZoom) / 2 });
        }
        break;
    }
  }, [canvasSize, layout]);

  const handleArrowClick = useCallback((entryIndex) => {
    if (onInspect) onInspect(entryIndex);
  }, [onInspect]);

  if (!data) return <LoadingSpinner />;

  const messages = showResponses ? data.messages : data.messages.filter(m => m.type === 'request');
  const pageMessages = messages.slice(offset, offset + limit);
  const participants = data.participants;

  const handleFitView = () => {
    const sx = canvasSize.width / layout.totalWidth;
    const sy = canvasSize.height / layout.totalHeight;
    const fitZoom = Math.min(sx, sy, 1) * 0.9;
    setZoom(fitZoom);
    setPan({ x: (canvasSize.width - layout.totalWidth * fitZoom) / 2, y: (canvasSize.height - layout.totalHeight * fitZoom) / 2 });
  };

  return (
    <div className="flex flex-col h-full">
      <div className="px-4 py-2 bg-white/80 dark:bg-card-dark/80 border-b border-gray-200 dark:border-gray-700 flex items-center gap-3 text-sm">
        <select value={filters.domain || ''} onChange={(e) => setFilters({ ...filters, domain: e.target.value || null })}
          className="px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-xs dark:text-white">
          <option value="">All domains</option>
          {domains.map(d => <option key={d.domain} value={d.domain}>{d.domain}</option>)}
        </select>
        <select value={filters.flow || ''} onChange={(e) => setFilters({ ...filters, flow: e.target.value || null })}
          className="px-2 py-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-xs dark:text-white">
          <option value="">All flows</option>
          {flows.map(f => <option key={f.id} value={f.id}>{f.name}</option>)}
        </select>
        <label className="flex items-center gap-1.5 text-xs text-gray-600 dark:text-gray-400 cursor-pointer">
          <input type="checkbox" checked={showResponses} onChange={(e) => setShowResponses(e.target.checked)} className="rounded" />
          Show responses
        </label>
        <span className="text-xs text-gray-400">{messages.length} messages</span>
        <div className="ml-auto flex items-center gap-2">
          <div className="flex items-center border border-gray-300 dark:border-gray-600 rounded overflow-hidden">
            <button onClick={() => setZoom(z => Math.max(0.2, z / 1.15))} title="Zoom out (-)"
              className="px-1.5 py-0.5 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 border-r border-gray-300 dark:border-gray-600">
              <Icon name="Minus" size={12} />
            </button>
            <input
              type="text"
              value={zoomInput !== null ? zoomInput : Math.round(zoom * 100) + '%'}
              onChange={(e) => setZoomInput(e.target.value)}
              onFocus={(e) => { setZoomInput(String(Math.round(zoom * 100))); e.target.select(); }}
              onBlur={() => {
                const v = parseInt(zoomInput, 10);
                if (!isNaN(v) && v >= 20 && v <= 300) setZoom(v / 100);
                setZoomInput(null);
              }}
              onKeyDown={(e) => {
                if (e.key === 'Enter') e.target.blur();
                if (e.key === 'Escape') { setZoomInput(null); e.target.blur(); }
              }}
              className="w-12 text-center text-xs font-mono bg-transparent text-gray-700 dark:text-gray-200 outline-none py-0.5"
              title="Type a zoom level (20-300) and press Enter"
            />
            <button onClick={() => setZoom(z => Math.min(3, z * 1.15))} title="Zoom in (+)"
              className="px-1.5 py-0.5 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 border-l border-gray-300 dark:border-gray-600">
              <Icon name="Plus" size={12} />
            </button>
          </div>
          <button onClick={handleFitView} title="Fit to view (Home)"
            className="px-2 py-0.5 text-xs rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white">
            Fit
          </button>
          <button onClick={() => { setPan({ x: 40, y: 40 }); setZoom(1); }} title="Reset zoom (0)"
            className="px-2 py-0.5 text-xs rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white">
            Reset
          </button>
        </div>
      </div>

      <div
        ref={canvasRef}
        className={`flex-1 seq-canvas ${isPanning ? 'panning' : ''}`}
        onWheel={handleWheel}
        onMouseDown={handleMouseDown}
        onMouseMove={handleMouseMove}
        onMouseUp={handleMouseUp}
        onMouseLeave={handleMouseUp}
        onKeyDown={handleKeyDown}
        tabIndex={0}
        style={{ outline: 'none' }}
      >
        {participants.length === 0 ? (
          <p className="text-gray-400 text-sm text-center py-8">No sequence data available</p>
        ) : (
          <>
            <div style={{
              transform: `translate(${pan.x}px, ${pan.y}px) scale(${zoom})`,
              transformOrigin: '0 0',
              position: 'absolute',
              top: 0, left: 0,
            }}>
              <SequenceSVGLayer
                layout={layout}
                hoveredIndex={hoveredIndex}
                onHover={setHoveredIndex}
                onArrowClick={handleArrowClick}
                isDark={isDark}
              />
              <SequenceParticipants positions={layout.participantPositions} isDark={isDark} />
            </div>

            <SequenceMinimap
              layout={layout}
              pan={pan}
              zoom={zoom}
              canvasSize={canvasSize}
              onNavigate={setPan}
              isDark={isDark}
            />
          </>
        )}

        {messages.length > limit && (
          <div className="absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-4 bg-white/90 dark:bg-gray-800/90 px-4 py-2 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
            <button onClick={() => setOffset(Math.max(0, offset - limit))} disabled={offset === 0}
              className="px-3 py-1 text-xs rounded border border-gray-300 dark:border-gray-600 disabled:opacity-30 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white">Prev</button>
            <span className="text-xs text-gray-400">{Math.floor(offset/limit)+1} / {Math.ceil(messages.length/limit)}</span>
            <button onClick={() => setOffset(offset + limit)} disabled={offset + limit >= messages.length}
              className="px-3 py-1 text-xs rounded border border-gray-300 dark:border-gray-600 disabled:opacity-30 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white">Next</button>
          </div>
        )}
      </div>
    </div>
  );
};

