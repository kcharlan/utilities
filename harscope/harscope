@app.post("/api/validate")
async def api_validate(file: UploadFile = File(...)):
    """Validate an uploaded EDL file against the currently loaded HAR.

    The loaded HAR should be the sanitized version. Validation checks
    each EDL decision against the actual values in the loaded file,
    without re-applying any current scanner recommendations.
    """
    _require_file()
    try:
        edl_content = await file.read(MAX_EDL_BYTES + 1)
        if len(edl_content) > MAX_EDL_BYTES:
            raise HTTPException(status_code=413, detail=f"EDL file exceeds {MAX_EDL_BYTES // (1024*1024)} MB limit")
        edl_data = json.loads(edl_content.decode('utf-8'))
    except HTTPException:
        raise
    except (json.JSONDecodeError, ValueError) as e:
        raise HTTPException(status_code=400, detail=f'Invalid EDL JSON: {e}')

    result = ExportEngine.validate_edl(har_manager.raw_data, edl_data)
