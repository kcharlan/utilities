// --- WaterfallView ---
const WaterfallView = ({ onInspect, securityFindings }) => {
  const [data, setData] = useState(null);
  const [domains, setDomains] = useState([]);
  const [filters, setFilters] = useState({});
  const [offset, setOffset] = useState(0);
  const limit = 50;

  // Build a map of entryIndex -> finding counts for security indicators
  const findingsByEntry = useMemo(() => {
    const map = {};
    (securityFindings || []).forEach(f => {
      if (!map[f.entryIndex]) map[f.entryIndex] = { total: 0, critical: 0 };
      map[f.entryIndex].total++;
      if (f.severity === 'critical') map[f.entryIndex].critical++;
    });
    return map;
  }, [securityFindings]);

  const fetchData = useCallback(async () => {
    const params = new URLSearchParams({ offset, limit });
    if (filters.domain) params.set('domain', filters.domain);
    if (filters.status) params.set('status', filters.status);
    if (filters.search) params.set('search', filters.search);
    const result = await api(`/api/waterfall?${params}`);
    setData(result);
  }, [offset, filters]);

  useEffect(() => { api('/api/domains').then(setDomains); }, []);
  useEffect(() => { fetchData(); }, [fetchData]);

  if (!data) return <LoadingSpinner />;

  const totalPages = Math.ceil(data.total / limit);
  const currentPage = Math.floor(offset / limit) + 1;

  return (
    <div className="flex flex-col h-full">
      <FilterBar domains={domains} filters={filters} onChange={(f) => { setFilters(f); setOffset(0); }} total={data.total} />
      <div className="grid grid-cols-[24px_42px_60px_50px_1fr_70px_70px_minmax(200px,2fr)] gap-0 px-4 py-1.5 text-xs font-medium text-gray-500 dark:text-gray-400 border-b border-gray-200 dark:border-gray-700 bg-white/50 dark:bg-card-dark/50">
        <span></span><span className="font-mono">#</span><span>Status</span><span>Method</span><span>URL</span><span className="text-right">Size</span><span className="text-right">Time</span><span className="pl-4">Waterfall</span>
      </div>
      <div className="flex-1 overflow-auto">
        {data.entries.map((entry) => {
          const ef = findingsByEntry[entry.index];
          return (
          <div key={entry.index} onClick={() => onInspect(entry.index)}
            className={`grid grid-cols-[24px_42px_60px_50px_1fr_70px_70px_minmax(200px,2fr)] gap-0 px-4 py-1.5 text-xs border-b cursor-pointer items-center ${ef ? 'bg-red-50/40 dark:bg-red-900/5 border-red-100 dark:border-red-900/20 hover:bg-red-50 dark:hover:bg-red-900/10' : 'border-gray-100 dark:border-gray-800 hover:bg-blue-50/50 dark:hover:bg-blue-900/10'}`}>
            <span className="flex items-center justify-center">
              {ef && <span title={`${ef.total} finding${ef.total !== 1 ? 's' : ''}${ef.critical ? ` (${ef.critical} critical)` : ''}`}>
                <Icon name="ShieldAlert" size={14} className={ef.critical ? 'text-red-500' : 'text-amber-500'} />
              </span>}
            </span>
            <span className="inline-flex items-center justify-center px-1.5 py-0.5 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded text-xs font-mono font-bold">{entry.index}</span>
            <span><StatusBadge status={entry.status} /></span>
            <span className="font-mono text-gray-600 dark:text-gray-400">{entry.method}</span>
            <span className="font-mono text-ink dark:text-gray-200 truncate" title={entry.url}>{formatUrl(entry.url, 80)}</span>
            <span className="text-right text-gray-500 dark:text-gray-400">{formatBytes(entry.bodySize)}</span>
            <span className="text-right text-gray-500 dark:text-gray-400">{formatMs(entry.time)}</span>
            <div className="pl-4">
              <WaterfallBar entry={entry} maxEnd={data.maxEndTime} />
            </div>
          </div>
          );
        })}
      </div>
      {totalPages > 1 && (
        <div className="flex items-center justify-center gap-4 px-4 py-2 border-t border-gray-200 dark:border-gray-700 bg-white/50 dark:bg-card-dark/50">
          <button onClick={() => setOffset(Math.max(0, offset - limit))} disabled={offset === 0}
            className="px-3 py-1 text-xs rounded border border-gray-300 dark:border-gray-600 disabled:opacity-30 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white">Prev</button>
          <span className="text-xs text-gray-500 dark:text-gray-400">{currentPage} / {totalPages}</span>
          <button onClick={() => setOffset(offset + limit)} disabled={offset + limit >= data.total}
            className="px-3 py-1 text-xs rounded border border-gray-300 dark:border-gray-600 disabled:opacity-30 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white">Next</button>
        </div>
      )}
    </div>
  );
};

const WaterfallBar = ({ entry, maxEnd }) => {
  if (!maxEnd || maxEnd === 0) return null;
  const t = entry.timings;
  const total = t.blocked + t.dns + t.connect + t.ssl + t.send + t.wait + t.receive;
  if (!total) return <div className="relative h-4" title="0 ms" />;
  const startPct = (entry.startOffset / maxEnd) * 100;
  const widthPct = Math.max(0.5, (total / maxEnd) * 100);
  const segments = [
    { key: 'blocked', val: t.blocked, color: TIMING_COLORS.blocked },
    { key: 'dns', val: t.dns, color: TIMING_COLORS.dns },
    { key: 'connect', val: t.connect, color: TIMING_COLORS.connect },
    { key: 'ssl', val: t.ssl, color: TIMING_COLORS.ssl },
    { key: 'send', val: t.send, color: TIMING_COLORS.send },
    { key: 'wait', val: t.wait, color: TIMING_COLORS.wait },
    { key: 'receive', val: t.receive, color: TIMING_COLORS.receive },
  ].filter(s => s.val > 0);

  return (
    <div className="relative h-4" title={`${formatMs(total)}`}>
      <div className="timing-bar absolute top-0" style={{ left: `${startPct}%`, width: `${widthPct}%` }}>
        {segments.map(s => (
          <div key={s.key} className="timing-segment" style={{ backgroundColor: s.color, width: `${(s.val / total) * 100}%` }} title={`${s.key}: ${formatMs(s.val)}`} />
        ))}
      </div>
    </div>
  );
};

// --- InspectorView ---
const InspectorView = ({ entryIndex, findingPath, securityFindings, redactionMap, onToggleRedaction }) => {
  const [data, setData] = useState(null);
  const [section, setSection] = useState('request');
  const [subTab, setSubTab] = useState('headers');

  // Determine which security findings apply to this entry
  const entryFindings = useMemo(() => {
    if (!securityFindings || entryIndex === null) return [];
    return securityFindings.filter(f => f.entryIndex === entryIndex);
  }, [securityFindings, entryIndex]);

  // Classify each finding as request or response, then by sub-tab
  const findingCounts = useMemo(() => {
    const counts = {
      request: { total: 0, headers: 0, cookies: 0, query: 0, body: 0 },
      response: { total: 0, headers: 0, cookies: 0, body: 0 },
      websocket: 0,
    };
    entryFindings.forEach(f => {
      const loc = (f.location || '').toLowerCase();
      if (loc.includes('_websocketmessages')) { counts.websocket++; return; }

      // Determine request vs response
      const isResp = loc.includes('.response.') || (loc.includes('(parsed)') && loc.includes('.content'));
      const side = isResp ? 'response' : 'request';
      counts[side].total++;

      if (loc.includes('header') || loc.includes('.headers')) counts[side].headers++;
      else if (loc.includes('cookie')) counts[side].cookies++;
      else if (loc.includes('querystring') || loc.includes('url_param')) counts[side].query = (counts[side].query || 0) + 1;
      else if (loc.includes('body') || loc.includes('postdata') || loc.includes('content') || loc.includes('(parsed)')) counts[side].body++;
    });
    return counts;
  }, [entryFindings]);

  useEffect(() => {
    if (entryIndex === null || entryIndex === undefined) { setData(null); return; }
    api(`/api/entry/${entryIndex}`).then(setData);
  }, [entryIndex]);

  // Auto-navigate to the right tab based on finding path
  useEffect(() => {
    if (!findingPath || !data) return;
    const p = findingPath.toLowerCase();
    if (p.includes('_websocketmessages')) {
      setSubTab('websocket');
    } else if (p.includes('response.')) {
      setSection('response');
      if (p.includes('headers')) setSubTab('headers');
      else if (p.includes('cookies')) setSubTab('cookies');
      else if (p.includes('content')) setSubTab('body');
    } else if (p.includes('request.')) {
      setSection('request');
      if (p.includes('headers')) setSubTab('headers');
      else if (p.includes('cookies')) setSubTab('cookies');
      else if (p.includes('querystring')) setSubTab('query');
      else if (p.includes('postdata')) setSubTab('body');
    } else if (p.includes('(parsed)')) {
      if (p.includes('request')) { setSection('request'); setSubTab('body'); }
      else { setSubTab('raw'); }
    } else {
      setSubTab('raw');
    }
  }, [findingPath, data]);

  if (entryIndex === null || entryIndex === undefined) {
    return (
      <div className="flex items-center justify-center h-full text-gray-400 dark:text-gray-500">
        <div className="text-center">
          <Icon name="MousePointerClick" size={48} className="mx-auto mb-3 opacity-50" />
          <p>Select a request from the Waterfall to inspect</p>
        </div>
      </div>
    );
  }
  if (!data) return <LoadingSpinner />;

  const entry = data.entry;
  const req = entry.request || {};
  const resp = entry.response || {};
  const active = section === 'request' ? req : resp;

  const headers = active.headers || [];
  const cookies = section === 'request' ? (req.cookies || []) : (resp.cookies || []);
  const queryString = req.queryString || [];
  const body = section === 'request' ? (req.postData || {}) : (resp.content || {});
  const timings = entry.timings || {};
  const wsMessages = entry._webSocketMessages || [];

  // Build dynamic sub-tabs based on what exists, using section-specific counts
  const sideCounts = findingCounts[section] || { headers: 0, cookies: 0, query: 0, body: 0 };
  const subTabs = [];
  subTabs.push({ id: 'headers', label: 'Headers', count: headers.length, alertCount: sideCounts.headers });
  if (cookies.length) subTabs.push({ id: 'cookies', label: 'Cookies', count: cookies.length, alertCount: sideCounts.cookies });
  if (section === 'request' && queryString.length) subTabs.push({ id: 'query', label: 'Query', count: queryString.length, alertCount: sideCounts.query || 0 });
  if ((body.text || '').length > 0 || (section === 'request' && req.postData?.params?.length))
    subTabs.push({ id: 'body', label: 'Body', alertCount: sideCounts.body });
  if (wsMessages.length) subTabs.push({ id: 'websocket', label: 'WebSocket', count: wsMessages.length, alertCount: findingCounts.websocket });
  subTabs.push({ id: 'timings', label: 'Timings' });
  // Findings tab shows only findings for current section (+ websocket which is neutral)
  const sectionFindings = entryFindings.filter(f => {
    const loc = (f.location || '').toLowerCase();
    if (loc.includes('_websocketmessages')) return true;
    const isResp = loc.includes('.response.') || (loc.includes('(parsed)') && loc.includes('.content'));
    return section === 'response' ? isResp : !isResp;
  });
  if (sectionFindings.length) subTabs.push({ id: 'findings', label: 'Findings', count: sectionFindings.length, alert: true });
  subTabs.push({ id: 'raw', label: 'Raw' });

  // Use valid sub-tab (fall back to first if current doesn't exist in list)
  const activeSubTab = subTabs.find(t => t.id === subTab) ? subTab : (subTabs[0]?.id || 'headers');

  return (
    <div className="flex flex-col h-full">
      <div className="px-4 py-3 bg-white/80 dark:bg-card-dark/80 border-b border-gray-200 dark:border-gray-700">
        <div className="flex items-center gap-3 mb-2">
          <span className="inline-flex items-center px-1.5 py-0.5 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded text-xs font-mono font-bold">#{entryIndex}</span>
          <StatusBadge status={data.status} />
          <span className="font-mono font-medium text-sm text-ink dark:text-white">{data.method}</span>
          <span className="font-mono text-xs text-gray-500 dark:text-gray-400 truncate flex-1" title={data.url}>{data.url}</span>
          <span className="text-xs text-gray-400">{formatMs(data.time)}</span>
          {entryFindings.length > 0 && (
            <span className="inline-flex items-center gap-1 px-2 py-0.5 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-full text-xs font-medium">
              <Icon name="Shield" size={12} /> {entryFindings.length} finding{entryFindings.length !== 1 ? 's' : ''}
            </span>
          )}
        </div>
        <div className="flex gap-1">
          <button onClick={() => setSection('request')} className={`px-3 py-1 text-xs rounded-full flex items-center gap-1 ${section === 'request' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 font-medium' : 'text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700'}`}>
            Request
            {findingCounts.request.total > 0 && <span className="text-[10px] px-1 rounded-full bg-red-500 text-white">{findingCounts.request.total}</span>}
          </button>
          <button onClick={() => setSection('response')} className={`px-3 py-1 text-xs rounded-full flex items-center gap-1 ${section === 'response' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 font-medium' : 'text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700'}`}>
            Response
            {findingCounts.response.total > 0 && <span className="text-[10px] px-1 rounded-full bg-red-500 text-white">{findingCounts.response.total}</span>}
          </button>
        </div>
      </div>
      <div className="flex gap-1 px-4 py-1 border-b border-gray-200 dark:border-gray-700 bg-white/50 dark:bg-card-dark/50 flex-wrap">
        {subTabs.map(t => (
          <button key={t.id} onClick={() => setSubTab(t.id)}
            className={`px-3 py-1 text-xs rounded flex items-center gap-1 ${activeSubTab === t.id ? 'bg-gray-200 dark:bg-gray-700 font-medium text-ink dark:text-white' : 'text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700'}`}>
            {t.label}
            {t.alertCount > 0 && <span className="text-[10px] px-1 rounded-full bg-red-500 text-white">{t.alertCount}</span>}
            {t.count !== undefined && !t.alert && <span className="text-[10px] px-1 rounded-full bg-gray-300 dark:bg-gray-600 text-gray-600 dark:text-gray-300">{t.count}</span>}
            {t.alert && <span className="text-[10px] px-1 rounded-full bg-red-500 text-white">{t.count}</span>}
          </button>
        ))}
      </div>
      <div className="flex-1 overflow-auto p-4">
        {activeSubTab === 'headers' && <HeaderTable headers={headers} findings={entryFindings} section={section} entryIndex={entryIndex} redactionMap={redactionMap} onToggleRedaction={onToggleRedaction} />}
        {activeSubTab === 'cookies' && <CookieTable cookies={cookies} findings={entryFindings} section={section} entryIndex={entryIndex} redactionMap={redactionMap} onToggleRedaction={onToggleRedaction} />}
        {activeSubTab === 'query' && <ParamTable params={queryString} findings={entryFindings} entryIndex={entryIndex} redactionMap={redactionMap} onToggleRedaction={onToggleRedaction} />}
        {activeSubTab === 'body' && <BodyViewer body={body} findings={entryFindings} section={section} entryIndex={entryIndex} redactionMap={redactionMap} onToggleRedaction={onToggleRedaction} />}
        {activeSubTab === 'websocket' && <WebSocketViewer messages={wsMessages} findings={entryFindings} entryIndex={entryIndex} redactionMap={redactionMap} onToggleRedaction={onToggleRedaction} />}
