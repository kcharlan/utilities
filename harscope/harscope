            total_req = stats.get('totalRequests', 1)
            for code, count in sorted(status_codes.items()):
                pct = round(count / total_req * 100, 1) if total_req else 0
                lines.append(f'| {code} | {count} | {pct}% |')

        timing = stats.get('timingPercentiles', {})
        if timing:
            lines += [
                '', '### Response Timing',
                '',
                '| Percentile | Time |',
                '|------------|------|',
            ]
            for k, v in timing.items():
                label = f'{k} (median)' if k == 'p50' else k
                lines.append(f'| {label} | {ExportEngine._fmt_time(v)} |')
            lines.append(f'| Average | {ExportEngine._fmt_time(stats.get("avgTime", 0))} |')

        lines += ['', '---', '', f'*Generated by harscope*']
        return '\n'.join(lines)

    @staticmethod
    def _html_report(har, stats, report, sev, ts) -> str:
        """Generate a self-contained HTML security analysis report."""
        total_findings = sev['total']
        total_req = stats.get('totalRequests', 0)
        cov = report['coverage']
        red = report['redaction']
        risk = report['riskLevel'].lower()

        # Severity bar widths
        crit_pct = round(sev['critical'] / total_findings * 100) if total_findings else 0
        warn_pct = round(sev['warning'] / total_findings * 100) if total_findings else 0
        info_pct = round(sev['info'] / total_findings * 100) if total_findings else 0

        # Build category rows
        cat_rows = ''
        for c in report['categories']:
            cat_rows += (
                f'<tr><td class="mono">{_he(c["category"])}</td>'
                f'<td class="num mono">{c["critical"] or "—"}</td>'
                f'<td class="num mono">{c["warning"] or "—"}</td>'
                f'<td class="num mono">{c["info"] or "—"}</td>'
                f'<td class="num mono"><strong>{c["total"]}</strong></td>'
                f'<td class="mono" style="font-size:11px">{_he(c["topDomain"])}</td></tr>'
            )

        # Build location bars
        max_loc = max((loc['count'] for loc in report['locations']), default=1)
        loc_bars = ''
        for loc in report['locations']:
            bar_w = round(loc['count'] / max_loc * 100) if max_loc else 0
            fill_class = loc['highestSeverity'] if loc['highestSeverity'] in _VALID_FILL_CLASSES else ''
            loc_bars += (
                f'<div class="bar-row">'
                f'<div class="bar-label">{_he(loc["area"])}</div>'
                f'<div class="bar-track"><div class="bar-fill {fill_class}" style="width:{bar_w}%"></div></div>'
                f'<div class="bar-value">{loc["count"]} ({loc["pct"]}%)</div>'
                f'</div>'
            )

        # Build domain bars
        max_dom = max((d['total'] for d in report['domains']), default=1)
        dom_bars = ''
        for d in report['domains'][:8]:
            bar_w = round(d['total'] / max_dom * 100) if max_dom else 0
            fill_class = 'critical' if d['critical'] > 0 else ('warning' if d['warning'] > 0 else '')
            dom_bars += (
                f'<div class="bar-row">'
                f'<div class="bar-label">{_he(d["domain"])}</div>'
                f'<div class="bar-track"><div class="bar-fill {fill_class}" style="width:{bar_w}%"></div></div>'
                f'<div class="bar-value">{d["total"]}</div>'
                f'</div>'
            )

        # Build critical findings details
        crit_details = ''
        for cf in report['criticalFindings']:
            entry = cf.get('entry', {})
            domain = _he(entry.get('domain', '—'))
            req_info = f'{_he(entry.get("method", "?"))} {_he(entry.get("path", "?"))} — {_he(entry.get("status", "?"))}' if entry else '—'
            crit_details += (
                f'<details><summary>'
                f'<span class="badge critical">Critical</span> '
                f'{_he(cf["description"])} — {domain}'
                f'</summary><div class="detail-content">'
                f'<table style="font-size:12px;margin-bottom:8px">'
                f'<tr><td style="width:100px;color:var(--slate-500)">Category</td><td>{_he(cf["category"])}</td></tr>'
                f'<tr><td style="color:var(--slate-500)">Location</td><td class="finding-location">{_he(cf["location"])}</td></tr>'
                f'<tr><td style="color:var(--slate-500)">Request</td><td class="mono">{req_info}</td></tr>'
                f'<tr><td style="color:var(--slate-500)">Action</td><td>{"Auto-redacted" if cf["redact"] else "Kept"}</td></tr>'
                f'</table>'
                f'<div class="finding-preview">{_he(cf["preview"])}</div>'
                f'</div></details>'
            )

        # Build status code rows
        status_rows = ''
        for code, count in sorted(stats.get('statusCodes', {}).items()):
            pct = round(count / total_req * 100, 1) if total_req else 0
            status_rows += f'<tr><td class="mono">{_he(code)}</td><td class="num mono">{count}</td><td class="num mono">{pct}%</td></tr>'

        # Build timing rows
        timing_rows = ''
        for k, v in stats.get('timingPercentiles', {}).items():
            label = f'{k} (median)' if k == 'p50' else k
            timing_rows += f'<tr><td class="mono">{label}</td><td class="num mono">{ExportEngine._fmt_time(v)}</td></tr>'
        timing_rows += f'<tr><td class="mono">Average</td><td class="num mono">{ExportEngine._fmt_time(stats.get("avgTime", 0))}</td></tr>'

        # WebSocket coverage stat
        ws_stat = ''
        if cov['totalWebSocket'] > 0:
            ws_alert = ' alert' if cov['webSocketWithFindingsPct'] > 30 else ''
            ws_stat = (
                f'<div class="coverage-stat{ws_alert}">'
                f'<div class="stat-label">WebSocket Exposure</div>'
                f'<div class="stat-pct">{cov["webSocketWithFindingsPct"]}%</div>'
                f'<div class="stat-detail">{cov["webSocketWithFindings"]} of {cov["totalWebSocket"]} connections contained secrets</div>'
                f'</div>'
            )

        html = f'''<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>HAR Security Analysis — {_he(har.file_name)}</title>
<style>
:root {{
  --slate-950:#0f172a;--slate-900:#1e293b;--slate-800:#334155;--slate-700:#475569;
  --slate-600:#64748b;--slate-500:#94a3b8;--slate-400:#cbd5e1;--slate-300:#e2e8f0;
  --slate-200:#f1f5f9;--slate-100:#f8fafc;
  --critical:#dc2626;--critical-bg:#fef2f2;--critical-border:#fecaca;
  --warning:#d97706;--warning-bg:#fffbeb;--warning-border:#fde68a;
  --info:#2563eb;--info-bg:#eff6ff;--info-border:#bfdbfe;
  --ok:#16a34a;--ok-bg:#f0fdf4;
  --mono:"Menlo","Consolas","SF Mono","Monaco",monospace;
  --sans:"Helvetica Neue","Segoe UI","Arial",sans-serif;
  color-scheme:light dark;
}}
@media(prefers-color-scheme:dark){{:root:not(.light){{
  --slate-950:#0f172a;--slate-900:#e2e8f0;--slate-800:#cbd5e1;--slate-700:#94a3b8;
  --slate-600:#94a3b8;--slate-500:#64748b;--slate-400:#475569;--slate-300:#334155;
  --slate-200:#1e293b;--slate-100:#1a2332;
  --critical:#f87171;--critical-bg:#3b1111;--critical-border:#7f1d1d;
  --warning:#fbbf24;--warning-bg:#3b2f08;--warning-border:#78350f;
  --info:#60a5fa;--info-bg:#0c1a3d;--info-border:#1e3a5f;
  --ok:#4ade80;--ok-bg:#0a2614;
}}}}
