// Check if a header/cookie name is flagged by any finding for this section
const isFlagged = (findings, name, section) => {
  if (!findings || !name) return false;
  const lower = name.toLowerCase();
  const sectionKey = section === 'response' ? '.response.' : '.request.';
  return findings.some(f => {
    const loc = f.location.toLowerCase();
    if (!loc.includes(sectionKey)) return false;
    return loc.includes(`.${lower}`) || loc.endsWith(`.${lower}`);
  });
};

