.severity-legend .critical::before{{background:var(--critical)}}.severity-legend .warning::before{{background:var(--warning)}}.severity-legend .info::before{{background:var(--info)}}
table{{width:100%;border-collapse:collapse;font-size:13px;margin-bottom:16px}}
