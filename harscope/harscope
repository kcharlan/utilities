.two-col{{display:grid;grid-template-columns:1fr 1fr;gap:24px}}
.doc-footer{{background:var(--slate-100);padding:16px 40px;border-top:1px solid var(--slate-300);font-family:var(--mono);font-size:10px;color:var(--slate-500);display:flex;justify-content:space-between}}
#theme-toggle{{position:absolute;top:16px;right:16px;background:none;border:1px solid var(--slate-500);color:var(--slate-400);width:32px;height:32px;border-radius:4px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:border-color .2s,color .2s}}
#theme-toggle:hover{{border-color:var(--slate-300);color:#fff}}
@media print{{#theme-toggle{{display:none}}:root,:root.dark{{--slate-950:#0f172a;--slate-900:#1e293b;--slate-800:#334155;--slate-700:#475569;--slate-600:#64748b;--slate-500:#94a3b8;--slate-400:#cbd5e1;--slate-300:#e2e8f0;--slate-200:#f1f5f9;--slate-100:#f8fafc;--critical:#dc2626;--critical-bg:#fef2f2;--critical-border:#fecaca;--warning:#d97706;--warning-bg:#fffbeb;--warning-border:#fde68a;--info:#2563eb;--info-bg:#eff6ff;--info-border:#bfdbfe;--ok:#16a34a;--ok-bg:#f0fdf4}}body{{background:#fff;padding:0;font-size:12px}}.report{{box-shadow:none;max-width:none;background:#fff}}.doc-header{{padding:20px 24px}}.section{{padding:16px 24px}}details{{break-inside:avoid}}.metrics{{grid-template-columns:repeat(4,1fr)}}.coverage-grid{{grid-template-columns:repeat(3,1fr)}}}}
@media(max-width:700px){{.metrics{{grid-template-columns:repeat(2,1fr)}}.two-col{{grid-template-columns:1fr}}.coverage-grid{{grid-template-columns:1fr}}.doc-header .meta{{flex-direction:column;gap:4px}}}}
</style>
</head>
<body>
<div class="report">
<div class="doc-header">
<button id="theme-toggle" title="Toggle dark/light mode" aria-label="Toggle dark/light mode">&#9790;</button>
<div class="label">harscope security analysis</div>
<h1>{_he(har.file_name)}</h1>
<div class="meta">
<span>Generated: {ts}</span>
<span>Requests: {total_req}</span>
<span>Domains: {cov["totalDomains"]}</span>
<span>Findings: {total_findings}</span>
</div>
</div>

<div class="section">
<div class="section-title">Executive Summary</div>
<div class="risk-banner {risk}">
<div class="ri"></div>
{_he(report["riskLevel"])} — {_he(report["riskDetail"])}
</div>
<div class="metrics">
<div class="metric{" alert" if sev["critical"] > 0 else ""}">
<div class="ml">Critical</div><div class="mv">{sev["critical"]}</div><div class="md">Auto-redacted</div>
</div>
<div class="metric">
<div class="ml">Warning</div><div class="mv">{sev["warning"]}</div><div class="md">Auto-redacted</div>
</div>
<div class="metric">
<div class="ml">Info</div><div class="mv">{sev["info"]}</div><div class="md">Not redacted</div>
</div>
<div class="metric">
<div class="ml">Manual</div><div class="mv">{red["manualRedacted"]}</div><div class="md">User-redacted</div>
</div>
</div>
<div class="metrics">
<div class="metric">
<div class="ml">Total Requests</div><div class="mv">{total_req}</div>
</div>
<div class="metric">
<div class="ml">Total Size</div><div class="mv">{ExportEngine._fmt_size(stats.get("totalSize", 0))}</div>
</div>
<div class="metric">
<div class="ml">Load Time</div><div class="mv">{ExportEngine._fmt_time(stats.get("loadTime", 0))}</div>
</div>
<div class="metric{" alert" if stats.get("errorRate", 0) > 5 else ""}">
<div class="ml">Error Rate</div><div class="mv">{stats.get("errorRate", 0):.1f}%</div>
<div class="md">{stats.get("errorCount", 0)} errors</div>
</div>
</div>
{"" if total_findings == 0 else f"""<div class="severity-bar-container">
<div class="severity-bar">
{"" if crit_pct == 0 else f'<div class="seg critical" style="width:{crit_pct}%">{sev["critical"]}</div>'}
{"" if warn_pct == 0 else f'<div class="seg warning" style="width:{warn_pct}%">{sev["warning"]}</div>'}
{"" if info_pct == 0 else f'<div class="seg info" style="width:{info_pct}%">{sev["info"]}</div>'}
</div>
<div class="severity-legend">
<span class="critical">Critical ({crit_pct}%)</span>
<span class="warning">Warning ({warn_pct}%)</span>
<span class="info">Info ({info_pct}%)</span>
</div>
</div>"""}
</div>

{"" if not report["categories"] else f"""<div class="section">
<div class="section-title">Findings by Category</div>
<table>
<thead><tr><th>Category</th><th class="num">Critical</th><th class="num">Warning</th><th class="num">Info</th><th class="num">Total</th><th>Top Domain</th></tr></thead>
<tbody>{cat_rows}</tbody>
</table>
</div>"""}

{"" if not report["locations"] or not report["domains"] else f"""<div class="section">
<div class="two-col">
<div>
<div class="section-title">Findings by Location</div>
<div class="bar-chart">{loc_bars}</div>
</div>
<div>
<div class="section-title">Findings by Domain</div>
<div class="bar-chart">{dom_bars}</div>
</div>
</div>
</div>"""}

<div class="section">
<div class="section-title">Coverage Statistics</div>
<div class="coverage-grid">
<div class="coverage-stat{" alert" if cov["entriesWithFindingsPct"] > 20 else ""}">
<div class="stat-label">Requests with Findings</div>
<div class="stat-pct">{cov["entriesWithFindingsPct"]}%</div>
<div class="stat-detail">{cov["entriesWithFindings"]} of {cov["totalEntries"]} requests</div>
</div>
<div class="coverage-stat">
<div class="stat-label">Domains with Findings</div>
<div class="stat-pct">{cov["domainsWithFindingsPct"]}%</div>
<div class="stat-detail">{cov["domainsWithFindings"]} of {cov["totalDomains"]} domains</div>
</div>
{ws_stat}
</div>
</div>

{"" if not report["criticalFindings"] else f"""<div class="section">
<div class="section-title">Critical Findings Detail</div>
{crit_details}
</div>"""}

<div class="section">
<div class="section-title">Redaction Summary</div>
<div class="metrics" style="grid-template-columns:repeat(5,1fr)">
<div class="metric"><div class="ml">Total Decisions</div><div class="mv">{red["totalDecisions"]}</div></div>
<div class="metric"><div class="ml">Auto-Redacted</div><div class="mv">{red["autoRedacted"]}</div></div>
<div class="metric"><div class="ml">Auto-Kept</div><div class="mv">{red["autoKept"]}</div><div class="md">Info-level findings</div></div>
<div class="metric"><div class="ml">Manual Redact</div><div class="mv">{red["manualRedacted"]}</div></div>
<div class="metric"><div class="ml">Redaction Rate</div><div class="mv">{red["redactionRate"]}%</div><div class="md">{red["totalRedacted"]} of {red["totalDecisions"]} values</div></div>
</div>
</div>

<div class="section">
<div class="two-col">
<div>
<div class="section-title">Status Code Distribution</div>
<table><thead><tr><th>Code</th><th class="num">Count</th><th class="num">Pct</th></tr></thead>
<tbody>{status_rows}</tbody></table>
</div>
<div>
<div class="section-title">Response Timing</div>
<table><thead><tr><th>Percentile</th><th class="num">Time</th></tr></thead>
<tbody>{timing_rows}</tbody></table>
</div>
</div>
</div>

<div class="doc-footer">
<span>Generated by harscope</span>
<span>Confidential — contains security analysis data</span>
</div>
</div>
<script>
(function(){{
  var s=localStorage.getItem('harscope-report-theme');
  if(s==='dark')document.documentElement.classList.add('dark');
  else if(s==='light')document.documentElement.classList.add('light');
  function isDark(){{
    var h=document.documentElement;
    return h.classList.contains('dark')||(!h.classList.contains('light')&&window.matchMedia('(prefers-color-scheme:dark)').matches);
  }}
  function updateIcon(){{
    var btn=document.getElementById('theme-toggle');
    if(btn)btn.textContent=isDark()?'\\u2600':'\\u263E';
  }}
  updateIcon();
  document.getElementById('theme-toggle').addEventListener('click',function(){{
