// --- Sequence Diagram Helpers ---
const SEQ_COL_WIDTH = 160;
const SEQ_ROW_HEIGHT = 36;
const SEQ_HEADER_HEIGHT = 56;
const SEQ_TOP_PADDING = 20;
const SEQ_PARTICIPANT_WIDTH = 140;
const SEQ_PARTICIPANT_HEIGHT = 44;

const computeSequenceLayout = (participants, messages) => {
  const participantPositions = participants.map((label, i) => ({
    xCenter: i * SEQ_COL_WIDTH + SEQ_COL_WIDTH / 2,
    x: i * SEQ_COL_WIDTH + SEQ_COL_WIDTH / 2 - SEQ_PARTICIPANT_WIDTH / 2,
    y: SEQ_TOP_PADDING,
    label,
  }));

  const lifelineY1 = SEQ_TOP_PADDING + SEQ_PARTICIPANT_HEIGHT;
  const lifelineY2 = SEQ_HEADER_HEIGHT + SEQ_TOP_PADDING + Math.max(messages.length, 1) * SEQ_ROW_HEIGHT + 20;

  const lifelinePositions = participantPositions.map(p => ({
    x: p.xCenter,
    y1: lifelineY1,
    y2: lifelineY2,
  }));

  const arrowPositions = messages.map((msg, i) => {
    const fromIdx = participants.indexOf(msg.from);
    const toIdx = participants.indexOf(msg.to);
    if (fromIdx === -1 || toIdx === -1) return null;
    const x1 = participantPositions[fromIdx].xCenter;
    const x2 = participantPositions[toIdx].xCenter;
    const y = SEQ_HEADER_HEIGHT + SEQ_TOP_PADDING + i * SEQ_ROW_HEIGHT + SEQ_ROW_HEIGHT / 2;
    return {
      x1, x2, y,
      label: msg.label,
      type: msg.type,
      status: msg.status,
      index: msg.index,
      length: Math.abs(x2 - x1),
    };
  }).filter(Boolean);

  const totalWidth = Math.max(participants.length * SEQ_COL_WIDTH, 200) + 40;
  const totalHeight = lifelineY2 + 40;

  return { participantPositions, lifelinePositions, arrowPositions, totalWidth, totalHeight };
};

const SEQ_MARKER_COLORS = {
  blue: '#3b82f6',
  gray: '#9ca3af',
  red: '#ef4444',
};

const SequenceSVGLayer = ({ layout, hoveredIndex, onHover, onArrowClick, isDark }) => {
  const { lifelinePositions, arrowPositions, totalWidth, totalHeight } = layout;

  return (
    <svg width={totalWidth} height={totalHeight} style={{ position: 'absolute', top: 0, left: 0 }}>
      <defs>
        {Object.entries(SEQ_MARKER_COLORS).map(([name, color]) => (
          <React.Fragment key={name}>
            <marker id={`seq-arrow-right-${name}`} viewBox="0 0 10 10" refX="9" refY="5"
              markerWidth="8" markerHeight="8" orient="auto">
              <path d="M 0 0 L 10 5 L 0 10 z" fill={color} />
            </marker>
            <marker id={`seq-arrow-left-${name}`} viewBox="0 0 10 10" refX="1" refY="5"
              markerWidth="8" markerHeight="8" orient="auto">
              <path d="M 10 0 L 0 5 L 10 10 z" fill={color} />
            </marker>
          </React.Fragment>
        ))}
      </defs>

      {/* Lifelines */}
      {lifelinePositions.map((ll, i) => (
        <line key={`ll-${i}`} x1={ll.x} y1={ll.y1} x2={ll.x} y2={ll.y2}
          stroke={isDark ? '#4b5563' : '#d1d5db'} strokeWidth={1.5} strokeDasharray="6 4" />
      ))}

      {/* Arrows */}
      {arrowPositions.map((arrow, i) => {
        const isResponse = arrow.type === 'response';
        const isError = arrow.status >= 400;
        const goesLeft = arrow.x2 < arrow.x1;

        let colorName, strokeColor;
        if (isResponse) {
          colorName = isError ? 'red' : 'gray';
          strokeColor = isError ? SEQ_MARKER_COLORS.red : SEQ_MARKER_COLORS.gray;
        } else {
          colorName = 'blue';
          strokeColor = SEQ_MARKER_COLORS.blue;
        }

        // Always draw line left-to-right so orient="auto" works correctly.
        // Place the arrowhead marker on the destination end.
        const lineX1 = Math.min(arrow.x1, arrow.x2);
        const lineX2 = Math.max(arrow.x1, arrow.x2);
        const markerAttr = goesLeft
          ? { markerStart: `url(#seq-arrow-left-${colorName})` }
          : { markerEnd: `url(#seq-arrow-right-${colorName})` };

        const isHovered = hoveredIndex !== null && arrow.index === hoveredIndex;
        const isFaded = hoveredIndex !== null && arrow.index !== hoveredIndex;
        const sw = isHovered ? 2.5 : 1.5;
        const opacity = isFaded ? 0.4 : 1;

        const labelX = lineX1 + 4;
        const maxLabelWidth = arrow.length - 8;

        return (
          <g key={`arrow-${i}`} style={{ cursor: 'pointer', opacity }}
            onMouseEnter={() => onHover(arrow.index)}
            onMouseLeave={() => onHover(null)}
            onClick={() => onArrowClick(arrow.index)}>
            <line x1={lineX1} y1={arrow.y} x2={lineX2} y2={arrow.y}
              stroke={strokeColor} strokeWidth={sw}
              strokeDasharray={isResponse ? '6 3' : 'none'}
              className="seq-arrow-anim"
              style={{ '--arrow-len': arrow.length, animationDelay: `${i * 15}ms` }}
              {...markerAttr}
            />
            {/* Invisible wider hit area */}
            <line x1={lineX1} y1={arrow.y} x2={lineX2} y2={arrow.y}
              stroke="transparent" strokeWidth={12} />
            <text x={labelX} y={arrow.y - 6}
              fill={strokeColor} fontSize={10} fontFamily="'JetBrains Mono', monospace"
              textLength={arrow.label.length * 6.5 > maxLabelWidth ? maxLabelWidth : undefined}
              lengthAdjust="spacing">
              {arrow.label.length * 6.5 > maxLabelWidth
                ? arrow.label.slice(0, Math.floor(maxLabelWidth / 6.5) - 1) + '\u2026'
                : arrow.label}
            </text>
          </g>
        );
      })}
    </svg>
  );
};

