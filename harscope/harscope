const TimingsChart = ({ timings, totalTime }) => {
  const phases = [
    { key: 'blocked', label: 'Blocked', color: TIMING_COLORS.blocked },
    { key: 'dns', label: 'DNS', color: TIMING_COLORS.dns },
    { key: 'connect', label: 'Connect', color: TIMING_COLORS.connect },
    { key: 'ssl', label: 'SSL/TLS', color: TIMING_COLORS.ssl },
    { key: 'send', label: 'Send', color: TIMING_COLORS.send },
    { key: 'wait', label: 'Wait (TTFB)', color: TIMING_COLORS.wait },
    { key: 'receive', label: 'Receive', color: TIMING_COLORS.receive },
  ];
  const total = phases.reduce((s, p) => s + Math.max(0, timings[p.key] || 0), 0);

  return (
    <div className="space-y-3">
      <div className="timing-bar h-6 rounded bg-gray-100 dark:bg-gray-800">
        {phases.map(p => {
          const val = Math.max(0, timings[p.key] || 0);
          if (val === 0) return null;
          return <div key={p.key} className="timing-segment" style={{ backgroundColor: p.color, width: `${(val / total) * 100}%` }} title={`${p.label}: ${formatMs(val)}`} />;
        })}
      </div>
      <div className="space-y-1">
        {phases.map(p => {
          const val = Math.max(0, timings[p.key] || 0);
          return (
            <div key={p.key} className="flex items-center gap-3 text-xs">
              <div className="w-3 h-3 rounded-sm flex-shrink-0" style={{ backgroundColor: p.color }}></div>
              <span className="text-gray-600 dark:text-gray-400 w-24">{p.label}</span>
              <div className="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded overflow-hidden">
                <div className="h-full rounded" style={{ backgroundColor: p.color, width: total > 0 ? `${(val / total) * 100}%` : '0%' }}></div>
              </div>
              <span className="font-mono text-gray-500 dark:text-gray-400 w-20 text-right">{formatMs(val)}</span>
            </div>
          );
        })}
      </div>
      <div className="text-xs text-gray-500 dark:text-gray-400 pt-2 border-t border-gray-200 dark:border-gray-700">
        Total: <span className="font-mono font-medium text-ink dark:text-white">{formatMs(totalTime)}</span>
      </div>
    </div>
  );
};

