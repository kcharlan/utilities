<script type="text/babel">
const { useState, useEffect, useCallback, useRef, useMemo } = React;

// --- Utilities ---
const api = async (path, opts = {}) => {
  const res = await fetch(path, {
    headers: { 'Content-Type': 'application/json', ...opts.headers },
    ...opts,
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({ detail: res.statusText }));
    throw new Error(err.detail || 'Request failed');
  }
  return res.json();
};

const formatBytes = (b) => {
  if (b === 0) return '0 B';
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
  return (b / 1048576).toFixed(1) + ' MB';
};

const formatMs = (ms) => {
  if (ms < 1) return '<1 ms';
  if (ms < 1000) return Math.round(ms) + ' ms';
  return (ms / 1000).toFixed(2) + ' s';
};

const formatUrl = (url, maxLen = 60) => {
  try {
    const u = new URL(url);
    const path = u.pathname + u.search;
    if (path.length > maxLen) return path.slice(0, maxLen - 3) + '...';
    return path;
  } catch { return url.slice(0, maxLen); }
};

const statusColor = (s) => {
  if (s >= 500) return 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300';
  if (s >= 400) return 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300';
  if (s >= 300) return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300';
  if (s >= 200) return 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300';
  return 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300';
};

const severityColor = (s) => ({
  critical: 'text-red-600 dark:text-red-400',
  warning: 'text-amber-600 dark:text-amber-400',
  info: 'text-gray-500 dark:text-gray-400',
}[s] || 'text-gray-500');

const severityBg = (s) => ({
  critical: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300',
  warning: 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300',
  info: 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300',
}[s] || 'bg-gray-100');

const TIMING_COLORS = {
  blocked: '#64748b', dns: '#06b6d4', connect: '#22c55e', ssl: '#a855f7',
  send: '#3b82f6', wait: '#eab308', receive: '#10b981',
};

// --- Icon Component ---
const Icon = ({ name, size = 18, className = '' }) => {
  const ref = useRef(null);
  useEffect(() => {
    if (ref.current && lucide[name]) {
      ref.current.innerHTML = '';
      const svg = lucide.createElement(lucide[name]);
      svg.setAttribute('width', size);
      svg.setAttribute('height', size);
      if (className) svg.setAttribute('class', className);
      ref.current.appendChild(svg);
    }
  }, [name, size, className]);
  return React.createElement('span', { ref, className: 'inline-flex items-center' });
};

// --- Toast ---
const Toast = ({ message, type = 'info', onClose }) => {
  useEffect(() => { const t = setTimeout(onClose, 3000); return () => clearTimeout(t); }, []);
  const bg = type === 'error' ? 'bg-red-600' : type === 'success' ? 'bg-green-600' : 'bg-blue-600';
  return (
    <div className={`toast-enter fixed top-4 right-4 z-50 ${bg} text-white px-4 py-2 rounded-lg shadow-lg flex items-center gap-2 text-sm`}>
      <span>{message}</span>
      <button onClick={onClose} className="ml-2 hover:opacity-70">&times;</button>
    </div>
  );
};

// --- ErrorBoundary ---
class ErrorBoundary extends React.Component {
  constructor(props) { super(props); this.state = { error: null }; }
  static getDerivedStateFromError(error) { return { error }; }
  render() {
    if (this.state.error) {
      return (
        <div className="flex items-center justify-center min-h-screen bg-cream dark:bg-ink p-8">
          <div className="bg-white dark:bg-card-dark rounded-xl p-8 shadow-lg max-w-lg">
            <h2 className="text-xl font-bold text-red-600 mb-2">Something went wrong</h2>
            <pre className="text-sm text-gray-600 dark:text-gray-400 whitespace-pre-wrap font-mono">{this.state.error.message}</pre>
            <button onClick={() => this.setState({ error: null })} className="mt-4 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm">Reload</button>
          </div>
        </div>
      );
    }
    return this.props.children;
  }
}

// --- StatusBadge ---
const StatusBadge = ({ status }) => (
  <span className={`inline-block px-2 py-0.5 rounded text-xs font-mono font-medium ${statusColor(status)}`}>{status}</span>
);

// --- LoadingSpinner ---
const LoadingSpinner = () => (
  <div className="flex items-center justify-center p-12">
    <div className="w-8 h-8 border-2 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
  </div>
);

// --- WelcomeScreen ---
const WelcomeScreen = ({ onLoad, showToast }) => {
  const [dragOver, setDragOver] = useState(false);
  const [pathInput, setPathInput] = useState('');
  const [loading, setLoading] = useState(false);
  const fileRef = useRef(null);

  const handleFile = async (file) => {
    setLoading(true);
    try {
      if (file.size > 50 * 1024 * 1024) {
        const form = new FormData();
        form.append('file', file);
        await fetch('/api/upload', { method: 'POST', body: form }).then(r => {
          if (!r.ok) throw new Error('Upload failed');
          return r.json();
        });
      } else {
        const text = await file.text();
        await api('/api/open-content', {
          method: 'POST',
          body: JSON.stringify({ content: text, filename: file.name }),
        });
      }
      onLoad();
    } catch (e) {
      showToast(e.message, 'error');
      if (fileRef.current) fileRef.current.value = '';
    }
    setLoading(false);
  };

  const handlePath = async () => {
    if (!pathInput.trim()) return;
    setLoading(true);
    try {
      await api('/api/open', { method: 'POST', body: JSON.stringify({ path: pathInput.trim() }) });
      onLoad();
    } catch (e) {
      showToast(e.message, 'error');
    }
    setLoading(false);
  };

  const handleDrop = (e) => {
    e.preventDefault();
    setDragOver(false);
    const file = e.dataTransfer.files[0];
    if (file) handleFile(file);
  };

  if (loading) return <LoadingSpinner />;

  return (
    <div className="flex flex-col items-center justify-center min-h-[70vh] px-4">
      <div className="text-center mb-8">
        <div className="flex items-center justify-center gap-3 mb-3">
          <Icon name="Shield" size={36} className="text-blue-600" />
          <h1 className="text-4xl font-bold text-ink dark:text-white tracking-tight">harscope</h1>
        </div>
        <p className="text-gray-500 dark:text-gray-400 text-lg">HAR File Analyzer &amp; Sanitizer</p>
      </div>

      <div
        className={`w-full max-w-lg border-2 border-dashed rounded-xl p-12 text-center transition-colors cursor-pointer
          ${dragOver ? 'drop-active border-blue-500' : 'border-gray-300 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500'}
          bg-white/50 dark:bg-white/5`}
        onDragOver={(e) => { e.preventDefault(); setDragOver(true); }}
        onDragLeave={() => setDragOver(false)}
        onDrop={handleDrop}
        onClick={() => fileRef.current?.click()}
      >
        <Icon name="FileUp" size={48} className="text-gray-400 mx-auto mb-4" />
        <p className="text-gray-600 dark:text-gray-300 font-medium mb-1">Drop a .har file here or click to browse</p>
        <p className="text-gray-400 dark:text-gray-500 text-sm">No file size limit</p>
        <input ref={fileRef} type="file" accept=".har" className="hidden" onChange={(e) => e.target.files[0] && handleFile(e.target.files[0])} />
      </div>

      <div className="flex items-center gap-3 mt-6 w-full max-w-lg">
        <input
          value={pathInput}
          onChange={(e) => setPathInput(e.target.value)}
          onKeyDown={(e) => e.key === 'Enter' && handlePath()}
          placeholder="Or enter a file path..."
          className="flex-1 px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm text-ink dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button onClick={handlePath} className="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">Open</button>
      </div>
    </div>
  );
};

