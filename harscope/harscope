            f'**Findings:** {sev["total"]}',
            '',
            '---',
            '',
            '## Risk Assessment',
            '',
            f'**{_md(report["riskLevel"])}** — {_md(report["riskDetail"])}',
            '',
            '## Executive Summary',
            '',
            '| Metric | Value |',
            '|--------|-------|',
            f'| Critical Findings | {sev["critical"]} |',
            f'| Warning Findings | {sev["warning"]} |',
            f'| Info Findings | {sev["info"]} |',
            f'| Manual Redactions | {report["redaction"]["manualRedacted"]} |',
            f'| Total Requests | {stats.get("totalRequests", 0)} |',
