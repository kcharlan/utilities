// --- ExportView ---
const ExportView = ({ showToast }) => {
  const [security, setSecurity] = useState(null);
  const [exporting, setExporting] = useState(false);
  const [validating, setValidating] = useState(false);
  const [validationResult, setValidationResult] = useState(null);

  useEffect(() => { api('/api/security').then(setSecurity); }, []);

  const handleBulk = async (action, severity) => {
    await api('/api/security/bulk', { method: 'POST', body: JSON.stringify({ action, severity }) });
    const fresh = await api('/api/security');
    setSecurity(fresh);
  };

  const doExport = async (type) => {
    setExporting(true);
    try {
      let url, filename;
      if (type === 'har') {
        url = '/api/export/har';
        filename = 'sanitized.har';
      } else if (type === 'edl') {
        url = '/api/export/edl';
        filename = 'sanitized.edl.json';
      } else if (type === 'csv') {
        url = '/api/export/csv';
        filename = 'export.csv';
      } else if (type === 'md') {
        url = '/api/export/report';
        filename = 'report.md';
      } else {
        url = '/api/export/report';
        filename = 'report.html';
      }

      const body = type === 'html' ? JSON.stringify({ format: 'html' }) : (type === 'md' ? JSON.stringify({ format: 'md' }) : '{}');
      const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body });
      const disposition = res.headers.get('Content-Disposition');
      if (disposition) {
        const fnMatch = disposition.match(/filename="?([^";]+)"?/);
        if (fnMatch) filename = fnMatch[1];
      }
      const blob = await res.blob();
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      a.click();
      URL.revokeObjectURL(a.href);
      showToast(`Exported ${type.toUpperCase()}`, 'success');
    } catch (e) {
      showToast(e.message, 'error');
    }
    setExporting(false);
  };

  const handleValidate = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json,.edl.json';
    input.onchange = async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      setValidating(true);
      setValidationResult(null);
      try {
        const formData = new FormData();
        formData.append('file', file);
        const res = await fetch('/api/validate', { method: 'POST', body: formData });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.detail || 'Validation failed');
        }
        const result = await res.json();
        setValidationResult(result);
        if (result.summary.valid) {
          showToast('Validation passed', 'success');
        } else {
          showToast(`Validation: ${result.summary.fail} failures, ${result.summary.error} errors`, 'error');
        }
      } catch (e) {
        showToast(e.message, 'error');
      }
      setValidating(false);
    };
    input.click();
  };

  if (!security) return <LoadingSpinner />;

  const autoRedactCount = security.findings.filter(f => f.redact).length;
  const manualRedactions = security.manualRedactions || [];
  const manualRedactCount = manualRedactions.filter(m => m.redact).length;
  const totalRedactCount = autoRedactCount + manualRedactCount;

  return (
    <div className="p-6 overflow-auto h-full max-w-3xl mx-auto">
      <h2 className="text-lg font-bold text-ink dark:text-white mb-4">Export</h2>

      {/* Redaction summary */}
      <div className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 mb-6">
        <h3 className="text-sm font-semibold text-ink dark:text-white mb-3">Redaction Summary</h3>
        <p className="text-xs text-gray-500 dark:text-gray-400 mb-3">
          {autoRedactCount} auto{manualRedactCount > 0 ? ` + ${manualRedactCount} manual` : ''} = {totalRedactCount} value{totalRedactCount !== 1 ? 's' : ''} will be redacted
        </p>
        <div className="flex gap-2 mb-3">
          <button onClick={() => handleBulk('select')} className="px-3 py-1 text-xs bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300 rounded hover:bg-red-200">Select All</button>
          <button onClick={() => handleBulk('deselect')} className="px-3 py-1 text-xs bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300 rounded hover:bg-gray-200">Deselect All</button>
        </div>
        <div className="flex gap-2 flex-wrap">
          {['critical', 'warning', 'info'].map(sev => {
            const count = security.findings.filter(f => f.severity === sev).length;
            const activeCount = security.findings.filter(f => f.severity === sev && f.redact).length;
            return (
              <div key={sev} className="flex items-center gap-2 text-xs">
                <span className={`capitalize ${severityColor(sev)}`}>{sev}: {activeCount}/{count}</span>
                <button onClick={() => handleBulk('select', sev)} className="text-blue-500 hover:underline">all</button>
                <button onClick={() => handleBulk('deselect', sev)} className="text-gray-400 hover:underline">none</button>
              </div>
            );
          })}
        </div>
      </div>

      {/* Export buttons */}
      <div className="grid grid-cols-2 gap-4 mb-6">
        <button onClick={() => doExport('har')} disabled={exporting}
          className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 transition-colors text-left disabled:opacity-50">
          <div className="flex items-center gap-2 mb-1"><Icon name="Shield" size={16} className="text-green-600" /><span className="font-medium text-sm text-ink dark:text-white">Sanitized HAR</span></div>
          <p className="text-xs text-gray-500">Download HAR with {totalRedactCount} values redacted</p>
        </button>
        <button onClick={() => doExport('edl')} disabled={exporting}
          className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 transition-colors text-left disabled:opacity-50">
          <div className="flex items-center gap-2 mb-1"><Icon name="ClipboardList" size={16} className="text-amber-600" /><span className="font-medium text-sm text-ink dark:text-white">Edit Decision List</span></div>
          <p className="text-xs text-gray-500">JSON decisions log (.edl.json) — {totalRedactCount} redacted, {security.findings.length - autoRedactCount} kept</p>
        </button>
        <button onClick={() => doExport('csv')} disabled={exporting}
          className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 transition-colors text-left disabled:opacity-50">
          <div className="flex items-center gap-2 mb-1"><Icon name="Table" size={16} className="text-blue-600" /><span className="font-medium text-sm text-ink dark:text-white">CSV Export</span></div>
          <p className="text-xs text-gray-500">Entry summaries as spreadsheet</p>
        </button>
        <button onClick={() => doExport('md')} disabled={exporting}
          className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 transition-colors text-left disabled:opacity-50">
          <div className="flex items-center gap-2 mb-1"><Icon name="FileText" size={16} className="text-purple-600" /><span className="font-medium text-sm text-ink dark:text-white">Markdown Report</span></div>
          <p className="text-xs text-gray-500">Analysis summary with stats and findings</p>
        </button>
        <button onClick={() => doExport('html')} disabled={exporting}
          className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 transition-colors text-left disabled:opacity-50">
          <div className="flex items-center gap-2 mb-1"><Icon name="Globe" size={16} className="text-orange-600" /><span className="font-medium text-sm text-ink dark:text-white">HTML Report</span></div>
          <p className="text-xs text-gray-500">Shareable HTML report with formatting</p>
        </button>
      </div>

      {/* Validate EDL */}
      <div className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 mb-6">
        <h3 className="text-sm font-semibold text-ink dark:text-white mb-2">Validate EDL</h3>
        <p className="text-xs text-gray-500 dark:text-gray-400 mb-3">
          Load a sanitized HAR, then upload the .edl.json to verify all redact/keep decisions were applied correctly.
        </p>
        <button onClick={handleValidate} disabled={validating}
          className="px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 flex items-center gap-2">
          <Icon name="CheckCircle" size={16} />
          {validating ? 'Validating...' : 'Upload EDL to Validate'}
        </button>
      </div>

      {/* Validation results */}
      {validationResult && (
        <div className="bg-white dark:bg-card-dark rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700">
          <div className="flex items-center gap-3 mb-4">
            <h3 className="text-sm font-semibold text-ink dark:text-white">Validation Results</h3>
            {validationResult.summary.valid ? (
              <span className="px-2 py-0.5 text-xs font-bold rounded bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300">VALID</span>
            ) : (
              <span className="px-2 py-0.5 text-xs font-bold rounded bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300">INVALID</span>
            )}
            <span className="text-xs text-gray-500 dark:text-gray-400 ml-auto">
              {validationResult.summary.pass} pass, {validationResult.summary.fail} fail, {validationResult.summary.error} error
            </span>
          </div>

          {validationResult.results.length > 0 && (
            <div className="overflow-x-auto">
              <table className="w-full text-xs">
                <thead>
                  <tr className="border-b border-gray-200 dark:border-gray-700 text-left">
                    <th className="py-1 px-2 font-medium text-gray-500 dark:text-gray-400">Status</th>
                    <th className="py-1 px-2 font-medium text-gray-500 dark:text-gray-400">#</th>
                    <th className="py-1 px-2 font-medium text-gray-500 dark:text-gray-400">Action</th>
                    <th className="py-1 px-2 font-medium text-gray-500 dark:text-gray-400">Area</th>
                    <th className="py-1 px-2 font-medium text-gray-500 dark:text-gray-400">Key</th>
                    <th className="py-1 px-2 font-medium text-gray-500 dark:text-gray-400">Detail</th>
                  </tr>
                </thead>
                <tbody>
                  {validationResult.results.map((r, i) => {
                    const statusColors = {
                      pass: 'text-green-600 dark:text-green-400',
                      fail: 'text-red-600 dark:text-red-400',
                      error: 'text-amber-600 dark:text-amber-400',
                    };
                    return (
                      <tr key={i} className="border-b border-gray-100 dark:border-gray-800">
                        <td className={`py-1 px-2 font-bold uppercase ${statusColors[r.status] || ''}`}>{r.status}</td>
                        <td className="py-1 px-2 font-mono">{r.entryIndex}</td>
                        <td className="py-1 px-2">{r.action}</td>
                        <td className="py-1 px-2">{r.side} &gt; {r.area}</td>
                        <td className="py-1 px-2 font-mono">{r.key}</td>
                        <td className="py-1 px-2 text-gray-500 dark:text-gray-400">{r.detail}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}
    </div>
  );
};

// --- DecisionsView (Edit Decision List) ---
const DecisionsView = ({ onInspect, onRefreshSecurity }) => {
  const [data, setData] = useState(null);
  const [filterAction, setFilterAction] = useState('');
  const [filterType, setFilterType] = useState('');
  const [filterArea, setFilterArea] = useState('');

  const fetchData = useCallback(() => {
    api('/api/redaction/decisions').then(setData);
  }, []);
  useEffect(() => { fetchData(); }, []);

  const handleToggle = useCallback(async (d) => {
    const entryIndex = d.entry.entryIndex;
    if (d.type === 'auto') {
      // Find the finding id - look it up by location
      const secData = await api('/api/security');
      const finding = secData.findings.find(f => f.entryIndex === entryIndex && f.location === d.location);
      if (finding) {
        await api('/api/security/toggle', { method: 'POST', body: JSON.stringify({ id: finding.id }) });
      }
    } else {
      // Manual — remove it
      await api('/api/redaction/remove-manual', { method: 'POST', body: JSON.stringify({ entryIndex, location: d.location }) });
    }
    if (onRefreshSecurity) onRefreshSecurity();
    fetchData();
  }, [fetchData, onRefreshSecurity]);

  if (!data) return <LoadingSpinner />;

  const decisions = data.decisions;
  const redactCount = decisions.filter(d => d.redact).length;
  const keepCount = decisions.filter(d => !d.redact).length;
  const manualCount = decisions.filter(d => d.type === 'manual').length;
  const areas = [...new Set(decisions.map(d => d.area))].sort();

  let filtered = decisions;
  if (filterAction === 'redact') filtered = filtered.filter(d => d.redact);
  else if (filterAction === 'keep') filtered = filtered.filter(d => !d.redact);
  if (filterType === 'auto') filtered = filtered.filter(d => d.type === 'auto');
  else if (filterType === 'manual') filtered = filtered.filter(d => d.type === 'manual');
  if (filterArea) filtered = filtered.filter(d => d.area === filterArea);

  const actionBadge = (d) => {
    if (d.type === 'manual' && d.redact) return { label: 'REDACT', cls: 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300' };
    if (d.redact) return { label: 'REDACT', cls: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300' };
    return { label: 'KEEP', cls: 'bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-300' };
  };

  return (
    <div className="flex flex-col h-full">
      <div className="px-4 py-3 bg-white/80 dark:bg-card-dark/80 border-b border-gray-200 dark:border-gray-700 flex items-center gap-4 flex-wrap">
        <div className="flex gap-3">
          <span className="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300">
            <Icon name="ShieldOff" size={12} /> {redactCount} Redact
          </span>
          <span className="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-300">
            <Icon name="ShieldCheck" size={12} /> {keepCount} Keep
          </span>
          {manualCount > 0 && (
