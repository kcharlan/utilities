def _expand_json_key_path(keys):
    """Expand key path segments like 'modifications[0]' into ['modifications', '[0]'].

    Scanner location paths after (parsed). look like:
      modifications[0].args[0].sessionId
    After split('.') we get ['modifications[0]', 'args[0]', 'sessionId'].
    This function expands those into individual navigation steps:
      ['modifications', '[0]', 'args', '[0]', 'sessionId']
    """
    expanded = []
    for k in keys:
        if '[' in k and not k.startswith('['):
            # e.g. 'modifications[0]' -> 'modifications', '[0]'
            parts = k.split('[', 1)
            expanded.append(parts[0])
            expanded.append('[' + parts[1])
        else:
            expanded.append(k)
    return expanded


_MISSING = object()


def _navigate_json_path(obj, keys):
    """Navigate a parsed JSON object along expanded key path.

    Returns (parent, target_key) or (None, None) if navigation fails.
    Keys should be pre-expanded via _expand_json_key_path.
    """
    current = obj
    for key in keys[:-1]:
        if key.startswith('[') and key.endswith(']'):
            try:
                current = current[int(key[1:-1])]
            except (ValueError, IndexError, TypeError):
                return None, None
        elif isinstance(current, dict):
            current = current.get(key, _MISSING)
            if current is _MISSING:
                return None, None
        else:
            return None, None
    return (current, keys[-1]) if keys else (None, None)


class ExportEngine:
    @staticmethod
    def sanitized_har(har: HARManager, scanner: SecurityScanner) -> dict:
        data = copy.deepcopy(har.raw_data)
        entries = data['log']['entries']

        for finding in scanner.findings:
            if not finding['redact']:
                continue
            idx = finding['entryIndex']
            if idx >= len(entries):
                continue
            entry = entries[idx]
            loc = finding['location']
            ExportEngine._redact_location(entry, loc, finding)

        # Apply manual redactions
        for key, manual in scanner.manual_redactions.items():
            if not manual['redact']:
                continue
            entry_index, location = key
            if entry_index >= len(entries):
                continue
            ExportEngine._redact_location(entries[entry_index], location, manual)

        return data

    @staticmethod
    def _redact_location(entry: dict, location: str, finding: dict = None):
        """Redact a value at the given scanner path.

        Scanner paths look like:
          entries[N].request.headers[2].Authorization
          entries[N].response.cookies[0].session_id
          entries[N].request.postData.text(parsed).prepare_token
          entries[N]._webSocketMessages[3].data(parsed).token
          entries[N].request.queryString[0].api_key
        """
        # Strip the entries[N]. prefix to get the path relative to the entry
        loc = location
        if loc.startswith('entries['):
            dot_pos = loc.find('.')
            if dot_pos >= 0:
                loc = loc[dot_pos + 1:]

        # Body content with (parsed) - needs JSON parse/modify/reserialize
        if '(parsed)' in loc:
            ExportEngine._redact_body_value(entry, location, finding)
            return

        # Navigate the entry dict using the path segments to find and redact
        # For name/value pairs (headers, cookies, queryString, params),
        # the last segment is the semantic name, not a dict key.
        # e.g. "request.headers[2].Authorization" means headers[2] has
        # name=Authorization and we redact its value.
        segments = loc.replace(']', '').split('.')
        current = entry
        for i, seg in enumerate(segments[:-1]):
            if '[' in seg:
                key, idx_str = seg.split('[', 1)
                current = current.get(key, []) if isinstance(current, dict) else current
                try:
                    current = current[int(idx_str)]
                except (IndexError, ValueError, TypeError):
                    return
            elif isinstance(current, dict):
                current = current.get(seg)
            else:
                return
            if current is None:
                return

        # At this point, current is the container, last segment is the key/name
        target = segments[-1]

        # If current is a name/value dict (header, cookie, param), redact value
        if isinstance(current, dict) and 'name' in current and 'value' in current:
            current['value'] = '[REDACTED]'
        elif isinstance(current, dict) and target in current:
            current[target] = '[REDACTED]'
        elif isinstance(current, list):
            # Look for name/value item with matching name
            for item in current:
                if isinstance(item, dict) and item.get('name', '').lower() == target.lower():
                    item['value'] = '[REDACTED]'

    @staticmethod
    def _redact_body_value(entry: dict, location: str, finding: dict):
        """Redact a specific value found inside a JSON body.

        Parses the body JSON, navigates to the target key extracted from the
        finding's location path, replaces the entire value with [REDACTED],
        then re-serializes the body.
        """
        if not finding:
            return

        # Strip (base64) suffix — the redaction target is the container key, not the decoded content
        location = location.replace('(base64)', '')

        # Determine which body text to modify
        loc_lower = location.lower()
        container = None
        text_key = 'text'
        if '_websocketmessages' in loc_lower:
            # WebSocket message body — container is the message dict, field is 'data'
            ws_match = re.search(r'_webSocketMessages\[(\d+)\]', location, re.IGNORECASE)
            if ws_match:
                ws_idx = int(ws_match.group(1))
                ws_msgs = entry.get('_webSocketMessages', [])
                if ws_idx < len(ws_msgs):
                    container = ws_msgs[ws_idx]
                    text_key = 'data'
        elif 'request' in loc_lower and 'postdata' in loc_lower:
            container = entry.get('request', {}).get('postData', {})
        elif 'response' in loc_lower and ('content' in loc_lower or 'body' in loc_lower):
            container = entry.get('response', {}).get('content', {})
        else:
            # Try both
            for section_key in ('request', 'response'):
                section = entry.get(section_key, {})
                for body_key in ('postData', 'content'):
                    c = section.get(body_key, {})
                    if isinstance(c, dict) and c.get('text'):
                        container = c
                        break
                if container:
                    break

        if not container or not isinstance(container, dict):
            return
        body_text = container.get(text_key, '')
        if not body_text:
            return

        # Extract the target key path from the location.
        # Location looks like: entries[N].request.postData.text(parsed).keyName
        # or nested: entries[N].request.postData.text(parsed).obj.keyName
        # We need the parts after '(parsed).'
        parsed_idx = location.find('(parsed).')
        if parsed_idx >= 0:
            key_path = location[parsed_idx + 9:]  # after '(parsed).'
            # Remove any further (parsed) suffixes
            key_path = key_path.replace('(parsed)', '')
            keys = [k for k in key_path.split('.') if k]
        else:
            # No parsed path - try using the last segment as key name
            parts = location.split('.')
            last = parts[-1] if parts else ''
            keys = [last] if last else []

        if not keys:
            return

        # Parse the body JSON and navigate to the target key
        try:
            body_obj = json.loads(body_text)
        except (json.JSONDecodeError, ValueError):
            return

        if not isinstance(body_obj, (dict, list)):
            return

        # Expand key segments with embedded array indices (e.g. modifications[0] -> modifications, [0])
        keys = _expand_json_key_path(keys)

        # Navigate to the parent and redact the target key's value
        current, target_key = _navigate_json_path(body_obj, keys)
        if current is None:
            return

        if isinstance(current, dict) and target_key in current:
            current[target_key] = '[REDACTED]'
            container[text_key] = json.dumps(body_obj, separators=(',', ':'))
        elif target_key and target_key.startswith('[') and target_key.endswith(']') and isinstance(current, list):
            try:
                idx = int(target_key[1:-1])
                current[idx] = '[REDACTED]'
                container[text_key] = json.dumps(body_obj, separators=(',', ':'))
            except (ValueError, IndexError):
                pass

    @staticmethod
    def csv_export(har: HARManager, scanner: SecurityScanner = None) -> str:
        output = io.StringIO()
        writer = csv.writer(output)
        # Build per-entry finding counts
        entry_findings = defaultdict(lambda: {'total': 0, 'critical': 0, 'warning': 0})
        if scanner:
            for f in scanner.findings:
                idx = f['entryIndex']
                entry_findings[idx]['total'] += 1
                if f['severity'] == 'critical':
                    entry_findings[idx]['critical'] += 1
                elif f['severity'] == 'warning':
                    entry_findings[idx]['warning'] += 1

        writer.writerow(['Index', 'Method', 'URL', 'Status', 'Domain', 'Content-Type',
                         'Size (bytes)', 'Time (ms)', 'Finding Count', 'Critical Count',
                         'Warning Count', 'Has WebSocket', 'WS Message Count'])
        for i, s in enumerate(har._summaries):
            entry = har.entries[i] if i < len(har.entries) else {}
            ws_msgs = entry.get('_webSocketMessages', [])
            ef = entry_findings[s['index']]
            writer.writerow([s['index'], s['method'], s['url'], s['status'],
                             s['domain'], s['contentType'], s['bodySize'], s['time'],
                             ef['total'], ef['critical'], ef['warning'],
                             'yes' if ws_msgs else 'no', len(ws_msgs)])
        return output.getvalue()

    @staticmethod
    def csv_findings_export(har: HARManager, scanner: SecurityScanner) -> str:
        """Export security findings as CSV."""
        output = io.StringIO()
        writer = csv.writer(output)
        writer.writerow(['Finding ID', 'Severity', 'Category', 'Description', 'Preview',
                         'Domain', 'Entry Index', 'Method', 'URL Path', 'Status',
                         'Side', 'Area', 'Key Name', 'Location', 'Action', 'Source'])

        def parse_loc(loc):
            parts = loc.lower()
            side = 'response' if '.response.' in parts or ('.content' in parts and '(parsed)' in parts) else 'request'
            area = 'other'
            if 'header' in parts or '.headers' in parts: area = 'headers'
            elif 'cookie' in parts: area = 'cookies'
            elif 'querystring' in parts: area = 'query'
            elif 'postdata' in parts or 'content' in parts or '(parsed)' in parts: area = 'body'
            elif '_websocketmessages' in parts: side = 'websocket'; area = 'message'
            segs = loc.split('.')
            key = segs[-1].split('[')[0].replace('(parsed)', '').replace('(base64)', '')
            if key in ('text', 'value', 'data', ''):
                key = segs[-2].split('[')[0].replace('(parsed)', '').replace('(base64)', '') if len(segs) >= 2 else key
            return side, area, key

        for f in scanner.findings:
            side, area, key = parse_loc(f['location'])
            entry_ctx = {}
            if f['entryIndex'] < len(har._summaries):
                s = har._summaries[f['entryIndex']]
                entry_ctx = {'domain': s['domain'], 'method': s['method'],
                             'path': urlparse(s['url']).path or '/', 'status': s['status']}
            action = 'redact' if f['redact'] else 'keep'
            writer.writerow([
                f['id'], f['severity'], f['category'], f['description'], f['preview'],
                entry_ctx.get('domain', ''), f['entryIndex'],
                entry_ctx.get('method', ''), entry_ctx.get('path', ''),
                entry_ctx.get('status', ''),
                side, area, key, f['location'], action, 'auto',
            ])

        # Include manual redactions
        for (entry_index, loc), m in scanner.manual_redactions.items():
            side, area, key = parse_loc(loc)
            entry_ctx = {}
            if entry_index < len(har._summaries):
                s = har._summaries[entry_index]
                entry_ctx = {'domain': s['domain'], 'method': s['method'],
                             'path': urlparse(s['url']).path or '/', 'status': s['status']}
            action = 'redact' if m['redact'] else 'keep'
            writer.writerow([
                '', '', 'Manual', '', m['preview'],
                entry_ctx.get('domain', ''), entry_index,
                entry_ctx.get('method', ''), entry_ctx.get('path', ''),
                entry_ctx.get('status', ''),
                side, area, key, loc, action, 'manual',
            ])

        return output.getvalue()

    @staticmethod
    def edl_export(har: HARManager, scanner: SecurityScanner) -> str:
        """Export an Edit Decision List as JSON (.edl.json)."""
        summaries = har._summaries

        def entry_context(idx):
            if idx < len(summaries):
                s = summaries[idx]
                path = urlparse(s['url']).path or '/'
                if len(path) > 50:
                    path = path[:47] + '...'
                return {
                    'method': s['method'],
                    'domain': s['domain'],
                    'path': path,
                    'status': s['status'],
                }
            return {'method': '?', 'domain': '?', 'path': '?', 'status': 0}

        def parse_loc(loc):
            parts = loc.lower()
            side = 'response' if '.response.' in parts or ('.content' in parts and '(parsed)' in parts) else 'request'
            area = 'other'
            if 'header' in parts or '.headers' in parts: area = 'headers'
            elif 'cookie' in parts: area = 'cookies'
            elif 'querystring' in parts: area = 'query'
            elif 'postdata' in parts or 'content' in parts or '(parsed)' in parts: area = 'body'
            elif '_websocketmessages' in parts: side = 'websocket'; area = 'message'
            segs = loc.split('.')
            key = segs[-1].split('[')[0].replace('(parsed)', '').replace('(base64)', '')
            if key in ('text', 'value', 'data', ''):
                key = segs[-2].split('[')[0].replace('(parsed)', '').replace('(base64)', '') if len(segs) >= 2 else key
            return side, area, key

        decisions = []
        for f in scanner.findings:
            side, area, key = parse_loc(f['location'])
            decisions.append({
                'entryIndex': f['entryIndex'],
                'location': f['location'],
                'action': 'redact' if f['redact'] else 'keep',
                'source': 'auto',
                'preview': f['preview'],
                'side': side,
                'area': area,
                'key': key,
                'severity': f.get('severity'),
                'category': f.get('category'),
                'entry': entry_context(f['entryIndex']),
            })
        for (entry_index, loc), m in scanner.manual_redactions.items():
            side, area, key = parse_loc(loc)
            decisions.append({
                'entryIndex': entry_index,
                'location': loc,
                'action': 'redact' if m['redact'] else 'keep',
                'source': 'manual',
                'preview': m['preview'],
                'side': side,
                'area': area,
                'key': key,
                'severity': None,
                'category': 'Manual',
                'entry': entry_context(entry_index),
            })

        auto_redact = sum(1 for d in decisions if d['source'] == 'auto' and d['action'] == 'redact')
        auto_keep = sum(1 for d in decisions if d['source'] == 'auto' and d['action'] == 'keep')
        manual_redact = sum(1 for d in decisions if d['source'] == 'manual' and d['action'] == 'redact')

        edl = {
            'version': 1,
            'generator': 'harscope',
            'generated': datetime.now().strftime('%Y-%m-%dT%H:%M:%S'),
            'sourceFile': har.file_name,
            'summary': {
                'totalDecisions': len(decisions),
                'autoRedacted': auto_redact,
                'autoKept': auto_keep,
                'manualRedacted': manual_redact,
            },
            'decisions': decisions,
        }
        return json.dumps(edl, indent=2)

    @staticmethod
    def validate_edl(har_data: dict, edl_data: dict) -> dict:
        """Validate a sanitized HAR against an EDL.

        For each decision in the EDL:
        - action=redact: value in HAR should be '[REDACTED]'
        - action=keep: value in HAR should NOT be '[REDACTED]'

        Returns a dict with 'results' list and 'summary'.
        """
        entries = har_data.get('log', {}).get('entries', [])
        results = []

        for d in edl_data.get('decisions', []):
            entry_index = d.get('entryIndex', -1)
            location = d.get('location', '')
            action = d.get('action', '')
            result = {
                'entryIndex': entry_index,
                'location': location,
                'action': action,
                'source': d.get('source', ''),
                'key': d.get('key', ''),
                'side': d.get('side', ''),
                'area': d.get('area', ''),
                'entry': d.get('entry', {}),
            }

            if entry_index < 0 or entry_index >= len(entries):
                result['status'] = 'error'
                result['detail'] = f'Entry index {entry_index} out of range'
                results.append(result)
                continue

            entry = entries[entry_index]
            value = ExportEngine._read_location_value(entry, location)

            if value is None:
                result['status'] = 'error'
                result['detail'] = 'Location not found in HAR'
            elif action == 'redact':
                if value == '[REDACTED]':
                    result['status'] = 'pass'
                    result['detail'] = 'Value is redacted'
                else:
                    result['status'] = 'fail'
                    result['detail'] = 'Expected [REDACTED] but value is present'
            elif action == 'keep':
                if value == '[REDACTED]':
                    result['status'] = 'fail'
                    result['detail'] = 'Value is [REDACTED] but should be kept'
                else:
                    result['status'] = 'pass'
                    result['detail'] = 'Value is present (not redacted)'
            else:
                result['status'] = 'error'
                result['detail'] = f'Unknown action: {action}'

            results.append(result)

        pass_count = sum(1 for r in results if r['status'] == 'pass')
        fail_count = sum(1 for r in results if r['status'] == 'fail')
        error_count = sum(1 for r in results if r['status'] == 'error')

        return {
            'results': results,
            'summary': {
                'total': len(results),
                'pass': pass_count,
                'fail': fail_count,
                'error': error_count,
                'valid': fail_count == 0 and error_count == 0,
            },
        }

    @staticmethod
    def _read_location_value(entry: dict, location: str):
        """Read the current value at a scanner location path. Returns None if not found."""
        # Strip (base64) suffix — the value lives at the container key
        location = location.replace('(base64)', '')
        loc = location
        if loc.startswith('entries['):
            dot_pos = loc.find('.')
            if dot_pos >= 0:
                loc = loc[dot_pos + 1:]

        # Body with (parsed) — parse JSON and navigate
        if '(parsed)' in loc:
            loc_lower = location.lower()
            container = None
            text_key = 'text'
            if '_websocketmessages' in loc_lower:
                ws_match = re.search(r'_webSocketMessages\[(\d+)\]', location, re.IGNORECASE)
                if ws_match:
                    ws_idx = int(ws_match.group(1))
                    ws_msgs = entry.get('_webSocketMessages', [])
                    if ws_idx < len(ws_msgs):
                        container = ws_msgs[ws_idx]
                        text_key = 'data'
            elif 'request' in loc_lower and 'postdata' in loc_lower:
                container = entry.get('request', {}).get('postData', {})
            elif 'response' in loc_lower and ('content' in loc_lower or 'body' in loc_lower):
                container = entry.get('response', {}).get('content', {})
            else:
                for section_key in ('request', 'response'):
                    section = entry.get(section_key, {})
                    for body_key in ('postData', 'content'):
                        c = section.get(body_key, {})
                        if isinstance(c, dict) and c.get('text'):
                            container = c
                            break
                    if container:
                        break
            if not container or not isinstance(container, dict):
                return None
            body_text = container.get(text_key, '')
            if not body_text:
                return None
            parsed_idx = location.find('(parsed).')
            if parsed_idx >= 0:
                key_path = location[parsed_idx + 9:].replace('(parsed)', '')
                keys = [k for k in key_path.split('.') if k]
            else:
                parts = location.split('.')
                keys = [parts[-1]] if parts else []
            if not keys:
                return None
            try:
                body_obj = json.loads(body_text)
            except (json.JSONDecodeError, ValueError):
                return None
            keys = _expand_json_key_path(keys)
            current, target_key = _navigate_json_path(body_obj, keys)
            if current is None:
                return None
            if isinstance(current, dict) and target_key in current:
                return current[target_key]
            elif target_key and target_key.startswith('[') and target_key.endswith(']') and isinstance(current, list):
                try:
                    return current[int(target_key[1:-1])]
                except (ValueError, IndexError):
                    return None
            return None

        # Non-body: navigate entry dict
        segments = loc.replace(']', '').split('.')
        current = entry
        for seg in segments[:-1]:
            if '[' in seg:
                key, idx_str = seg.split('[', 1)
                current = current.get(key, []) if isinstance(current, dict) else current
                try:
                    current = current[int(idx_str)]
                except (IndexError, ValueError, TypeError):
                    return None
            elif isinstance(current, dict):
                current = current.get(seg)
            else:
                return None
            if current is None:
                return None

        target = segments[-1]
        if isinstance(current, dict) and 'name' in current and 'value' in current:
            return current['value']
        elif isinstance(current, dict) and target in current:
            return current[target]
        elif isinstance(current, list):
            for item in current:
                if isinstance(item, dict) and item.get('name', '').lower() == target.lower():
                    return item.get('value')
        return None

    @staticmethod
    def _fmt_size(b: int) -> str:
        """Format byte count as human-readable size."""
        if b < 0:
            return 'unknown'
        if b < 1024:
            return f'{b} B'
        elif b < 1024 * 1024:
            return f'{b / 1024:.1f} KB'
        elif b < 1024 * 1024 * 1024:
            return f'{b / (1024 * 1024):.1f} MB'
        return f'{b / (1024 * 1024 * 1024):.1f} GB'

    @staticmethod
    def _fmt_time(ms: float) -> str:
        """Format milliseconds as human-readable time."""
        if ms < 0:
            return 'unknown'
        if ms < 1000:
            return f'{ms:.0f} ms'
        elif ms < 60000:
            return f'{ms / 1000:.1f}s'
        return f'{ms / 60000:.1f}m'

    @staticmethod
    def summary_report(har: HARManager, scanner: SecurityScanner, fmt: str = 'md') -> str:
        stats = har.get_stats()
        report = scanner.get_report_data(har)
        sev = report['severity']
        ts = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

        if fmt == 'md':
            return ExportEngine._markdown_report(har, stats, report, sev, ts)
        else:
            return ExportEngine._html_report(har, stats, report, sev, ts)

    @staticmethod
