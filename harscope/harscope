        # Findings by Category
        if report['categories']:
            lines += [
                '', '---', '',
                '## Findings by Category',
                '',
                '| Category | Critical | Warning | Info | Total | Top Domain |',
                '|----------|----------|---------|------|-------|------------|',
            ]
            for c in report['categories']:
                lines.append(
                    f'| {_md(c["category"])} '
                    f'| {c["critical"] or "—"} '
                    f'| {c["warning"] or "—"} '
                    f'| {c["info"] or "—"} '
                    f'| **{c["total"]}** '
                    f'| {_md(c["topDomain"])} |'
                )

        # Findings by Location
        if report['locations']:
            lines += [
                '', '---', '',
                '## Findings by Location',
                '',
                '| Location | Count | Pct | Highest Severity |',
                '|----------|-------|-----|------------------|',
            ]
            for loc in report['locations']:
                lines.append(f'| {_md(loc["area"])} | {loc["count"]} | {loc["pct"]}% | {_md(loc["highestSeverity"].title())} |')

        # Findings by Domain
        if report['domains']:
            lines += [
                '', '---', '',
                '## Findings by Domain',
                '',
                '| Domain | Critical | Warning | Info | Total |',
                '|--------|----------|---------|------|-------|',
            ]
            for d in report['domains']:
                lines.append(
                    f'| {_md(d["domain"])} '
                    f'| {d["critical"] or "—"} '
                    f'| {d["warning"] or "—"} '
                    f'| {d["info"] or "—"} '
                    f'| **{d["total"]}** |'
                )

        # Coverage Statistics
        cov = report['coverage']
        lines += [
            '', '---', '',
            '## Coverage Statistics',
            '',
            f'- **Requests with findings:** {cov["entriesWithFindings"]} of {cov["totalEntries"]} ({cov["entriesWithFindingsPct"]}%)',
            f'- **Domains with findings:** {cov["domainsWithFindings"]} of {cov["totalDomains"]} ({cov["domainsWithFindingsPct"]}%)',
        ]
        if cov['totalWebSocket'] > 0:
            lines.append(
                f'- **WebSocket exposure:** {cov["webSocketWithFindings"]} of {cov["totalWebSocket"]} '
                f'connections contained secrets ({cov["webSocketWithFindingsPct"]}%)'
            )

        # Critical Findings Detail
        if report['criticalFindings']:
            lines += ['', '---', '', '## Critical Findings Detail', '']
            for i, cf in enumerate(report['criticalFindings'], 1):
                entry = cf.get('entry', {})
                domain = _md(entry.get('domain', '—'))
                lines.append(f'### {i}. {_md(cf["description"])} — {domain}')
                lines.append(f'- **Category:** {_md(cf["category"])}')
                lines.append(f'- **Location:** `{_md(cf["location"])}`')
