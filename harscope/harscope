@app.get("/api/redaction/decisions")
async def api_redaction_decisions():
    _require_file()
    decisions = []
    summaries = har_manager._summaries

    def _entry_context(idx):
        if idx < len(summaries):
            s = summaries[idx]
            path = urlparse(s['url']).path or '/'
            if len(path) > 50:
                path = path[:47] + '...'
            return {
                'entryIndex': idx,
                'method': s['method'],
                'path': path,
                'domain': s['domain'],
                'status': s['status'],
            }
        return {'entryIndex': idx, 'method': '?', 'path': '?', 'domain': '?', 'status': 0}

    def _parse_location(loc):
        """Parse a scanner location into human-readable section/area/keyName."""
        parts = loc.lower()
        side = 'response' if '.response.' in parts or ('.content' in parts and '(parsed)' in parts) else 'request'
        area = 'other'
        if 'header' in parts or '.headers' in parts:
            area = 'headers'
        elif 'cookie' in parts:
            area = 'cookies'
        elif 'querystring' in parts:
            area = 'query'
        elif 'postdata' in parts or 'content' in parts or '(parsed)' in parts:
            area = 'body'
        elif '_websocketmessages' in parts:
            side = 'websocket'
            area = 'message'
        # Extract key name: last segment, strip array indices and (parsed)
        segs = loc.split('.')
        key_name = segs[-1] if segs else ''
        key_name = key_name.split('[')[0].replace('(parsed)', '').replace('(base64)', '')
        if key_name in ('text', 'value', 'data', ''):
            key_name = segs[-2].split('[')[0].replace('(parsed)', '').replace('(base64)', '') if len(segs) >= 2 else key_name
        return side, area, key_name

    # Auto-detected findings
    for f in security_scanner.findings:
        side, area, key_name = _parse_location(f['location'])
        decisions.append({
            'type': 'auto',
            'redact': f['redact'],
            'severity': f['severity'],
            'category': f['category'],
            'keyName': key_name,
            'preview': f['preview'],
            'side': side,
            'area': area,
            'location': f['location'],
            'entry': _entry_context(f['entryIndex']),
        })

    # Manual redactions
    for key, m in security_scanner.manual_redactions.items():
        entry_index, loc = key
        side, area, key_name = _parse_location(loc)
        decisions.append({
            'type': 'manual',
            'redact': m['redact'],
            'severity': None,
            'category': 'Manual',
            'keyName': key_name,
            'preview': m['preview'],
            'side': side,
            'area': area,
            'location': loc,
            'entry': _entry_context(entry_index),
        })

    return {'decisions': decisions}


