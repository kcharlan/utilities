class SequenceBuilder:
    def build(self, entries: list, summaries: list, filters: dict = None) -> dict:
        indices = list(range(len(entries)))

        if filters:
            if filters.get('domain'):
                domain = filters['domain']
                indices = [i for i in indices if summaries[i]['domain'] == domain]
            if filters.get('flow'):
                flow_indices = self._get_flow_indices(entries, summaries, filters['flow'])
                indices = [i for i in indices if i in flow_indices]

        participants = ['Browser']
        participant_set = {'Browser'}
        messages = []

        for i in indices:
            entry = entries[i]
            summary = summaries[i]
            domain = summary['domain']
            if domain not in participant_set:
                participant_set.add(domain)
                participants.append(domain)

            method = summary['method']
            url_path = urlparse(summary['url']).path or '/'
            if len(url_path) > 60:
                url_path = url_path[:57] + '...'

            messages.append({
                'index': i,
                'from': 'Browser',
                'to': domain,
                'label': f'{method} {url_path}',
                'type': 'request',
                'status': summary['status'],
                'time': summary['time'],
            })
            messages.append({
                'index': i,
                'from': domain,
                'to': 'Browser',
                'label': f'{summary["status"]}',
                'type': 'response',
                'status': summary['status'],
                'time': summary['time'],
            })

        flows = self._detect_flows(entries, summaries)

        return {
            'participants': participants,
            'messages': messages,
            'flows': flows,
        }

    def _detect_flows(self, entries: list, summaries: list) -> List[dict]:
        flows = []

        # Detect redirect chains
        redirect_chains = []
        current_chain = []
        for i, s in enumerate(summaries):
            if 300 <= s['status'] < 400:
                current_chain.append(i)
            else:
                if current_chain:
                    current_chain.append(i)  # final destination
                    if len(current_chain) >= 2:
                        redirect_chains.append(current_chain)
                    current_chain = []
        for j, chain in enumerate(redirect_chains):
            flows.append({
                'id': f'redirect-{j}',
                'name': f'Redirect chain ({len(chain)} hops)',
                'type': 'redirect',
                'indices': chain,
            })

        # Detect OAuth flows
        oauth_indices = []
        for i, s in enumerate(summaries):
            url_lower = s['url'].lower()
            if any(k in url_lower for k in ['/oauth', '/authorize', '/token', '/callback', '/auth/']):
                oauth_indices.append(i)
        if len(oauth_indices) >= 2:
            flows.append({
                'id': 'oauth-0',
                'name': f'OAuth flow ({len(oauth_indices)} requests)',
                'type': 'oauth',
                'indices': oauth_indices,
            })

        # Detect API CRUD groups by path prefix
        api_paths = defaultdict(list)
        for i, s in enumerate(summaries):
            path = urlparse(s['url']).path or ''
            if '/api/' in path.lower():
                parts = path.split('/')
                if len(parts) >= 3:
                    prefix = '/'.join(parts[:4])
                    api_paths[prefix].append(i)
        for prefix, indices in api_paths.items():
            if len(indices) >= 3:
                flows.append({
                    'id': f'api-{hashlib.md5(prefix.encode()).hexdigest()[:8]}',
                    'name': f'API: {prefix} ({len(indices)} requests)',
                    'type': 'api',
                    'indices': indices,
                })

        return flows

    def _get_flow_indices(self, entries, summaries, flow_id) -> set:
        flows = self._detect_flows(entries, summaries)
        for f in flows:
            if f['id'] == flow_id:
                return set(f['indices'])
        return set()


