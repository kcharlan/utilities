#!/bin/bash
set -euo pipefail

PLAN_FILE="$1"
WORKSPACE="$2"

INPUT="$(grep '^INPUT:' "$PLAN_FILE" | head -n1 | cut -d: -f2- | xargs)"
OUTPUT="$(grep '^OUTPUT:' "$PLAN_FILE" | head -n1 | cut -d: -f2- | xargs)"
ARGS="$(grep '^FFMPEG_ARGS:' "$PLAN_FILE" | head -n1 | cut -d: -f2- | xargs)"

if [ -z "$INPUT" ] || [ -z "$OUTPUT" ]; then
  cat > "${PLAN_FILE%.plan.md}.status" <<EOF
STATUS: blocked
COMMITS: none
TESTS_RAN: none
TEST_RESULT: fail
BLOCKED_REASON: INPUT and OUTPUT must be provided in the plan file
EOF
  exit 1
fi

ffmpeg -y -i "$INPUT" $ARGS "$OUTPUT"

cat > "${PLAN_FILE%.plan.md}.status" <<EOF
STATUS: done
COMMITS: none
TESTS_RAN: none
TEST_RESULT: skip
NOTES: Transcode complete
EOF
