#!/bin/sh
set -eu

REPO_ROOT="${COGNITIVE_SWITCHYARD_REPO_ROOT:-}"

if [ -z "$REPO_ROOT" ]; then
  echo "COGNITIVE_SWITCHYARD_REPO_ROOT must point at the repository root for git-worktree isolation." >&2
  exit 1
fi

if ! git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Git worktree isolation requires COGNITIVE_SWITCHYARD_REPO_ROOT to point at a git repository." >&2
  exit 1
fi

BRANCH="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "Refusing to run claude-code on $BRANCH; use a feature branch first." >&2
  exit 1
fi

echo "Pack preflight passed for repository $REPO_ROOT on branch $BRANCH."
