#!/bin/sh
set -eu

SLOT_NUMBER="${1:?slot required}"
TASK_ID="${2:?task id required}"
WORKSPACE_PATH="${3:?workspace path required}"
FINAL_STATUS="${4:?final status required}"

REPO_ROOT="${COGNITIVE_SWITCHYARD_REPO_ROOT:-}"
BRANCH_MERGED=false

if [ -n "$REPO_ROOT" ]; then
  BRANCH_NAME="switchyard-$TASK_ID-$SLOT_NUMBER"

  if [ "$FINAL_STATUS" = "done" ]; then
    # Squash-merge the worktree branch back to the source branch
    SOURCE_BRANCH="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"

    if git -C "$REPO_ROOT" rev-parse --verify "$BRANCH_NAME" >/dev/null 2>&1; then
      MERGE_BASE="$(git -C "$REPO_ROOT" merge-base "$SOURCE_BRANCH" "$BRANCH_NAME" 2>/dev/null || true)"
      BRANCH_HEAD="$(git -C "$REPO_ROOT" rev-parse "$BRANCH_NAME" 2>/dev/null || true)"

      if [ -n "$MERGE_BASE" ] && [ -n "$BRANCH_HEAD" ] && [ "$MERGE_BASE" != "$BRANCH_HEAD" ]; then
        if git -C "$REPO_ROOT" merge --squash "$BRANCH_NAME" >/dev/null 2>&1; then
          git -C "$REPO_ROOT" commit -m "feat: merge task $TASK_ID from slot $SLOT_NUMBER" >/dev/null 2>&1
          MERGE_SHA="$(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || true)"
          if [ -n "$MERGE_SHA" ]; then
            echo "$MERGE_SHA"
          fi
          BRANCH_MERGED=true
        else
          # Merge conflict — abort and preserve branch for manual resolution
          git -C "$REPO_ROOT" merge --abort >/dev/null 2>&1 || git -C "$REPO_ROOT" reset --hard HEAD >/dev/null 2>&1
          echo "CONFLICT: merge of $BRANCH_NAME failed; branch preserved for manual resolution." >&2
        fi
      else
        # No new commits on the branch — safe to clean up
        BRANCH_MERGED=true
      fi
    fi
  fi

  # Only delete the branch if it was merged or the task was not done (blocked/aborted)
  if [ "$BRANCH_MERGED" = "true" ] || [ "$FINAL_STATUS" != "done" ]; then
    git -C "$REPO_ROOT" branch -D "$BRANCH_NAME" >/dev/null 2>&1 || true
  fi
fi

# Remove the worktree
if [ -d "$WORKSPACE_PATH" ]; then
  git worktree remove --force "$WORKSPACE_PATH" >/dev/null 2>&1 || rm -rf "$WORKSPACE_PATH"
fi

echo "Cleaned up slot $SLOT_NUMBER for $TASK_ID ($FINAL_STATUS)."
