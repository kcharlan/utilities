#!/bin/sh
set -eu

PLAN_PATH="${1:?plan path required}"
WORKSPACE_PATH="${2:?workspace path required}"
TASK_FILE="$(basename "$PLAN_PATH")"
TASK_ID="${TASK_FILE%.plan.md}"
STATUS_PATH="$(dirname "$PLAN_PATH")/$TASK_ID.status"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
SYSTEM_PROMPT_PATH="$SCRIPT_DIR/../prompts/system.md"
WORKER_PROMPT_PATH="$SCRIPT_DIR/../prompts/worker.md"
MODEL="${CLAUDE_CODE_WORKER_MODEL:-sonnet}"

# Build the combined prompt (system + worker)
if [ -f "$SYSTEM_PROMPT_PATH" ]; then
  PROMPT="$(printf '%s\n\n%s' "$(cat "$SYSTEM_PROMPT_PATH")" "$(cat "$WORKER_PROMPT_PATH")")"
else
  PROMPT="$(cat "$WORKER_PROMPT_PATH")"
fi

# Phase 1: reading
echo "##PROGRESS## $TASK_ID | Phase: reading | 1/5"

# Phase 2: entry-tests
echo "##PROGRESS## $TASK_ID | Phase: entry-tests | 2/5"

# Phase 3: implementing (Claude does the actual work)
echo "##PROGRESS## $TASK_ID | Phase: implementing | 3/5"
echo "##PROGRESS## $TASK_ID | Detail: Launching Claude CLI ($MODEL)"

# Run Claude with stream-json output for incremental progress visibility.
# A background sampler reads the NDJSON output file and emits ##PROGRESS## detail markers.
CLAUDE_OUTPUT_FILE="$(dirname "$PLAN_PATH")/$TASK_ID.claude_output"
: >"$CLAUDE_OUTPUT_FILE"

# Stop-file for cooperative sampler shutdown
SAMPLER_STOP_FILE="$(dirname "$PLAN_PATH")/$TASK_ID.sampler_stop"
rm -f "$SAMPLER_STOP_FILE"

# Helper: signal sampler to stop via stop-file, then escalate if needed
kill_sampler() {
  touch "$SAMPLER_STOP_FILE"
  _wait_count=0
  while kill -0 "$SAMPLER_PID" 2>/dev/null && [ "$_wait_count" -lt 6 ]; do
    sleep 0.5
    _wait_count=$((_wait_count + 1))
  done
  if kill -0 "$SAMPLER_PID" 2>/dev/null; then
    kill "$SAMPLER_PID" 2>/dev/null || true
    sleep 1
    kill -9 "$SAMPLER_PID" 2>/dev/null || true
  fi
  wait "$SAMPLER_PID" 2>/dev/null || true
  rm -f "$SAMPLER_STOP_FILE"
}

# Background sampler: parse NDJSON lines and emit detail markers
_LAST_LINE_COUNT=0
(
  while [ ! -f "$SAMPLER_STOP_FILE" ]; do
    # Sleep in short increments so we notice the stop-file within ~0.5s
    _i=0
    while [ "$_i" -lt 6 ] && [ ! -f "$SAMPLER_STOP_FILE" ]; do
      sleep 0.5
      _i=$((_i + 1))
    done
    [ -f "$SAMPLER_STOP_FILE" ] && break
    [ -f "$CLAUDE_OUTPUT_FILE" ] || continue
    _CURRENT_COUNT=$(wc -l < "$CLAUDE_OUTPUT_FILE" 2>/dev/null | tr -d ' ' || echo 0)
    if [ "$_CURRENT_COUNT" -gt "$_LAST_LINE_COUNT" ] 2>/dev/null; then
      _START=$(( _LAST_LINE_COUNT + 1 ))
      _NEW_LINES=$(sed -n "${_START},${_CURRENT_COUNT}p" "$CLAUDE_OUTPUT_FILE" 2>/dev/null || true)
      if [ -n "$_NEW_LINES" ]; then
        _DETAIL=$(printf '%s\n' "$_NEW_LINES" | jq -s -r '
          [ .[] |
            if .type == "system" then
              { score: 1, detail: "CLI initialized" }
            elif .type == "assistant" then
              (.message.content // []) as $c |
              ([ $c[] | select(.type == "tool_use") | .name ]) as $tools |
              ([ $c[] | select(.type == "text" and (.text | length > 0)) | .text ]) as $texts |
              if ($texts | length) > 0 then
                { score: 3, detail: ($texts[-1] | split("\n")[0] | .[0:80]) }
              elif ($tools | length) > 0 then
                { score: 2, detail: ("Using: " + ($tools[0:4] | join(", ")) | .[0:80]) }
              else
                empty
              end
            elif .type == "result" then
              if .result and (.result | length > 0) then
                { score: 4, detail: ("Completed: " + (.result | split("\n")[0]) | .[0:80]) }
              else
                empty
              end
            else
              empty
            end
          ] |
          sort_by(.score) |
          if length > 0 then .[-1].detail else empty end
        ' 2>/dev/null || true)
        if [ -n "$_DETAIL" ]; then
          echo "##PROGRESS## $TASK_ID | Detail: $_DETAIL"
        fi
      fi
      _LAST_LINE_COUNT=$_CURRENT_COUNT
    else
      echo "##PROGRESS## $TASK_ID | Detail: Working... (no new output)"
    fi
  done
) &
SAMPLER_PID=$!

CLAUDE_EXIT=0
claude --dangerously-skip-permissions --model "$MODEL" --output-format stream-json --verbose -p "$PROMPT" <"$PLAN_PATH" >"$CLAUDE_OUTPUT_FILE" 2>&1 || CLAUDE_EXIT=$?

if [ "$CLAUDE_EXIT" -eq 0 ]; then
  echo "##PROGRESS## $TASK_ID | Phase: exit-tests | 4/5"
  echo "##PROGRESS## $TASK_ID | Detail: Extracting commit SHAs"

  # Extract commit SHAs made in the workspace during this session
  COMMITS="none"
  if [ -d "$WORKSPACE_PATH/.git" ] || [ -f "$WORKSPACE_PATH/.git" ]; then
    # Get commits on the worktree branch that aren't on the source
    WORKTREE_COMMITS="$(git -C "$WORKSPACE_PATH" log --format='%h' HEAD --not --remotes 2>/dev/null | paste -sd, - 2>/dev/null || true)"
    if [ -n "$WORKTREE_COMMITS" ]; then
      COMMITS="$WORKTREE_COMMITS"
    fi
  fi

  echo "##PROGRESS## $TASK_ID | Detail: Parsing result text"
  # Extract the result text from stream-json for test detection
  RESULT_TEXT=$(python3 -c "
import json, sys
lines = open(sys.argv[1]).readlines()
for line in reversed(lines):
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
        if obj.get('type') == 'result':
            print(obj.get('result', ''))
            break
    except Exception:
        continue
" "$CLAUDE_OUTPUT_FILE" 2>/dev/null || true)

  # Determine test results from Claude output
  TESTS_RAN="none"
  TEST_RESULT="skip"
  if echo "$RESULT_TEXT" | grep -qi "pytest\|test.*pass\|tests.*pass\|test.*fail\|tests.*fail\|npm test\|jest\|vitest\|playwright" 2>/dev/null; then
    TESTS_RAN="targeted"
    if echo "$RESULT_TEXT" | grep -qi "test.*fail\|tests.*fail\|FAILED\|AssertionError" 2>/dev/null; then
      TEST_RESULT="fail"
    else
      TEST_RESULT="pass"
    fi
  fi

  echo "##PROGRESS## $TASK_ID | Detail: Detecting code changes"
  # Detect if the task modified code files (not just docs/config)
  CODE_CHANGED="no"
  if [ "$COMMITS" != "none" ]; then
    FIRST_SHA=$(echo "$COMMITS" | tr ',' '\n' | tail -1)
    CODE_EXTS=$(git -C "$WORKSPACE_PATH" diff --name-only "${FIRST_SHA}~1"..HEAD 2>/dev/null \
      | grep -E '\.(py|js|jsx|ts|tsx|sh|go|rs|java|c|cpp|h|html|css|sql)$' \
      || true)
    if [ -n "$CODE_EXTS" ]; then
      CODE_CHANGED="yes"
    fi
  fi

  # Flag warning if code changed but no tests detected
  NOTES="Claude worker completed in $WORKSPACE_PATH"
  if [ "$CODE_CHANGED" = "yes" ] && [ "$TESTS_RAN" = "none" ]; then
    NOTES="WARNING: Code files were modified but no test execution was detected in worker output. $NOTES"
  fi

  echo "##PROGRESS## $TASK_ID | Detail: Writing status sidecar"
  cat >"$STATUS_PATH" <<EOF
STATUS: done
COMMITS: $COMMITS
TESTS_RAN: $TESTS_RAN
TEST_RESULT: $TEST_RESULT
NOTES: $NOTES
EOF

  echo "##PROGRESS## $TASK_ID | Phase: finalizing | 5/5"
  kill_sampler
  rm -f "$CLAUDE_OUTPUT_FILE"
  exit 0
fi

# Failure path — extract reason from stream-json output
BLOCKED_REASON="Claude worker command failed (exit code $CLAUDE_EXIT)."
echo "##PROGRESS## $TASK_ID | Detail: Extracting failure reason"
if [ -f "$CLAUDE_OUTPUT_FILE" ]; then
  RESULT_TAIL=$(python3 -c "
import json, sys
lines = open(sys.argv[1]).readlines()
for line in reversed(lines):
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
        if obj.get('type') == 'result':
            r = obj.get('result', '')
            if r:
                print(r.strip()[:200])
                break
    except Exception:
        continue
" "$CLAUDE_OUTPUT_FILE" 2>/dev/null || true)
  if [ -n "$RESULT_TAIL" ]; then
    BLOCKED_REASON="Claude CLI exit $CLAUDE_EXIT: $(echo "$RESULT_TAIL" | tr '\n' ' ' | head -c 200)"
  else
    TAIL_LINES="$(tail -5 "$CLAUDE_OUTPUT_FILE" 2>/dev/null | head -3 || true)"
    if [ -n "$TAIL_LINES" ]; then
      BLOCKED_REASON="Claude CLI exit $CLAUDE_EXIT: $(echo "$TAIL_LINES" | tr '\n' ' ' | head -c 200)"
    fi
  fi
fi

echo "##PROGRESS## $TASK_ID | Detail: Writing blocked status sidecar"
cat >"$STATUS_PATH" <<EOF
STATUS: blocked
COMMITS: none
TESTS_RAN: none
TEST_RESULT: fail
BLOCKED_REASON: $BLOCKED_REASON
EOF

kill_sampler
rm -f "$CLAUDE_OUTPUT_FILE"
exit 1
