#!/bin/sh
set -eu

SESSION_ROOT="${1:-$PWD}"
REPO_ROOT="${COGNITIVE_SWITCHYARD_REPO_ROOT:-}"

if [ -z "${COGNITIVE_SWITCHYARD_PACK_ROOT:-}" ]; then
  echo "COGNITIVE_SWITCHYARD_PACK_ROOT is required for verify." >&2
  exit 1
fi

if [ -z "$REPO_ROOT" ]; then
  echo "COGNITIVE_SWITCHYARD_REPO_ROOT is required for verify." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Test scoping
# ---------------------------------------------------------------------------
# 1. If COGNITIVE_SWITCHYARD_PROJECT_DIR is set, scope to that subdir.
# 2. Otherwise, run at REPO_ROOT (single-project default).
# ---------------------------------------------------------------------------

PROJECT_DIR="${COGNITIVE_SWITCHYARD_PROJECT_DIR:-}"

BOOTSTRAP_VENV="${HOME}/.cognitive_switchyard_venv"

run_pytest_in() {
  local target="$1"
  echo "Running verification in $target"
  if [ -f "$target/.venv/bin/pytest" ]; then
    "$target/.venv/bin/pytest" "$target" --tb=short -q
    return $?
  elif [ -f "$target/venv/bin/pytest" ]; then
    "$target/venv/bin/pytest" "$target" --tb=short -q
    return $?
  elif [ -f "$BOOTSTRAP_VENV/bin/pytest" ]; then
    "$BOOTSTRAP_VENV/bin/pytest" "$target" --tb=short -q
    rc=$?
    if [ "$rc" -eq 5 ]; then
      echo "No tests collected in $target. Verification passed (no-op)."
      return 0
    fi
    return "$rc"
  elif [ -f "$target/package.json" ] && command -v npm >/dev/null 2>&1; then
    (cd "$target" && npm test)
    return $?
  fi
  echo "No test runner detected in $target. Verification FAILED (no test runner found)." >&2
  return 1
}

# Case 1: Explicit project directory
if [ -n "$PROJECT_DIR" ]; then
  target="$REPO_ROOT/$PROJECT_DIR"
  if [ ! -d "$target" ]; then
    echo "PROJECT_DIR '$PROJECT_DIR' does not exist under $REPO_ROOT" >&2
    exit 1
  fi
  run_pytest_in "$target"
  exit $?
fi

# Case 2: No explicit project dir — treat as single-project repo at REPO_ROOT.
# For monorepos, users should set COGNITIVE_SWITCHYARD_PROJECT_DIR to scope
# verification to the correct subdirectory.
run_pytest_in "$REPO_ROOT"
exit $?
