#!/usr/bin/env python3

import collections
import re
import subprocess
import sys


def get_git_stats() -> str:
    """Extract git commit statistics (additions and deletions) by date."""
    try:
        result = subprocess.run(
            ["git", "log", "--pretty=format:%ad", "--date=short", "--shortstat"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout
    except subprocess.CalledProcessError as e:
        print(f"Error running git command: {e}", file=sys.stderr)
        sys.exit(1)


def aggregate_stats(log_output: str) -> dict[str, dict[str, int]]:
    """Aggregate insertions and deletions by date."""
    stats = collections.defaultdict(lambda: {"added": 0, "removed": 0})
    current_date = None

    for line in log_output.splitlines():
        line = line.strip()
        if not line:
            continue

        # Check if the line is a date (YYYY-MM-DD)
        if re.match(r"^\d{4}-\d{2}-\d{2}$", line):
            current_date = line
            continue

        # Match "X files changed, Y insertions(+), Z deletions(-)"
        insertions = re.search(r"(\d+)\s+insertion", line)
        deletions = re.search(r"(\d+)\s+deletion", line)

        if current_date:
            if insertions:
                stats[current_date]["added"] += int(insertions.group(1))
            if deletions:
                stats[current_date]["removed"] += int(deletions.group(1))

    return dict(stats)


def print_table(stats: dict[str, dict[str, int]]) -> None:
    """Print the aggregated stats in a markdown table format."""
    print("| Date       | Added   | Removed | Net Change |")
    print("|------------|---------|---------|------------|")
    for date in sorted(stats.keys(), reverse=True):
        added = stats[date]["added"]
        removed = stats[date]["removed"]
        net = added - removed
        print(f"| {date} | {added:7,} | {removed:7,} | {net:10,} |")


if __name__ == "__main__":
    output = get_git_stats()
    daily_stats = aggregate_stats(output)
    print_table(daily_stats)