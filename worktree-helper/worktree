def load_state() -> HistoryState:
    if not STATE_FILE.exists():
        return HistoryState()
    try:
        data = json.loads(STATE_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return HistoryState()
    return HistoryState(
        recent_repos=[str(Path(p).expanduser()) for p in data.get("recent_repos", [])][:15],
        recent_target_parents=[
            str(Path(p).expanduser()) for p in data.get("recent_target_parents", [])
        ][:15],
        recent_worktrees=[str(Path(p).expanduser()) for p in data.get("recent_worktrees", [])][:25],
    )


def remember_path(bucket: list[str], path: Path, limit: int) -> list[str]:
    raw = str(path.expanduser())
    updated = [raw] + [item for item in bucket if item != raw]
    return updated[:limit]


def normalize_ui_path(path: Path) -> Path:
    raw = os.path.abspath(os.path.expanduser(str(path)))
    return Path(raw)


def save_state(state: HistoryState) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "recent_repos": state.recent_repos[:15],
        "recent_target_parents": state.recent_target_parents[:15],
        "recent_worktrees": state.recent_worktrees[:25],
    }
    STATE_FILE.write_text(json.dumps(payload, indent=2) + "\n")


def shell_join(parts: Iterable[str]) -> str:
    return " ".join(shlex.quote(part) for part in parts)


def supports_color(no_color: bool) -> bool:
    return sys.stdout.isatty() and not no_color and os.getenv("TERM", "dumb") != "dumb"


def ansi(code: str, text: str, enabled: bool) -> str:
    if not enabled:
        return text
    return f"\033[{code}m{text}\033[0m"


def git(
    repo: Optional[Path],
    args: list[str],
    *,
    check: bool = True,
    capture: bool = True,
) -> subprocess.CompletedProcess[str]:
    cmd = ["git"]
    if repo is not None:
        cmd.extend(["-C", str(repo)])
    cmd.extend(args)
    completed = subprocess.run(
        cmd,
        text=True,
        capture_output=capture,
        check=False,
    )
    if check and completed.returncode != 0:
        stderr = completed.stderr.strip() or completed.stdout.strip() or "git command failed"
        raise WorktreeError(stderr)
    return completed


def resolve_repo_root(path: Path) -> Optional[Path]:
    candidate = path.expanduser().resolve()
    completed = git(candidate, ["rev-parse", "--show-toplevel"], check=False)
    if completed.returncode != 0:
        return None
    return Path(completed.stdout.strip()).resolve()


def pick_default_repo(seed: Optional[Path]) -> Optional[Path]:
    if seed is not None:
        root = resolve_repo_root(seed)
        if root is not None:
            return root
    return resolve_repo_root(Path.cwd())


def parse_worktree_list(text: str) -> list[WorktreeEntry]:
    entries: list[WorktreeEntry] = []
    current: dict[str, Any] = {}
    for raw_line in text.splitlines():
        line = raw_line.rstrip()
        if not line:
            if current.get("path"):
                entries.append(
                    WorktreeEntry(
                        path=Path(current["path"]).expanduser().resolve(),
                        head=current.get("head", ""),
                        branch_ref=current.get("branch_ref", ""),
                        detached=current.get("detached", False),
                        bare=current.get("bare", False),
                        locked=current.get("locked", False),
                        lock_reason=current.get("lock_reason", ""),
                        prunable=current.get("prunable", ""),
                    )
                )
            current = {}
            continue
        key, _, value = line.partition(" ")
        if key == "worktree":
            current["path"] = value
        elif key == "HEAD":
            current["head"] = value
        elif key == "branch":
            current["branch_ref"] = value
        elif key == "detached":
            current["detached"] = True
        elif key == "bare":
            current["bare"] = True
        elif key == "locked":
            current["locked"] = True
            current["lock_reason"] = value
        elif key == "prunable":
            current["prunable"] = value
    if current.get("path"):
        entries.append(
            WorktreeEntry(
                path=Path(current["path"]).expanduser().resolve(),
                head=current.get("head", ""),
                branch_ref=current.get("branch_ref", ""),
                detached=current.get("detached", False),
                bare=current.get("bare", False),
                locked=current.get("locked", False),
                lock_reason=current.get("lock_reason", ""),
                prunable=current.get("prunable", ""),
            )
        )
    return entries


def list_worktrees(repo: Path) -> list[WorktreeEntry]:
    completed = git(repo, ["worktree", "list", "--porcelain"])
    return parse_worktree_list(completed.stdout)


def get_local_branches(repo: Path) -> list[BranchEntry]:
    completed = git(
        repo,
        [
            "for-each-ref",
            "--sort=-committerdate",
            "--format=%(refname:short)\t%(refname)\t%(upstream:short)\t%(objectname:short)\t%(committerdate:relative)",
            "refs/heads",
        ],
    )
    branches: list[BranchEntry] = []
    for line in completed.stdout.splitlines():
        name, full_ref, upstream, sha, relative_date = (line.split("\t") + ["", "", "", "", ""])[:5]
        branches.append(
            BranchEntry(
                name=name,
                full_ref=full_ref,
                kind="local",
                upstream=upstream,
                sha=sha,
                relative_date=relative_date,
            )
        )
    return branches


def get_remote_refs(repo: Path) -> list[BranchEntry]:
    completed = git(
        repo,
        [
            "for-each-ref",
            "--sort=-committerdate",
            "--format=%(refname:short)\t%(refname)\t%(objectname:short)\t%(committerdate:relative)",
            "refs/remotes",
        ],
    )
    refs: list[BranchEntry] = []
    for line in completed.stdout.splitlines():
        name, full_ref, sha, relative_date = (line.split("\t") + ["", "", "", ""])[:4]
        if name.endswith("/HEAD"):
            continue
        refs.append(
            BranchEntry(
                name=name,
                full_ref=full_ref,
                kind="remote",
                sha=sha,
                relative_date=relative_date,
            )
        )
    return refs


def get_current_branch(repo: Path) -> Optional[str]:
    completed = git(repo, ["branch", "--show-current"], check=False)
    name = completed.stdout.strip()
    return name or None


def git_status_summary(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {
            "exists": False,
            "clean": False,
            "branch_line": "(missing on disk)",
            "changes": 0,
            "untracked": 0,
            "raw": [],
        }
    completed = git(path, ["status", "--short", "--branch"], check=False)
    if completed.returncode != 0:
        return {
            "exists": True,
            "clean": False,
            "branch_line": "(unable to read status)",
            "changes": 0,
            "untracked": 0,
            "raw": [],
        }
    lines = completed.stdout.splitlines()
    branch_line = lines[0] if lines else "## ?"
    changes = 0
    untracked = 0
    for line in lines[1:]:
        if line.startswith("??"):
            untracked += 1
        if line.strip():
            changes += 1
    return {
        "exists": True,
        "clean": changes == 0,
        "branch_line": branch_line.replace("## ", ""),
        "changes": changes,
        "untracked": untracked,
        "raw": lines[1:],
    }


def path_name_for_branch(repo: Path, branch_like: str) -> str:
    safe = branch_like.replace("/", "-").replace(" ", "-")
    safe = "".join(ch for ch in safe if ch.isalnum() or ch in "-_.")
    safe = safe.strip("-_.") or "worktree"
    return f"{repo.name}-{safe}"


def ensure_git_available() -> None:
    if shutil.which("git") is None:
        raise WorktreeError("git is not installed or not available on PATH.")


def ensure_repo(value: Optional[Path]) -> Path:
    repo = pick_default_repo(value)
    if repo is None:
        raise WorktreeError(
            "Could not detect a git repository. Run inside a repo, pass --repo, or use the interactive picker."
        )
    return repo


def validate_create_request(request: ActionRequest, repo: Path) -> None:
    modes = [
        bool(request.branch),
        bool(request.new_branch),
        bool(request.reset_branch),
        request.detach,
        request.orphan,
    ]
    if sum(1 for mode in modes if mode) == 0:
        raise WorktreeError(
            "Create mode is ambiguous. Use --branch, --new-branch, --reset-branch, --detach, or --orphan."
        )
    if sum(1 for mode in modes if mode) > 1:
        raise WorktreeError(
            "Choose only one create mode: existing branch, new branch, reset branch, detached, or orphan."
        )
    if request.path is None:
        raise WorktreeError("Missing target path for create. Pass --path or use the picker.")
    if request.orphan and not (request.new_branch or request.reset_branch):
        raise WorktreeError("Orphan creation needs --new-branch or --reset-branch.")
    if request.branch:
        available = {entry.name for entry in get_local_branches(repo)}
        if request.branch not in available:
            raise WorktreeError(f"Local branch '{request.branch}' does not exist in {repo}.")
        for entry in list_worktrees(repo):
            if entry.branch_name == request.branch and entry.path != request.path and not request.force:
                raise WorktreeError(
                    f"Branch '{request.branch}' is already checked out in {entry.path}. Use --force or choose a different branch."
                )


def validate_target_path(path: Path, *, allow_existing_empty: bool) -> tuple[Path, list[str]]:
    resolved = path.expanduser().resolve()
    notes: list[str] = []
    if resolved.exists():
        if not resolved.is_dir():
            raise WorktreeError(f"{resolved} exists but is not a directory.")
        entries = list(resolved.iterdir())
        if entries and not allow_existing_empty:
            raise WorktreeError(f"{resolved} exists and is not empty.")
        if entries and allow_existing_empty:
            notes.append("Target directory already exists and is not empty. Git may reject this path.")
        elif not entries:
            notes.append("Target directory already exists and is empty.")
    else:
        notes.append("Target directory does not exist yet and will be created by git.")
    return resolved, notes


def equivalent_command(request: ActionRequest) -> str:
    parts = ["worktree"]
    action_to_flag = {
        "create": "--create",
        "delete": "--delete",
        "list": "--list",
        "status": "--status",
        "prune": "--prune",
        "open": "--open",
        "cd": "--cd",
        "lock": "--lock",
        "unlock": "--unlock",
        "move": "--move",
        "repair": "--repair",
        "doctor": "--doctor",
    }
    if request.action:
        parts.append(action_to_flag[request.action])
    if request.repo:
        parts.extend(["--repo", str(request.repo)])
    if request.path:
        parts.extend(["--path", str(request.path)])
    if request.worktree:
        parts.extend(["--worktree", str(request.worktree)])
    if request.new_path:
        parts.extend(["--new-path", str(request.new_path)])
    if request.branch:
        parts.extend(["--branch", request.branch])
    if request.new_branch:
        parts.extend(["--new-branch", request.new_branch])
    if request.reset_branch:
        parts.extend(["--reset-branch", request.reset_branch])
    if request.from_ref:
        parts.extend(["--from", request.from_ref])
    if request.detach:
        parts.append("--detach")
    if request.orphan:
        parts.append("--orphan")
    if request.force:
        parts.append("--force")
    if request.no_checkout:
        parts.append("--no-checkout")
    if request.lock_on_create:
        parts.append("--lock-on-create")
    if request.lock_reason:
        parts.extend(["--lock-reason", request.lock_reason])
    if request.expire:
        parts.extend(["--expire", request.expire])
    if request.dry_run:
        parts.append("--dry-run")
    for repair_path in request.repair_paths:
        parts.extend(["--repair-path", str(repair_path)])
    if request.raw_path:
        parts.append("--raw-path")
    if request.yes:
        parts.append("--yes")
    if request.verbose:
        parts.append("--verbose")
    return shell_join(parts)


def detect_action(namespace: argparse.Namespace) -> Optional[str]:
    for name in (
        "create",
        "delete",
        "list",
        "status",
        "prune",
        "open",
        "cd",
        "lock",
        "unlock",
        "move",
        "repair",
        "doctor",
    ):
        if getattr(namespace, name):
            return name
    return None


def request_from_args(namespace: argparse.Namespace) -> ActionRequest:
    return ActionRequest(
        action=detect_action(namespace),
        repo=Path(namespace.repo).expanduser().resolve() if namespace.repo else None,
        path=Path(namespace.path).expanduser().resolve() if namespace.path else None,
        worktree=Path(namespace.worktree).expanduser().resolve() if namespace.worktree else None,
        new_path=Path(namespace.new_path).expanduser().resolve() if namespace.new_path else None,
        branch=namespace.branch,
        new_branch=namespace.new_branch,
        reset_branch=namespace.reset_branch,
        from_ref=namespace.from_ref,
        detach=namespace.detach,
        orphan=namespace.orphan,
        force=namespace.force,
        no_checkout=namespace.no_checkout,
        lock_on_create=namespace.lock_on_create,
        lock_reason=namespace.lock_reason,
        expire=namespace.expire,
        dry_run=namespace.dry_run,
        repair_paths=[Path(item).expanduser().resolve() for item in namespace.repair_path or []],
        raw_path=namespace.raw_path,
        yes=namespace.yes,
        verbose=namespace.verbose,
        no_color=namespace.no_color,
    )


class TUI:
    def __init__(self, stdscr: "curses._CursesWindow", state: HistoryState):
        self.stdscr = stdscr
        self.state = state
        self.status_message = ""
        if hasattr(curses, "set_escdelay"):
            curses.set_escdelay(25)
        curses.curs_set(0)
        curses.use_default_colors()
        self._init_colors()
        self.stdscr.keypad(True)

    def _init_colors(self) -> None:
        self.colors: dict[str, int] = {
            "header": curses.A_BOLD,
            "accent": curses.A_BOLD,
            "muted": curses.A_NORMAL,
            "highlight": curses.A_REVERSE | curses.A_BOLD,
            "status": curses.A_BOLD,
        }
        if curses.has_colors():
            curses.start_color()
            try:
                curses.init_pair(1, curses.COLOR_CYAN, -1)
                curses.init_pair(2, curses.COLOR_YELLOW, -1)
                curses.init_pair(3, curses.COLOR_BLACK, curses.COLOR_CYAN)
                curses.init_pair(4, curses.COLOR_GREEN, -1)
                self.colors["header"] = curses.color_pair(1) | curses.A_BOLD
                self.colors["accent"] = curses.color_pair(2) | curses.A_BOLD
                self.colors["highlight"] = curses.color_pair(3) | curses.A_BOLD
                self.colors["status"] = curses.color_pair(4) | curses.A_BOLD
            except curses.error:
                pass

    def _screen_size(self) -> tuple[int, int]:
        return self.stdscr.getmaxyx()

    def _wrap(self, text: str, width: int) -> list[str]:
        if width <= 10:
            return [text[:width]]
        wrapped = textwrap.wrap(text, width=width) or [""]
        return wrapped

    def _truncate(self, text: str, width: int) -> str:
        if width <= 0:
            return ""
        if len(text) <= width:
            return text
        if width <= 3:
            return text[:width]
        return text[: width - 3] + "..."

    def _draw_frame(self, title: str, subtitle: str = "", footer: str = "") -> tuple[int, int]:
        self.stdscr.erase()
        height, width = self._screen_size()
        line = "+" + "-" * max(0, width - 2) + "+"
        self.stdscr.addnstr(0, 0, line, width, self.colors["accent"])
        self.stdscr.addnstr(1, 2, title, max(1, width - 4), self.colors["header"])
        if subtitle:
            self.stdscr.addnstr(2, 2, subtitle, max(1, width - 4), self.colors["muted"])
        self.stdscr.addnstr(height - 2, 0, line, width, self.colors["accent"])
        if footer:
            self.stdscr.addnstr(height - 1, 2, footer, max(1, width - 4), self.colors["muted"])
        elif self.status_message:
            self.stdscr.addnstr(height - 1, 2, self.status_message, max(1, width - 4), self.colors["status"])
        self.stdscr.refresh()
        return height, width

    def choose(self, title: str, subtitle: str, items: list[MenuItem], footer: str) -> Any:
        filter_text = ""
        index = 0
        offset = 0
        while True:
            filtered = [
                item
                for item in items
                if not filter_text
                or filter_text.lower() in item.label.lower()
                or filter_text.lower() in item.meta.lower()
                or filter_text.lower() in item.keywords.lower()
            ]
            if not filtered:
                filtered = [MenuItem(None, "[no matches]", "Backspace clears the filter")]
            index = max(0, min(index, len(filtered) - 1))
            height, width = self._draw_frame(title, subtitle, footer)
            filter_line = f"Filter: {filter_text}" if filter_text else "Filter: type to narrow the list"
            self.stdscr.addnstr(4, 2, filter_line, max(1, width - 4), self.colors["accent"])
            visible = max(1, (height - 9) // 2)
            if index < offset:
                offset = index
            if index >= offset + visible:
                offset = index - visible + 1
            for row in range(visible):
                item_index = offset + row
                y = 6 + (row * 2)
                if item_index >= len(filtered):
                    break
                item = filtered[item_index]
                selected = item_index == index
                label_attr = self.colors["highlight"] if selected else curses.A_NORMAL
                meta_attr = self.colors["highlight"] if selected else self.colors["muted"]
                self.stdscr.addnstr(
                    y,
                    2,
                    self._truncate(item.label, max(1, width - 4)),
                    max(1, width - 4),
                    label_attr,
                )
                if item.meta and y + 1 < height - 2:
                    self.stdscr.addnstr(
                        y + 1,
                        4,
                        self._truncate(item.meta, max(1, width - 6)),
                        max(1, width - 6),
                        meta_attr,
                    )
            self.stdscr.refresh()
            key = self.stdscr.get_wch()
            if key in ("q", "\x1b"):
                return None
            if key in (curses.KEY_UP, "k"):
                index = max(0, index - 1)
            elif key in (curses.KEY_DOWN, "j"):
                index = min(len(filtered) - 1, index + 1)
            elif key in (curses.KEY_NPAGE,):
                index = min(len(filtered) - 1, index + visible)
            elif key in (curses.KEY_PPAGE,):
                index = max(0, index - visible)
            elif key in ("\n", curses.KEY_ENTER, "\r"):
                return filtered[index].value
            elif key in ("\b", "\x7f", curses.KEY_BACKSPACE):
                filter_text = filter_text[:-1]
            elif isinstance(key, str) and key.isprintable():
                filter_text += key

    def prompt(
        self,
        title: str,
        subtitle: str,
        prompt: str,
        *,
        default: str = "",
        allow_empty: bool = False,
        replace_on_first_edit: bool = False,
    ) -> Optional[str]:
        value = default
        pristine = bool(default)
        while True:
            footer = "Enter submits. Esc cancels. Ctrl-U clears."
            if replace_on_first_edit and default:
                footer = "Enter submits. Esc cancels. First key replaces. Ctrl-U clears."
            height, width = self._draw_frame(title, subtitle, footer)
            for idx, line in enumerate(self._wrap(prompt, width - 4)):
                self.stdscr.addnstr(4 + idx, 2, line, max(1, width - 4), curses.A_NORMAL)
            self.stdscr.addnstr(7, 2, "> ", 2, self.colors["accent"])
            self.stdscr.addnstr(7, 4, value, max(1, width - 6), curses.A_BOLD)
            self.stdscr.move(7, min(width - 2, 4 + len(value)))
            curses.curs_set(1)
            self.stdscr.refresh()
            key = self.stdscr.get_wch()
            curses.curs_set(0)
            if key == "\x1b":
                return None
            if key in ("\n", curses.KEY_ENTER, "\r"):
                trimmed = value.strip()
                if trimmed or allow_empty:
                    return trimmed
                self.status_message = "A value is required."
            elif key == "\x15":
                value = ""
                pristine = False
            elif key in ("\b", "\x7f", curses.KEY_BACKSPACE):
                if replace_on_first_edit and pristine:
                    value = ""
                else:
                    value = value[:-1]
                pristine = False
            elif isinstance(key, str) and key.isprintable():
                if replace_on_first_edit and pristine:
                    value = key
                else:
                    value += key
                pristine = False

    def confirm(self, title: str, message: str, default_yes: bool = True) -> bool:
        items = [
            MenuItem(True, "[Yes] Continue", "Proceed with this action"),
            MenuItem(False, "[No] Cancel", "Back out safely"),
        ]
        if not default_yes:
            items.reverse()
        result = self.choose(title, message, items, "Enter chooses. q or Esc cancels.")
        return bool(result)

    def message(self, title: str, lines: list[str]) -> None:
        offset = 0
        while True:
            height, width = self._draw_frame(title, "", "Up/Down scroll. q returns.")
            visible = max(4, height - 6)
            for row in range(visible):
                idx = offset + row
                if idx >= len(lines):
                    break
                self.stdscr.addnstr(3 + row, 2, lines[idx], max(1, width - 4), curses.A_NORMAL)
            self.stdscr.refresh()
            key = self.stdscr.get_wch()
            if key in ("q", "\x1b", "\n", curses.KEY_ENTER, "\r"):
                return
            if key in (curses.KEY_UP, "k"):
                offset = max(0, offset - 1)
            elif key in (curses.KEY_DOWN, "j"):
                offset = min(max(0, len(lines) - visible), offset + 1)

    def browse_directory(
        self,
        title: str,
        subtitle: str,
        *,
        start: Path,
        select_label: str,
        allow_manual: bool = True,
        allow_new_child: bool = False,
        repo_mode: bool = False,
    ) -> Optional[Path]:
        current = normalize_ui_path(start)
        while True:
            items: list[MenuItem] = []
            if repo_mode:
                repo_root = resolve_repo_root(current)
                if repo_root is not None:
                    label = f"[Select repo] {repo_root}"
                    meta = "Detected repository root"
                    items.append(MenuItem(("select", repo_root), label, meta, str(repo_root)))
            else:
                items.append(MenuItem(("select", current), select_label, str(current), str(current)))
            if allow_new_child:
                items.append(MenuItem(("new-child", current), "[Create a new path under this folder]", "Enter just the new folder name"))
            if allow_manual:
                items.append(MenuItem(("manual", current), "[Type a full path manually]", "Absolute or relative path"))
            parent = current.parent if current.parent != current else current
            if parent != current:
                items.append(MenuItem(("enter", parent), "[..]", str(parent), str(parent)))
            try:
                children = sorted(
                    [child for child in current.iterdir() if child.is_dir()],
                    key=lambda item: (item.name.lower().startswith("."), item.name.lower()),
                )
            except OSError as exc:
                self.status_message = str(exc)
                children = []
            for child in children:
                marker = "[repo]" if resolve_repo_root(child) == child or (child / ".git").exists() else "[dir]"
                items.append(MenuItem(("enter", child), child.name, marker, str(child)))
            choice = self.choose(
                title,
                f"{subtitle} Current folder: {current}",
                items,
                "Arrows move. Enter selects. Type to filter. q backs out.",
            )
            if choice is None:
                return None
            kind, payload = choice
            if kind == "select":
                return payload
            if kind == "enter":
                current = normalize_ui_path(payload)
                continue
            if kind == "new-child":
                name = self.prompt(
                    title,
                    f"{subtitle} Current folder: {current}",
                    "Folder name to create under the current directory:",
                    default="",
                )
                if name is None:
                    continue
                return (current / name).expanduser()
            if kind == "manual":
                typed = self.prompt(
                    title,
                    f"{subtitle} Current folder: {current}",
                    "Type any full or relative path. Leave it blank and press Esc to return.",
                    default="",
                )
                if typed is None:
                    continue
                candidate = Path(typed).expanduser()
                if not candidate.is_absolute():
                    candidate = current / candidate
                return candidate


class InteractiveWizard:
    def __init__(self, tui: TUI, state: HistoryState):
        self.tui = tui
        self.state = state

    def _reset_to_action(self, request: ActionRequest) -> None:
        request.action = None
        self._reset_to_repo(request)

    def _reset_to_repo(self, request: ActionRequest) -> None:
        request.repo = None
        request.path = None
        request.worktree = None
        request.new_path = None
        request.branch = None
        request.new_branch = None
        request.reset_branch = None
        request.from_ref = None
        request.detach = False
        request.orphan = False
        request.force = False
        request.lock_reason = None
        request.repair_paths = []
        request.yes = False

    def complete(self, request: ActionRequest) -> Optional[ActionRequest]:
        action_locked = request.action is not None
        if request.action is None:
            request.action = self.choose_action()
            if request.action is None:
                return None
        while True:
            if request.action is None:
                request.action = self.choose_action()
                if request.action is None:
                    return None
            repo = self.complete_repo(request)
            if repo is BACK:
                if action_locked:
                    return None
                self._reset_to_action(request)
                continue
            request.repo = repo
            if request.action == "create":
                completed = self.complete_create(request)
                if completed is BACK:
                    self._reset_to_repo(request)
                    continue
                return completed
            if request.action in {"delete", "open", "cd", "lock", "unlock", "move"}:
                completed = self.complete_existing_worktree_action(request)
                if completed is BACK:
                    self._reset_to_repo(request)
                    continue
                return completed
            if request.action == "repair":
                completed = self.complete_repair(request)
                if completed is BACK:
                    self._reset_to_repo(request)
                    continue
                return completed
            if request.action in {"list", "status", "prune", "doctor"}:
                if request.action == "prune" and not request.yes:
                    message = "Prune removes stale worktree admin records, not live directories."
                    if not self.tui.confirm("Prune", message):
                        self._reset_to_repo(request)
                        continue
                    request.yes = True
                return request
            return request

    def choose_action(self) -> Optional[str]:
        items = [
            MenuItem("create", "Create a worktree", "Choose repo, branch mode, and target path"),
            MenuItem("delete", "Delete a worktree", "Remove a linked worktree safely"),
            MenuItem("list", "List worktrees", "Quick table of every worktree in a repo family"),
            MenuItem("status", "Status overview", "Clean or dirty state for each worktree"),
            MenuItem("prune", "Prune stale records", "Clean broken metadata entries"),
            MenuItem("open", "Open a worktree", "Reveal a worktree in Finder"),
            MenuItem("cd", "CD helper", "Print the cd command or raw path"),
            MenuItem("lock", "Lock a worktree", "Protect a linked worktree from pruning/removal"),
            MenuItem("unlock", "Unlock a worktree", "Remove a lock from a linked worktree"),
            MenuItem("move", "Move a worktree", "Relocate a linked worktree directory"),
            MenuItem("repair", "Repair worktree paths", "Repair metadata after manual moves"),
            MenuItem("doctor", "Doctor", "Inspect the repo family and flag issues"),
        ]
        return self.tui.choose(
            "WORKTREE CONTROL",
            "Keyboard-first git worktree helper",
            items,
            "Arrows move. Enter selects. Type to filter. q quits.",
        )

    def complete_repo(self, request: ActionRequest) -> Any:
        while True:
            existing = pick_default_repo(request.repo or request.worktree or request.path or request.new_path)
            if existing is not None:
                if request.action in {"list", "status", "prune", "doctor"}:
                    return existing
                if request.repo is None and self.tui.confirm(
                    "Repository",
                    f"Use detected repository root?\n{existing}",
                ):
                    return existing
            items: list[MenuItem] = []
            seen: set[str] = set()
            if existing is not None:
                items.append(MenuItem(existing, f"Use detected repo: {existing.name}", str(existing)))
                seen.add(str(existing))
            for raw in self.state.recent_repos:
                path = Path(raw)
                if path.exists() and str(path) not in seen:
                    items.append(MenuItem(path, f"Recent repo: {path.name}", str(path)))
                    seen.add(str(path))
            items.append(MenuItem("__browse__", "Browse for a repository", "Pick a folder and let worktree detect the root"))
            choice = self.tui.choose(
                "Repository",
                "Select the repo family to manage",
                items,
                "Enter selects. q cancels.",
            )
            if choice is None:
                return BACK
            if choice == "__browse__":
                start = (
                    existing
                    or (Path(self.state.recent_repos[0]).expanduser() if self.state.recent_repos else Path.cwd())
                )
                picked = self.tui.browse_directory(
                    "Repository Browser",
                    "Navigate to a repository folder or any folder inside one.",
                    start=start,
                    select_label="Use this folder",
                    repo_mode=True,
                )
                if picked is None:
                    continue
                repo = resolve_repo_root(picked)
                if repo is None:
                    self.tui.message("Repository", [f"{picked} is not inside a git repository."])
                    continue
                return repo
            return choice

    def complete_create(self, request: ActionRequest) -> Any:
        assert request.repo is not None
        while True:
            if not any([request.branch, request.new_branch, request.reset_branch, request.detach, request.orphan]):
                mode = self.choose_create_mode(request.repo)
                if mode is None:
                    return BACK
                mode_kind = mode["kind"]
                if mode_kind == "existing":
                    request.branch = mode["branch"]
                elif mode_kind == "new":
                    request.new_branch = mode["branch"]
                    request.from_ref = mode["from_ref"]
                elif mode_kind == "reset":
                    request.reset_branch = mode["branch"]
                    request.from_ref = mode["from_ref"]
                elif mode_kind == "detach":
                    request.detach = True
                    request.from_ref = mode["from_ref"]
                elif mode_kind == "orphan":
                    request.orphan = True
                    request.new_branch = mode["branch"]
            default_target_name = path_name_for_branch(
                request.repo,
                request.branch or request.new_branch or request.reset_branch or request.from_ref or "detached",
            )
            if request.path is None:
                request.path = self.choose_target_path(request.repo, default_target_name)
                if request.path is None:
                    request.branch = None
                    request.new_branch = None
                    request.reset_branch = None
                    request.from_ref = None
                    request.detach = False
                    request.orphan = False
                    continue
            notes = []
            try:
                _, notes = validate_target_path(request.path, allow_existing_empty=True)
            except WorktreeError as exc:
                self.tui.message("Target Path", [str(exc)])
                request.path = None
                continue
            if request.path.exists():
                if not self.tui.confirm("Target Path", "\n".join(notes + [f"Proceed with {request.path}?"])):
                    request.path = None
                    continue
            elif not self.tui.confirm(
                "Target Path",
                f"{request.path} does not exist yet.\nGit will create it during add.\nContinue?",
            ):
                request.path = None
                continue
            if request.branch and not request.force:
                for entry in list_worktrees(request.repo):
                    if entry.branch_name == request.branch:
                        if not self.tui.confirm(
                            "Branch Already In Use",
                            f"{request.branch} is already checked out at {entry.path}.\nUse --force and continue anyway?",
                            default_yes=False,
                        ):
                            request.path = None
                            break
                        request.force = True
                        break
                if request.path is None:
                    continue
            if not request.yes and not self.tui.confirm(
                "Create Worktree",
                f"Create the worktree now?\nRepo: {request.repo}\nPath: {request.path}",
            ):
                request.path = None
                continue
            request.yes = True
            return request

    def choose_target_path(self, repo: Path, default_name: str) -> Optional[Path]:
        recent_parent = (
            Path(self.state.recent_target_parents[0]).expanduser()
            if self.state.recent_target_parents
            else repo.parent
        )
        while True:
            picked = self.tui.browse_directory(
                "Target Parent",
                "Choose the parent folder that should receive the new worktree.",
                start=recent_parent,
                select_label="[Use this folder as the parent]",
                allow_new_child=False,
                repo_mode=False,
            )
            if picked is None:
                return None
            name = self.tui.prompt(
                "Target Path",
                f"Parent: {picked}",
                "Worktree folder name. You can include slashes for a nested relative path.",
                default=default_name,
                replace_on_first_edit=True,
            )
            if name is None:
                recent_parent = picked
                continue
            return (picked / name).expanduser()

    def choose_create_mode(self, repo: Path) -> Optional[dict[str, str]]:
        local = get_local_branches(repo)
        items: list[MenuItem] = [
            MenuItem(("special", "new"), "[Create a new branch]", "Recommended for feature work"),
            MenuItem(("special", "reset"), "[Create or reset a branch]", "Uses git worktree add -B"),
            MenuItem(("special", "detach"), "[Detached HEAD]", "Temporary checkout from a ref or commit"),
            MenuItem(("special", "orphan"), "[Orphan branch]", "Creates an unborn branch with no history"),
        ]
        for branch in local:
            meta = "local branch"
            if branch.upstream:
                meta = f"tracks {branch.upstream}"
            details = f"{meta} | {branch.sha} | {branch.relative_date}"
            items.append(MenuItem(("existing", branch.name), branch.name, details, f"{branch.name} {branch.upstream}"))
        while True:
            choice = self.tui.choose(
                "Create Mode",
                "Pick an existing branch or choose how to create a new worktree branch.",
                items,
                "Type to filter branch names. q cancels.",
            )
            if choice is None:
                return None
            kind, payload = choice
            if kind == "existing":
                return {"kind": "existing", "branch": payload}
            if payload == "detach":
                base_refs = self.choose_base_ref(repo, prompt_for_detach=True)
                if base_refs is None:
                    continue
                return {"kind": "detach", "from_ref": base_refs}
            branch_name = self.tui.prompt(
                "Branch Name",
                "Name the branch that the worktree should use.",
                "Branch name:",
                default="",
            )
            if branch_name is None:
                continue
            if payload == "orphan":
                return {"kind": "orphan", "branch": branch_name}
            base_refs = self.choose_base_ref(repo)
            if base_refs is None:
                continue
            return {"kind": payload, "branch": branch_name, "from_ref": base_refs}

    def choose_base_ref(self, repo: Path, *, prompt_for_detach: bool = False) -> Optional[str]:
        local = get_local_branches(repo)
        remote = get_remote_refs(repo)
        items = [MenuItem("HEAD", "HEAD", "Current checkout of the selected repo")]
        for branch in local:
            items.append(
                MenuItem(
                    branch.name,
                    branch.name,
                    f"local | {branch.sha} | {branch.relative_date}",
                    f"{branch.name} {branch.upstream}",
                )
            )
        for branch in remote:
            items.append(
                MenuItem(
                    branch.name,
                    branch.name,
                    f"remote | {branch.sha} | {branch.relative_date}",
                    branch.name,
                )
            )
        items.append(MenuItem("__manual__", "[Type a ref manually]", "Any branch, tag, or commit SHA"))
        title = "Detach From" if prompt_for_detach else "Base Ref"
        subtitle = "Choose the start-point for the new worktree branch."
        while True:
            choice = self.tui.choose(title, subtitle, items, "Type to filter. q cancels.")
            if choice is None:
                return None
            if choice == "__manual__":
                manual = self.tui.prompt(title, subtitle, "Type a branch name, tag, or commit SHA:", default="HEAD")
                if manual is None:
                    continue
                return manual
            return str(choice)

    def complete_existing_worktree_action(self, request: ActionRequest) -> Any:
        assert request.repo is not None
        while True:
            if request.worktree is None:
                selected = self.choose_existing_worktree(request.repo, request.action)
                if selected is BACK:
                    return BACK
                request.worktree = selected.path
            if request.action == "move" and request.new_path is None:
                default_name = request.worktree.name if request.worktree else "worktree"
                request.new_path = self.choose_target_path(request.repo, default_name)
                if request.new_path is None:
                    request.worktree = None
                    continue
            if request.action == "lock" and request.lock_reason is None:
                request.lock_reason = self.tui.prompt(
                    "Lock Reason",
                    "Optional",
                    "Why are you locking this worktree?",
                    default="",
                    allow_empty=True,
                )
                if request.lock_reason is None:
                    request.worktree = None
                    continue
            if request.action in {"delete", "move"} and not request.force and request.worktree is not None:
                summary = git_status_summary(request.worktree)
                if summary["changes"]:
                    if not self.tui.confirm(
                        request.action.title(),
                        f"{request.worktree} has {summary['changes']} change(s).\nUse --force and continue?",
                        default_yes=False,
                    ):
                        request.worktree = None
                        request.new_path = None
                        continue
                    request.force = True
            if request.action in {"delete", "move", "lock", "unlock"} and not request.yes:
                prompt = f"Proceed with {request.action} on\n{request.worktree}?"
                if request.new_path is not None:
                    prompt += f"\nNew path: {request.new_path}"
                if not self.tui.confirm(request.action.title(), prompt):
                    request.worktree = None
                    request.new_path = None
                    request.lock_reason = None if request.action == "lock" else request.lock_reason
                    continue
                request.yes = True
            return request

    def choose_existing_worktree(self, repo: Path, action: str) -> Any:
        entries = list_worktrees(repo)
        if action in {"delete", "lock", "unlock", "move"}:
            entries = [entry for entry in entries if not entry.is_main]
        items = []
        for entry in entries:
            status = git_status_summary(entry.path)
            state = "clean" if status["clean"] else f"{status['changes']} change(s)"
            extra = []
            if entry.locked:
                extra.append("locked")
            if entry.prunable:
                extra.append("prunable")
            if not status["exists"]:
                extra.append("missing")
            meta = " | ".join([entry.branch_name, state] + extra + [str(entry.path)])
            items.append(MenuItem(entry, entry.path.name or str(entry.path), meta, f"{entry.path} {entry.branch_name}"))
        if not items:
            self.tui.message("Worktrees", [f"No selectable worktrees were found for {action}."])
            return BACK
        choice = self.tui.choose(
            "Worktree",
            f"Select the worktree to {action}.",
            items,
            "Type to filter. q cancels.",
        )
        if choice is None:
            return BACK
        return choice

    def complete_repair(self, request: ActionRequest) -> Any:
        assert request.repo is not None
        if request.repair_paths:
            return request
        while True:
            selected: list[Path] = []
            confirmed = False
            while True:
                choice = self.tui.choose(
                    "Repair",
                    "Add paths that were moved manually and need git worktree repair.",
                    [
                        MenuItem("known", "Add a known worktree path", "Choose from git worktree list"),
                        MenuItem("browse", "Browse for a path", "Pick any directory on disk"),
                        MenuItem("done", "Finish path selection", "Run repair with the paths collected so far"),
                    ],
                    "Enter selects. q cancels.",
                )
                if choice is None:
                    return BACK
                if choice == "done":
                    confirmed = True
                    break
                if choice == "known":
                    picked = self.choose_existing_worktree(request.repo, "repair")
                    if picked is not BACK:
                        selected.append(picked.path)
                        self.tui.status_message = f"Added {picked.path}"
                    continue
                path = self.tui.browse_directory(
                    "Repair Browser",
                    "Choose the moved repo or worktree path to repair.",
                    start=Path.cwd(),
                    select_label="[Use this directory]",
                    allow_new_child=False,
                    repo_mode=False,
                )
                if path is not None:
                    selected.append(path)
                    self.tui.status_message = f"Added {path}"
            if not confirmed:
                continue
            request.repair_paths = selected
            if not request.yes and selected:
                if not self.tui.confirm("Repair", "Run git worktree repair now?"):
                    request.repair_paths = []
                    continue
                request.yes = True
            return request


def needs_interactive(request: ActionRequest) -> bool:
    if request.action is None:
        return True
    if request.action == "create":
        if request.repo is None or request.path is None:
            return True
        if not any([request.branch, request.new_branch, request.reset_branch, request.detach, request.orphan]):
            return True
    if request.action in {"delete", "open", "cd", "lock", "unlock", "move"}:
        if request.repo is None and request.worktree is None:
            return True
        if request.worktree is None:
            return True
        if request.action == "move" and request.new_path is None:
            return True
    if request.action == "repair" and request.repo is None and not request.repair_paths:
        return True
    return False


def execute_create(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo)
    request.repo = repo
    validate_create_request(request, repo)
    path, notes = validate_target_path(request.path, allow_existing_empty=True)
    request.path = path
    cmd = ["worktree", "add"]
    if request.force:
        cmd.append("-f")
    if request.no_checkout:
        cmd.append("--no-checkout")
    if request.lock_on_create:
        cmd.append("--lock")
        if request.lock_reason:
            cmd.extend(["--reason", request.lock_reason])
    if request.orphan:
        cmd.append("--orphan")
    if request.detach:
        cmd.append("--detach")
    if request.new_branch:
        cmd.extend(["-b", request.new_branch])
    if request.reset_branch:
        cmd.extend(["-B", request.reset_branch])
    cmd.append(str(request.path))
    if request.branch:
        cmd.append(request.branch)
    elif request.new_branch or request.reset_branch or request.detach or request.orphan:
        if request.from_ref:
            cmd.append(request.from_ref)
    completed = git(repo, cmd)
    status = git_status_summary(request.path)
    branch_name = request.branch or request.new_branch or request.reset_branch or "DETACHED"
    lines = [
        completed.stdout.strip() or f"Created worktree at {request.path}",
        f"Repo family: {repo}",
        f"Target path: {request.path}",
        f"Branch mode: {branch_name}",
        f"Status: {status['branch_line']}",
    ]
    lines.extend(notes)
    return ActionResult(
        action="create",
        title="Worktree created",
        lines=lines,
        command_hint=equivalent_command(request),
    )


def find_matching_entry(repo: Path, worktree_path: Path) -> Optional[WorktreeEntry]:
    target = worktree_path.expanduser().resolve()
    for entry in list_worktrees(repo):
        if entry.path == target:
            return entry
    return None


def execute_delete(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo or request.worktree)
    request.repo = repo
    if request.worktree is None:
        raise WorktreeError("Missing --worktree for delete.")
    entry = find_matching_entry(repo, request.worktree)
    if entry is None:
        raise WorktreeError(f"{request.worktree} is not a known worktree in {repo}.")
    if entry.is_main:
        raise WorktreeError("The main working tree cannot be removed with git worktree remove.")
    if entry.locked:
        raise WorktreeError(f"{entry.path} is locked. Unlock it first.")
    cmd = ["worktree", "remove"]
    if request.force:
        cmd.append("-f")
    cmd.append(str(entry.path))
    completed = git(repo, cmd)
    lines = [
        completed.stdout.strip() or f"Removed worktree {entry.path}",
        f"Repo family: {repo}",
        f"Removed path: {entry.path}",
    ]
    return ActionResult(
        action="delete",
        title="Worktree removed",
        lines=lines,
        command_hint=equivalent_command(request),
    )


def render_list(repo: Path, *, detailed: bool) -> list[str]:
    entries = list_worktrees(repo)
    lines = [f"Repo family: {repo}", ""]
    for entry in entries:
        status = git_status_summary(entry.path)
        prefix = "*" if entry.is_main else "-"
        state = "clean" if status["clean"] else f"dirty:{status['changes']}"
        missing = " missing" if not status["exists"] else ""
        lock_state = " locked" if entry.locked else ""
        prune_state = f" prunable({entry.prunable})" if entry.prunable else ""
        lines.append(f"{prefix} {entry.path}")
        lines.append(f"    branch: {entry.branch_name} @ {entry.short_head}")
        lines.append(f"    state:  {state}{missing}{lock_state}{prune_state}")
        if detailed and status["exists"]:
            lines.append(f"    git:    {status['branch_line']}")
            raw = status["raw"][:5]
            if raw:
                lines.append("    changes:")
                for item in raw:
                    lines.append(f"      {item}")
                if len(status["raw"]) > len(raw):
                    lines.append(f"      ... and {len(status['raw']) - len(raw)} more")
        lines.append("")
    return lines


def execute_list(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo)
    request.repo = repo
    return ActionResult(
        action="list",
        title="Worktree list",
        lines=render_list(repo, detailed=False),
        command_hint=equivalent_command(request),
    )


def execute_status(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo)
    request.repo = repo
    return ActionResult(
        action="status",
        title="Worktree status",
        lines=render_list(repo, detailed=True),
        command_hint=equivalent_command(request),
    )


def execute_prune(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo)
    request.repo = repo
    cmd = ["worktree", "prune"]
    if request.dry_run:
        cmd.append("-n")
    if request.verbose or request.dry_run:
        cmd.append("-v")
    if request.expire:
        cmd.extend(["--expire", request.expire])
    completed = git(repo, cmd)
    output = completed.stdout.strip() or "No stale worktree entries were pruned."
    lines = [
        f"Repo family: {repo}",
        output,
    ]
    return ActionResult(
        action="prune",
        title="Worktree prune",
        lines=lines,
        command_hint=equivalent_command(request),
    )


def opener_command() -> Optional[list[str]]:
    if sys.platform == "darwin":
        return ["open"]
    if shutil.which("xdg-open"):
        return ["xdg-open"]
    return None


def execute_open(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo or request.worktree)
    request.repo = repo
    if request.worktree is None:
        raise WorktreeError("Missing --worktree for open.")
    target = request.worktree.expanduser().resolve()
    opener = opener_command()
    if opener is None:
        raise WorktreeError("No system opener was found. Use --cd or open the path manually.")
    subprocess.run(opener + [str(target)], check=False)
    return ActionResult(
        action="open",
        title="Worktree opened",
        lines=[f"Opened {target}"],
        command_hint=equivalent_command(request),
    )


def execute_cd(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo or request.worktree)
    request.repo = repo
    if request.worktree is None:
        raise WorktreeError("Missing --worktree for cd.")
    target = request.worktree.expanduser().resolve()
    if request.raw_path:
        return ActionResult(
            action="cd",
            title="Worktree path",
            lines=[],
            command_hint=equivalent_command(request),
            raw_output=str(target),
        )
    return ActionResult(
        action="cd",
        title="CD helper",
        lines=[
            f"cd {shlex.quote(str(target))}",
            "",
            "Shell integration:",
            '  function cwt() { eval "$(worktree --cd "$@")"; }',
        ],
        command_hint=equivalent_command(request),
    )


def execute_lock(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo or request.worktree)
    request.repo = repo
    if request.worktree is None:
        raise WorktreeError("Missing --worktree for lock.")
    cmd = ["worktree", "lock"]
    if request.lock_reason:
        cmd.extend(["--reason", request.lock_reason])
    cmd.append(str(request.worktree.expanduser().resolve()))
    completed = git(repo, cmd)
    return ActionResult(
        action="lock",
        title="Worktree locked",
        lines=[completed.stdout.strip() or f"Locked {request.worktree}"],
        command_hint=equivalent_command(request),
    )


def execute_unlock(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo or request.worktree)
    request.repo = repo
    if request.worktree is None:
        raise WorktreeError("Missing --worktree for unlock.")
    completed = git(repo, ["worktree", "unlock", str(request.worktree.expanduser().resolve())])
    return ActionResult(
        action="unlock",
        title="Worktree unlocked",
        lines=[completed.stdout.strip() or f"Unlocked {request.worktree}"],
        command_hint=equivalent_command(request),
    )


def execute_move(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo or request.worktree)
    request.repo = repo
    if request.worktree is None or request.new_path is None:
        raise WorktreeError("Move needs --worktree and --new-path.")
    entry = find_matching_entry(repo, request.worktree)
    if entry is None:
        raise WorktreeError(f"{request.worktree} is not a known worktree in {repo}.")
    if entry.is_main:
        raise WorktreeError("The main worktree cannot be moved with git worktree move.")
    request.new_path, _ = validate_target_path(request.new_path, allow_existing_empty=True)
    cmd = ["worktree", "move"]
    cmd.extend([str(entry.path), str(request.new_path.expanduser())])
    completed = git(repo, cmd)
    return ActionResult(
        action="move",
        title="Worktree moved",
        lines=[
            completed.stdout.strip() or f"Moved {entry.path} to {request.new_path}",
            f"From: {entry.path}",
            f"To:   {request.new_path}",
        ],
        command_hint=equivalent_command(request),
    )


def execute_repair(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo or (request.repair_paths[0] if request.repair_paths else None))
    request.repo = repo
    cmd = ["worktree", "repair"] + [str(path.expanduser()) for path in request.repair_paths]
    completed = git(repo, cmd)
    paths = ", ".join(str(path) for path in request.repair_paths) if request.repair_paths else "(current repo)"
    return ActionResult(
        action="repair",
        title="Worktree repaired",
        lines=[completed.stdout.strip() or f"Repaired metadata for {paths}"],
        command_hint=equivalent_command(request),
    )


def execute_doctor(request: ActionRequest) -> ActionResult:
    repo = ensure_repo(request.repo)
    request.repo = repo
    entries = list_worktrees(repo)
    issues: list[str] = []
    branch_map: dict[str, list[Path]] = {}
    lines = [f"Repo family: {repo}", ""]
    for entry in entries:
        status = git_status_summary(entry.path)
        branch_map.setdefault(entry.branch_name, []).append(entry.path)
        lines.append(f"{entry.path}")
        lines.append(f"  branch: {entry.branch_name} @ {entry.short_head}")
        lines.append(f"  status: {status['branch_line']}")
        if not status["exists"]:
            issues.append(f"Missing worktree path: {entry.path}")
        if entry.prunable:
            issues.append(f"Prunable metadata for {entry.path}: {entry.prunable}")
        if status["changes"]:
            issues.append(f"Dirty worktree: {entry.path} ({status['changes']} change(s))")
        if entry.locked:
            lines.append(f"  lock:   {entry.lock_reason or '(locked)'}")
        lines.append("")
    for branch_name, paths in branch_map.items():
        if branch_name != "DETACHED" and len(paths) > 1:
            issues.append(f"Branch '{branch_name}' appears in multiple worktrees: {', '.join(str(path) for path in paths)}")
    if issues:
        lines.append("Issues:")
        for issue in issues:
            lines.append(f"  - {issue}")
    else:
        lines.append("Issues:")
        lines.append("  - None detected.")
    lines.append("")
    lines.append("Suggested follow-ups:")
    lines.append(f"  - {shell_join(['worktree', '--status', '--repo', str(repo)])}")
    lines.append(f"  - {shell_join(['worktree', '--prune', '--repo', str(repo), '--dry-run'])}")
    return ActionResult(
        action="doctor",
        title="Worktree doctor",
        lines=lines,
        command_hint=equivalent_command(request),
    )


ACTION_HANDLERS = {
    "create": execute_create,
    "delete": execute_delete,
    "list": execute_list,
    "status": execute_status,
    "prune": execute_prune,
    "open": execute_open,
    "cd": execute_cd,
    "lock": execute_lock,
    "unlock": execute_unlock,
    "move": execute_move,
    "repair": execute_repair,
    "doctor": execute_doctor,
}


def update_history_from_request(state: HistoryState, request: ActionRequest) -> None:
    if request.repo:
        state.recent_repos = remember_path(state.recent_repos, request.repo, 15)
    if request.path:
        state.recent_target_parents = remember_path(state.recent_target_parents, request.path.parent, 15)
    if request.new_path:
        state.recent_target_parents = remember_path(state.recent_target_parents, request.new_path.parent, 15)
    if request.worktree:
        state.recent_worktrees = remember_path(state.recent_worktrees, request.worktree, 25)


def print_result(result: ActionResult, *, color: bool) -> None:
    if result.raw_output is not None:
        print(result.raw_output)
        return
    print(ansi("1;36", result.title, color))
    for line in result.lines:
        print(line)
    print()
    print(ansi("1;33", "Repeat this without the wizard:", color))
    print(f"  {result.command_hint}")


def interactive_result_lines(result: ActionResult) -> list[str]:
    lines = [result.raw_output] if result.raw_output is not None else list(result.lines)
    if result.command_hint:
        if lines:
            lines.append("")
        lines.append("Repeat this without the wizard:")
        lines.append(f"  {result.command_hint}")
    return lines


def show_result_tui(result: ActionResult, state: HistoryState) -> None:
    def runner(stdscr: "curses._CursesWindow") -> None:
        tui = TUI(stdscr, state)
        tui.message(result.title, interactive_result_lines(result))

    curses.wrapper(runner)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="worktree",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description=textwrap.dedent(
            """\
            WORKTREE CONTROL

            Interactive, keyboard-first helper for the git worktree commands people never remember.

            With no action flags, `worktree` launches a curses TUI that walks through the missing choices.
            With flags, it can run headlessly for scripting or quick repeat use.
            """
        ),
        epilog=textwrap.dedent(
            """\
            Core actions:
              --create    Create a new linked worktree
              --delete    Remove a linked worktree
              --list      List every worktree in the repo family
              --status    Show clean/dirty state for each worktree
              --prune     Remove stale worktree admin records
              --open      Open a selected worktree in Finder
              --cd        Print a `cd ...` command, or a raw path with --raw-path
              --lock      Lock a linked worktree
              --unlock    Unlock a linked worktree
              --move      Move a linked worktree to a new path
              --repair    Repair worktree metadata after manual moves
              --doctor    Inspect the repo family and flag issues

            Create modes:
              --branch NAME         Use an existing local branch
              --new-branch NAME     Create a new branch from --from
              --reset-branch NAME   Create or reset a branch from --from
              --detach              Create a detached HEAD worktree from --from
              --orphan              Create an unborn branch; pair with --new-branch or --reset-branch

            Useful examples:
              worktree
              worktree --create --repo ~/src/myapp --new-branch feature/auth --from main --path ~/wt/myapp-auth
              worktree --delete --repo ~/src/myapp --worktree ~/wt/myapp-auth --force
              worktree --status --repo ~/src/myapp
              worktree --prune --repo ~/src/myapp --dry-run
              eval "$(worktree --cd --repo ~/src/myapp --worktree ~/wt/myapp-auth)"
            """
        ),
    )
    action_group = parser.add_mutually_exclusive_group()
    action_group.add_argument("--create", action="store_true", help="Create a new worktree.")
    action_group.add_argument("--delete", action="store_true", help="Delete a linked worktree.")
    action_group.add_argument("--list", action="store_true", help="List worktrees in a repo family.")
    action_group.add_argument("--status", action="store_true", help="Show worktree status details.")
    action_group.add_argument("--prune", action="store_true", help="Prune stale worktree metadata.")
    action_group.add_argument("--open", action="store_true", help="Open a worktree in Finder.")
    action_group.add_argument("--cd", action="store_true", help="Print a shell-safe cd command.")
    action_group.add_argument("--lock", action="store_true", help="Lock a linked worktree.")
    action_group.add_argument("--unlock", action="store_true", help="Unlock a linked worktree.")
    action_group.add_argument("--move", action="store_true", help="Move a linked worktree.")
    action_group.add_argument("--repair", action="store_true", help="Repair moved worktree metadata.")
    action_group.add_argument("--doctor", action="store_true", help="Inspect the repo family for issues.")

    parser.add_argument("--repo", help="Path to any worktree in the repo family you want to manage.")
    parser.add_argument("--path", help="Target path for --create.")
    parser.add_argument("--worktree", help="Existing worktree path for --delete, --open, --cd, --lock, --unlock, or --move.")
    parser.add_argument("--new-path", help="Destination path for --move.")
    parser.add_argument("--branch", help="Existing local branch for --create.")
    parser.add_argument("--new-branch", help="Create a new branch for --create.")
    parser.add_argument("--reset-branch", help="Create or reset a branch for --create.")
    parser.add_argument("--from", dest="from_ref", help="Start-point ref, branch, tag, or commit for create flows.")
    parser.add_argument("--detach", action="store_true", help="Create a detached worktree from --from.")
    parser.add_argument("--orphan", action="store_true", help="Create an unborn branch. Pair with --new-branch or --reset-branch.")
    parser.add_argument("--force", action="store_true", help="Pass -f where the underlying git command supports it.")
    parser.add_argument("--no-checkout", action="store_true", help="Create metadata without populating files for --create.")
    parser.add_argument("--lock-on-create", action="store_true", help="Lock the new worktree immediately after create.")
    parser.add_argument("--lock-reason", help="Reason to use with --lock or --lock-on-create.")
    parser.add_argument("--expire", help="Expire specification for --prune, such as now or 3.days.ago.")
    parser.add_argument("--dry-run", action="store_true", help="Preview --prune without changing anything.")
    parser.add_argument("--repair-path", action="append", default=[], help="Path to repair. Repeat for multiple values.")
    parser.add_argument("--raw-path", action="store_true", help="For --cd, print only the path so scripts can capture it.")
    parser.add_argument("--yes", action="store_true", help="Skip interactive confirmation prompts when flags are sufficient.")
    parser.add_argument("--verbose", action="store_true", help="Show extra detail where supported.")
    parser.add_argument("--no-color", action="store_true", help="Disable ANSI color in printed output.")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    return parser


def launch_wizard(request: ActionRequest, state: HistoryState) -> Optional[ActionRequest]:
    def runner(stdscr: "curses._CursesWindow") -> Optional[ActionRequest]:
        tui = TUI(stdscr, state)
        wizard = InteractiveWizard(tui, state)
        return wizard.complete(request)

    return curses.wrapper(runner)


def main(argv: Optional[list[str]] = None) -> int:
    ensure_git_available()
    parser = build_parser()
    args = parser.parse_args(argv)
    request = request_from_args(args)
    state = load_state()
    session_mode = request.action is None
    if needs_interactive(request):
        if not (sys.stdin.isatty() and sys.stdout.isatty()):
            parser.error("Missing required options and no TTY is available for the interactive wizard.")
        if session_mode:
            session_defaults = ActionRequest(verbose=request.verbose, no_color=request.no_color)
            while True:
                try:
                    completed = launch_wizard(request, state)
                except curses.error as exc:
                    raise WorktreeError(f"Unable to start the TUI: {exc}")
                if completed is None:
                    return 130
                handler = ACTION_HANDLERS[completed.action]
                result = handler(completed)
                update_history_from_request(state, completed)
                save_state(state)
                try:
                    show_result_tui(result, state)
                except curses.error as exc:
                    raise WorktreeError(f"Unable to show the TUI result view: {exc}")
                request = ActionRequest(verbose=session_defaults.verbose, no_color=session_defaults.no_color)
        else:
            try:
                completed = launch_wizard(request, state)
            except curses.error as exc:
                raise WorktreeError(f"Unable to start the TUI: {exc}")
            if completed is None:
                return 130
            request = completed

    if request.action is None:
        parser.print_help()
        return 0

    handler = ACTION_HANDLERS[request.action]
    result = handler(request)
    update_history_from_request(state, request)
    save_state(state)
    print_result(result, color=supports_color(request.no_color))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except WorktreeError as exc:
        color = supports_color(False)
        print(ansi("1;31", "Error", color), file=sys.stderr)
        print(str(exc), file=sys.stderr)
        raise SystemExit(2)
