def update_history_from_request(state: HistoryState, request: ActionRequest) -> None:
    if request.repo:
        state.recent_repos = remember_path(state.recent_repos, request.repo, 15)
    if request.path:
        state.recent_target_parents = remember_path(state.recent_target_parents, request.path.parent, 15)
    if request.new_path:
        state.recent_target_parents = remember_path(state.recent_target_parents, request.new_path.parent, 15)
    if request.worktree:
        state.recent_worktrees = remember_path(state.recent_worktrees, request.worktree, 25)


def print_result(result: ActionResult, *, color: bool) -> None:
    if result.raw_output is not None:
        print(result.raw_output)
        return
    print(ansi("1;36", result.title, color))
    for line in result.lines:
        print(line)
    print()
    print(ansi("1;33", "Repeat this without the wizard:", color))
    print(f"  {result.command_hint}")


def interactive_result_lines(result: ActionResult) -> list[str]:
    lines = [result.raw_output] if result.raw_output is not None else list(result.lines)
    if result.command_hint:
        if lines:
            lines.append("")
        lines.append("Repeat this without the wizard:")
        lines.append(f"  {result.command_hint}")
    return lines


def show_result_tui(result: ActionResult, state: HistoryState) -> None:
    def runner(stdscr: "curses._CursesWindow") -> None:
        tui = TUI(stdscr, state)
        tui.message(result.title, interactive_result_lines(result))

    curses.wrapper(runner)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="worktree",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description=textwrap.dedent(
            """\
            WORKTREE CONTROL

            Interactive, keyboard-first helper for the git worktree commands people never remember.

            With no action flags, `worktree` launches a curses TUI that walks through the missing choices.
            With flags, it can run headlessly for scripting or quick repeat use.
            """
        ),
        epilog=textwrap.dedent(
            """\
            Core actions:
              --create    Create a new linked worktree
              --delete    Remove a linked worktree
              --list      List every worktree in the repo family
              --status    Show clean/dirty state for each worktree
              --prune     Remove stale worktree admin records
              --open      Open a selected worktree in Finder
              --cd        Print a `cd ...` command, or a raw path with --raw-path
              --lock      Lock a linked worktree
              --unlock    Unlock a linked worktree
              --move      Move a linked worktree to a new path
              --repair    Repair worktree metadata after manual moves
              --doctor    Inspect the repo family and flag issues

            Create modes:
              --branch NAME         Use an existing local branch
              --new-branch NAME     Create a new branch from --from
              --reset-branch NAME   Create or reset a branch from --from
              --detach              Create a detached HEAD worktree from --from
              --orphan              Create an unborn branch; pair with --new-branch or --reset-branch

            Useful examples:
              worktree
              worktree --create --repo ~/src/myapp --new-branch feature/auth --from main --path ~/wt/myapp-auth
              worktree --delete --repo ~/src/myapp --worktree ~/wt/myapp-auth --force
              worktree --status --repo ~/src/myapp
              worktree --prune --repo ~/src/myapp --dry-run
              eval "$(worktree --cd --repo ~/src/myapp --worktree ~/wt/myapp-auth)"
            """
        ),
    )
    action_group = parser.add_mutually_exclusive_group()
    action_group.add_argument("--create", action="store_true", help="Create a new worktree.")
    action_group.add_argument("--delete", action="store_true", help="Delete a linked worktree.")
    action_group.add_argument("--list", action="store_true", help="List worktrees in a repo family.")
    action_group.add_argument("--status", action="store_true", help="Show worktree status details.")
    action_group.add_argument("--prune", action="store_true", help="Prune stale worktree metadata.")
    action_group.add_argument("--open", action="store_true", help="Open a worktree in Finder.")
    action_group.add_argument("--cd", action="store_true", help="Print a shell-safe cd command.")
    action_group.add_argument("--lock", action="store_true", help="Lock a linked worktree.")
    action_group.add_argument("--unlock", action="store_true", help="Unlock a linked worktree.")
    action_group.add_argument("--move", action="store_true", help="Move a linked worktree.")
    action_group.add_argument("--repair", action="store_true", help="Repair moved worktree metadata.")
    action_group.add_argument("--doctor", action="store_true", help="Inspect the repo family for issues.")

    parser.add_argument("--repo", help="Path to any worktree in the repo family you want to manage.")
    parser.add_argument("--path", help="Target path for --create.")
    parser.add_argument("--worktree", help="Existing worktree path for --delete, --open, --cd, --lock, --unlock, or --move.")
    parser.add_argument("--new-path", help="Destination path for --move.")
    parser.add_argument("--branch", help="Existing local branch for --create.")
    parser.add_argument("--new-branch", help="Create a new branch for --create.")
    parser.add_argument("--reset-branch", help="Create or reset a branch for --create.")
    parser.add_argument("--from", dest="from_ref", help="Start-point ref, branch, tag, or commit for create flows.")
    parser.add_argument("--detach", action="store_true", help="Create a detached worktree from --from.")
    parser.add_argument("--orphan", action="store_true", help="Create an unborn branch. Pair with --new-branch or --reset-branch.")
    parser.add_argument("--force", action="store_true", help="Pass -f where the underlying git command supports it.")
    parser.add_argument("--no-checkout", action="store_true", help="Create metadata without populating files for --create.")
    parser.add_argument("--lock-on-create", action="store_true", help="Lock the new worktree immediately after create.")
    parser.add_argument("--lock-reason", help="Reason to use with --lock or --lock-on-create.")
    parser.add_argument("--expire", help="Expire specification for --prune, such as now or 3.days.ago.")
    parser.add_argument("--dry-run", action="store_true", help="Preview --prune without changing anything.")
    parser.add_argument("--repair-path", action="append", default=[], help="Path to repair. Repeat for multiple values.")
    parser.add_argument("--raw-path", action="store_true", help="For --cd, print only the path so scripts can capture it.")
    parser.add_argument("--yes", action="store_true", help="Skip interactive confirmation prompts when flags are sufficient.")
    parser.add_argument("--verbose", action="store_true", help="Show extra detail where supported.")
    parser.add_argument("--no-color", action="store_true", help="Disable ANSI color in printed output.")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    return parser


def launch_wizard(request: ActionRequest, state: HistoryState) -> Optional[ActionRequest]:
    def runner(stdscr: "curses._CursesWindow") -> Optional[ActionRequest]:
        tui = TUI(stdscr, state)
        wizard = InteractiveWizard(tui, state)
        return wizard.complete(request)

    return curses.wrapper(runner)


def main(argv: Optional[list[str]] = None) -> int:
    ensure_git_available()
    parser = build_parser()
    args = parser.parse_args(argv)
    request = request_from_args(args)
    state = load_state()
    session_mode = request.action is None
    if needs_interactive(request):
        if not (sys.stdin.isatty() and sys.stdout.isatty()):
            parser.error("Missing required options and no TTY is available for the interactive wizard.")
        if session_mode:
            session_defaults = ActionRequest(verbose=request.verbose, no_color=request.no_color)
            while True:
                try:
                    completed = launch_wizard(request, state)
                except curses.error as exc:
                    raise WorktreeError(f"Unable to start the TUI: {exc}")
                if completed is None:
                    return 130
                handler = ACTION_HANDLERS[completed.action]
                result = handler(completed)
                update_history_from_request(state, completed)
                save_state(state)
                state.last_result_summary = f"\u2713 {result.title}"
                try:
                    show_result_tui(result, state)
                except curses.error as exc:
                    raise WorktreeError(f"Unable to show the TUI result view: {exc}")
                request = ActionRequest(verbose=session_defaults.verbose, no_color=session_defaults.no_color)
        else:
            try:
                completed = launch_wizard(request, state)
            except curses.error as exc:
                raise WorktreeError(f"Unable to start the TUI: {exc}")
            if completed is None:
                return 130
            request = completed

    if request.action is None:
        parser.print_help()
        return 0

    handler = ACTION_HANDLERS[request.action]
    result = handler(request)
    update_history_from_request(state, request)
    save_state(state)
    print_result(result, color=supports_color(request.no_color))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except WorktreeError as exc:
        color = supports_color(False)
        print(ansi("1;31", "Error", color), file=sys.stderr)
        print(str(exc), file=sys.stderr)
        raise SystemExit(2)
