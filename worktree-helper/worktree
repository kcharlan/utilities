class WorktreeError(RuntimeError):
    """Raised for user-facing worktree problems."""


@dataclass
class HistoryState:
    recent_repos: list[str] = field(default_factory=list)
    recent_target_parents: list[str] = field(default_factory=list)
    recent_worktrees: list[str] = field(default_factory=list)
    last_result_summary: str = ""  # session-only, not persisted


@dataclass
class WorktreeEntry:
    path: Path
    head: str = ""
    branch_ref: str = ""
    detached: bool = False
    bare: bool = False
    locked: bool = False
    lock_reason: str = ""
    prunable: str = ""

    @property
    def branch_name(self) -> str:
        if self.branch_ref.startswith("refs/heads/"):
            return self.branch_ref[len("refs/heads/") :]
        if self.branch_ref:
            return self.branch_ref
        if self.detached:
            return "DETACHED"
        return "(unknown)"

    @property
    def short_head(self) -> str:
        return self.head[:10] if self.head else "?"

    @property
    def is_main(self) -> bool:
        git_dir = self.path / ".git"
        return git_dir.is_dir()


@dataclass
class BranchEntry:
    name: str
    full_ref: str
    kind: str
    upstream: str = ""
    sha: str = ""
    relative_date: str = ""


