class WorktreeError(RuntimeError):
    """Raised for user-facing worktree problems."""


@dataclass
class HistoryState:
    recent_repos: list[str] = field(default_factory=list)
    recent_target_parents: list[str] = field(default_factory=list)
    recent_worktrees: list[str] = field(default_factory=list)


@dataclass
class WorktreeEntry:
    path: Path
    head: str = ""
    branch_ref: str = ""
    detached: bool = False
    bare: bool = False
    locked: bool = False
    lock_reason: str = ""
    prunable: str = ""

    @property
    def branch_name(self) -> str:
        if self.branch_ref.startswith("refs/heads/"):
            return self.branch_ref[len("refs/heads/") :]
        if self.branch_ref:
            return self.branch_ref
        if self.detached:
            return "DETACHED"
        return "(unknown)"

    @property
    def short_head(self) -> str:
        return self.head[:10] if self.head else "?"

    @property
    def is_main(self) -> bool:
        git_dir = self.path / ".git"
        return git_dir.is_dir()


@dataclass
class BranchEntry:
    name: str
    full_ref: str
    kind: str
    upstream: str = ""
    sha: str = ""
    relative_date: str = ""


@dataclass
class ActionRequest:
    action: Optional[str] = None
    repo: Optional[Path] = None
    path: Optional[Path] = None
    worktree: Optional[Path] = None
    new_path: Optional[Path] = None
    branch: Optional[str] = None
    new_branch: Optional[str] = None
    reset_branch: Optional[str] = None
    from_ref: Optional[str] = None
    detach: bool = False
    orphan: bool = False
    force: bool = False
    no_checkout: bool = False
    lock_on_create: bool = False
    lock_reason: Optional[str] = None
    expire: Optional[str] = None
    dry_run: bool = False
    repair_paths: list[Path] = field(default_factory=list)
    raw_path: bool = False
    yes: bool = False
    verbose: bool = False
    no_color: bool = False


@dataclass
class ActionResult:
    action: str
    title: str
    lines: list[str]
    command_hint: str
    raw_output: Optional[str] = None


@dataclass
class MenuItem:
    value: Any
    label: str
    meta: str = ""
