def load_state() -> HistoryState:
    if not STATE_FILE.exists():
        return HistoryState()
    try:
        data = json.loads(STATE_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return HistoryState()
    return HistoryState(
        recent_repos=[str(Path(p).expanduser()) for p in data.get("recent_repos", [])][:15],
        recent_target_parents=[
            str(Path(p).expanduser()) for p in data.get("recent_target_parents", [])
        ][:15],
        recent_worktrees=[str(Path(p).expanduser()) for p in data.get("recent_worktrees", [])][:25],
    )


def remember_path(bucket: list[str], path: Path, limit: int) -> list[str]:
    raw = str(path.expanduser())
    updated = [raw] + [item for item in bucket if item != raw]
    return updated[:limit]


def normalize_ui_path(path: Path) -> Path:
    raw = os.path.abspath(os.path.expanduser(str(path)))
    return Path(raw)


def save_state(state: HistoryState) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "recent_repos": state.recent_repos[:15],
        "recent_target_parents": state.recent_target_parents[:15],
        "recent_worktrees": state.recent_worktrees[:25],
    }
    STATE_FILE.write_text(json.dumps(payload, indent=2) + "\n")


def shell_join(parts: Iterable[str]) -> str:
    return " ".join(shlex.quote(part) for part in parts)


def supports_color(no_color: bool) -> bool:
    return sys.stdout.isatty() and not no_color and os.getenv("TERM", "dumb") != "dumb"


def ansi(code: str, text: str, enabled: bool) -> str:
    if not enabled:
        return text
    return f"\033[{code}m{text}\033[0m"


def git(
    repo: Optional[Path],
    args: list[str],
    *,
    check: bool = True,
    capture: bool = True,
) -> subprocess.CompletedProcess[str]:
    cmd = ["git"]
    if repo is not None:
        cmd.extend(["-C", str(repo)])
    cmd.extend(args)
    completed = subprocess.run(
        cmd,
        text=True,
        capture_output=capture,
        check=False,
    )
    if check and completed.returncode != 0:
        stderr = completed.stderr.strip() or completed.stdout.strip() or "git command failed"
        raise WorktreeError(stderr)
    return completed


def resolve_repo_root(path: Path) -> Optional[Path]:
    candidate = path.expanduser().resolve()
    completed = git(candidate, ["rev-parse", "--show-toplevel"], check=False)
    if completed.returncode != 0:
        return None
    return Path(completed.stdout.strip()).resolve()


def pick_default_repo(seed: Optional[Path]) -> Optional[Path]:
    if seed is not None:
        root = resolve_repo_root(seed)
        if root is not None:
            return root
    return resolve_repo_root(Path.cwd())


def parse_worktree_list(text: str) -> list[WorktreeEntry]:
    entries: list[WorktreeEntry] = []
    current: dict[str, Any] = {}
    for raw_line in text.splitlines():
        line = raw_line.rstrip()
        if not line:
            if current.get("path"):
                entries.append(
                    WorktreeEntry(
                        path=Path(current["path"]).expanduser().resolve(),
                        head=current.get("head", ""),
                        branch_ref=current.get("branch_ref", ""),
                        detached=current.get("detached", False),
                        bare=current.get("bare", False),
                        locked=current.get("locked", False),
                        lock_reason=current.get("lock_reason", ""),
                        prunable=current.get("prunable", ""),
                    )
                )
            current = {}
            continue
        key, _, value = line.partition(" ")
        if key == "worktree":
            current["path"] = value
        elif key == "HEAD":
            current["head"] = value
        elif key == "branch":
            current["branch_ref"] = value
        elif key == "detached":
            current["detached"] = True
        elif key == "bare":
            current["bare"] = True
        elif key == "locked":
            current["locked"] = True
            current["lock_reason"] = value
        elif key == "prunable":
            current["prunable"] = value
    if current.get("path"):
        entries.append(
            WorktreeEntry(
                path=Path(current["path"]).expanduser().resolve(),
                head=current.get("head", ""),
                branch_ref=current.get("branch_ref", ""),
                detached=current.get("detached", False),
                bare=current.get("bare", False),
                locked=current.get("locked", False),
                lock_reason=current.get("lock_reason", ""),
                prunable=current.get("prunable", ""),
            )
        )
    return entries


def list_worktrees(repo: Path) -> list[WorktreeEntry]:
    completed = git(repo, ["worktree", "list", "--porcelain"])
    return parse_worktree_list(completed.stdout)


def get_local_branches(repo: Path) -> list[BranchEntry]:
    completed = git(
        repo,
        [
            "for-each-ref",
            "--sort=-committerdate",
            "--format=%(refname:short)\t%(refname)\t%(upstream:short)\t%(objectname:short)\t%(committerdate:relative)",
            "refs/heads",
        ],
    )
    branches: list[BranchEntry] = []
    for line in completed.stdout.splitlines():
        name, full_ref, upstream, sha, relative_date = (line.split("\t") + ["", "", "", "", ""])[:5]
        branches.append(
            BranchEntry(
                name=name,
                full_ref=full_ref,
                kind="local",
                upstream=upstream,
                sha=sha,
                relative_date=relative_date,
            )
        )
    return branches


def get_remote_refs(repo: Path) -> list[BranchEntry]:
    completed = git(
        repo,
        [
            "for-each-ref",
            "--sort=-committerdate",
            "--format=%(refname:short)\t%(refname)\t%(objectname:short)\t%(committerdate:relative)",
            "refs/remotes",
        ],
    )
    refs: list[BranchEntry] = []
    for line in completed.stdout.splitlines():
        name, full_ref, sha, relative_date = (line.split("\t") + ["", "", "", ""])[:4]
        if name.endswith("/HEAD"):
            continue
        refs.append(
            BranchEntry(
                name=name,
                full_ref=full_ref,
                kind="remote",
                sha=sha,
                relative_date=relative_date,
            )
        )
    return refs


def get_current_branch(repo: Path) -> Optional[str]:
    completed = git(repo, ["branch", "--show-current"], check=False)
    name = completed.stdout.strip()
    return name or None


def git_status_summary(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {
            "exists": False,
            "clean": False,
            "branch_line": "(missing on disk)",
            "changes": 0,
            "untracked": 0,
            "raw": [],
        }
    completed = git(path, ["status", "--short", "--branch"], check=False)
    if completed.returncode != 0:
        return {
            "exists": True,
            "clean": False,
            "branch_line": "(unable to read status)",
            "changes": 0,
            "untracked": 0,
            "raw": [],
        }
    lines = completed.stdout.splitlines()
    branch_line = lines[0] if lines else "## ?"
    changes = 0
    untracked = 0
    for line in lines[1:]:
        if line.startswith("??"):
            untracked += 1
        if line.strip():
            changes += 1
    return {
        "exists": True,
        "clean": changes == 0,
        "branch_line": branch_line.replace("## ", ""),
        "changes": changes,
        "untracked": untracked,
        "raw": lines[1:],
    }


def path_name_for_branch(repo: Path, branch_like: str) -> str:
    safe = branch_like.replace("/", "-").replace(" ", "-")
    safe = "".join(ch for ch in safe if ch.isalnum() or ch in "-_.")
    safe = safe.strip("-_.") or "worktree"
    return f"{repo.name}-{safe}"


def ensure_git_available() -> None:
    if shutil.which("git") is None:
        raise WorktreeError("git is not installed or not available on PATH.")


def ensure_repo(value: Optional[Path]) -> Path:
    repo = pick_default_repo(value)
    if repo is None:
        raise WorktreeError(
            "Could not detect a git repository. Run inside a repo, pass --repo, or use the interactive picker."
        )
    return repo


def validate_create_request(request: ActionRequest, repo: Path) -> None:
    modes = [
        bool(request.branch),
        bool(request.new_branch),
        bool(request.reset_branch),
        request.detach,
        request.orphan,
    ]
    if sum(1 for mode in modes if mode) == 0:
        raise WorktreeError(
            "Create mode is ambiguous. Use --branch, --new-branch, --reset-branch, --detach, or --orphan."
        )
    if sum(1 for mode in modes if mode) > 1:
        raise WorktreeError(
            "Choose only one create mode: existing branch, new branch, reset branch, detached, or orphan."
        )
    if request.path is None:
        raise WorktreeError("Missing target path for create. Pass --path or use the picker.")
    if request.orphan and not (request.new_branch or request.reset_branch):
        raise WorktreeError("Orphan creation needs --new-branch or --reset-branch.")
    if request.branch:
        available = {entry.name for entry in get_local_branches(repo)}
        if request.branch not in available:
            raise WorktreeError(f"Local branch '{request.branch}' does not exist in {repo}.")
        for entry in list_worktrees(repo):
            if entry.branch_name == request.branch and entry.path != request.path and not request.force:
                raise WorktreeError(
                    f"Branch '{request.branch}' is already checked out in {entry.path}. Use --force or choose a different branch."
                )


def validate_target_path(path: Path, *, allow_existing_empty: bool) -> tuple[Path, list[str]]:
    resolved = path.expanduser().resolve()
    notes: list[str] = []
    if resolved.exists():
        if not resolved.is_dir():
            raise WorktreeError(f"{resolved} exists but is not a directory.")
        entries = list(resolved.iterdir())
        if entries and not allow_existing_empty:
            raise WorktreeError(f"{resolved} exists and is not empty.")
        if entries and allow_existing_empty:
            notes.append("Target directory already exists and is not empty. Git may reject this path.")
        elif not entries:
            notes.append("Target directory already exists and is empty.")
    else:
        notes.append("Target directory does not exist yet and will be created by git.")
    return resolved, notes


def equivalent_command(request: ActionRequest) -> str:
    parts = ["worktree"]
    action_to_flag = {
        "create": "--create",
        "delete": "--delete",
        "list": "--list",
        "status": "--status",
        "prune": "--prune",
        "open": "--open",
        "cd": "--cd",
        "lock": "--lock",
        "unlock": "--unlock",
        "move": "--move",
        "repair": "--repair",
        "doctor": "--doctor",
    }
    if request.action:
        parts.append(action_to_flag[request.action])
    if request.repo:
        parts.extend(["--repo", str(request.repo)])
    if request.path:
        parts.extend(["--path", str(request.path)])
    if request.worktree:
        parts.extend(["--worktree", str(request.worktree)])
    if request.new_path:
        parts.extend(["--new-path", str(request.new_path)])
    if request.branch:
        parts.extend(["--branch", request.branch])
    if request.new_branch:
        parts.extend(["--new-branch", request.new_branch])
    if request.reset_branch:
        parts.extend(["--reset-branch", request.reset_branch])
    if request.from_ref:
        parts.extend(["--from", request.from_ref])
    if request.detach:
        parts.append("--detach")
    if request.orphan:
        parts.append("--orphan")
    if request.force:
        parts.append("--force")
    if request.no_checkout:
        parts.append("--no-checkout")
    if request.lock_on_create:
        parts.append("--lock-on-create")
    if request.lock_reason:
        parts.extend(["--lock-reason", request.lock_reason])
    if request.expire:
        parts.extend(["--expire", request.expire])
    if request.dry_run:
        parts.append("--dry-run")
    for repair_path in request.repair_paths:
        parts.extend(["--repair-path", str(repair_path)])
    if request.raw_path:
        parts.append("--raw-path")
    if request.yes:
        parts.append("--yes")
    if request.verbose:
        parts.append("--verbose")
    return shell_join(parts)


def detect_action(namespace: argparse.Namespace) -> Optional[str]:
    for name in (
        "create",
        "delete",
        "list",
        "status",
        "prune",
        "open",
        "cd",
        "lock",
        "unlock",
        "move",
        "repair",
        "doctor",
    ):
        if getattr(namespace, name):
            return name
    return None


def request_from_args(namespace: argparse.Namespace) -> ActionRequest:
    return ActionRequest(
        action=detect_action(namespace),
        repo=Path(namespace.repo).expanduser().resolve() if namespace.repo else None,
        path=Path(namespace.path).expanduser().resolve() if namespace.path else None,
        worktree=Path(namespace.worktree).expanduser().resolve() if namespace.worktree else None,
        new_path=Path(namespace.new_path).expanduser().resolve() if namespace.new_path else None,
        branch=namespace.branch,
        new_branch=namespace.new_branch,
        reset_branch=namespace.reset_branch,
        from_ref=namespace.from_ref,
        detach=namespace.detach,
        orphan=namespace.orphan,
        force=namespace.force,
        no_checkout=namespace.no_checkout,
        lock_on_create=namespace.lock_on_create,
        lock_reason=namespace.lock_reason,
        expire=namespace.expire,
        dry_run=namespace.dry_run,
        repair_paths=[Path(item).expanduser().resolve() for item in namespace.repair_path or []],
        raw_path=namespace.raw_path,
        yes=namespace.yes,
        verbose=namespace.verbose,
        no_color=namespace.no_color,
    )



