        return {"ok": True, "lookups": lookups, "updated_at": config["lookup_cache_updated_at"]}
    except GraphAPIError as exc:
        raise HTTPException(status_code=400, detail=str(exc)) from exc
    except ValueError as exc:
        raise HTTPException(status_code=400, detail=str(exc)) from exc
    finally:
