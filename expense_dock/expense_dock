                        </form>
                      </div>

                    </section>

                    <section className="space-y-6">
                      <div className="rounded-[1.75rem] border border-[var(--line)] p-6">
                        <div className="text-xs uppercase tracking-[0.22em] text-[var(--accent)]">Workflow</div>
                        <h2 className="font-display text-2xl mt-1">What this run does</h2>
                        <ol className="mt-4 space-y-4 text-sm">
                          <li>1. Resolves the shared <span className="font-mono">Business Expenses</span> folder from your OneDrive share URL.</li>
                          <li>2. Ensures the year and month folders exist.</li>
                          <li>3. Uploads the file only if the normalized receipt filename is not already present.</li>
