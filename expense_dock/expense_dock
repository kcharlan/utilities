@app.post("/api/submit")
async def submit_expense(payload: str = Form(...), receipt: UploadFile = File(...)):
    config = load_config()
    if not config_is_complete(config):
        raise HTTPException(status_code=400, detail="Config is incomplete.")
    try:
        submission = parse_submission(json.loads(payload))
    except json.JSONDecodeError as exc:
        raise HTTPException(status_code=400, detail="Payload must be valid JSON.") from exc
    if not receipt:
        raise HTTPException(status_code=400, detail="A receipt file is required.")
    file_bytes = await receipt.read()
    if not file_bytes:
        raise HTTPException(status_code=400, detail="Receipt file is empty.")
    result = process_submission(config, submission, file_bytes, receipt.filename or "receipt", receipt.content_type or "")
    if result["ok"]:
        return result
    return JSONResponse(status_code=500, content=result)


