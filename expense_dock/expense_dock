                        </div>
                        {status?.lookup_cache_updated_at ? (
                          <div className="mt-2 text-[var(--muted)]">
                            Dropdown cache refreshed: <span className="font-mono">{status.lookup_cache_updated_at}</span>
                          </div>
                        ) : null}
                      </div>
                    </div>
                    <div className="mt-5 rounded-2xl border border-[var(--line)] p-4 text-sm text-[var(--muted)]">
                      <div className="font-semibold text-[var(--ink)] mb-2">App registration notes</div>
                      <p>Use a public client app with personal Microsoft accounts and add <span className="font-mono">http://localhost</span> as a mobile/desktop redirect URI.</p>
                    </div>
                  </section>

                  <section className="rounded-[1.5rem] border border-[var(--line)] p-5">
                    <div className="text-xs uppercase tracking-[0.22em] text-[var(--accent)]">Queue</div>
                    <h2 className="font-display text-2xl mt-1">Pending workbook retries</h2>
                    <div className="space-y-3 mt-4">
                      {(status?.pending || []).length === 0 ? (
                        <div className="text-sm text-[var(--muted)]">Nothing waiting. If workbook upload fails after the receipt is already in OneDrive, the retry item appears here.</div>
                      ) : (
                        status.pending.map((item) => (
                          <div key={item.id} className="rounded-2xl border border-[var(--line)] p-4">
                            <div className="flex items-start justify-between gap-3">
                              <div>
                                <div className="font-semibold">{item.vendor} • ${Number(item.amount || 0).toFixed(2)}</div>
                                <div className="text-sm text-[var(--muted)] mt-1">{item.date}</div>
                                <div className="text-xs font-mono mt-2 break-all">{item.receipt_filename}</div>
                              </div>
                              <Badge tone="warn">Retry</Badge>
                            </div>
                            <div className="text-sm text-rose-700 dark:text-rose-300 mt-3">{item.error}</div>
                            <div className="mt-4 flex flex-wrap gap-2">
                              <button onClick={() => retryPending(item.id)} disabled={busy === `retry-${item.id}`} className="rounded-full bg-[var(--accent-2)] text-white px-4 py-2 text-sm font-semibold disabled:opacity-60">
                                {busy === `retry-${item.id}` ? 'Retrying…' : 'Retry workbook append'}
                              </button>
                              <button onClick={() => window.open(`/api/pending/${item.id}/csv`, '_blank')} className="rounded-full border border-[var(--line)] px-4 py-2 text-sm font-semibold">
                                Download CSV fallback
                              </button>
                            </div>
                          </div>
                        ))
                      )}
                    </div>
                  </section>
                </aside>

                <main className="p-5 md:p-7">
                  <div className="grid lg:grid-cols-[minmax(0,1fr)_300px] gap-6">
                    <section className="space-y-6">
                      <div className="rounded-[1.75rem] border border-[var(--line)] p-6">
                        <div className="flex flex-wrap items-center justify-between gap-4">
                          <div>
                            <div className="text-xs uppercase tracking-[0.22em] text-[var(--accent)]">New submission</div>
                            <h2 className="font-display text-3xl mt-1">Ledger entry</h2>
                          </div>
                          <div className="flex flex-wrap gap-2">
                            <Badge tone={status?.ready ? 'good' : 'warn'}>{status?.ready ? 'Config ready' : 'Config incomplete'}</Badge>
                            <Badge tone={status?.auth?.connected ? 'good' : 'warn'}>{status?.auth?.account || 'No account cached'}</Badge>
                          </div>
                        </div>

                        <form className="space-y-5 mt-6" onSubmit={submitExpense}>
                          <div className="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
                            <Field label="Expense date">
                              <input className={inputClass()} type="date" value={formDraft.date} onChange={(e) => setFormDraft({ ...formDraft, date: e.target.value })} />
                            </Field>
                            <Field label="Vendor">
                              <input className={inputClass()} value={formDraft.vendor} onChange={(e) => setFormDraft({ ...formDraft, vendor: e.target.value })} placeholder="OpenRouter" />
                            </Field>
                            <Field label="Amount">
                              <input className={inputClass()} type="number" step="0.01" min="0" value={formDraft.amount} onChange={(e) => setFormDraft({ ...formDraft, amount: e.target.value })} placeholder="105.50" />
                            </Field>
                          </div>

                          <div className="grid md:grid-cols-2 gap-4">
                            <SelectOrInput
                              label="Category"
                              value={formDraft.category}
                              onChange={(value) => setFormDraft({ ...formDraft, category: value })}
                              options={lookups.categories}
                              placeholder="Choose category"
                            />
                            <Field label="Short filename purpose" hint="Optional; falls back to Business Purpose">
                              <input className={inputClass()} value={formDraft.filename_purpose} onChange={(e) => setFormDraft({ ...formDraft, filename_purpose: e.target.value })} placeholder="LLM model usage for BSE" />
                            </Field>
                          </div>

                          <Field label="Business Purpose">
                            <textarea className={inputClass()} rows="3" value={formDraft.business_purpose} onChange={(e) => setFormDraft({ ...formDraft, business_purpose: e.target.value })} placeholder="API credits for BSE development and test" />
                          </Field>

                          <div className="grid md:grid-cols-2 xl:grid-cols-4 gap-4">
                            <SelectOrInput label="Paid By" value={formDraft.paid_by} onChange={(value) => setFormDraft({ ...formDraft, paid_by: value })} options={lookups.paid_by} />
                            <SelectOrInput label="Payment Method" value={formDraft.payment_method} onChange={(value) => setFormDraft({ ...formDraft, payment_method: value })} options={lookups.payment_methods} />
                            <SelectOrInput label="Reimbursable?" value={formDraft.reimbursable} onChange={(value) => setFormDraft({ ...formDraft, reimbursable: value })} options={lookups.reimbursable} />
                            <SelectOrInput label="Reimb. Status" value={formDraft.reimbursement_status} onChange={(value) => setFormDraft({ ...formDraft, reimbursement_status: value })} options={lookups.reimbursement_statuses} />
                          </div>

                          <Field label="Notes">
                            <textarea className={inputClass()} rows="3" value={formDraft.notes} onChange={(e) => setFormDraft({ ...formDraft, notes: e.target.value })} placeholder="Optional context for the accountant or later reference" />
                          </Field>

                          <Field label="Receipt file" hint="PDF, image, or any file type">
                            <label className="block rounded-[1.5rem] border border-dashed border-[var(--line)] bg-white/40 dark:bg-white/5 p-6 cursor-pointer">
                              <input type="file" className="hidden" onChange={(e) => setFile(e.target.files?.[0] || null)} />
                              <div className="flex items-center justify-between gap-4">
                                <div>
                                  <div className="font-semibold">{file ? file.name : 'Choose or drop a file'}</div>
                                  <div className="text-sm text-[var(--muted)] mt-1">OneDrive destination: <span className="font-mono">{formDraft.date ? `${formDraft.date.slice(0, 4)}/${formDraft.date.slice(0, 7)}` : 'YYYY/YYYY-MM'}</span></div>
                                </div>
                                {icon('FileUp', { size: 26 })}
                              </div>
                            </label>
                          </Field>

                          <div className="rounded-[1.5rem] border border-[var(--line)] p-5 bg-white/35 dark:bg-white/5">
                            <div className="text-xs uppercase tracking-[0.22em] text-[var(--accent)]">Filename preview</div>
