        os.makedirs(path, exist_ok=True)


def atomic_write_json(path: str, data: dict) -> None:
    directory = os.path.dirname(path)
    if directory:
        os.makedirs(directory, exist_ok=True)
    tmp_path = f"{path}.tmp"
    with open(tmp_path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, sort_keys=True)
    os.replace(tmp_path, path)


def load_json_file(path: str, default: dict) -> dict:
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except FileNotFoundError:
        return json.loads(json.dumps(default))
    except json.JSONDecodeError:
        logger.warning("Invalid JSON at %s; using defaults.", path)
        return json.loads(json.dumps(default))


def default_config() -> dict:
    return {
        "client_id": "",
        "root_share_url": "",
        "workbook_name": DEFAULT_WORKBOOK,
        "worksheet_name": DEFAULT_WORKSHEET,
        "categories_sheet_name": DEFAULT_CATEGORIES_SHEET,
        "defaults": {
            "paid_by": "Kevin",
            "payment_method": "Personal Card",
            "reimbursable": "Yes",
            "reimbursement_status": "To Submit",
        },
        "lookup_cache": json.loads(json.dumps(DEFAULT_LOOKUPS)),
        "lookup_cache_updated_at": None,
    }


def merge_config(existing: dict, incoming: dict) -> dict:
    merged = default_config()
    merged.update(existing or {})
    for key in ("client_id", "root_share_url", "workbook_name", "worksheet_name", "categories_sheet_name"):
        if key in incoming:
            merged[key] = (incoming.get(key) or "").strip()
    defaults = dict(merged.get("defaults") or {})
    defaults.update(incoming.get("defaults") or {})
    merged["defaults"] = {
        "paid_by": (defaults.get("paid_by") or "").strip(),
        "payment_method": (defaults.get("payment_method") or "").strip(),
        "reimbursable": (defaults.get("reimbursable") or "").strip(),
        "reimbursement_status": (defaults.get("reimbursement_status") or "").strip(),
    }
    if "lookup_cache" in incoming:
        merged["lookup_cache"] = incoming.get("lookup_cache") or json.loads(json.dumps(DEFAULT_LOOKUPS))
    else:
        merged["lookup_cache"] = merged.get("lookup_cache") or json.loads(json.dumps(DEFAULT_LOOKUPS))
    if "lookup_cache_updated_at" in incoming:
        merged["lookup_cache_updated_at"] = incoming.get("lookup_cache_updated_at")
    return merged


def load_config() -> dict:
    return merge_config(load_json_file(CONFIG_FILE, default_config()), {})


def save_config(config: dict) -> dict:
    config = merge_config(load_config(), config)
    atomic_write_json(CONFIG_FILE, config)
    return config


