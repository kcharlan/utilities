    function sanitizeSegment(value, fallback) {
      let text = (value || '').trim().replace(/[\\\\/:*?"<>|]+/g, ' ').replace(/[\\x00-\\x1f]+/g, ' ');
      text = text.replace(/\\s+/g, ' ').replace(/^[ ._-]+|[ ._-]+$/g, '');
