def normalize_space(value: str) -> str:
    return re.sub(r"\s+", " ", (value or "").strip())


def sanitize_filename_segment(value: str, fallback: str) -> str:
    cleaned = normalize_space(value)
    cleaned = re.sub(r'[\\/:*?"<>|]+', " ", cleaned)
    cleaned = re.sub(r"[\x00-\x1f]+", " ", cleaned)
    cleaned = re.sub(r"\s+", " ", cleaned).strip(" .-_")
    return cleaned or fallback


def format_amount_filename(amount: float) -> str:
    return f"{amount:.2f}"


def build_receipt_filename(submission: dict, original_filename: str) -> str:
    _, ext = os.path.splitext(original_filename or "")
    ext = ext or ".bin"
    vendor = sanitize_filename_segment(submission["vendor"], "Vendor")
    purpose = sanitize_filename_segment(submission.get("filename_purpose") or submission["business_purpose"], "Expense")
    if len(purpose) > 80:
        purpose = purpose[:80].rstrip(" .-_")
    return f"{submission['date']}-{vendor}-{format_amount_filename(submission['amount'])}-{purpose}{ext}"


def parse_submission(payload: dict) -> dict:
    required = [
        "date",
        "vendor",
        "amount",
        "category",
        "business_purpose",
        "paid_by",
        "payment_method",
        "reimbursable",
        "reimbursement_status",
    ]
    missing = [key for key in required if not normalize_space(str(payload.get(key, "")))]
    if missing:
        raise HTTPException(status_code=400, detail=f"Missing required fields: {', '.join(missing)}")

    try:
        date.fromisoformat(str(payload["date"]))
    except ValueError as exc:
        raise HTTPException(status_code=400, detail="Date must be YYYY-MM-DD.") from exc

    try:
        amount = round(float(payload["amount"]), 2)
    except (TypeError, ValueError) as exc:
        raise HTTPException(status_code=400, detail="Amount must be numeric.") from exc

    return {
        "date": str(payload["date"]).strip(),
        "vendor": normalize_space(str(payload["vendor"])),
        "amount": amount,
        "category": normalize_space(str(payload["category"])),
        "business_purpose": normalize_space(str(payload["business_purpose"])),
        "filename_purpose": normalize_space(str(payload.get("filename_purpose", ""))),
        "paid_by": normalize_space(str(payload["paid_by"])),
        "payment_method": normalize_space(str(payload["payment_method"])),
        "reimbursable": normalize_space(str(payload["reimbursable"])),
        "reimbursement_status": normalize_space(str(payload["reimbursement_status"])),
        "notes": normalize_space(str(payload.get("notes", ""))),
    }


def encode_share_url(share_url: str) -> str:
    encoded = base64.urlsafe_b64encode(share_url.encode("utf-8")).decode("ascii").rstrip("=")
    return f"u!{encoded}"


def load_token_cache() -> msal.SerializableTokenCache:
    cache = msal.SerializableTokenCache()
    if os.path.exists(TOKEN_CACHE_FILE):
        with open(TOKEN_CACHE_FILE, "r", encoding="utf-8") as f:
            cache.deserialize(f.read())
    return cache


def persist_token_cache(cache: msal.SerializableTokenCache) -> None:
    if cache.has_state_changed:
        with open(TOKEN_CACHE_FILE, "w", encoding="utf-8") as f:
            f.write(cache.serialize())


def build_public_client(client_id: str, cache: msal.SerializableTokenCache) -> msal.PublicClientApplication:
    return msal.PublicClientApplication(client_id=client_id, authority=AUTHORITY, token_cache=cache)


def interactive_login(config: dict) -> dict:
    client_id = config.get("client_id") or ""
    if not client_id:
        raise HTTPException(status_code=400, detail="Microsoft client ID is not configured.")

    cache = load_token_cache()
    app_obj = build_public_client(client_id, cache)
    try:
        result = app_obj.acquire_token_interactive(
            scopes=GRAPH_SCOPES,
            prompt="select_account",
        )
    except Exception as exc:
        logger.exception("Interactive Microsoft login failed")
        raise HTTPException(status_code=500, detail=f"Microsoft login failed: {exc}") from exc
    persist_token_cache(cache)
    if "access_token" not in result:
        detail = result.get("error_description") or result.get("error") or "Authentication failed."
        raise HTTPException(status_code=400, detail=detail)
    return {
        "username": result.get("id_token_claims", {}).get("preferred_username") or "",
        "expires_in": result.get("expires_in"),
    }


def get_auth_status(config: dict) -> dict:
    status = {
        "configured": bool(config.get("client_id")),
        "connected": False,
        "account": "",
    }
    if not status["configured"]:
        return status
    cache = load_token_cache()
    app_obj = build_public_client(config["client_id"], cache)
    accounts = app_obj.get_accounts()
    if accounts:
        account = accounts[0]
        status["connected"] = True
        status["account"] = account.get("username") or account.get("home_account_id") or ""
    return status


def get_access_token(config: dict) -> str:
    client_id = config.get("client_id") or ""
    if not client_id:
        raise HTTPException(status_code=400, detail="Microsoft client ID is not configured.")
    cache = load_token_cache()
    app_obj = build_public_client(client_id, cache)
    accounts = app_obj.get_accounts()
    result = None
    if accounts:
        result = app_obj.acquire_token_silent(scopes=GRAPH_SCOPES, account=accounts[0])
    persist_token_cache(cache)
    if not result or "access_token" not in result:
        raise HTTPException(status_code=401, detail="Microsoft login required. Use Connect in the UI.")
    return result["access_token"]


