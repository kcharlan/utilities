                      </div>
                      <div className="rounded-2xl border border-[var(--line)] p-4 text-sm">
                        <div className="font-semibold">
                          {status?.auth?.connected ? 'Connected to Microsoft' : 'Microsoft not connected'}
                        </div>
                        <div className="mt-1 text-[var(--muted)] break-all">
                          {status?.auth?.connected
