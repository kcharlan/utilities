class GraphClient:
    def __init__(self, access_token: str):
        self.access_token = access_token
        self.client = httpx.Client(timeout=90.0, follow_redirects=True)

    def close(self) -> None:
        self.client.close()

    def _request(
        self,
        method: str,
        path: str,
        *,
        full_url: bool = False,
        include_auth: bool = True,
        expected: Tuple[int, ...] = (200, 201, 202),
        **kwargs: Any,
    ) -> httpx.Response:
        url = path if full_url else f"{GRAPH_ROOT}{path}"
        headers = dict(kwargs.pop("headers", {}))
        if include_auth:
            headers["Authorization"] = f"Bearer {self.access_token}"
        response = self.client.request(method, url, headers=headers, **kwargs)
        if response.status_code not in expected:
            payload = {}
            try:
                payload = response.json()
            except Exception:
                payload = {}
            message = (
                payload.get("error", {}).get("message")
                or payload.get("error_description")
                or response.text[:400]
                or f"Graph request failed with status {response.status_code}."
            )
            raise GraphAPIError(response.status_code, message, payload)
        return response

    def resolve_share_url(self, share_url: str) -> dict:
        token = encode_share_url(share_url)
        response = self._request("GET", f"/shares/{token}/driveItem")
        return response.json()

    def get_drive_id(self, item: dict) -> str:
        drive_id = (
            item.get("parentReference", {}).get("driveId")
            or item.get("remoteItem", {}).get("parentReference", {}).get("driveId")
        )
        if drive_id:
            return drive_id
        item_id = item.get("id", "")
        if "!" in item_id:
            return item_id.split("!", 1)[0]
        raise GraphAPIError(400, "Could not determine drive ID for the shared item.")

    def list_children(self, drive_id: str, parent_id: str) -> List[dict]:
        url = f"{GRAPH_ROOT}/drives/{drive_id}/items/{parent_id}/children?$select=id,name,folder,file,webUrl,parentReference"
        items: List[dict] = []
        while url:
            response = self._request("GET", url, full_url=True, include_auth=True, expected=(200,))
            data = response.json()
            items.extend(data.get("value", []))
            url = data.get("@odata.nextLink")
        return items

    def find_child_by_name(self, drive_id: str, parent_id: str, child_name: str) -> Optional[dict]:
        for item in self.list_children(drive_id, parent_id):
            if item.get("name") == child_name:
                return item
        return None

    def ensure_folder(self, drive_id: str, parent_id: str, folder_name: str) -> Tuple[dict, bool]:
        existing = self.find_child_by_name(drive_id, parent_id, folder_name)
        if existing:
            if "folder" not in existing:
                raise GraphAPIError(409, f"'{folder_name}' exists but is not a folder.")
            return existing, False

        body = {
            "name": folder_name,
            "folder": {},
            "@microsoft.graph.conflictBehavior": "fail",
        }
        try:
            response = self._request("POST", f"/drives/{drive_id}/items/{parent_id}/children", json=body, expected=(201,))
            return response.json(), True
        except GraphAPIError as exc:
            if exc.status_code == 409:
                existing = self.find_child_by_name(drive_id, parent_id, folder_name)
                if existing:
                    return existing, False
            raise

    def upload_file(self, drive_id: str, parent_id: str, filename: str, content: bytes, content_type: str) -> Tuple[dict, bool]:
        existing = self.find_child_by_name(drive_id, parent_id, filename)
        if existing:
            return existing, False

        encoded_name = quote(filename, safe="")
        if len(content) <= 4 * 1024 * 1024:
            response = self._request(
                "PUT",
                f"/drives/{drive_id}/items/{parent_id}:/{encoded_name}:/content",
                headers={"Content-Type": content_type or "application/octet-stream"},
                content=content,
                expected=(200, 201),
            )
            return response.json(), True

        session = self._request(
            "POST",
            f"/drives/{drive_id}/items/{parent_id}:/{encoded_name}:/createUploadSession",
            json={"item": {"@microsoft.graph.conflictBehavior": "fail"}},
            expected=(200,),
        ).json()
        upload_url = session["uploadUrl"]
        chunk_size = 327680 * 10
        total = len(content)
        start = 0
        item: Optional[dict] = None
        while start < total:
            end = min(start + chunk_size, total) - 1
            chunk = content[start : end + 1]
            response = self._request(
                "PUT",
                upload_url,
                full_url=True,
                include_auth=False,
                headers={
                    "Content-Length": str(len(chunk)),
                    "Content-Range": f"bytes {start}-{end}/{total}",
                },
                content=chunk,
                expected=(200, 201, 202),
            )
            if response.status_code in (200, 201):
                item = response.json()
            start = end + 1
        if not item:
            raise GraphAPIError(500, "Large file upload did not return a completed item.")
        return item, True

    def create_view_link(self, drive_id: str, item_id: str) -> str:
        response = self._request(
            "POST",
            f"/drives/{drive_id}/items/{item_id}/createLink",
            json={"type": "view", "scope": "anonymous"},
            expected=(200, 201),
        )
        return response.json()["link"]["webUrl"]

    def download_item_content(self, drive_id: str, item_id: str) -> bytes:
        response = self._request("GET", f"/drives/{drive_id}/items/{item_id}/content", expected=(200,))
        return response.content

    def upload_item_content(self, drive_id: str, item_id: str, content: bytes, content_type: str) -> dict:
        response = self._request(
            "PUT",
            f"/drives/{drive_id}/items/{item_id}/content",
            headers={"Content-Type": content_type},
            content=content,
            expected=(200, 201),
        )
        return response.json()


def extract_lookup_values(workbook_bytes: bytes, categories_sheet_name: str) -> dict:
    with io.BytesIO(workbook_bytes) as buffer:
        wb = load_workbook(buffer, data_only=True)
        if categories_sheet_name not in wb.sheetnames:
            raise ValueError(f"Lookup sheet '{categories_sheet_name}' not found.")
        ws = wb[categories_sheet_name]
        lookups = json.loads(json.dumps(DEFAULT_LOOKUPS))
        for key, column_index in LOOKUP_COLUMNS.items():
            values = []
            seen = set()
            for row in range(2, ws.max_row + 1):
                value = ws.cell(row=row, column=column_index).value
                if value is None:
                    continue
                text = normalize_space(str(value))
                if not text or text in seen:
                    continue
                seen.add(text)
                values.append(text)
            lookups[key] = values
        return lookups


def find_last_data_row(ws, max_col: int) -> int:
    for row in range(ws.max_row, 1, -1):
        for col in range(1, max_col + 1):
            value = ws.cell(row=row, column=col).value
            if value not in (None, ""):
                return row
    return 1


def copy_row_format(ws, source_row: int, target_row: int, max_col: int) -> None:
    for col in range(1, max_col + 1):
        src = ws.cell(row=source_row, column=col)
        dst = ws.cell(row=target_row, column=col)
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.protection:
            dst.protection = copy(src.protection)


def header_index_map(ws) -> Dict[str, int]:
    return {normalize_space(str(ws.cell(row=1, column=col).value)): col for col in range(1, ws.max_column + 1) if ws.cell(row=1, column=col).value}


def append_expense_row(
    workbook_bytes: bytes,
    worksheet_name: str,
    submission: dict,
    receipt_link: str,
    receipt_filename: str,
) -> Tuple[bytes, int, int]:
    with io.BytesIO(workbook_bytes) as buffer:
        wb = load_workbook(buffer)
    if worksheet_name not in wb.sheetnames:
        raise ValueError(f"Worksheet '{worksheet_name}' not found.")
    ws = wb[worksheet_name]
    header_map = header_index_map(ws)
    missing = [header for header in EXPECTED_HEADERS if header not in header_map]
    if missing:
        raise ValueError(f"Worksheet is missing expected headers: {', '.join(missing)}")

    last_row = find_last_data_row(ws, max(header_map.values()))
    max_id = 0
    receipt_link_col = header_map["Receipt Link"]
    receipt_filename_col = header_map["Receipt Filename"]
    id_col = header_map["ID"]
    for row in range(2, last_row + 1):
        existing_id = ws.cell(row=row, column=id_col).value
        try:
            max_id = max(max_id, int(existing_id))
        except (TypeError, ValueError):
            pass
        existing_link = normalize_space(str(ws.cell(row=row, column=receipt_link_col).value or ""))
        existing_filename = normalize_space(str(ws.cell(row=row, column=receipt_filename_col).value or ""))
        if existing_filename and existing_filename == receipt_filename:
            raise DuplicateExpenseError(row, ws.cell(row=row, column=id_col).value)
        if existing_link and existing_link == receipt_link:
            raise DuplicateExpenseError(row, ws.cell(row=row, column=id_col).value)

    target_row = last_row + 1
    source_row = max(2, last_row)
    if target_row != source_row:
        copy_row_format(ws, source_row, target_row, max(header_map.values()))

    next_id = max_id + 1 if max_id else 1
    row_values = {
        "ID": next_id,
        "Date": date.fromisoformat(submission["date"]),
        "Vendor": submission["vendor"],
        "Amount": submission["amount"],
        "Category": submission["category"],
        "Business Purpose": submission["business_purpose"],
        "Paid By": submission["paid_by"],
        "Payment Method": submission["payment_method"],
        "Reimbursable?": submission["reimbursable"],
        "Reimb. Status": submission["reimbursement_status"],
        "Receipt Link": receipt_link,
        "Receipt Filename": receipt_filename,
        "Notes": submission["notes"],
    }
    for header, value in row_values.items():
        cell = ws.cell(row=target_row, column=header_map[header])
        cell.value = value
    ws.cell(row=target_row, column=header_map["Date"]).number_format = "yyyy-mm-dd"
    ws.cell(row=target_row, column=header_map["Amount"]).number_format = "$#,##0.00"
    ws.cell(row=target_row, column=header_map["Receipt Link"]).hyperlink = receipt_link

    output = io.BytesIO()
    wb.save(output)
    return output.getvalue(), target_row, next_id


def build_csv_text(submission: dict, receipt_link: str, receipt_filename: str) -> str:
    buffer = io.StringIO()
    writer = csv.writer(buffer)
    writer.writerow(EXPECTED_HEADERS)
    writer.writerow(
        [
            "",
            submission["date"],
            submission["vendor"],
            f"{submission['amount']:.2f}",
            submission["category"],
            submission["business_purpose"],
            submission["paid_by"],
            submission["payment_method"],
            submission["reimbursable"],
            submission["reimbursement_status"],
            receipt_link,
            receipt_filename,
            submission["notes"],
        ]
    )
    return buffer.getvalue()


def pending_path(operation_id: str) -> str:
    return os.path.join(PENDING_DIR, f"{operation_id}.json")


def list_pending_operations() -> List[dict]:
    entries = []
    for name in sorted(os.listdir(PENDING_DIR), reverse=True):
        if not name.endswith(".json"):
            continue
        path = os.path.join(PENDING_DIR, name)
        try:
            with open(path, "r", encoding="utf-8") as f:
                entry = json.load(f)
            entries.append(
                {
                    "id": entry.get("id"),
                    "created_at": entry.get("created_at"),
                    "updated_at": entry.get("updated_at"),
                    "vendor": entry.get("submission", {}).get("vendor", ""),
                    "date": entry.get("submission", {}).get("date", ""),
                    "amount": entry.get("submission", {}).get("amount", ""),
                    "receipt_filename": entry.get("receipt_filename", ""),
                    "receipt_link": entry.get("receipt_link", ""),
                    "error": entry.get("error", ""),
                }
            )
        except Exception:
            logger.warning("Skipping unreadable pending operation %s", path)
    return entries


def save_pending_operation(submission: dict, receipt_filename: str, receipt_link: str, receipt_item_id: str, error: str) -> dict:
    operation_id = uuid.uuid4().hex[:12]
    now = datetime.utcnow().isoformat() + "Z"
    entry = {
        "id": operation_id,
        "created_at": now,
        "updated_at": now,
        "submission": submission,
        "receipt_filename": receipt_filename,
        "receipt_link": receipt_link,
        "receipt_item_id": receipt_item_id,
        "error": error,
        "fallback_csv": build_csv_text(submission, receipt_link, receipt_filename),
    }
    atomic_write_json(pending_path(operation_id), entry)
    return {
        "id": operation_id,
        "created_at": now,
        "updated_at": now,
        "vendor": submission["vendor"],
        "date": submission["date"],
        "amount": submission["amount"],
        "receipt_filename": receipt_filename,
        "receipt_link": receipt_link,
        "error": error,
    }


def load_pending_operation(operation_id: str) -> dict:
    path = pending_path(operation_id)
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except FileNotFoundError as exc:
        raise HTTPException(status_code=404, detail="Pending operation not found.") from exc


def update_pending_operation(entry: dict, error: str) -> dict:
    entry["error"] = error
    entry["updated_at"] = datetime.utcnow().isoformat() + "Z"
    atomic_write_json(pending_path(entry["id"]), entry)
    return entry


def delete_pending_operation(operation_id: str) -> None:
    try:
        os.remove(pending_path(operation_id))
    except FileNotFoundError:
        pass


def resolve_root_and_workbook(graph: GraphClient, config: dict) -> Tuple[dict, dict, str]:
    root_item = graph.resolve_share_url(config["root_share_url"])
    drive_id = graph.get_drive_id(root_item)
    workbook_item = graph.find_child_by_name(drive_id, root_item["id"], config["workbook_name"])
    if not workbook_item:
        raise HTTPException(
            status_code=400,
            detail=f"Workbook '{config['workbook_name']}' was not found in the shared root folder.",
        )
    return root_item, workbook_item, drive_id


def process_submission(config: dict, submission: dict, file_bytes: bytes, original_filename: str, content_type: str) -> dict:
    receipt_item = None
    share_link = ""
    receipt_filename = build_receipt_filename(submission, original_filename)
    access_token = get_access_token(config)
    graph = GraphClient(access_token)
    try:
        root_item, workbook_item, drive_id = resolve_root_and_workbook(graph, config)
        year_folder_name = submission["date"][:4]
        month_folder_name = submission["date"][:7]
        year_folder, _ = graph.ensure_folder(drive_id, root_item["id"], year_folder_name)
        month_folder, _ = graph.ensure_folder(drive_id, year_folder["id"], month_folder_name)
        receipt_item, uploaded = graph.upload_file(
            drive_id,
            month_folder["id"],
            receipt_filename,
            file_bytes,
            content_type or "application/octet-stream",
        )
        share_link = graph.create_view_link(drive_id, receipt_item["id"])
        workbook_bytes = graph.download_item_content(drive_id, workbook_item["id"])
        updated_workbook, row_number, expense_id = append_expense_row(
            workbook_bytes,
            config["worksheet_name"],
            submission,
            share_link,
            receipt_filename,
        )
        graph.upload_item_content(
            drive_id,
            workbook_item["id"],
            updated_workbook,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        )
        return {
            "ok": True,
            "uploaded": uploaded,
            "receipt_filename": receipt_filename,
            "receipt_link": share_link,
            "expense_id": expense_id,
            "row_number": row_number,
            "duplicate": False,
        }
    except DuplicateExpenseError as exc:
        return {
            "ok": True,
            "uploaded": False,
            "receipt_filename": receipt_filename,
            "receipt_link": share_link,
            "expense_id": exc.expense_id,
            "row_number": exc.row_number,
            "duplicate": True,
        }
    except Exception as exc:
        message = str(exc)
        pending = None
        if receipt_item and share_link:
            pending = save_pending_operation(
                submission,
                receipt_filename,
                share_link,
                receipt_item["id"],
                message,
            )
        return {
            "ok": False,
            "error": message,
            "receipt_filename": receipt_filename,
            "receipt_link": share_link,
            "fallback_csv": build_csv_text(submission, share_link, receipt_filename),
            "pending": pending,
            "traceback": traceback.format_exc(),
        }
    finally:
        graph.close()


def retry_pending_operation(config: dict, operation_id: str) -> dict:
    entry = load_pending_operation(operation_id)
    access_token = get_access_token(config)
    graph = GraphClient(access_token)
    try:
        _, workbook_item, drive_id = resolve_root_and_workbook(graph, config)
        workbook_bytes = graph.download_item_content(drive_id, workbook_item["id"])
        updated_workbook, row_number, expense_id = append_expense_row(
            workbook_bytes,
            config["worksheet_name"],
            entry["submission"],
            entry["receipt_link"],
            entry["receipt_filename"],
        )
        graph.upload_item_content(
            drive_id,
            workbook_item["id"],
            updated_workbook,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        )
        delete_pending_operation(operation_id)
        return {
            "ok": True,
            "duplicate": False,
            "receipt_filename": entry["receipt_filename"],
            "receipt_link": entry["receipt_link"],
            "expense_id": expense_id,
            "row_number": row_number,
        }
    except DuplicateExpenseError as exc:
        delete_pending_operation(operation_id)
        return {
            "ok": True,
            "duplicate": True,
            "receipt_filename": entry["receipt_filename"],
            "receipt_link": entry["receipt_link"],
            "expense_id": exc.expense_id,
            "row_number": exc.row_number,
        }
    except Exception as exc:
        update_pending_operation(entry, str(exc))
        return {
            "ok": False,
            "error": str(exc),
            "receipt_filename": entry["receipt_filename"],
            "receipt_link": entry["receipt_link"],
            "fallback_csv": entry.get("fallback_csv") or build_csv_text(entry["submission"], entry["receipt_link"], entry["receipt_filename"]),
        }
    finally:
        graph.close()


