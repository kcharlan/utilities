                            </button>
                            {message?.csv ? (
                              <button type="button" onClick={() => downloadCsv(message.csv, `expense-dock-fallback-${todayIso()}.csv`)} className="rounded-full border border-[var(--line)] px-6 py-3 font-semibold">
