                    {theme === 'dark' ? 'Light ledger' : 'Night ledger'}
                  </button>
                </div>
              </div>

              <div className="grid xl:grid-cols-[360px_minmax(0,1fr)]">
                <aside className="border-r border-[var(--line)] p-5 md:p-6 space-y-5">
                  <section className="rounded-[1.5rem] border border-[var(--line)] p-5">
                    <div className="flex items-center justify-between gap-3">
                      <div>
                        <div className="text-xs uppercase tracking-[0.22em] text-[var(--accent)]">Setup</div>
                        <h2 className="font-display text-2xl mt-1">Connection dossier</h2>
                      </div>
                      {icon('Settings2', { size: 20 })}
                    </div>
                    <div className="space-y-4 mt-5">
                      <Field label="Microsoft client ID">
                        <input
                          className={inputClass()}
