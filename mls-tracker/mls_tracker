# ============================================================
# Helpers
# ============================================================

def safe_int(val, default=0) -> int:
    if val is None:
        return default
    try:
        return int(float(val))
    except (ValueError, TypeError):
        return default


def process_team_colors(color: str, alt_color: str) -> Dict[str, str]:
    """Ensure usable contrast: swap black/white primaries to alternateColor."""
    color = (color or "").strip().lstrip("#")
    alt_color = (alt_color or "").strip().lstrip("#")

    low_contrast = {"000000", "ffffff", ""}
    if color.lower() in low_contrast and alt_color.lower() not in low_contrast:
        primary = f"#{alt_color}"
        secondary = f"#{color}" if color else "#1f2937"
    else:
        primary = f"#{color}" if color else "#6366f1"
        secondary = f"#{alt_color}" if alt_color else "#1f2937"

    # Compute accent: white if primary is dark, dark if primary is light
    try:
        r, g, b = int(primary[1:3], 16), int(primary[3:5], 16), int(primary[5:7], 16)
        luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255
        accent = "#1f2937" if luminance > 0.6 else "#ffffff"
    except (ValueError, IndexError):
        accent = "#ffffff"

    return {"primary": primary, "secondary": secondary, "accent": accent}


# ============================================================
# Data Cache
# ============================================================

class DataCache:
    def __init__(self, ttl: int = CACHE_TTL_SECONDS):
        self._ttl = ttl
        self._standings: Dict[int, Any] = {}
        self._standings_ts: Dict[int, float] = {}
        self._teams: Optional[List[Dict]] = None
        self._teams_ts: float = 0

    def invalidate(self):
        self._standings.clear()
        self._standings_ts.clear()
        self._teams = None
        self._teams_ts = 0

    def _expired(self, ts: float) -> bool:
        return (time.time() - ts) > self._ttl

    # ---------- Teams ----------
    def get_teams(self) -> List[Dict]:
        if self._teams is not None and not self._expired(self._teams_ts):
            return self._teams
        self._teams = fetch_teams_from_espn()
        self._teams_ts = time.time()
        return self._teams

    # ---------- Standings ----------
    def get_standings(self, season: int) -> Dict[str, List[Dict]]:
        if season in self._standings and not self._expired(self._standings_ts.get(season, 0)):
            return self._standings[season]
        self._standings[season] = fetch_standings_from_espn(season)
        self._standings_ts[season] = time.time()
        return self._standings[season]


cache = DataCache()


