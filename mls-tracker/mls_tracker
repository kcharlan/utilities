    return HTMLResponse(content=HTML_TEMPLATE)


@app.get("/api/data")
async def api_data(season: Optional[int] = None):
    """All standings + team metadata for both conferences."""
    if season is None:
        season = datetime.now().year
    try:
        standings = cache.get_standings(season)
        teams_list = cache.get_teams()
        merged = merge_team_metadata(standings, teams_list)
        return {"season": season, "conferences": merged}
    except Exception as e:
        logger.error("Error in /api/data: %s", e)
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/scenarios")
async def api_scenarios(
    team: str = "Atlanta United FC",
    season: Optional[int] = None,
    cutoff: int = 9,
):
    """Playoff scenarios for a specific team against a cutoff position."""
    if season is None:
        season = datetime.now().year
    try:
        standings = cache.get_standings(season)
        teams_list = cache.get_teams()
        merged = merge_team_metadata(standings, teams_list)

        # Find team and its conference
        target = None
        conf_name = None
        for cname, team_list in merged.items():
            for t in team_list:
                if t["name"] == team:
                    target = t
                    conf_name = cname
                    break
            if target:
                break

        if not target:
            raise HTTPException(status_code=404, detail=f"Team '{team}' not found in {season} standings")

        # Get cutoff team (cutoff position is 1-indexed)
        conf_teams = merged[conf_name]
        if cutoff < 1 or cutoff > len(conf_teams):
            raise HTTPException(status_code=400, detail=f"Cutoff position {cutoff} out of range (1-{len(conf_teams)})")

        cutoff_team = conf_teams[cutoff - 1]
        scenarios = compute_scenarios(target, cutoff_team)
        scenarios["conference"] = conf_name
        return scenarios
    except HTTPException:
        raise
    except Exception as e:
        logger.error("Error in /api/scenarios: %s", e)
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/api/refresh")
async def api_refresh():
    """Invalidate cache."""
    cache.invalidate()
    return {"status": "ok"}


