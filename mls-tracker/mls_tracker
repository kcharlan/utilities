#!/usr/bin/env python3
import os
import sys
import subprocess

# --- Self-Bootstrapper ---
def bootstrap():
    """Ensure dependencies are installed in a private venv and re-run script."""
    venv_dir = os.path.expanduser("~/.mls_tracker_venv")
    venv_python = os.path.join(venv_dir, "bin", "python3")

    # Always use venv if it exists
    if os.path.exists(venv_python) and sys.executable != venv_python:
        os.execv(venv_python, [venv_python] + sys.argv)

    # Check if we are already running inside our private venv
    if sys.executable == venv_python:
        return

    # If venv doesn't exist or dependencies are missing, set it up
    try:
        import fastapi
        import uvicorn
        import requests
        return
    except ImportError:
        pass

    if not os.path.exists(venv_python):
        print("First-time setup: Creating environment in", venv_dir)
        subprocess.check_call([sys.executable, "-m", "venv", venv_dir])
        print("Installing dependencies (fastapi, uvicorn, python-multipart, requests)...")
        subprocess.check_call([venv_python, "-m", "pip", "install", "--upgrade", "pip"],
                              stdout=subprocess.DEVNULL)
        subprocess.check_call([venv_python, "-m", "pip", "install",
                               "fastapi", "uvicorn", "python-multipart", "requests"])

    os.execv(venv_python, [venv_python] + sys.argv)

if __name__ == "__main__":
    bootstrap()

