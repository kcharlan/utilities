/* ========== MAIN APP ========== */
function App() {
  const [darkMode, setDarkMode] = useState(() => {
    const saved = localStorage.getItem('mls-dark-mode');
    if (saved !== null) return saved === 'true';
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  });
  const [conference, setConference] = useState('eastern');
  const [team, setTeam] = useState('Atlanta United FC');
  const [season, setSeason] = useState(new Date().getFullYear());
  const [cutoff, setCutoff] = useState(9);
  const [conferences, setConferences] = useState({});
  const [scenarios, setScenarios] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  // Dark mode
  useEffect(() => {
    document.documentElement.classList.toggle('dark', darkMode);
    localStorage.setItem('mls-dark-mode', String(darkMode));
  }, [darkMode]);

  // Team theming
  useEffect(() => {
    if (scenarios?.target?.colors) {
      const { primary, secondary, accent } = scenarios.target.colors;
      document.documentElement.style.setProperty('--team-primary', primary || '#6366f1');
      document.documentElement.style.setProperty('--team-secondary', secondary || '#1f2937');
      document.documentElement.style.setProperty('--team-accent', accent || '#ffffff');
    }
  }, [scenarios]);

  // Fetch conference data
  const fetchData = useCallback(async () => {
    try {
      const resp = await fetch(`/api/data?season=${season}`);
      if (!resp.ok) throw new Error(`API error: ${resp.status}`);
      const data = await resp.json();
      setConferences(data.conferences || {});
      setError(null);
      return data.conferences || {};
    } catch (e) {
      setError(e.message);
      return {};
    }
  }, [season]);

  // Fetch scenarios
  const fetchScenarios = useCallback(async () => {
    if (!team) return;
    try {
      const resp = await fetch(`/api/scenarios?season=${season}&team=${encodeURIComponent(team)}&cutoff=${cutoff}`);
      if (!resp.ok) throw new Error(`API error: ${resp.status}`);
      const data = await resp.json();
      setScenarios(data);
      setError(null);
    } catch (e) {
      setError(e.message);
    }
  }, [season, team, cutoff]);

  // Load data on mount / season change
  useEffect(() => {
    setLoading(true);
    fetchData().then(confs => {
      // Verify team is in conference, or auto-select first
      const confKey = Object.keys(confs).find(k => k.toLowerCase().includes(conference.toLowerCase()));
      if (confKey && confs[confKey]) {
        const teamInConf = confs[confKey].some(t => t.name === team);
        if (!teamInConf && confs[confKey].length > 0) {
          setTeam(confs[confKey][0].name);
        }
      }
      setLoading(false);
    });
  }, [season]);

  // Fetch scenarios when team/cutoff changes
  useEffect(() => {
    if (Object.keys(conferences).length > 0 && team) {
      fetchScenarios();
    }
  }, [team, cutoff, conferences]);

  // Conference change
  const handleConferenceChange = (newConf) => {
    setConference(newConf);
    const confKey = Object.keys(conferences).find(k => k.toLowerCase().includes(newConf.toLowerCase()));
    if (confKey && conferences[confKey]?.length > 0) {
      const teamInConf = conferences[confKey].some(t => t.name === team);
      if (!teamInConf) {
        setTeam(conferences[confKey][0].name);
      }
    }
  };

  // Refresh
  const handleRefresh = async () => {
    setLoading(true);
    await fetch('/api/refresh', { method: 'POST' });
    const confs = await fetchData();
    const confKey = Object.keys(confs).find(k => k.toLowerCase().includes(conference.toLowerCase()));
    if (confKey && confs[confKey]) {
      const teamInConf = confs[confKey].some(t => t.name === team);
      if (!teamInConf && confs[confKey].length > 0) {
        setTeam(confs[confKey][0].name);
      }
    }
    setLoading(false);
  };

