def fetch_teams_from_espn() -> List[Dict]:
    """Fetch all MLS teams with colors, logos, abbreviations."""
    try:
        resp = requests.get(ESPN_TEAMS_URL, headers=ESPN_HEADERS, timeout=10)
        resp.raise_for_status()
        data = resp.json()
    except requests.exceptions.RequestException as e:
        logger.error("Failed to fetch teams: %s", e)
        return []

    teams = []
    for item in data.get("sports", [{}])[0].get("leagues", [{}])[0].get("teams", []):
        t = item.get("team", {})
        colors = process_team_colors(t.get("color", ""), t.get("alternateColor", ""))
        logo = ""
        for lg in t.get("logos", []):
            logo = lg.get("href", "")
            break
        teams.append({
            "id": t.get("id"),
            "name": t.get("displayName", "Unknown"),
            "abbreviation": t.get("abbreviation", ""),
            "shortName": t.get("shortDisplayName", ""),
            "colors": colors,
            "logo": logo,
        })
    return teams


def fetch_standings_from_espn(season: int) -> Dict[str, List[Dict]]:
    """Fetch standings for a season, returning plain dicts sorted by rank per conference."""
    url = f"{ESPN_STANDINGS_URL}?season={season}"
    try:
        resp = requests.get(url, headers=ESPN_HEADERS, timeout=10)
        resp.raise_for_status()
        data = resp.json()
    except requests.exceptions.RequestException as e:
        logger.error("Failed to fetch standings for season %d: %s", season, e)
        return {}

    output: Dict[str, List[Dict]] = {}
    for conf in data.get("children", []):
        cname = conf.get("name", "Unknown Conference")
        teams: List[Dict] = []
        for entry in conf.get("standings", {}).get("entries", []):
            stats_dict = {s.get("name"): s.get("value") for s in entry.get("stats", [])}
            tinfo = entry.get("team", {})
            gp = safe_int(stats_dict.get("gamesPlayed"))
            pts = safe_int(stats_dict.get("points"))
            gf = safe_int(stats_dict.get("pointsFor"))
            ga = safe_int(stats_dict.get("pointsAgainst"))
            team = {
                "position": safe_int(stats_dict.get("rank"), 99),
                "name": tinfo.get("displayName", "N/A"),
                "id": str(tinfo.get("id", "")),
                "gp": gp,
                "w": safe_int(stats_dict.get("wins")),
                "l": safe_int(stats_dict.get("losses")),
                "t": safe_int(stats_dict.get("ties")),
                "pts": pts,
                "gf": gf,
                "ga": ga,
                "gd": gf - ga,
                "ppg": round(pts / gp, 3) if gp > 0 else 0.0,
            }
            teams.append(team)
        teams.sort(key=lambda t: t["position"])
        output[cname] = teams
    return output


def merge_team_metadata(standings: Dict[str, List[Dict]], teams_list: List[Dict]) -> Dict[str, List[Dict]]:
    """Merge colors and logos from the teams endpoint into standings data."""
    teams_by_name: Dict[str, Dict] = {}
    teams_by_id: Dict[str, Dict] = {}
    for t in teams_list:
        teams_by_name[t["name"]] = t
        if t.get("id"):
            teams_by_id[str(t["id"])] = t

    result = {}
    for conf, team_list in standings.items():
        merged = []
        for team in team_list:
            meta = teams_by_id.get(team.get("id")) or teams_by_name.get(team["name"]) or {}
            team_copy = dict(team)
            team_copy["colors"] = meta.get("colors", process_team_colors("", ""))
            team_copy["logo"] = meta.get("logo", "")
            team_copy["abbreviation"] = meta.get("abbreviation", "")
            merged.append(team_copy)
        result[conf] = merged
    return result


# ============================================================
# Playoff Computation
# ============================================================

def compute_scenarios(target: Dict, cutoff_team: Dict, season_games: int = SEASON_GAMES) -> Dict:
    """Compute playoff scenarios for target team against a cutoff-position team."""
    pts_target = target["pts"]
    pts_cutoff = cutoff_team["pts"]
    gp_target = target["gp"]
    gp_cutoff = cutoff_team["gp"]
    gr_target = max(0, season_games - gp_target)
    gr_cutoff = max(0, season_games - gp_cutoff)

    # Max possible points
    max_possible_target = pts_target + 3 * gr_target
    max_possible_cutoff = pts_cutoff + 3 * gr_cutoff

    # Projected finish for cutoff if they continue at current PPG
    ppg_cutoff = pts_cutoff / gp_cutoff if gp_cutoff > 0 else 0
    projected_cutoff = pts_cutoff + gr_cutoff * ppg_cutoff

    # Clinch: target already above cutoff's max possible
    clinched = pts_target > max_possible_cutoff

    # Eliminated: can't reach cutoff's current points even winning out
    eliminated = max_possible_target < pts_cutoff

    # Need help: can win out but cutoff projected to finish higher
    need_help = (not eliminated) and (not clinched) and (max_possible_target < projected_cutoff)

    # Points we must beat (projected cutoff + 1)
    must_beat = int(projected_cutoff) + 1

    worst_case = _compute_worst_case(pts_target, gr_target, must_beat)
    easiest_path = _compute_easiest_path(pts_target, gr_target, must_beat)
    need_help_info = _compute_need_help(cutoff_team, season_games, max_possible_target) if need_help else None

    # Determine status
    if eliminated:
        status = "eliminated"
    elif clinched:
        status = "clinched"
    elif need_help:
        status = "need_help"
    else:
        status = "contention"

    return {
        "status": status,
        "target": {
            "name": target["name"],
            "pts": pts_target,
            "gp": gp_target,
            "gr": gr_target,
            "position": target["position"],
            "max_possible": max_possible_target,
            "ppg": target["ppg"],
            "colors": target.get("colors", {}),
            "logo": target.get("logo", ""),
        },
        "cutoff": {
            "name": cutoff_team["name"],
            "pts": pts_cutoff,
            "gp": gp_cutoff,
            "gr": gr_cutoff,
            "position": cutoff_team["position"],
            "projected": round(projected_cutoff, 1),
            "ppg": round(ppg_cutoff, 3),
            "max_possible": max_possible_cutoff,
            "colors": cutoff_team.get("colors", {}),
            "logo": cutoff_team.get("logo", ""),
        },
        "worst_case": worst_case,
        "easiest_path": easiest_path,
        "need_help_info": need_help_info,
        "points_to_safety": max(0, int(projected_cutoff) + 1 - pts_target),
        "ppg_required": round(max(0, int(projected_cutoff) + 1 - pts_target) / gr_target, 2) if gr_target > 0 else 0,
    }


def _compute_worst_case(pts_target: int, gr_target: int, must_beat: int) -> Dict:
    """Worst case: wins only, no ties."""
    points_needed = must_beat - pts_target
    wins_needed = (points_needed + 2) // 3 if points_needed > 0 else 0

    if gr_target <= 0 or wins_needed > gr_target:
        possible = False
        losses = 0
    else:
        possible = True
        losses = gr_target - wins_needed

    return {
        "wins": wins_needed,
        "ties": 0,
        "losses": losses,
        "final_pts": pts_target + 3 * wins_needed,
        "possible": possible,
    }


def _compute_easiest_path(pts_target: int, gr_target: int, must_beat: int) -> Dict:
    """Easiest path: maximize ties (fewest wins needed)."""
    for ties in range(gr_target, -1, -1):
        points_needed = must_beat - (pts_target + ties)
        wins_needed = (points_needed + 2) // 3 if points_needed > 0 else 0
        losses = gr_target - wins_needed - ties
        if 0 <= wins_needed <= gr_target and 0 <= losses <= gr_target and wins_needed + ties + losses == gr_target:
            total_pts = pts_target + 3 * wins_needed + ties
            if total_pts >= must_beat:
                return {
                    "wins": wins_needed,
                    "ties": ties,
                    "losses": losses,
                    "final_pts": total_pts,
                    "possible": True,
                }

    # Not achievable
    points_needed = must_beat - pts_target
    wins_needed = (points_needed + 2) // 3 if points_needed > 0 else 0
    losses = max(0, gr_target - wins_needed)
    return {
        "wins": wins_needed,
        "ties": 0,
        "losses": losses,
        "final_pts": pts_target + 3 * wins_needed,
        "possible": False,
    }


def _compute_need_help(cutoff_team: Dict, season_games: int, max_possible_target: int) -> Dict:
    """What the cutoff team must do for target to qualify."""
    pts_cutoff = cutoff_team["pts"]
    gr_cutoff = max(0, season_games - cutoff_team["gp"])
    limit_pts = max_possible_target - 1
    delta = limit_pts - pts_cutoff

    if delta <= 0:
        return {
            "message": f"{cutoff_team['name']} must lose all remaining {gr_cutoff} games.",
            "max_wins": 0,
            "max_ties": 0,
            "max_additional_pts": 0,
            "cutoff_gr": gr_cutoff,
        }

    max_wins = delta // 3
    max_ties = delta % 3
    return {
        "message": (f"{cutoff_team['name']} must earn no more than {delta} additional points "
                    f"in their last {gr_cutoff} games (at most {max_wins} wins and {max_ties} ties)."),
        "max_wins": max_wins,
        "max_ties": max_ties,
        "max_additional_pts": delta,
        "cutoff_gr": gr_cutoff,
    }


