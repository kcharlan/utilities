    border-radius: 3px;
  }
  .exit-code.zero { color: var(--status-running); }
  .exit-code.nonzero { color: var(--status-failed); background: rgba(255,23,68,0.10); }

  .pid-text { color: var(--text-secondary); font-size: 11px; }
  .schedule-text { color: var(--text-secondary); font-size: 11px; max-width: 180px; overflow: hidden; text-overflow: ellipsis; }

  .row-actions {
    display: flex;
    gap: 2px;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .job-table tbody tr:hover .row-actions { opacity: 1; }

  .row-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px; height: 26px;
    border: none;
    border-radius: 3px;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.1s;
  }
  .row-action-btn:hover { background: var(--bg-active); color: var(--text-primary); }
  .row-action-btn.danger:hover { color: var(--status-failed); background: var(--danger-bg); }
  .row-action-btn svg { width: 13px; height: 13px; }

  /* Checkbox */
  .checkbox {
    width: 14px; height: 14px;
    border: 1.5px solid var(--border-strong);
    border-radius: 3px;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .checkbox:hover { border-color: var(--accent); }
  .checkbox.checked {
    background: var(--accent);
    border-color: var(--accent);
  }
  .checkbox.checked::after {
    content: '';
    width: 4px; height: 7px;
    border: solid var(--text-inverse);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg) translate(-1px, -1px);
  }

  /* ---- Slide-out Detail Panel ---- */
  .panel-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 200;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .panel-overlay.visible { opacity: 1; }

  .detail-panel {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 680px;
    max-width: 90vw;
    background: var(--bg-base);
    border-left: 1px solid var(--border-default);
    z-index: 201;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.25s ease-out;
    box-shadow: -8px 0 32px rgba(0,0,0,0.4);
  }
  .detail-panel.open { transform: translateX(0); }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border-default);
    background: var(--bg-surface);
    flex-shrink: 0;
  }
  .panel-header-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .panel-header-actions {
    display: flex;
    gap: 4px;
  }

  .panel-tabs {
    display: flex;
    border-bottom: 1px solid var(--border-default);
    background: var(--bg-surface);
    flex-shrink: 0;
  }
  .panel-tab {
    padding: 8px 16px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-tertiary);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
  }
  .panel-tab:hover { color: var(--text-secondary); }
  .panel-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .panel-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }

  /* Panel info grid */
  .info-grid {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 6px 12px;
    margin-bottom: 16px;
  }
  .info-label {
    font-size: 11px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .info-value {
    font-size: 12px;
    color: var(--text-primary);
    word-break: break-all;
  }

  /* Plist editor */
  .plist-editor {
    background: var(--bg-void);
    border: 1px solid var(--border-default);
    border-radius: 4px;
    overflow: hidden;
  }
  .plist-editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 12px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-default);
  }
  .plist-editor-header span {
    font-size: 11px;
    color: var(--text-tertiary);
  }
  .plist-editor textarea {
    width: 100%;
    min-height: 300px;
    padding: 12px;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.6;
    resize: vertical;
    outline: none;
    tab-size: 4;
  }

  /* Log viewer */
  .log-viewer {
    background: var(--bg-void);
    border: 1px solid var(--border-default);
    border-radius: 4px;
    overflow: hidden;
  }
  .log-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 12px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-default);
  }
  .log-toolbar-left {
    display: flex;
    gap: 4px;
  }
  .log-tab {
    padding: 3px 10px;
    font-size: 11px;
    border-radius: 3px;
    cursor: pointer;
    color: var(--text-tertiary);
    transition: all 0.15s;
  }
  .log-tab:hover { color: var(--text-secondary); }
  .log-tab.active { color: var(--accent); background: var(--accent-bg); }
  .log-content {
    padding: 12px;
    max-height: 300px;
    overflow-y: auto;
    font-size: 11px;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  .log-line { white-space: pre-wrap; word-break: break-all; }
  .log-line .timestamp { color: var(--text-tertiary); }
  .log-line .error { color: var(--status-failed); }
  .log-line .warn { color: var(--accent); }

  /* ---- Create Job Modal ---- */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .modal {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    width: 640px;
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 16px 64px rgba(0,0,0,0.5);
    animation: slideInUp 0.2s ease-out;
  }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border-default);
  }
  .modal-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
  }
  .modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }
  .modal-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    padding: 12px 20px;
    border-top: 1px solid var(--border-default);
  }

  /* Form fields */
  .form-group { margin-bottom: 14px; }
  .form-label {
    display: block;
    font-size: 11px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }
  .form-input {
    width: 100%;
    padding: 7px 10px;
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: 4px;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 12px;
    outline: none;
    transition: border-color 0.15s;
  }
  .form-input:focus { border-color: var(--accent-border); }
  .form-input::placeholder { color: var(--text-tertiary); }
  .form-row {
    display: flex;
    gap: 12px;
  }
  .form-row .form-group { flex: 1; }

  .form-hint {
    font-size: 10px;
    color: var(--text-tertiary);
    margin-top: 3px;
  }

  .toggle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .toggle-row-label { font-size: 12px; color: var(--text-secondary); }
  .toggle-switch {
    width: 36px; height: 20px;
    border-radius: 10px;
    background: var(--border-strong);
    cursor: pointer;
    position: relative;
    transition: background 0.2s;
  }
  .toggle-switch.on { background: var(--accent); }
  .toggle-switch::after {
    content: '';
    position: absolute;
    top: 2px; left: 2px;
    width: 16px; height: 16px;
    border-radius: 50%;
    background: var(--text-primary);
    transition: transform 0.2s;
  }
  .toggle-switch.on::after { transform: translateX(16px); }

  /* ---- Toast Notifications ---- */
  .toast-container {
    position: fixed;
    bottom: 20px;
    right: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 500;
  }
  .toast {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    border-radius: 6px;
    font-size: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    animation: toast-in 0.25s ease-out;
    min-width: 280px;
  }
  .toast.success { border-color: var(--status-running-border); }
  .toast.success .toast-icon { color: var(--status-running); }
  .toast.error { border-color: var(--status-failed-border); }
  .toast.error .toast-icon { color: var(--status-failed); }
  .toast.warning { border-color: var(--accent-border); }
  .toast.warning .toast-icon { color: var(--accent); }
  .toast svg { width: 16px; height: 16px; flex-shrink: 0; }
  .toast-message { flex: 1; }
  .toast-close {
    color: var(--text-tertiary);
    cursor: pointer;
    background: none;
    border: none;
    display: flex;
    padding: 2px;
  }
  .toast-close:hover { color: var(--text-secondary); }

  /* ---- Confirm Dialog ---- */
  .confirm-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 400;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .confirm-dialog {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    padding: 20px;
    width: 420px;
    max-width: 90vw;
    box-shadow: 0 16px 64px rgba(0,0,0,0.5);
    animation: slideInUp 0.15s ease-out;
  }
  .confirm-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 8px;
  }
  .confirm-message {
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 16px;
    line-height: 1.6;
  }
  .confirm-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
  }

  /* ---- Keyboard shortcut hints ---- */
  .kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1px 5px;
    font-size: 10px;
    font-family: var(--font-mono);
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    border-radius: 3px;
    color: var(--text-tertiary);
    min-width: 18px;
  }

  /* ---- Settings Panel ---- */
  .settings-section {
    margin-bottom: 20px;
  }
  .settings-section-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border-subtle);
  }

  /* ---- Bulk action bar ---- */
  .bulk-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 16px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: 6px;
    animation: fadeIn 0.15s ease-out;
  }
  .bulk-bar-count {
    font-weight: 600;
    color: var(--accent);
    font-size: 12px;
    white-space: nowrap;
  }
  .bulk-bar-divider {
    width: 1px;
    height: 20px;
    background: var(--accent-border);
  }

  /* ---- Preview plist in Create modal ---- */
  .plist-preview {
    background: var(--bg-void);
    border: 1px solid var(--border-default);
    border-radius: 4px;
    padding: 12px;
    font-size: 11px;
    line-height: 1.6;
    color: var(--text-secondary);
    max-height: 300px;
    overflow-y: auto;
    white-space: pre;
  }
  .plist-preview .xml-tag { color: var(--status-idle); }
  .plist-preview .xml-key { color: var(--accent); }
  .plist-preview .xml-value { color: var(--status-running); }
  .plist-preview .xml-comment { color: var(--text-tertiary); font-style: italic; }

  /* ---- Light mode (toggle) ---- */
  html:not(.dark) {
    --bg-void: #f5f5f7;
    --bg-base: #ffffff;
    --bg-surface: #fafafa;
    --bg-elevated: #f0f0f2;
    --bg-hover: #eaeaee;
    --bg-active: #e0e0e6;
    --border-subtle: #e8e8ec;
    --border-default: #d8d8de;
    --border-strong: #c0c0c8;
    --text-primary: #1a1a24;
    --text-secondary: #6a6a7a;
    --text-tertiary: #9a9aaa;
    --text-inverse: #ffffff;
    --scanline-opacity: 0;
  }
</style>
</head>
<body>
<div id="root"></div>

<script type="text/babel">
const { useState, useEffect, useRef, useMemo, useCallback } = React;

// ---- API helper ----
async function api(path, options = {}) {
  const resp = await fetch('/api' + path, {
    headers: { 'Content-Type': 'application/json' },
    ...options,
  });
  if (!resp.ok) {
    const text = await resp.text();
    throw new Error(text || resp.statusText);
  }
  return resp.json();
}

// ---- WebSocket hook for live data ----
function useWebSocket() {
  const [jobs, setJobs] = useState([]);
  const [connected, setConnected] = useState(false);
  const wsRef = useRef(null);

  useEffect(() => {
    const connect = () => {
      const protocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
      const ws = new WebSocket(protocol + '//' + location.host + '/ws');
      wsRef.current = ws;
      ws.onopen = () => setConnected(true);
      ws.onclose = () => { setConnected(false); setTimeout(connect, 3000); };
      ws.onmessage = (e) => {
        const msg = JSON.parse(e.data);
        if (msg.type === 'jobs') setJobs(msg.data);
      };
    };
    connect();
    return () => wsRef.current && wsRef.current.close();
  }, []);

  const refresh = () => wsRef.current && wsRef.current.send(JSON.stringify({type: 'refresh'}));
  return { jobs, connected, refresh };
}

// ---- Icon components (using inline SVGs for the prototype) ----
function Icon({ name, size = 16, className = '' }) {
  const ref = useRef(null);
  useEffect(() => {
    if (ref.current && lucide.icons[name]) {
      ref.current.innerHTML = '';
      const svg = lucide.createElement(lucide.icons[name]);
      svg.setAttribute('width', size);
      svg.setAttribute('height', size);
      ref.current.appendChild(svg);
    }
  }, [name, size]);
  return <span ref={ref} className={className} style={{ display: 'inline-flex', alignItems: 'center' }} />;
}

// ---- Apple logo SVG (inline, no font dependency) ----
function AppleLogo({ size = 14, color = 'currentColor', className = '' }) {
  return (
    <svg width={size} height={size} viewBox="0 0 24 24" fill={color} className={className} style={{ display: 'inline-block', verticalAlign: 'middle' }}>
      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
    </svg>
  );
}

// ---- Helper functions ----
function getJobStatus(job) {
  if (!job.loaded) return 'unloaded';
  if (!job.enabled) return 'disabled';
  if (job.pid != null && job.pid > 0) return 'running';
  if (job.last_exit !== 0 && job.last_exit !== null) return 'failed';
  return 'idle';
}

function statusLabel(s) {
  return { running: 'Running', idle: 'Idle', failed: 'Failed', disabled: 'Disabled', unloaded: 'Unloaded' }[s] || s;
}

function isAppleDomain(domain) {
  return domain === 'apple-agent' || domain === 'apple-daemon' || (domain && domain.startsWith('apple'));
}

// ---- Toast system ----
function ToastContainer({ toasts, removeToast }) {
  return (
    <div className="toast-container">
      {toasts.map(t => (
        <div key={t.id} className={'toast ' + t.type}>
          <span className="toast-icon">
            <Icon name={t.type === 'success' ? 'check-circle' : t.type === 'error' ? 'x-circle' : 'alert-triangle'} size={16} />
          </span>
          <span className="toast-message">{t.message}</span>
          <button className="toast-close" onClick={() => removeToast(t.id)}>
            <Icon name="x" size={14} />
          </button>
        </div>
      ))}
    </div>
  );
}

// ---- Confirm Dialog ----
function ConfirmDialog({ title, message, onConfirm, onCancel, danger = false }) {
  return (
    <div className="confirm-overlay" onClick={onCancel}>
      <div className="confirm-dialog" onClick={e => e.stopPropagation()}>
        <div className="confirm-title">{title}</div>
        <div className="confirm-message">{message}</div>
        <div className="confirm-actions">
          <button className="btn" onClick={onCancel}>Cancel</button>
          <button className={'btn ' + (danger ? 'btn-danger' : 'btn-accent')} onClick={onConfirm}>
            {danger ? 'Delete' : 'Confirm'}
          </button>
        </div>
      </div>
    </div>
  );
}

// ---- Status Cards ----
function StatusCards({ jobs, activeFilter, setActiveFilter }) {
  const counts = useMemo(() => {
    const c = { running: 0, idle: 0, failed: 0, disabled: 0, unloaded: 0 };
    jobs.forEach(j => { c[getJobStatus(j)]++; });
    return c;
  }, [jobs]);

  return (
    <div className="status-cards">
      {['running', 'idle', 'failed', 'disabled', 'unloaded'].map(s => (
        <div
          key={s}
          className={'status-card ' + s + (activeFilter === s ? ' active' : '')}
          onClick={() => setActiveFilter(activeFilter === s ? null : s)}
        >
          <div className="status-card-count">{counts[s]}</div>
          <div className="status-card-label">{statusLabel(s)}</div>
        </div>
      ))}
    </div>
  );
}

// ---- Failed Jobs Panel ----
function FailedPanel({ jobs, onOpenDetail, onOpenLogs, onOpenEdit, onReload }) {
  const [collapsed, setCollapsed] = useState(false);
  const failedJobs = jobs.filter(j => getJobStatus(j) === 'failed');

  if (failedJobs.length === 0) return null;

  return (
    <div className="failed-panel">
      <div className="failed-panel-header" onClick={() => setCollapsed(!collapsed)}>
        <div className="failed-panel-title">
          <div className="failed-pulse" />
          {failedJobs.length} Failed Job{failedJobs.length > 1 ? 's' : ''} — Attention Required
        </div>
        <Icon name={collapsed ? 'chevron-down' : 'chevron-up'} size={16} />
      </div>
      {!collapsed && (
        <div className="failed-panel-body">
          {failedJobs.map((j, i) => (
            <div key={j.label} className="failed-job-row" style={{ animationDelay: (i * 50) + 'ms', cursor: 'pointer' }} onClick={() => onOpenDetail(j)}>
              <div className="failed-job-info">
                <span className="failed-job-label">{j.label}</span>
                <span className="failed-job-exit">exit {j.last_exit}</span>
                {j.blame && <span className="failed-job-blame" title={j.blame}>{j.blame}</span>}
              </div>
              <div className="failed-job-actions">
                <button className="btn btn-sm btn-ghost" onClick={(e) => { e.stopPropagation(); onOpenLogs(j); }}>
                  <Icon name="file-text" size={12} /> Logs
                </button>
                <button className="btn btn-sm btn-ghost" onClick={(e) => { e.stopPropagation(); onOpenEdit(j); }}>
                  <Icon name="pencil" size={12} /> Edit
                </button>
                <button className="btn btn-sm btn-ghost" onClick={(e) => { e.stopPropagation(); onReload(j); }}>
                  <Icon name="refresh-cw" size={12} /> Reload
                </button>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ---- Filter Bar ----
function FilterBar({ search, setSearch, domainFilter, setDomainFilter, showApple, setShowApple, activeFilter, setActiveFilter }) {
  const searchRef = useRef(null);
  const appleForced = domainFilter === 'apple';

  // Esc clears search when focused
  const handleSearchKeyDown = (e) => {
    if (e.key === 'Escape') {
      if (search) {
        e.preventDefault();
        e.stopPropagation();
        setSearch('');
      } else {
        searchRef.current && searchRef.current.blur();
      }
    }
  };

  return (
    <div className="filter-bar">
      <Icon name="search" size={14} />
      <div style={{ flex: 1, minWidth: 200, position: 'relative' }}>
        <input
          ref={searchRef}
          className="filter-search"
          style={{ width: '100%', paddingRight: search ? 60 : 10 }}
          placeholder="Search jobs by label...  (/ to focus, Esc to clear)"
          value={search}
          onChange={e => setSearch(e.target.value)}
          onKeyDown={handleSearchKeyDown}
        />
        {search && (
          <button
            onClick={() => { setSearch(''); searchRef.current && searchRef.current.focus(); }}
            style={{
              position: 'absolute', right: 6, top: '50%', transform: 'translateY(-50%)',
              background: 'var(--bg-hover)', border: '1px solid var(--border-strong)',
              borderRadius: 4, color: 'var(--text-primary)', cursor: 'pointer',
              display: 'flex', alignItems: 'center', gap: 3,
              padding: '2px 8px', lineHeight: 1, zIndex: 2,
              fontSize: 11, fontFamily: 'var(--font-mono)',
            }}
            title="Clear search (Esc)"
          >
            <Icon name="x" size={11} /> clear
          </button>
        )}
      </div>
      <select className="filter-select" value={domainFilter} onChange={e => {
        const val = e.target.value;
        setDomainFilter(val);
        // If selecting Apple domain, auto-enable apple visibility
        if (val === 'apple') setShowApple(true);
      }}>
        <option value="all">All Domains</option>
        <option value="user-agent">User Agents</option>
        <option value="global-agent">Global Agents</option>
        <option value="system-daemon">System Daemons</option>
        {showApple && <option value="apple">Apple</option>}
      </select>
      <div
        className={'filter-toggle' + (showApple ? ' active' : '') + (appleForced ? ' forced' : '')}
        onClick={() => {
          if (appleForced) return; // Can't toggle off while filtering to Apple
          setShowApple(!showApple);
        }}
        style={appleForced ? { opacity: 0.5, cursor: 'not-allowed' } : {}}
        title={appleForced ? 'Cannot hide Apple jobs while filtering by Apple domain' : 'Toggle Apple system jobs'}
      >
        <Icon name="shield" size={14} />
        Apple Jobs
      </div>
      {activeFilter && (
        <div className="filter-chip" onClick={() => setActiveFilter(null)}>
          {statusLabel(activeFilter)} <Icon name="x" size={10} />
        </div>
      )}
      <div style={{ flex: 1 }} />
      <span style={{ fontSize: 11, color: 'var(--text-tertiary)' }}>
        <kbd className="kbd">?</kbd> shortcuts
      </span>
    </div>
  );
}

// ---- Pagination ----
function Pagination({ currentPage, totalPages, onPageChange }) {
  const [editingPage, setEditingPage] = useState(false);
  const [pageInput, setPageInput] = useState('');

  if (totalPages <= 1) return null;

  const handleSubmit = (e) => {
    e.preventDefault();
    const p = parseInt(pageInput, 10);
    if (p >= 1 && p <= totalPages) onPageChange(p);
    setEditingPage(false);
    setPageInput('');
  };

  const PgBtn = ({ onClick, disabled, children, title }) => (
    <button
      onClick={onClick}
      disabled={disabled}
      title={title}
      style={{
        display: 'inline-flex', alignItems: 'center', justifyContent: 'center',
        minWidth: 32, height: 28, padding: '0 8px',
        background: disabled ? 'transparent' : 'var(--bg-surface)',
        border: '1px solid ' + (disabled ? 'var(--border-subtle)' : 'var(--border-default)'),
        borderRadius: 4,
        color: disabled ? 'var(--text-tertiary)' : 'var(--text-primary)',
        cursor: disabled ? 'default' : 'pointer',
        fontFamily: 'var(--font-mono)', fontSize: 12, fontWeight: 500,
        opacity: disabled ? 0.4 : 1,
        transition: 'all 0.15s',
      }}
      onMouseEnter={e => { if (!disabled) { e.target.style.background = 'var(--bg-hover)'; e.target.style.borderColor = 'var(--border-strong)'; }}}
      onMouseLeave={e => { if (!disabled) { e.target.style.background = 'var(--bg-surface)'; e.target.style.borderColor = 'var(--border-default)'; }}}
    >
      {children}
    </button>
  );

  return (
    <div style={{
      display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 6,
      fontSize: 12,
    }}>
      <PgBtn onClick={() => onPageChange(1)} disabled={currentPage === 1} title="First page">
        &laquo; First
      </PgBtn>
      <PgBtn onClick={() => onPageChange(currentPage - 1)} disabled={currentPage === 1} title="Previous page">
        &lsaquo; Prev
      </PgBtn>

      {editingPage ? (
        <form onSubmit={handleSubmit} style={{ display: 'inline-flex', alignItems: 'center', gap: 4 }}>
          <input
            autoFocus
            className="form-input"
            style={{ width: 48, height: 28, padding: '2px 6px', textAlign: 'center', fontSize: 12 }}
            value={pageInput}
            onChange={e => setPageInput(e.target.value)}
            onBlur={() => { setEditingPage(false); setPageInput(''); }}
            placeholder={String(currentPage)}
          />
          <span style={{ color: 'var(--text-tertiary)' }}>/ {totalPages}</span>
        </form>
      ) : (
        <span
          style={{
            padding: '4px 12px', cursor: 'pointer', color: 'var(--text-secondary)',
            userSelect: 'none', border: '1px solid var(--border-default)',
            borderRadius: 4, background: 'var(--bg-surface)',
          }}
          onClick={() => { setEditingPage(true); setPageInput(String(currentPage)); }}
          title="Click to jump to page"
        >
          Page <span style={{ color: 'var(--accent)', fontWeight: 700 }}>{currentPage}</span> of {totalPages}
        </span>
      )}

      <PgBtn onClick={() => onPageChange(currentPage + 1)} disabled={currentPage === totalPages} title="Next page">
        Next &rsaquo;
      </PgBtn>
      <PgBtn onClick={() => onPageChange(totalPages)} disabled={currentPage === totalPages} title="Last page">
        Last &raquo;
      </PgBtn>
    </div>
  );
}

// ---- Job Table ----
const PAGE_SIZE = 25;

function JobTable({ jobs, selected, setSelected, onRowClick, showApple, addToast, setShowConfirm }) {
  const [sortCol, setSortCol] = useState('status');
  const [sortAsc, setSortAsc] = useState(true);
  const [currentPage, setCurrentPage] = useState(1);

  const handleSort = (col) => {
    if (sortCol === col) setSortAsc(!sortAsc);
    else { setSortCol(col); setSortAsc(true); }
  };

  const toggleSelect = (label, e) => {
    e.stopPropagation();
    setSelected(prev =>
      prev.includes(label) ? prev.filter(l => l !== label) : [...prev, label]
    );
  };

  const toggleAll = () => {
    if (selected.length === jobs.length) setSelected([]);
    else setSelected(jobs.map(j => j.label));
  };

  // Reset to page 1 when filters/jobs change
  useEffect(() => { setCurrentPage(1); }, [jobs.length]);

  const sorted = useMemo(() => {
    const order = { failed: 0, running: 1, idle: 2, disabled: 3, unloaded: 4 };
    return [...jobs].sort((a, b) => {
      let cmp = 0;
      if (sortCol === 'status') cmp = order[getJobStatus(a)] - order[getJobStatus(b)];
      else if (sortCol === 'label') cmp = a.label.localeCompare(b.label);
      else if (sortCol === 'domain') cmp = a.domain.localeCompare(b.domain);
      else if (sortCol === 'exit') cmp = (a.last_exit || 0) - (b.last_exit || 0);
      return sortAsc ? cmp : -cmp;
    });
  }, [jobs, sortCol, sortAsc]);

  const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));
  const page = Math.min(currentPage, totalPages);
  const paginatedJobs = sorted.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);

  // ---- Row action handlers ----
  const handleRowAction = async (e, job, action) => {
    e.stopPropagation();
    const label = encodeURIComponent(job.label);
    try {
      if (action === 'start') {
        await api('/jobs/' + label + '/start', { method: 'POST' });
        addToast('success', 'Started ' + job.label);
      } else if (action === 'stop') {
        await api('/jobs/' + label + '/stop', { method: 'POST' });
        addToast('success', 'Stopped ' + job.label);
      } else if (action === 'run-now') {
        await api('/jobs/' + label + '/run-now', { method: 'POST' });
        addToast('success', 'Running ' + job.label + ' (one-shot)...');
      } else if (action === 'reload') {
        await api('/jobs/' + label + '/reload', { method: 'POST' });
        addToast('success', 'Reloading ' + job.label + '...');
      } else if (action === 'export') {
        // Trigger file download
        const a = document.createElement('a');
        a.href = '/api/jobs/' + label + '/export';
        a.download = job.label + '.plist';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        addToast('success', 'Exported ' + job.label + '.plist');
      } else if (action === 'delete') {
        setShowConfirm({
          title: 'Delete Job',
          message: 'Are you sure you want to delete "' + job.label + '"? This will unload and remove the plist file.',
          danger: true,
          onConfirm: async () => {
            try {
              await api('/jobs/' + label, { method: 'DELETE' });
              addToast('success', 'Deleted ' + job.label);
            } catch (err) {
              addToast('error', 'Failed to delete: ' + err.message);
            }
          }
        });
      }
    } catch (err) {
      addToast('error', action + ' failed: ' + err.message);
    }
  };

  const SortHeader = ({ col, children, style }) => (
    <th
      className={sortCol === col ? 'sorted' : ''}
      onClick={() => handleSort(col)}
      style={style}
    >
      {children}
      <span className="sort-arrow">{sortCol === col ? (sortAsc ? '\u25B2' : '\u25BC') : '\u25B2'}</span>
    </th>
  );

  return (
    <div className="job-table-container" style={{ overflow: 'auto' }}>
      <table className="job-table">
        <thead>
          <tr>
            <th style={{ width: 36 }}>
              <div
                className={'checkbox' + (selected.length === jobs.length && jobs.length > 0 ? ' checked' : '')}
                onClick={toggleAll}
              />
            </th>
            <SortHeader col="status" style={{ width: 60 }}>Status</SortHeader>
            <SortHeader col="label">Label</SortHeader>
            <SortHeader col="domain" style={{ width: 120 }}>Domain</SortHeader>
            <th style={{ width: 180 }}>Schedule</th>
            <th style={{ width: 70 }}>PID</th>
            <SortHeader col="exit" style={{ width: 80 }}>Last Exit</SortHeader>
            <th style={{ width: 180, textAlign: 'right' }}>Actions</th>
          </tr>
        </thead>
        <tbody>
          {paginatedJobs.map((job, i) => {
            const status = getJobStatus(job);
            const apple = isAppleDomain(job.domain);
            return (
              <tr
                key={job.label}
                className={(selected.includes(job.label) ? 'selected ' : '') + 'status-' + status + (apple ? ' apple-row' : '')}
                onClick={() => onRowClick(job)}
                style={{ animationDelay: (i * 20) + 'ms' }}
              >
                <td>
                  <div
                    className={'checkbox' + (selected.includes(job.label) ? ' checked' : '')}
                    onClick={e => toggleSelect(job.label, e)}
                  />
                </td>
                <td>
                  <div className={'status-dot ' + status} title={statusLabel(status)} />
                </td>
                <td>
                  <div className="job-label-cell">
                    {apple && <span className="apple-row-icon" title="Apple system job"><AppleLogo size={14} color="#d0a050" /></span>}
                    <span className="job-label-text">{job.label}</span>
                  </div>
                </td>
                <td>
                  <span className={'domain-badge ' + (apple ? 'apple' : job.domain)}>
                    {apple && <AppleLogo size={10} color="#e8a030" className="apple-badge-icon" />}
                    {job.domain.replace('-', ' ')}
                  </span>
                </td>
                <td><span className="schedule-text" title={job.schedule}>{job.schedule_human}</span></td>
                <td><span className="pid-text">{job.pid || '\u2014'}</span></td>
                <td>
                  {job.last_exit !== null ? (
                    <span className={'exit-code ' + (job.last_exit === 0 ? 'zero' : 'nonzero')}>
                      {job.last_exit}
                    </span>
                  ) : '\u2014'}
                </td>
                <td style={{ textAlign: 'right' }}>
                  <div className="row-actions">
                    <button className="row-action-btn" title="Start (s)" onClick={e => handleRowAction(e, job, 'start')}>
                      <Icon name="play" size={13} />
                    </button>
                    <button className="row-action-btn" title="Stop (x)" onClick={e => handleRowAction(e, job, 'stop')}>
                      <Icon name="square" size={13} />
                    </button>
                    <button className="row-action-btn" title="Run Now (one-shot)" onClick={e => handleRowAction(e, job, 'run-now')}>
                      <Icon name="zap" size={13} />
                    </button>
                    <button className="row-action-btn" title="Reload (r)" onClick={e => handleRowAction(e, job, 'reload')}>
                      <Icon name="refresh-cw" size={13} />
                    </button>
                    <button className="row-action-btn" title="Edit (e)" onClick={e => { e.stopPropagation(); onRowClick(job, 'edit'); }}>
                      <Icon name="pencil" size={13} />
                    </button>
                    <button className="row-action-btn" title="Logs (l)" onClick={e => { e.stopPropagation(); onRowClick(job, 'logs'); }}>
                      <Icon name="file-text" size={13} />
                    </button>
                    <button className="row-action-btn" title="Export" onClick={e => handleRowAction(e, job, 'export')}>
                      <Icon name="download" size={13} />
                    </button>
                    <button className="row-action-btn danger" title="Delete" onClick={e => handleRowAction(e, job, 'delete')}>
                      <Icon name="trash-2" size={13} />
                    </button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div style={{
        display: 'flex', alignItems: 'center', justifyContent: 'space-between',
        padding: '6px 12px', borderTop: '1px solid var(--border-subtle)',
        background: 'var(--bg-elevated)', fontSize: 11, color: 'var(--text-tertiary)',
      }}>
        <span>{sorted.length} job{sorted.length !== 1 ? 's' : ''}{sorted.length !== jobs.length ? ' (filtered from ' + jobs.length + ')' : ''}</span>
        <Pagination currentPage={page} totalPages={totalPages} onPageChange={setCurrentPage} />
        <span>{PAGE_SIZE} per page</span>
      </div>
    </div>
  );
}

// ---- Bulk Action Bar ----
function BulkBar({ count, onClear, selectedLabels, addToast, setShowConfirm }) {

  const bulkAction = async (action, label) => {
    let successes = 0;
    let failures = 0;
    for (const jobLabel of selectedLabels) {
      try {
        const encoded = encodeURIComponent(jobLabel);
        if (action === 'delete') {
          await api('/jobs/' + encoded, { method: 'DELETE' });
        } else {
          await api('/jobs/' + encoded + '/' + action, { method: 'POST' });
        }
        successes++;
      } catch (err) {
        failures++;
      }
    }
    if (failures === 0) {
      addToast('success', label + ' ' + successes + ' job' + (successes !== 1 ? 's' : ''));
    } else {
      addToast('warning', label + ': ' + successes + ' succeeded, ' + failures + ' failed');
    }
    onClear();
  };

  if (count === 0) return null;
  return (
    <div className="bulk-bar">
      <span className="bulk-bar-count">{count} selected</span>
      <div className="bulk-bar-divider" />
      <button className="btn btn-sm" onClick={() => bulkAction('start', 'Started')}><Icon name="play" size={12} /> Start All</button>
      <button className="btn btn-sm" onClick={() => bulkAction('stop', 'Stopped')}><Icon name="square" size={12} /> Stop All</button>
      <button className="btn btn-sm" onClick={() => bulkAction('reload', 'Reloaded')}><Icon name="refresh-cw" size={12} /> Reload All</button>
      <button className="btn btn-sm" onClick={() => bulkAction('enable', 'Enabled')}><Icon name="toggle-left" size={12} /> Enable</button>
      <button className="btn btn-sm" onClick={() => bulkAction('disable', 'Disabled')}><Icon name="toggle-right" size={12} /> Disable</button>
      <button className="btn btn-sm btn-danger" onClick={() => {
        setShowConfirm({
          title: 'Delete ' + count + ' Jobs',
          message: 'Are you sure you want to delete ' + count + ' selected job' + (count !== 1 ? 's' : '') + '? This will unload and remove the plist files.',
          danger: true,
          onConfirm: () => bulkAction('delete', 'Deleted'),
        });
      }}><Icon name="trash-2" size={12} /> Delete</button>
      <div style={{ flex: 1 }} />
      <button className="btn btn-sm btn-ghost" onClick={onClear}>Clear Selection</button>
    </div>
  );
}

// ---- Detail Panel ----
function DetailPanel({ job, initialTab, onClose, addToast, setShowConfirm }) {
  const [activeTab, setActiveTab] = useState(initialTab || 'info');
  const [logTab, setLogTab] = useState('stderr');
  const [logContent, setLogContent] = useState('');
  const [logLoading, setLogLoading] = useState(false);
  const [plistContent, setPlistContent] = useState('');
  const [plistLoading, setPlistLoading] = useState(false);
  const [modified, setModified] = useState(false);

  // Reset tab when job or initialTab changes
  useEffect(() => {
    setActiveTab(initialTab || 'info');
  }, [job && job.label, initialTab]);

  // Fetch logs when logs tab is active or logTab changes
  useEffect(() => {
    if (!job || activeTab !== 'logs') return;
    let cancelled = false;
    setLogLoading(true);
    const encoded = encodeURIComponent(job.label);
    api('/jobs/' + encoded + '/logs/' + logTab)
      .then(data => {
        if (!cancelled) {
          setLogContent(data.content || data.lines || '');
          setLogLoading(false);
        }
      })
      .catch(err => {
        if (!cancelled) {
          setLogContent('Error loading logs: ' + err.message);
          setLogLoading(false);
        }
      });
    return () => { cancelled = true; };
  }, [job && job.label, activeTab, logTab]);

  // Fetch plist when edit tab is active
  useEffect(() => {
    if (!job || activeTab !== 'edit') return;
    let cancelled = false;
    setPlistLoading(true);
    setModified(false);
    const encoded = encodeURIComponent(job.label);
    api('/jobs/' + encoded + '/plist')
      .then(data => {
        if (!cancelled) {
          setPlistContent(data.content || '');
          setPlistLoading(false);
        }
      })
      .catch(err => {
        if (!cancelled) {
          setPlistContent('Error loading plist: ' + err.message);
          setPlistLoading(false);
        }
      });
    return () => { cancelled = true; };
  }, [job && job.label, activeTab]);

  if (!job) return null;
  const status = getJobStatus(job);
  const encoded = encodeURIComponent(job.label);

  const handleAction = async (action) => {
    try {
      await api('/jobs/' + encoded + '/' + action, { method: 'POST' });
      addToast('success', (action === 'start' ? 'Started ' : action === 'stop' ? 'Stopped ' : action === 'run-now' ? 'Running ' : action === 'reload' ? 'Reloading ' : action === 'enable' ? 'Enabled ' : action === 'disable' ? 'Disabled ' : action === 'load' ? 'Loaded ' : 'Unloaded ') + job.label);
    } catch (err) {
      addToast('error', action + ' failed: ' + err.message);
    }
  };

  const handleSavePlist = async () => {
    try {
      await api('/jobs/' + encoded + '/plist', {
        method: 'PUT',
        body: JSON.stringify({ content: plistContent }),
      });
      setModified(false);
      addToast('success', 'Plist saved. Reload to apply changes.');
    } catch (err) {
      addToast('error', 'Save failed: ' + err.message);
    }
  };

  const handleSaveAndReload = async () => {
    try {
      await api('/jobs/' + encoded + '/plist', {
        method: 'PUT',
        body: JSON.stringify({ content: plistContent }),
      });
      setModified(false);
      await api('/jobs/' + encoded + '/reload', { method: 'POST' });
      addToast('success', 'Saved and reloading ' + job.label + '...');
    } catch (err) {
      addToast('error', 'Save & reload failed: ' + err.message);
    }
  };

  const handleExport = () => {
    const a = document.createElement('a');
    a.href = '/api/jobs/' + encoded + '/export';
    a.download = job.label + '.plist';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    addToast('success', 'Exported ' + job.label + '.plist');
  };

  const handleDelete = () => {
    setShowConfirm({
      title: 'Delete Job',
      message: 'Are you sure you want to delete "' + job.label + '"? This will unload and remove the plist file.',
      danger: true,
      onConfirm: async () => {
        try {
          await api('/jobs/' + encoded, { method: 'DELETE' });
          addToast('success', 'Deleted ' + job.label);
          onClose();
        } catch (err) {
          addToast('error', 'Delete failed: ' + err.message);
        }
      }
    });
  };

  return (
    <>
      <div className={'panel-overlay' + (job ? ' visible' : '')} onClick={onClose} />
      <div className={'detail-panel' + (job ? ' open' : '')}>
        <div className="panel-header">
          <div className="panel-header-title">
            <div className={'status-dot ' + status} />
            {job.label}
          </div>
          <div className="panel-header-actions">
            <button className="btn btn-sm" onClick={() => handleAction('start')}>
              <Icon name="play" size={12} /> Start
            </button>
            <button className="btn btn-sm" onClick={() => handleAction('stop')}>
              <Icon name="square" size={12} /> Stop
            </button>
            <button className="btn btn-sm" onClick={() => handleAction('run-now')} title="One-shot execution via kickstart">
              <Icon name="zap" size={12} /> Run Now
            </button>
            <button className="btn btn-sm btn-accent" onClick={() => handleAction('reload')}>
              <Icon name="refresh-cw" size={12} /> Reload
            </button>
            <button className="icon-btn" onClick={onClose}>
              <Icon name="x" size={16} />
            </button>
          </div>
        </div>

        <div className="panel-tabs">
          {['info', 'logs', 'edit'].map(t => (
            <div
              key={t}
              className={'panel-tab' + (activeTab === t ? ' active' : '')}
              onClick={() => setActiveTab(t)}
            >
              {t === 'info' ? 'Info' : t === 'logs' ? 'Logs' : 'Edit Plist'}
            </div>
          ))}
        </div>

        <div className="panel-body">
          {activeTab === 'info' && (
            <div className="animate-fade">
              <div className="info-grid">
                <span className="info-label">Label</span>
                <span className="info-value">{job.label}</span>
                <span className="info-label">Status</span>
                <span className="info-value">
                  <span className={'status-dot ' + status} style={{ marginRight: 8 }} />
                  {statusLabel(status)}
                  {job.pid && ' (PID ' + job.pid + ')'}
                </span>
                <span className="info-label">Domain</span>
                <span className="info-value">{job.domain}</span>
                <span className="info-label">Plist</span>
                <span className="info-value">{job.plist_path}</span>
                <span className="info-label">Schedule</span>
                <span className="info-value">{job.schedule_human}</span>
                <span className="info-label">Loaded</span>
                <span className="info-value">{job.loaded ? 'Yes' : 'No'}</span>
                <span className="info-label">Enabled</span>
                <span className="info-value">{job.enabled ? 'Yes' : 'No'}</span>
                <span className="info-label">Last Exit</span>
                <span className="info-value">
                  {job.last_exit !== null ? (
                    <span className={'exit-code ' + (job.last_exit === 0 ? 'zero' : 'nonzero')}>{job.last_exit}</span>
                  ) : '\u2014'}
                </span>
                {job.blame && (
                  <>
                    <span className="info-label">Blame</span>
                    <span className="info-value" style={{ color: 'var(--status-failed)' }}>{job.blame}</span>
                  </>
                )}
                {job.program && (
                  <>
                    <span className="info-label">Program</span>
                    <span className="info-value">{job.program}</span>
                  </>
                )}
                {job.program_arguments && job.program_arguments.length > 0 && (
                  <>
                    <span className="info-label">Arguments</span>
                    <span className="info-value">{job.program_arguments.join(' ')}</span>
                  </>
                )}
                {job.working_directory && (
                  <>
                    <span className="info-label">Working Dir</span>
                    <span className="info-value">{job.working_directory}</span>
                  </>
                )}
                <span className="info-label">Stdout</span>
                <span className="info-value">{job.stdout_path || '\u2014'}</span>
                <span className="info-label">Stderr</span>
                <span className="info-value">{job.stderr_path || '\u2014'}</span>
              </div>

              <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap', marginTop: 12 }}>
                <button className="btn" onClick={() => handleAction(job.enabled ? 'disable' : 'enable')}>
                  <Icon name="toggle-left" size={14} /> {job.enabled ? 'Disable' : 'Enable'}
                </button>
                <button className="btn" onClick={() => handleAction(job.loaded ? 'unload' : 'load')}>
                  <Icon name={job.loaded ? 'log-out' : 'log-in'} size={14} /> {job.loaded ? 'Unload' : 'Load'}
                </button>
                <button className="btn" onClick={handleExport}>
                  <Icon name="download" size={14} /> Export Plist
                </button>
                <button className="btn btn-danger" onClick={handleDelete}><Icon name="trash-2" size={14} /> Delete Job</button>
              </div>
            </div>
          )}

          {activeTab === 'edit' && (
            <div className="animate-fade">
              <div className="plist-editor">
                <div className="plist-editor-header">
                  <span>{job.plist_path}</span>
                  <div style={{ display: 'flex', gap: 8 }}>
                    {modified && <span style={{ color: 'var(--accent)', fontSize: 11 }}>{'\u25CF'} Modified</span>}
                    <button
                      className="btn btn-sm btn-accent"
                      onClick={handleSavePlist}
                      disabled={!modified}
                      style={{ opacity: modified ? 1 : 0.5 }}
                    >
                      <Icon name="save" size={12} /> Save
                    </button>
                    <button
                      className="btn btn-sm"
                      onClick={handleSaveAndReload}
                    >
                      <Icon name="refresh-cw" size={12} /> Save & Reload
                    </button>
                  </div>
                </div>
                {plistLoading ? (
                  <div style={{ padding: 20, color: 'var(--text-tertiary)' }}>Loading plist...</div>
                ) : (
                  <textarea
                    value={plistContent}
                    onChange={e => { setPlistContent(e.target.value); setModified(true); }}
                    spellCheck={false}
                  />
                )}
              </div>
            </div>
          )}

          {activeTab === 'logs' && (
            <div className="animate-fade">
              <div className="log-viewer">
                <div className="log-toolbar">
                  <div className="log-toolbar-left">
                    {['stderr', 'stdout', 'unified'].map(t => (
                      <div
                        key={t}
                        className={'log-tab' + (logTab === t ? ' active' : '')}
                        onClick={() => setLogTab(t)}
                      >
                        {t}
                      </div>
                    ))}
                  </div>
                  <div style={{ display: 'flex', gap: 4 }}>
                    <button className="btn btn-sm btn-ghost" onClick={() => {
                      // Refresh logs
                      setLogLoading(true);
                      api('/jobs/' + encoded + '/logs/' + logTab)
                        .then(data => { setLogContent(data.content || data.lines || ''); setLogLoading(false); })
                        .catch(err => { setLogContent('Error: ' + err.message); setLogLoading(false); });
                    }}>
                      <Icon name="refresh-cw" size={12} /> Refresh
                    </button>
                  </div>
                </div>
                <div className="log-content">
                  {logLoading ? (
                    <div style={{ color: 'var(--text-tertiary)' }}>Loading logs...</div>
                  ) : (
                    typeof logContent === 'string' ? (
                      logContent.split('\\n').map((line, i) => (
                        <div key={i} className="log-line">
                          <span className={line.toLowerCase().includes('error') || line.toLowerCase().includes('traceback') ? 'error' : line.toLowerCase().includes('warn') ? 'warn' : ''}>
                            {line}
                          </span>
                        </div>
                      ))
                    ) : Array.isArray(logContent) ? (
                      logContent.map((line, i) => (
                        <div key={i} className="log-line">
                          {line.time && <span className="timestamp">{line.time} </span>}
                          <span className={line.level === 'error' ? 'error' : line.level === 'warn' ? 'warn' : ''}>
                            {line.text || line}
                          </span>
                        </div>
                      ))
                    ) : null
                  )}
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </>
  );
}

// ---- Create Job Modal ----
function CreateJobModal({ onClose, addToast }) {
  const [step, setStep] = useState('form'); // form | preview
  const [creating, setCreating] = useState(false);
  const [formData, setFormData] = useState({
    label: '',
    program: '',
    args: '',
    domain: 'user-agent',
    runAtLoad: true,
    keepAlive: false,
    scheduleType: 'none',
    startInterval: '',
    calendarHour: '',
    calendarMinute: '0',
    calendarWeekdays: [],
    calendarDay: '',
    watchPaths: '',
    stdoutPath: '',
    stderrPath: '',
    workingDir: '',
  });

  const update = (k, v) => setFormData(prev => ({ ...prev, [k]: v }));

  const buildPlistData = () => {
    const data = {
      Label: formData.label || 'com.example.my-tool',
      ProgramArguments: [formData.program || '/usr/local/bin/python3'].concat(
        formData.args ? formData.args.split('\\n').filter(Boolean) : []
      ),
    };
    if (formData.scheduleType === 'interval' && formData.startInterval) {
      data.StartInterval = parseInt(formData.startInterval, 10);
    }
    if (formData.scheduleType === 'calendar') {
      if (formData.calendarWeekdays.length > 1) {
        data.StartCalendarInterval = formData.calendarWeekdays.map(wd => {
          const entry = {};
          if (formData.calendarHour) entry.Hour = parseInt(formData.calendarHour, 10);
          if (formData.calendarMinute) entry.Minute = parseInt(formData.calendarMinute, 10);
          entry.Weekday = wd;
          if (formData.calendarDay) entry.Day = parseInt(formData.calendarDay, 10);
          return entry;
        });
      } else {
        const entry = {};
        if (formData.calendarHour) entry.Hour = parseInt(formData.calendarHour, 10);
        if (formData.calendarMinute) entry.Minute = parseInt(formData.calendarMinute, 10);
        if (formData.calendarWeekdays.length === 1) entry.Weekday = formData.calendarWeekdays[0];
        if (formData.calendarDay) entry.Day = parseInt(formData.calendarDay, 10);
        data.StartCalendarInterval = entry;
      }
    }
    if (formData.scheduleType === 'watch' && formData.watchPaths) {
      data.WatchPaths = formData.watchPaths.split('\\n').filter(Boolean);
    }
    if (formData.runAtLoad) data.RunAtLoad = true;
    if (formData.keepAlive) data.KeepAlive = true;
    if (formData.stdoutPath) data.StandardOutPath = formData.stdoutPath;
    if (formData.stderrPath) data.StandardErrorPath = formData.stderrPath;
    if (formData.workingDir) data.WorkingDirectory = formData.workingDir;
    return data;
  };

  const handleCreate = async () => {
    setCreating(true);
    try {
      await api('/jobs', {
        method: 'POST',
        body: JSON.stringify({
          plist_data: buildPlistData(),
          domain: formData.domain,
        }),
      });
      addToast('success', 'Created and loaded ' + (formData.label || 'new job'));
      onClose();
    } catch (err) {
      addToast('error', 'Create failed: ' + err.message);
    } finally {
      setCreating(false);
    }
  };

  // Generate preview XML for display
  const previewXml = useMemo(() => {
    const label = formData.label || 'com.kevin.my-tool';
    const prog = formData.program || '/usr/local/bin/python3';
    let xml = '<?xml version="1.0" encoding="UTF-8"?>\\n';
    xml += '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"\\n';
    xml += '  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">\\n';
    xml += '<plist version="1.0">\\n<dict>\\n';
    xml += '    <key>Label</key>\\n    <string>' + label + '</string>\\n';
    xml += '    <key>ProgramArguments</key>\\n    <array>\\n';
    xml += '        <string>' + prog + '</string>\\n';
    if (formData.args) {
      formData.args.split('\\n').filter(Boolean).forEach(a => {
        xml += '        <string>' + a + '</string>\\n';
      });
    }
    xml += '    </array>\\n';
    if (formData.scheduleType === 'interval' && formData.startInterval) {
      xml += '    <key>StartInterval</key>\\n    <integer>' + formData.startInterval + '</integer>\\n';
    }
    if (formData.scheduleType === 'calendar') {
      if (formData.calendarWeekdays.length > 1) {
        xml += '    <key>StartCalendarInterval</key>\\n    <array>\\n';
        formData.calendarWeekdays.forEach(wd => {
          xml += '        <dict>\\n';
          if (formData.calendarHour) xml += '            <key>Hour</key>\\n            <integer>' + formData.calendarHour + '</integer>\\n';
          if (formData.calendarMinute) xml += '            <key>Minute</key>\\n            <integer>' + formData.calendarMinute + '</integer>\\n';
          xml += '            <key>Weekday</key>\\n            <integer>' + wd + '</integer>\\n';
          if (formData.calendarDay) xml += '            <key>Day</key>\\n            <integer>' + formData.calendarDay + '</integer>\\n';
          xml += '        </dict>\\n';
        });
        xml += '    </array>\\n';
      } else {
        xml += '    <key>StartCalendarInterval</key>\\n    <dict>\\n';
        if (formData.calendarHour) xml += '        <key>Hour</key>\\n        <integer>' + formData.calendarHour + '</integer>\\n';
        if (formData.calendarMinute) xml += '        <key>Minute</key>\\n        <integer>' + formData.calendarMinute + '</integer>\\n';
        if (formData.calendarWeekdays.length === 1) xml += '        <key>Weekday</key>\\n        <integer>' + formData.calendarWeekdays[0] + '</integer>\\n';
        if (formData.calendarDay) xml += '        <key>Day</key>\\n        <integer>' + formData.calendarDay + '</integer>\\n';
        xml += '    </dict>\\n';
      }
    }
    if (formData.scheduleType === 'watch' && formData.watchPaths) {
      xml += '    <key>WatchPaths</key>\\n    <array>\\n';
      formData.watchPaths.split('\\n').filter(Boolean).forEach(p => {
        xml += '        <string>' + p + '</string>\\n';
      });
      xml += '    </array>\\n';
    }
    if (formData.runAtLoad) xml += '    <key>RunAtLoad</key>\\n    <true/>\\n';
    if (formData.keepAlive) xml += '    <key>KeepAlive</key>\\n    <true/>\\n';
    if (formData.stdoutPath) xml += '    <key>StandardOutPath</key>\\n    <string>' + formData.stdoutPath + '</string>\\n';
    if (formData.stderrPath) xml += '    <key>StandardErrorPath</key>\\n    <string>' + formData.stderrPath + '</string>\\n';
    if (formData.workingDir) xml += '    <key>WorkingDirectory</key>\\n    <string>' + formData.workingDir + '</string>\\n';
    xml += '</dict>\\n</plist>';
    return xml;
  }, [formData]);

  return (
    <div className="modal-overlay" onClick={onClose}>
      <div className="modal" onClick={e => e.stopPropagation()}>
        <div className="modal-header">
          <div className="modal-title">
            <Icon name="plus-circle" size={18} /> Create New Job
          </div>
          <button className="icon-btn" onClick={onClose}>
            <Icon name="x" size={16} />
          </button>
        </div>

        <div className="modal-body">
          {step === 'form' ? (
            <div className="animate-fade">
              <div className="form-group">
                <label className="form-label">Label (reverse-DNS)</label>
                <input
                  className="form-input"
                  placeholder="com.kevin.my-tool"
                  value={formData.label}
                  onChange={e => update('label', e.target.value)}
                />
                <div className="form-hint">Unique identifier, e.g. com.kevin.tool-name</div>
              </div>

              <div className="form-group">
                <label className="form-label">Program / Command</label>
                <input
                  className="form-input"
                  placeholder="/usr/local/bin/python3"
                  value={formData.program}
                  onChange={e => update('program', e.target.value)}
                />
              </div>

              <div className="form-group">
                <label className="form-label">Arguments (one per line)</label>
                <textarea
                  className="form-input"
                  rows={3}
                  placeholder={"/path/to/script.py\\n--flag\\nvalue"}
                  value={formData.args}
                  onChange={e => update('args', e.target.value)}
                  style={{ fontFamily: 'var(--font-mono)', resize: 'vertical' }}
                />
              </div>

              <div className="form-group">
                <label className="form-label">Domain</label>
                <select className="form-input" value={formData.domain} onChange={e => update('domain', e.target.value)}>
                  <option value="user-agent">User Agent (~/Library/LaunchAgents)</option>
                  <option value="global-agent">Global Agent (/Library/LaunchAgents)</option>
                  <option value="system-daemon">System Daemon (/Library/LaunchDaemons)</option>
                </select>
              </div>

              {/* Schedule Section */}
              <div style={{ background: 'var(--bg-base)', border: '1px solid var(--border-default)', borderRadius: 6, padding: 14, marginBottom: 14 }}>
                <div style={{ fontFamily: 'var(--font-display)', fontWeight: 600, fontSize: 12, textTransform: 'uppercase', letterSpacing: 1, color: 'var(--text-secondary)', marginBottom: 10 }}>
                  Schedule
                </div>
                <div className="form-group">
                  <label className="form-label">Schedule Type</label>
                  <select className="form-input" value={formData.scheduleType} onChange={e => update('scheduleType', e.target.value)}>
                    <option value="none">None (manual start only)</option>
                    <option value="interval">Interval (every N seconds)</option>
                    <option value="calendar">Calendar (cron-like schedule)</option>
                    <option value="watch">Watch Paths (run when files change)</option>
                  </select>
                  <div className="form-hint">
                    {formData.scheduleType === 'none' && 'Job will only run when started manually or via RunAtLoad/KeepAlive.'}
                    {formData.scheduleType === 'interval' && 'Job repeats at a fixed interval.'}
                    {formData.scheduleType === 'calendar' && 'Job runs at specific times (like cron). Leave fields blank for "any".'}
                    {formData.scheduleType === 'watch' && 'Job runs whenever the specified paths are modified.'}
                  </div>
                </div>

                {formData.scheduleType === 'interval' && (
                  <div className="form-group animate-fade">
                    <label className="form-label">Interval (seconds)</label>
                    <div className="form-row">
                      <div className="form-group" style={{ marginBottom: 0 }}>
                        <input
                          className="form-input"
                          type="number"
                          placeholder="e.g. 300"
                          value={formData.startInterval}
                          onChange={e => update('startInterval', e.target.value)}
                        />
                      </div>
                      <div style={{ display: 'flex', alignItems: 'center', color: 'var(--text-tertiary)', fontSize: 11 }}>
                        {formData.startInterval && ('= ' + (formData.startInterval >= 3600 ? Math.floor(formData.startInterval / 3600) + 'h ' + Math.floor((formData.startInterval % 3600) / 60) + 'm' : formData.startInterval >= 60 ? Math.floor(formData.startInterval / 60) + 'm ' + (formData.startInterval % 60) + 's' : formData.startInterval + 's'))}
                      </div>
                    </div>
                  </div>
                )}

                {formData.scheduleType === 'calendar' && (
                  <div className="animate-fade">
                    <div className="form-row">
                      <div className="form-group">
                        <label className="form-label">Hour (0-23)</label>
                        <input className="form-input" type="number" min="0" max="23" placeholder="any" value={formData.calendarHour} onChange={e => update('calendarHour', e.target.value)} />
                      </div>
                      <div className="form-group">
                        <label className="form-label">Minute (0-59)</label>
                        <input className="form-input" type="number" min="0" max="59" placeholder="0" value={formData.calendarMinute} onChange={e => update('calendarMinute', e.target.value)} />
                      </div>
                    </div>
                    <div className="form-group">
                      <label className="form-label">Weekdays (click to select, leave empty for every day)</label>
                      <div style={{ display: 'flex', gap: 4 }}>
                        {['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map((day, idx) => {
                          const isSelected = formData.calendarWeekdays.includes(idx);
                          return (
                            <div
                              key={idx}
                              onClick={() => {
                                const next = isSelected
                                  ? formData.calendarWeekdays.filter(d => d !== idx)
                                  : [...formData.calendarWeekdays, idx].sort();
                                update('calendarWeekdays', next);
                              }}
                              style={{
                                padding: '4px 10px',
                                borderRadius: 4,
                                fontSize: 11,
                                fontFamily: 'var(--font-mono)',
                                cursor: 'pointer',
                                userSelect: 'none',
                                transition: 'all 0.15s',
                                background: isSelected ? 'var(--accent)' : 'var(--bg-elevated)',
                                color: isSelected ? 'var(--text-inverse)' : 'var(--text-secondary)',
                                border: '1px solid ' + (isSelected ? 'var(--accent)' : 'var(--border-default)'),
                                fontWeight: isSelected ? 600 : 400,
                              }}
                            >
                              {day}
                            </div>
                          );
                        })}
                      </div>
                      <div className="form-hint" style={{ marginTop: 4 }}>
                        {formData.calendarWeekdays.length === 0
                          ? 'Every day'
                          : formData.calendarWeekdays.map(d => ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d]).join(', ')}
                      </div>
                    </div>
                    <div className="form-group">
                      <label className="form-label">Day of Month</label>
                      <div style={{ display: 'flex', gap: 6, alignItems: 'center' }}>
                        <input
                          className="form-input"
                          style={{ width: 80 }}
                          type="number"
                          min="1"
                          max="31"
                          placeholder="any"
                          value={formData.calendarDay}
                          onChange={e => {
                            let v = e.target.value;
                            if (v !== '') {
                              const n = parseInt(v, 10);
                              if (isNaN(n)) v = '';
                              else if (n > 31) v = '31';
                              else if (n < 1 && v !== '') v = '1';
                            }
                            update('calendarDay', v);
                          }}
                        />
                        {formData.calendarDay && (
                          <button
                            className="btn btn-sm btn-ghost"
                            onClick={() => update('calendarDay', '')}
                            title="Clear to 'any day'"
                          >
                            <Icon name="x" size={12} /> Any
                          </button>
                        )}
                        {!formData.calendarDay && (
                          <span style={{ fontSize: 11, color: 'var(--text-tertiary)' }}>any day of month</span>
                        )}
                      </div>
                    </div>
                    <div className="form-hint" style={{ marginTop: -8, marginBottom: 8 }}>
                      Preview: {(() => {
                        const parts = [];
                        const wd = formData.calendarWeekdays;
                        if (wd.length > 0) parts.push(wd.map(d => ['Sundays','Mondays','Tuesdays','Wednesdays','Thursdays','Fridays','Saturdays'][d]).join(', '));
                        if (formData.calendarDay) parts.push('day ' + formData.calendarDay + ' of month');
                        if (wd.length === 0 && !formData.calendarDay) parts.push('Daily');
                        parts.push('at ' + (formData.calendarHour || '*') + ':' + (formData.calendarMinute || '0').padStart(2, '0'));
                        return parts.join(' ');
                      })()}
                    </div>
                  </div>
                )}

                {formData.scheduleType === 'watch' && (
                  <div className="form-group animate-fade">
                    <label className="form-label">Watch Paths (one per line)</label>
                    <textarea
                      className="form-input"
                      rows={3}
                      placeholder={"~/Downloads\\n/tmp/trigger-file"}
                      value={formData.watchPaths}
                      onChange={e => update('watchPaths', e.target.value)}
                      style={{ fontFamily: 'var(--font-mono)', resize: 'vertical' }}
                    />
                    <div className="form-hint">Job runs whenever any of these paths are modified.</div>
                  </div>
                )}
              </div>

              <div className="form-row">
                <div className="form-group">
                  <label className="form-label">Stdout Path</label>
                  <input className="form-input" placeholder="/tmp/my-tool.log" value={formData.stdoutPath} onChange={e => update('stdoutPath', e.target.value)} />
                </div>
                <div className="form-group">
                  <label className="form-label">Stderr Path</label>
                  <input className="form-input" placeholder="/tmp/my-tool.err" value={formData.stderrPath} onChange={e => update('stderrPath', e.target.value)} />
                </div>
              </div>

              <div className="form-group">
                <label className="form-label">Working Directory</label>
                <input className="form-input" placeholder="(optional)" value={formData.workingDir} onChange={e => update('workingDir', e.target.value)} />
              </div>

              <div style={{ marginTop: 8 }}>
                <div className="toggle-row">
                  <span className="toggle-row-label">Run at Load</span>
                  <div className={'toggle-switch' + (formData.runAtLoad ? ' on' : '')} onClick={() => update('runAtLoad', !formData.runAtLoad)} />
                </div>
                <div className="toggle-row">
                  <span className="toggle-row-label">Keep Alive</span>
                  <div className={'toggle-switch' + (formData.keepAlive ? ' on' : '')} onClick={() => update('keepAlive', !formData.keepAlive)} />
                </div>
              </div>
            </div>
          ) : (
            <div className="animate-fade">
              <div style={{ marginBottom: 12, fontSize: 12, color: 'var(--text-secondary)' }}>
                Preview the generated plist before creating:
              </div>
              <div className="plist-preview">{previewXml}</div>
            </div>
          )}
        </div>

        <div className="modal-footer">
          {step === 'preview' && (
            <button className="btn" onClick={() => setStep('form')} style={{ marginRight: 'auto' }}>
              <Icon name="arrow-left" size={14} /> Back
            </button>
          )}
          <button className="btn" onClick={onClose}>Cancel</button>
          {step === 'form' ? (
            <button className="btn btn-accent" onClick={() => setStep('preview')}>
              Preview Plist <Icon name="arrow-right" size={14} />
            </button>
          ) : (
            <button
              className="btn btn-accent"
              onClick={handleCreate}
              disabled={creating}
              style={{ opacity: creating ? 0.6 : 1 }}
            >
              <Icon name="plus" size={14} /> {creating ? 'Creating...' : 'Create & Load'}
            </button>
          )}
        </div>
      </div>
    </div>
  );
}

// ---- Settings Modal ----
function SettingsModal({ onClose, settings, setSettings, addToast }) {
  const [saving, setSaving] = useState(false);

  const handleSave = async () => {
    setSaving(true);
    try {
      await api('/settings', {
        method: 'PUT',
        body: JSON.stringify(settings),
      });
      addToast('success', 'Settings saved');
      onClose();
    } catch (err) {
      addToast('error', 'Failed to save settings: ' + err.message);
    } finally {
      setSaving(false);
    }
  };

  return (
    <div className="modal-overlay" onClick={onClose}>
      <div className="modal" onClick={e => e.stopPropagation()} style={{ width: 480 }}>
        <div className="modal-header">
          <div className="modal-title"><Icon name="settings" size={18} /> Settings</div>
          <button className="icon-btn" onClick={onClose}><Icon name="x" size={16} /></button>
        </div>
        <div className="modal-body">
          <div className="settings-section">
            <div className="settings-section-title">Refresh</div>
            <div className="form-group">
              <label className="form-label">Poll Interval (seconds)</label>
              <input
                className="form-input"
                type="number"
                value={settings.pollInterval}
                onChange={e => setSettings(s => ({ ...s, pollInterval: e.target.value }))}
                style={{ width: 120 }}
              />
              <div className="form-hint">How often to refresh job status via WebSocket</div>
            </div>
          </div>

          <div className="settings-section">
            <div className="settings-section-title">Display</div>
            <div className="toggle-row">
              <span className="toggle-row-label">Show Apple System Jobs</span>
              <div
                className={'toggle-switch' + (settings.showApple ? ' on' : '')}
                onClick={() => setSettings(s => ({ ...s, showApple: !s.showApple }))}
              />
            </div>
            <div className="toggle-row">
              <span className="toggle-row-label">Dark Mode</span>
              <div
                className={'toggle-switch' + (settings.darkMode ? ' on' : '')}
                onClick={() => setSettings(s => ({ ...s, darkMode: !s.darkMode }))}
              />
            </div>
          </div>

          <div className="settings-section">
            <div className="settings-section-title">Safety</div>
            <div className="toggle-row">
              <span className="toggle-row-label">Confirm before destructive actions</span>
              <div
                className={'toggle-switch' + (settings.confirmDestructive ? ' on' : '')}
                onClick={() => setSettings(s => ({ ...s, confirmDestructive: !s.confirmDestructive }))}
              />
