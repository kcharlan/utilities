              <kbd className="kbd">e</kbd> <span>Edit selected job</span>
              <kbd className="kbd">l</kbd> <span>View logs</span>
              <kbd className="kbd">n</kbd> <span>Create new job</span>
              <kbd className="kbd">Esc</kbd> <span>Close panel / deselect</span>
