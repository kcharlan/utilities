def _load_config() -> Dict[str, Any]:
    """Load config from disk, returning defaults if missing."""
    defaults = {
        "poll_interval": 5,
        "show_apple_jobs": False,
        "dark_mode": True,
        "confirm_destructive": True,
        "confirm_apple_modify": True,
    }
    if not os.path.isfile(CONFIG_FILE):
        return dict(defaults)
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
        if isinstance(data, dict):
            merged = dict(defaults)
            merged.update(data)
            return merged
        return dict(defaults)
    except (json.JSONDecodeError, OSError):
        return dict(defaults)


def _save_config(config: Dict[str, Any]) -> None:
    """Write config to disk."""
    os.makedirs(DATA_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w", encoding="utf-8") as f:
        json.dump(config, f, indent=2)
        f.write("\n")


def _find_job(label: str) -> Optional[Dict[str, Any]]:
    """Find a job by label in the cached job list."""
    for job in _cached_jobs:
        if job.get("label") == label:
            return job
    return None


async def _refresh_jobs() -> None:
    """Rebuild cached job list and broadcast to WebSocket clients."""
    global _cached_jobs
    _cached_jobs = await asyncio.to_thread(build_job_list, True)
    await _broadcast_jobs()


async def _broadcast_jobs() -> None:
    """Push current job list to all connected WebSocket clients."""
    global _ws_clients
    data = json.dumps({"type": "jobs", "data": _cached_jobs}, default=str)
    dead: Set[WebSocket] = set()
    for ws in _ws_clients:
        try:
            await ws.send_text(data)
        except Exception:
            dead.add(ws)
    _ws_clients -= dead


async def _poll_loop() -> None:
    """Periodically re-scan job state and push to WebSocket clients."""
    global _cached_jobs
    while True:
        interval = _config.get("poll_interval", 5)
        await asyncio.sleep(interval)
        try:
            new_jobs = await asyncio.to_thread(build_job_list, True)
            if new_jobs != _cached_jobs:
                _cached_jobs = new_jobs
                await _broadcast_jobs()
        except Exception as exc:
            logger.warning("Poll loop error: %s", exc)


@asynccontextmanager
async def lifespan(application):
    """FastAPI lifespan handler -- startup and shutdown."""
    global _cached_jobs, _config, _poll_task
    _config = _load_config()
    _cached_jobs = await asyncio.to_thread(build_job_list, True)
    _poll_task = asyncio.create_task(_poll_loop())
    yield
    if _poll_task:
        _poll_task.cancel()


