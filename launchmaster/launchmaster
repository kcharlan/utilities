async def save_plist(plist_path: str, content: str) -> Dict[str, Any]:
    """Validate and save plist content to disk."""
    # Validate plist XML
    try:
        plistlib.loads(content.encode("utf-8"))
    except Exception as exc:
        return {"success": False, "message": f"Invalid plist XML: {exc}"}

    try:
        with open(plist_path, "w", encoding="utf-8") as f:
            f.write(content)
        return {"success": True, "message": f"Saved {plist_path}"}
    except PermissionError:
        return {"success": False, "message": f"Permission denied writing {plist_path}"}
    except OSError as exc:
        return {"success": False, "message": f"Error writing {plist_path}: {exc}"}


async def create_job(plist_data: Dict[str, Any], domain: str) -> Dict[str, Any]:
    """Create a new job from plist data dict."""
    label = plist_data.get("Label")
    if not label:
        return {"success": False, "message": "Plist data must contain a 'Label' key"}

    # Determine target directory
    domain_dir = PLIST_DIRS.get(domain)
    if not domain_dir:
        return {"success": False, "message": f"Unknown domain: {domain}"}

    target_path = os.path.join(domain_dir, f"{label}.plist")
    if os.path.exists(target_path):
        return {"success": False, "message": f"Plist already exists: {target_path}"}

    # Write plist
    try:
        plist_bytes = plistlib.dumps(plist_data, fmt=plistlib.FMT_XML)
        with open(target_path, "wb") as f:
            f.write(plist_bytes)
    except PermissionError:
        return {"success": False, "message": f"Permission denied writing {target_path}"}
    except OSError as exc:
        return {"success": False, "message": f"Error writing plist: {exc}"}

    # Auto-load
    load_result = await load_job(target_path, domain)
    if load_result["success"]:
        return {"success": True, "message": f"Created and loaded {label} at {target_path}"}
    return {
        "success": True,
        "message": f"Created {label} at {target_path}, but load failed: {load_result['message']}",
    }


async def delete_job(label: str, domain: str, plist_path: str) -> Dict[str, Any]:
    """Backup, unload, and delete a job."""
    if not plist_path or not os.path.isfile(plist_path):
        return {"success": False, "message": f"Plist file not found: {plist_path}"}

    # Backup first
    backup_path = backup_plist(plist_path)

    # Unload if loaded
    await unload_job(label, domain, plist_path)

    # Delete
    try:
        os.remove(plist_path)
        return {
            "success": True,
            "message": f"Deleted {label}. Backup saved to {backup_path}",
        }
    except PermissionError:
        return {"success": False, "message": f"Permission denied deleting {plist_path}"}
    except OSError as exc:
        return {"success": False, "message": f"Error deleting {plist_path}: {exc}"}


async def export_job(plist_path: str) -> str:
    """Read and return plist file contents as string."""
    try:
        with open(plist_path, "r", encoding="utf-8") as f:
            return f.read()
    except UnicodeDecodeError:
        # Binary plist -- convert to XML
        with open(plist_path, "rb") as f:
            data = plistlib.load(f)
        return plistlib.dumps(data, fmt=plistlib.FMT_XML).decode("utf-8")


async def import_job(content: str, domain: str) -> Dict[str, Any]:
    """Validate plist XML, extract label, write to disk, and auto-load."""
    try:
        plist_data = plistlib.loads(content.encode("utf-8"))
    except Exception as exc:
        return {"success": False, "message": f"Invalid plist XML: {exc}"}

    label = plist_data.get("Label")
    if not label:
        return {"success": False, "message": "Plist must contain a 'Label' key"}

    domain_dir = PLIST_DIRS.get(domain)
    if not domain_dir:
        return {"success": False, "message": f"Unknown domain: {domain}"}

    target_path = os.path.join(domain_dir, f"{label}.plist")
    try:
        with open(target_path, "w", encoding="utf-8") as f:
            f.write(content)
    except PermissionError:
        return {"success": False, "message": f"Permission denied writing {target_path}"}
    except OSError as exc:
        return {"success": False, "message": f"Error writing {target_path}: {exc}"}

    load_result = await load_job(target_path, domain)
    if load_result["success"]:
        return {"success": True, "message": f"Imported and loaded {label}"}
    return {
        "success": True,
        "message": f"Imported {label}, but load failed: {load_result['message']}",
    }


def backup_plist(plist_path: str) -> str:
    """Copy plist to backup directory with timestamp."""
    import shutil
    os.makedirs(BACKUP_DIR, exist_ok=True)
    label = os.path.basename(plist_path).replace(".plist", "")
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    backup_name = f"{label}.{timestamp}.plist"
    backup_path = os.path.join(BACKUP_DIR, backup_name)
    shutil.copy2(plist_path, backup_path)
    return backup_path


def list_backups() -> List[Dict[str, Any]]:
    """Scan backup directory and return list of backup info dicts."""
    backups = []
    if not os.path.isdir(BACKUP_DIR):
        return backups
    for filename in sorted(os.listdir(BACKUP_DIR)):
        if not filename.endswith(".plist"):
            continue
        filepath = os.path.join(BACKUP_DIR, filename)
        # Parse label and timestamp from filename: label.YYYYMMDD_HHMMSS.plist
        parts = filename.rsplit(".", 2)
        if len(parts) >= 3:
            label = parts[0]
            timestamp_str = parts[1]
        else:
            label = filename.replace(".plist", "")
            timestamp_str = ""
        backups.append({
            "filename": filename,
            "label": label,
            "timestamp": timestamp_str,
            "path": filepath,
        })
    return backups


