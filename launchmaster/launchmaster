async def read_log_file(path: str, tail_lines: int = 200) -> List[str]:
    """Read last N lines of a log file."""
    if not path:
        return []
    if not os.path.isfile(path):
        return [f"[Log file not found: {path}]"]
    try:
        def _read():
            with open(path, "r", encoding="utf-8", errors="replace") as f:
                lines = f.readlines()
            return [line.rstrip("\n") for line in lines[-tail_lines:]]
        return await asyncio.to_thread(_read)
    except PermissionError:
        return [f"[Permission denied: {path}]"]
    except OSError as exc:
        return [f"[Error reading {path}: {exc}]"]


async def read_unified_log(label: str, limit: int = 100) -> List[str]:
    """Query macOS unified log for entries matching a label."""
    try:
        def _query():
            result = subprocess.run(
                [
                    "log", "show",
                    "--predicate", f'process == "{label}"',
                    "--last", "1h",
                    "--style", "compact",
                    "--info",
                ],
                capture_output=True, text=True, timeout=5,
            )
            if result.returncode != 0:
                return [f"[Unified log query failed: {result.stderr.strip()}]"]
            lines = result.stdout.strip().splitlines()
            # Return last N lines (skip header line if present)
            if lines and lines[0].startswith("Filtering"):
                lines = lines[1:]
            return lines[-limit:]
        return await asyncio.to_thread(_query)
    except Exception as exc:
        return [f"[Unified log error: {exc}]"]


