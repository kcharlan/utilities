@app.post("/api/backups/{filename}/restore")
async def api_restore_backup(filename: str):
    import shutil
    backup_path = os.path.join(BACKUP_DIR, filename)
    if not os.path.isfile(backup_path):
        return JSONResponse(
            status_code=404,
            content={"success": False, "message": f"Backup not found: {filename}"},
        )
    # Parse label from filename
    parts = filename.rsplit(".", 2)
    label = parts[0] if len(parts) >= 3 else filename.replace(".plist", "")

    # Try to find original domain from label
    try:
        with open(backup_path, "rb") as f:
            plist_data = plistlib.load(f)
        plist_label = plist_data.get("Label", label)
    except Exception:
        plist_label = label

    # Default restore to user-agent domain
    target_dir = PLIST_DIRS["user-agent"]
    target_path = os.path.join(target_dir, f"{plist_label}.plist")
    try:
        shutil.copy2(backup_path, target_path)
    except PermissionError:
        return {"success": False, "message": f"Permission denied writing {target_path}"}
    except OSError as exc:
        return {"success": False, "message": f"Error restoring backup: {exc}"}

    load_result = await load_job(target_path, "user-agent")
    await _refresh_jobs()
    return {
        "success": True,
        "message": f"Restored {plist_label} to {target_path}. Load: {load_result['message']}",
    }


# --- Settings ---

@app.get("/api/settings")
async def api_get_settings():
    return _config


@app.put("/api/settings")
async def api_put_settings(request: Request):
    global _config
    body = await request.json()
    _config.update(body)
    await asyncio.to_thread(_save_config, _config)
    return {"success": True, "message": "Settings saved"}


# --- WebSocket ---

@app.websocket("/ws")
async def websocket_endpoint(ws: WebSocket):
    await ws.accept()
    _ws_clients.add(ws)
    try:
        # Send initial state
        await ws.send_text(json.dumps({"type": "jobs", "data": _cached_jobs}, default=str))
        # Keep alive, receive commands
        while True:
            data = await ws.receive_text()
            try:
                msg = json.loads(data)
            except json.JSONDecodeError:
                continue
            if msg.get("type") == "refresh":
                await _refresh_jobs()
    except WebSocketDisconnect:
        pass
    except Exception:
        pass
    finally:
        _ws_clients.discard(ws)


