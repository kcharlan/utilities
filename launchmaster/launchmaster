# === GLOBALS ===
_cached_jobs: List[Dict[str, Any]] = []
_ws_clients: Set[WebSocket] = set()
_config: Dict[str, Any] = {}
_poll_task: Optional[asyncio.Task] = None

# === PLIST DIRECTORIES ===
PLIST_DIRS = {
    "user-agent": os.path.expanduser("~/Library/LaunchAgents"),
    "global-agent": "/Library/LaunchAgents",
    "system-daemon": "/Library/LaunchDaemons",
    "apple-agent": "/System/Library/LaunchAgents",
    "apple-daemon": "/System/Library/LaunchDaemons",
}

WEEKDAY_NAMES = {0: "Sun", 1: "Mon", 2: "Tue", 3: "Wed", 4: "Thu", 5: "Fri", 6: "Sat"}


# ============================================================
# Step 2: launchd Discovery Engine
# ============================================================

def discover_plists() -> List[Dict[str, Any]]:
    """Scan all plist directories and parse each .plist file."""
    results = []
    for domain, directory in PLIST_DIRS.items():
        if not os.path.isdir(directory):
            continue
        try:
            entries = os.listdir(directory)
        except PermissionError:
            logger.warning("Permission denied scanning %s", directory)
            continue
        except OSError as exc:
            logger.warning("Error scanning %s: %s", directory, exc)
            continue

        for filename in entries:
            if not filename.endswith(".plist"):
                continue
            filepath = os.path.join(directory, filename)
            entry: Dict[str, Any] = {
                "plist_path": filepath,
                "domain": domain,
                "is_apple": domain.startswith("apple"),
                "parse_error": None,
            }
            try:
                with open(filepath, "rb") as f:
                    plist_data = plistlib.load(f)
                entry["label"] = plist_data.get("Label", filename.replace(".plist", ""))
                entry["program_arguments"] = plist_data.get("ProgramArguments")
                entry["program"] = plist_data.get("Program")
                entry["run_at_load"] = plist_data.get("RunAtLoad", False)
                entry["keep_alive"] = plist_data.get("KeepAlive", False)
                entry["start_interval"] = plist_data.get("StartInterval")
                entry["start_calendar_interval"] = plist_data.get("StartCalendarInterval")
                entry["watch_paths"] = plist_data.get("WatchPaths")
                entry["stdout_path"] = plist_data.get("StandardOutPath")
                entry["stderr_path"] = plist_data.get("StandardErrorPath")
                entry["working_directory"] = plist_data.get("WorkingDirectory")
                entry["environment_variables"] = plist_data.get("EnvironmentVariables")
                entry["disabled"] = plist_data.get("Disabled", False)
                entry["plist_data"] = plist_data
            except PermissionError:
                entry["label"] = filename.replace(".plist", "")
                entry["parse_error"] = "Permission denied"
                entry["plist_data"] = {}
            except (plistlib.InvalidFileException, Exception) as exc:
                entry["label"] = filename.replace(".plist", "")
                entry["parse_error"] = str(exc)
                entry["plist_data"] = {}
            results.append(entry)
    return results


def get_launchctl_state() -> Dict[str, Dict[str, Any]]:
    """Parse 'launchctl list' output and return state keyed by label."""
    state: Dict[str, Dict[str, Any]] = {}
    try:
        result = subprocess.run(
            ["launchctl", "list"],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            logger.warning("launchctl list returned %d", result.returncode)
            return state
    except (subprocess.TimeoutExpired, OSError) as exc:
        logger.warning("Failed to run launchctl list: %s", exc)
        return state

    for line in result.stdout.strip().splitlines()[1:]:  # skip header
        parts = line.split("\t")
        if len(parts) < 3:
            continue
        pid_str, status_str, label = parts[0], parts[1], parts[2]
        pid = None if pid_str == "-" else _safe_int(pid_str)
        last_exit = None if status_str == "-" else _safe_int(status_str)
        state[label] = {"pid": pid, "last_exit": last_exit}
    return state


def _safe_int(value: str) -> Optional[int]:
    try:
        return int(value)
    except (ValueError, TypeError):
        return None


def get_job_blame(label: str, domain: str) -> Optional[str]:
    """Run launchctl blame for a job and return the blame string."""
    target = _domain_target(label, domain)
    try:
        result = subprocess.run(
            ["launchctl", "blame", target],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
        return None
    except (subprocess.TimeoutExpired, OSError):
        return None


def get_job_detail(label: str, domain: str) -> Dict[str, Any]:
    """Run launchctl print for detailed job state."""
    target = _domain_target(label, domain)
    detail: Dict[str, Any] = {"raw_output": None}
    try:
        result = subprocess.run(
            ["launchctl", "print", target],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode == 0:
            detail["raw_output"] = result.stdout
            # Parse key fields from the output
            for line in result.stdout.splitlines():
                line = line.strip()
                if line.startswith("state ="):
                    detail["state"] = line.split("=", 1)[1].strip()
                elif line.startswith("pid ="):
                    detail["print_pid"] = _safe_int(line.split("=", 1)[1].strip())
                elif line.startswith("last exit code ="):
                    detail["last_exit_code"] = _safe_int(line.split("=", 1)[1].strip())
                elif line.startswith("path ="):
                    detail["print_path"] = line.split("=", 1)[1].strip()
    except (subprocess.TimeoutExpired, OSError):
        pass
    return detail


def get_disabled_labels() -> Set[str]:
    """Query launchctl print-disabled for the user domain to find explicitly disabled jobs."""
    disabled = set()
    uid = os.getuid()
    try:
        result = subprocess.run(
            ["launchctl", "print-disabled", f"gui/{uid}"],
            capture_output=True, text=True, timeout=10,
        )
        for line in result.stdout.splitlines():
            line = line.strip()
            if "=>" in line:
                label_part, state_part = line.split("=>", 1)
                label = label_part.strip().strip('"')
                if "disabled" in state_part.lower():
                    disabled.add(label)
    except (subprocess.TimeoutExpired, OSError):
        pass
    return disabled


def build_job_list(include_apple: bool = False) -> List[Dict[str, Any]]:
    """Merge plist discovery with runtime state from launchctl."""
    plists = discover_plists()
    runtime_state = get_launchctl_state()
    disabled_labels = get_disabled_labels()

    # Build lookup by label from plists
    jobs_by_label: Dict[str, Dict[str, Any]] = {}
    for plist_entry in plists:
        label = plist_entry.get("label", "")
        if not label:
            continue
        if plist_entry.get("is_apple", False) and not include_apple:
            continue
        job = dict(plist_entry)
        # Merge runtime state
        rt = runtime_state.pop(label, {})
        job["pid"] = rt.get("pid")
        job["last_exit"] = rt.get("last_exit")
        job["loaded"] = rt != {} or job["pid"] is not None
        # Enabled: not in plist Disabled AND not in launchctl print-disabled
        job["enabled"] = not job.get("disabled", False) and label not in disabled_labels
        job["status"] = get_job_status(job)
        job["schedule_human"] = humanize_schedule(job.get("plist_data", {}))
        # Remove plist_data from the response to keep payloads small
        job.pop("plist_data", None)
        jobs_by_label[label] = job

    # Detect orphan jobs (loaded but no plist on disk)
    for label, rt in runtime_state.items():
        # Skip Apple-like labels when not including Apple jobs
        if not include_apple and (
            label.startswith("com.apple.") or label.startswith("com.openssh.")
        ):
            continue
        if label in jobs_by_label:
            continue
        orphan: Dict[str, Any] = {
            "label": label,
            "plist_path": None,
            "domain": "unknown",
            "is_apple": label.startswith("com.apple."),
            "parse_error": None,
            "pid": rt.get("pid"),
            "last_exit": rt.get("last_exit"),
            "loaded": True,
            "disabled": label in disabled_labels,
            "enabled": label not in disabled_labels,
            "program": None,
            "program_arguments": None,
            "run_at_load": False,
            "keep_alive": False,
            "start_interval": None,
            "start_calendar_interval": None,
            "watch_paths": None,
            "stdout_path": None,
            "stderr_path": None,
            "working_directory": None,
            "environment_variables": None,
            "schedule_human": "Unknown (no plist)",
        }
        orphan["status"] = get_job_status(orphan)
        if not include_apple and orphan["is_apple"]:
            continue
        jobs_by_label[label] = orphan

    return list(jobs_by_label.values())


def get_job_status(job: Dict[str, Any]) -> str:
    """Derive a status string from job state."""
    if not job.get("enabled", True):
        return "disabled"
    pid = job.get("pid")
    last_exit = job.get("last_exit")
    loaded = job.get("loaded", False)

    if pid is not None and pid > 0:
        return "running"
    if not loaded and job.get("plist_path") is not None:
        # Has plist but not in launchctl list
        return "unloaded"
    if last_exit is not None and last_exit != 0:
        return "failed"
    return "idle"


def humanize_schedule(plist_data: Dict[str, Any]) -> str:
    """Convert plist schedule keys to a human-readable string."""
    if not plist_data:
        return "Manual"

    keep_alive = plist_data.get("KeepAlive", False)
    if keep_alive:
        return "Always running (KeepAlive)"

    start_interval = plist_data.get("StartInterval")
    if start_interval is not None:
        try:
            seconds = int(start_interval)
        except (ValueError, TypeError):
            return f"Every {start_interval}s"
        if seconds >= 3600 and seconds % 3600 == 0:
            hours = seconds // 3600
            return f"Every {hours} hour{'s' if hours != 1 else ''}"
        elif seconds >= 60 and seconds % 60 == 0:
            minutes = seconds // 60
            return f"Every {minutes} minute{'s' if minutes != 1 else ''}"
        else:
            return f"Every {seconds} second{'s' if seconds != 1 else ''}"

    sci = plist_data.get("StartCalendarInterval")
    if sci is not None:
        return _humanize_calendar_interval(sci)

    watch_paths = plist_data.get("WatchPaths")
    if watch_paths:
        if isinstance(watch_paths, list):
            paths_str = ", ".join(str(p) for p in watch_paths)
        else:
            paths_str = str(watch_paths)
        return f"Watching: {paths_str}"

    if plist_data.get("RunAtLoad", False):
        return "Run at load"

    return "Manual"


def _humanize_calendar_interval(sci: Any) -> str:
    """Convert StartCalendarInterval (dict or list of dicts) to readable string."""
    if isinstance(sci, dict):
        entries = [sci]
    elif isinstance(sci, list):
        entries = sci
    else:
        return "Calendar schedule"

    if not entries:
        return "Calendar schedule"

    # Collect all weekdays mentioned
    weekdays: List[str] = []
    hour = None
    minute = None

    for entry in entries:
        if not isinstance(entry, dict):
            continue
        wd = entry.get("Weekday")
        if wd is not None:
            weekdays.append(WEEKDAY_NAMES.get(wd, str(wd)))
        h = entry.get("Hour")
        m = entry.get("Minute")
        if h is not None:
            hour = h
        if m is not None:
            minute = m

    # Build time string
    if hour is not None:
        minute_val = minute if minute is not None else 0
        h_int = int(hour)
        m_int = int(minute_val)
        ampm = "AM" if h_int < 12 else "PM"
        h_display = h_int % 12
        if h_display == 0:
            h_display = 12
        time_str = f"{h_display}:{m_int:02d} {ampm}"
    elif minute is not None:
        time_str = f":{int(minute):02d} past every hour"
    else:
        time_str = None

    # Build day string
    if weekdays:
        day_str = ", ".join(weekdays)
    elif any(isinstance(e, dict) and "Day" in e for e in entries):
        days = [str(e["Day"]) for e in entries if isinstance(e, dict) and "Day" in e]
        day_str = "Day " + ", ".join(days) + " of month"
    else:
        day_str = None

    parts = []
    if day_str:
        parts.append(day_str)
    if time_str:
        parts.append(f"at {time_str}")

    if parts:
        return " ".join(parts)
    return "Calendar schedule"


# ============================================================
# Step 3: Job Control Operations
# ============================================================

def _domain_target(label: str, domain: str) -> str:
    """Return the launchctl domain target path for a job."""
    uid = os.getuid()
    if domain in ("system-daemon",):
        return f"system/{label}"
    return f"gui/{uid}/{label}"


def _domain_prefix(domain: str) -> str:
    """Return the domain prefix (without label) for bootstrap/bootout."""
    uid = os.getuid()
    if domain in ("system-daemon",):
        return "system"
    return f"gui/{uid}"


def _run_launchctl(args: List[str], timeout: int = 10) -> Dict[str, Any]:
    """Run a launchctl command and return structured result."""
    try:
        result = subprocess.run(
            ["launchctl"] + args,
            capture_output=True, text=True, timeout=timeout,
        )
        return {
            "returncode": result.returncode,
            "stdout": result.stdout.strip(),
            "stderr": result.stderr.strip(),
        }
    except subprocess.TimeoutExpired:
        return {"returncode": -1, "stdout": "", "stderr": "Command timed out"}
    except OSError as exc:
        return {"returncode": -1, "stdout": "", "stderr": str(exc)}


async def start_job(label: str, domain: str) -> Dict[str, Any]:
    """Start (kickstart) a job."""
    target = _domain_target(label, domain)
    result = await asyncio.to_thread(_run_launchctl, ["kickstart", "-p", target])
    if result["returncode"] == 0:
        return {"success": True, "message": f"Started {label}. {result['stdout']}".strip()}
    return {"success": False, "message": f"Failed to start {label}: {result['stderr']}"}


async def stop_job(label: str, domain: str) -> Dict[str, Any]:
    """Stop a job by sending SIGTERM, then SIGKILL if needed."""
    target = _domain_target(label, domain)
    result = await asyncio.to_thread(_run_launchctl, ["kill", "SIGTERM", target])
    if result["returncode"] == 0:
        return {"success": True, "message": f"Stopped {label}"}
    # Try SIGKILL as fallback
    result = await asyncio.to_thread(_run_launchctl, ["kill", "SIGKILL", target])
    if result["returncode"] == 0:
        return {"success": True, "message": f"Force-stopped {label} (SIGKILL)"}
    return {"success": False, "message": f"Failed to stop {label}: {result['stderr']}"}


async def reload_job(label: str, domain: str, plist_path: str) -> Dict[str, Any]:
    """Reload a job by unloading then loading."""
    target = _domain_target(label, domain)
    prefix = _domain_prefix(domain)

    # Bootout (unload)
    unload_result = await asyncio.to_thread(_run_launchctl, ["bootout", target])
    await asyncio.sleep(0.5)

    # Bootstrap (load)
    load_result = await asyncio.to_thread(_run_launchctl, ["bootstrap", prefix, plist_path])

    if load_result["returncode"] == 0:
        msg = f"Reloaded {label}"
        if unload_result["returncode"] != 0:
            msg += f" (unload warning: {unload_result['stderr']})"
        return {"success": True, "message": msg}
    return {
        "success": False,
        "message": f"Reload failed for {label}: unload={'ok' if unload_result['returncode'] == 0 else unload_result['stderr']}, load={load_result['stderr']}",
    }


async def enable_job(label: str, domain: str) -> Dict[str, Any]:
    """Enable a job."""
    target = _domain_target(label, domain)
    result = await asyncio.to_thread(_run_launchctl, ["enable", target])
    if result["returncode"] == 0:
        return {"success": True, "message": f"Enabled {label}"}
    return {"success": False, "message": f"Failed to enable {label}: {result['stderr']}"}


async def disable_job(label: str, domain: str) -> Dict[str, Any]:
