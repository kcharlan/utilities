async def load_job(plist_path: str, domain: str) -> Dict[str, Any]:
    """Load (bootstrap) a job from its plist."""
    prefix = _domain_prefix(domain)
    result = await asyncio.to_thread(_run_launchctl, ["bootstrap", prefix, plist_path])
    if result["returncode"] == 0:
        return {"success": True, "message": f"Loaded {plist_path}"}
    # Fallback to legacy load
    result = await asyncio.to_thread(_run_launchctl, ["load", plist_path])
    if result["returncode"] == 0:
        return {"success": True, "message": f"Loaded {plist_path} (legacy)"}
    return {"success": False, "message": f"Failed to load {plist_path}: {result['stderr']}"}


async def unload_job(label: str, domain: str, plist_path: str) -> Dict[str, Any]:
    """Unload (bootout) a job."""
    target = _domain_target(label, domain)
    result = await asyncio.to_thread(_run_launchctl, ["bootout", target])
    if result["returncode"] == 0:
        return {"success": True, "message": f"Unloaded {label}"}
    # Fallback to legacy unload
    if plist_path:
        result = await asyncio.to_thread(_run_launchctl, ["unload", plist_path])
        if result["returncode"] == 0:
            return {"success": True, "message": f"Unloaded {label} (legacy)"}
    return {"success": False, "message": f"Failed to unload {label}: {result['stderr']}"}


